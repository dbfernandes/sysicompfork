{
    "extends": [
      "standard",
      "plugin:prettier/recommended"
    ],
    "env": {
      "browser": true,
      "node": true,
      "es6": true
    },
    "rules": {
      "prettier/prettier": ["error"],
      "indent": ["error", 2],
      "no-unused-vars": ["warn"],
      "no-console": "off"
    },
    "plugins": ["prettier"],
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module"
    }
  }
  