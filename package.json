{
  "name": "sysicomp",
  "version": "1.0.0",
  "description": "Sistema da Secretaria do Icomp",
  "main": "index.js",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "start": "nodemon --watch src --exec npx ts-node src/server.ts",
    "start:prod": "nodemon --watch src --exec npx ts-node src/server.ts",
    "build": "npx tsc",
    "prisma:init:dev": "npx prisma migrate dev && npx prisma db seed",
    "start:dev": "nodemon --watch src --exec npx ts-node src/server.ts",
    "criar-modulo": "node src/utils/criarNovoModulo.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json,css,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbfernandes/sysicomp.git"
  },
  "keywords": [
    "express",
    "prisma",
    "mysql",
    "handlebars",
    "nodejs",
    "jest"
  ],
  "author": "Lucas Oliveira",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dbfernandes/sysicomp/issues"
  },
  "homepage": "https://github.com/dbfernandes/sysicomp#readme",
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@sendgrid/mail": "^8.1.3",
    "admin-lte": "^3.1.0-rc",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.19.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csurf": "^1.11.0",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-handlebars": "^7.1.2",
    "express-session": "^1.17.2",
    "fastest-levenshtein": "^1.0.16",
    "handlebars": "^4.7.7",
    "handlebars-i18n": "^1.6.4",
    "jquery-mask-plugin": "^1.14.16",
    "multer": "^1.4.5-lts.1",
    "pdfmake": "^0.2.12",
    "puppeteer": "^23.0.2",
    "uuid": "^8.3.2",
    "winston": "^3.13.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "rootDir": ".",
    "testRegex": "(/test/.*|(\\.|/)(test|spec))$",
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.0.0",
    "@faker-js/faker": "^8.0.2",
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.13",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdfmake": "^0.2.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^8.3.1",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "cross-env": "^7.0.3",
    "ember-template-lint-plugin-prettier": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-html": "^8.1.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "exceljs": "^4.4.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.14",
    "prettier": "^3.2.5",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
