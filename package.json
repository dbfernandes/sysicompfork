{
  "name": "sysicomp",
  "version": "1.0.0",
  "description": "Sistema da Secretaria do Icomp",
  "main": "index.js",
  "scripts": {
    "start": "nodemon --watch 'src/**/*.js' --exec 'node src/server.js'",
    "start:dev": "nodemon --watch 'src/**/*.js' --exec 'NODE_ENV=dev node src/server.js'",
    "criar-modulo": "node src/utils/criar-novo-modulo.js",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbfernandes/sysicomp.git"
  },
  "keywords": [
    "express",
    "sequelize",
    "mysql",
    "handlebars",
    "nodejs",
    "jest"
  ],
  "author": "Lucas Oliveira",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dbfernandes/sysicomp/issues"
  },
  "homepage": "https://github.com/dbfernandes/sysicomp#readme",
  "dependencies": {
    "admin-lte": "^3.1.0-rc",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "express": "^4.17.1",
    "express-handlebars": "^5.2.1",
    "express-session": "^1.17.2",
    "handlebars": "^4.7.7",
    "jest": "^26.6.3",
    "morgan": "^1.10.0",
    "mysql2": "^2.2.5",
    "nodemailer": "^6.6.3",
    "nodemailer-express-handlebars": "^4.0.0",
    "nodemon": "^2.0.7",
    "uuid": "^8.3.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "rootDir": "",
    "testRegex": ".spec.js$",
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/uuid": "^8.3.1",
    "sequelize": "^6.6.2",
    "sequelize-auto": "^0.8.2",
    "sequelize-cli": "^6.2.0"
  }
}
