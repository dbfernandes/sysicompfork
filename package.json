{
  "name": "sysicomp",
  "version": "1.0.0",
  "description": "Sistema da Secretaria do Icomp",
  "main": "index.js",
  "scripts": {
    "start": "nodemon --watch 'src/**/*.js' --exec 'node -r esm src/server.js'",
    "db:reset:dev": "npx sequelize-cli db:migrate:undo:all",
    "db:init:dev": "sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "start:dev": "nodemon -L -r esm src/server.js",
    "criar-modulo": "node src/utils/criar-novo-modulo.js",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbfernandes/sysicomp.git"
  },
  "keywords": [
    "express",
    "sequelize",
    "mysql",
    "handlebars",
    "nodejs",
    "jest"
  ],
  "author": "Lucas Oliveira",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dbfernandes/sysicomp/issues"
  },
  "homepage": "https://github.com/dbfernandes/sysicomp#readme",
  "dependencies": {
    "admin-lte": "^3.1.0-rc",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csurf": "^1.11.0",
    "dotenv": "^10.0.0",
    "esm": "^3.2.25",
    "express": "^4.17.1",
    "express-handlebars": "^5.2.1",
    "express-session": "^1.17.2",
    "fastest-levenshtein": "^1.0.16",
    "handlebars": "^4.7.7",
    "html-pdf": "^3.0.1",
    "jest": "^26.6.3",
    "jquery-mask-plugin": "^1.14.16",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^2.3.3",
    "nodemailer": "^6.6.3",
    "nodemailer-express-handlebars": "^4.0.0",
    "uuid": "^8.3.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "rootDir": "",
    "testRegex": ".spec.js$",
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.2",
    "@types/bcrypt": "^5.0.0",
    "@types/uuid": "^8.3.1",
    "exceljs": "^4.4.0",
    "nodemon": "^2.0.14",
    "sequelize": "^6.6.2",
    "sequelize-auto": "^0.8.2",
    "sequelize-cli": "^6.2.0"
  }
}
