{
  "name": "sysicomp",
  "version": "1.0.0",
  "description": "Sistema da Secretaria do Icomp",
  "main": "src/app.ts",
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "start:prod": "NODE_ENV=production docker compose build --no-cache && NODE_ENV=production docker compose up --force-recreate",
    "start:prod-syscomp": "npm run prisma:init:dev && NODE_ENV=production node build/server.js",
    "start:dev": "NODE_ENV=development docker compose -f docker-compose.devlopment.yml up",
    "start:dev:dbs": "NODE_ENV=development docker compose -f docker-compose.devlopment.yml up --build redis phpmyadmin db gotenberg",
    "start:syscomp": "NODE_ENV=development tsx watch --watch src/server.ts",
    "start:selecao": "NODE_ENV=development tsx watch --watch src/serverSelecao.ts ",
    "start:numeros": "NODE_ENV=development tsx watch  src/app/serverNumerosIcomp.ts",
    "build": "tsc && tsc-alias && npm run copy-static",
    "copy-static": "node scripts/copy-static.js",
    "docker:start": "docker compose up -d",
    "docker:test:start": "docker compose -f docker-compose.test.yml up -d",
    "criar-modulo": "node src/utils/criarNovoModulo.js",
    "db:up": "docker compose -f docker-compose.test.yml up --build",
    "db:down": "docker compose -f docker-compose.test.yml down",
    "test": "NODE_ENV=test jest --verbose --selectProjects unit",
    "test:prisma": "dotenv -e .env.test npx prisma migrate dev && dotenv -e .env.test npx prisma db seed",
    "test:unit": "NODE_ENV=test jest --selectProjects unit",
    "test:integration": "NODE_ENV=test jest --selectProjects integration",
    "test:salas": "NODE_ENV=test jest ./tests/integration/sala/salas.test.ts --detectOpenHandles --verbose",
    "test:reservas": "NODE_ENV=test jest ./tests/integration/reserva/reservas.test.ts --detectOpenHandles --verbose",
    "test:alunos": "NODE_ENV=test jest ./tests/integration/aluno/alunos.test.ts --detectOpenHandles --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json,css,md}\"",
    "prisma:init:dev": "npx prisma migrate dev && npx prisma db seed",
    "prisma:migrate": "npx prisma migrate dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbfernandes/sysicomp.git"
  },
  "keywords": [
    "express",
    "prisma",
    "mysql",
    "handlebars",
    "nodejs",
    "jest"
  ],
  "author": "Lucas Oliveira",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dbfernandes/sysicomp/issues"
  },
  "homepage": "https://github.com/dbfernandes/sysicomp#readme",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@types/xml2json": "^0.11.6",
    "admin-lte": "^3.2.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "chromiumly": "^4.1.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.17.1",
    "express-handlebars": "^7.1.2",
    "express-session": "^1.18.1",
    "fastest-levenshtein": "^1.0.16",
    "handlebars": "^4.7.7",
    "handlebars-i18n": "^1.6.4",
    "html-to-text": "^9.0.5",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "luxon": "^3.7.1",
    "mime-types": "^3.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.5",
    "redis": "^5.6.0",
    "resend": "^4.7.0",
    "ts-node": "^10.9.2",
    "uuid": "^8.3.2",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xml2json": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.0.0",
    "@jest/types": "^29.6.3",
    "@swc/core": "^1.7.40",
    "@swc/jest": "^0.2.36",
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/html-to-text": "^9.0.4",
    "@types/http-status-codes": "^1.2.0",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.19",
    "@types/nodemailer": "^6.4.17",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^8.3.1",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "copy-webpack-plugin": "^13.0.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-html": "^8.1.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "handlebars-loader": "^1.7.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "mysql2": "^3.11.3",
    "prettier": "^3.2.5",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
