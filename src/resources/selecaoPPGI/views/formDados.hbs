{{ setTitle title="Dados Pessoais" }}

<style>
	.forms-page {
		height: 100vh;
		display: block;
		justify-content: center;
		align-items: center;
		background-color: #fff;
		overflow-y: auto;
	}
	.forms-page header {
		width: 100%;
		position: sticky;
		top: 0;
		left: 0;
		z-index: 1;
		height: 50px;
		background-color: #222;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-weight: bold;
		padding: 10px 45px;
		z-index: 9999;
	}

	.forms-page header h1 {
		font-size: 1.4rem;
		color: #dbdbdb;
		cursor: pointer;
	}

	.forms-page header h1:hover {
		color: #fff;
	}

	@media screen and (max-width: 720pt) {
		.forms-page header {
			padding: 10px 15px;
		}
	}

	.forms-page header .options {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.forms-page header .options button {
		background-color: transparent;
		border: none;
		cursor: pointer;
		color: #c7c7c7;
		transition: all .3s;
	}

	.forms-page header .options button:hover {
		color: #fff;
	}


	.forms-page section {
		display: flex;
		flex-direction: column;
		width: 90%;
		margin: auto;
		margin-top: 2%;
		min-height: 100vh;
		display: flex;
		justify-content: space-between;
		align-items: center;
		overflow-y: auto;
		color: #222;
	}

	.forms-page section h1 {
		font-size: 1.4rem;
		color: #222;
		margin-bottom: 10px;
	}

	.forms-page section .line {
		width: 100%;
		height: 1px;
		background-color: #c2c2c2;
		margin-bottom: 10px;
	}

	.forms-page section .info {
		width: 100%;
		height: 100%;
	}


	@media (max-width: 576px) {
	.forms-page section form {
		padding: 0;
	}
	}

	.forms-page section button {
		position: relative;
		bottom: 0;
	}

	.forms-page footer {
		width: 100%;
		height: 50px;
		position: fixed;
		bottom: 0;
		left: 0;
		background-color: #000;
	}



	.forms-page .progress .progress-bar {
		background-color: #006eff;
	}

	.forms-page nav .active {
		background-color: #006eff;
	}

	.toast-container {
		top: 0;
    	right: 0;
    	position: fixed;
   	 	margin-top: 3.5rem;
		margin-right: 1rem;
		z-index: 1050;
	}

	.alert {
		display: flex;
   		gap: 1rem;
   		align-items: center;
	}
</style>

<link href="https://cdn.rawgit.com/bantikyan/icheck-bootstrap/master/icheck-bootstrap.min.css" rel="stylesheet">
 
<div class="forms-page">
	<header>
		<div class="container">
			<h1 class="header-title">PPGI</h1>
			<div class="options">
				<button id="btn_inicio">Início</button>
				<button id="btn_logout">Sair</button>
			</div>
		</div>
	</header>
    <div class="toast-container position-fixed ">
        <div id="myToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="alert alert-primary mb-0" role="alert">
                <span id="toastMessage">This is a primary alert with <a href="#" class="alert-link">an example link</a>. Give it a click if you like.</span>
                 <button type="button" class="close" data-dismiss="alert" aria-label="Close">
    				<span aria-hidden="true">&times;</span>
  				</button>
            </div>
        </div>
    </div>
	<section class="content container">
		<nav>
			<ul>
				<li>
					<i class="nav-icon fas fa-user active"></i>
					Dados
				</li>
				<li>
					<i class="nav-icon fas fa-history"></i>
					Histórico
				</li>
				<li>
					<i class="nav-icon fas fa-project-diagram"></i>
					Proposta de Projeto
				</li>
				<li>
					<i class="nav-icon fas fa-check"></i>
					Confirmação
				</li>
			</ul>
			<div class="progress">
				<div class="progress-bar progress-bar-striped progress-bar-animated pbar-1" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
				</div>
			</div>
		</nav>
	
		<div class="container-fluid">
			<form id="candidato-formulario">
				<input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}">
				<input id="email" type="hidden" value="{{email}}">
				<input id="editalPosicao" type="hidden" value="{{editalPosicao}}">
				<input id="ComoSoubeObj" type="hidden" value="{{comoSoube}}">
				<input id="NascimentoObj" type="hidden" value="{{dataNascimento}}">
				<input id="UFObj" type="hidden" value="{{uf}}">
				<input id="CotistaObj" type="hidden" value="{{cotista}}">
				<input id="CotistaTipoObj" type="hidden" value="{{cotistaTipo}}">
				<input id="CondicaoObj" type="hidden" value="{{condicao}}">
				<input id="CondicaoTipoObj" type="hidden" value="{{condicaoTipo}}">
				<input id="BolsaObj" type="hidden" value="{{bolsista}}">

				<div class="card card-primary">
					<div class="card-header">
						<h3 class="card-title">Identificação do Candidato</h3>
					</div>
					<div class="card-body">
						<div class="row">

							<div class="form-group col-md-6">
								<label for="candidato-nome">
									<font color="#FF0000">*</font>
									<b>Nome:</b>
								</label>
								<input class="form-control" id="candidato-nome" placeholder="Insira seu nome" type="text" name="nome"
									maxlength="60" value="{{nome}}">
							</div>
							<div class="col-md-3 campo-candidato-datanascimento">
								<label class="control-label" for="data-nascimento">
									<font color="#FF0000">*</font>
									<b>Data de Nascimento:</b>
								</label>
								<div class="input-group">
									<div class="input-group date" id="candidato-datanascimento" data-target-input="nearest">
										<input type="text" class="form-control datetimepicker-input" id="data-nascimento"
											name="dataNascimento" data-target="#candidato-datanascimento">
										<div class="input-group-append" data-target="#candidato-datanascimento"
											data-toggle="datetimepicker">
											<div class="input-group-text"><i class="fa fa-calendar"></i></div>
										</div>
									</div>
								</div>

								<div class="help-block"></div>
							</div>

							<div class="col-md-3 " role="radiogroup">
								<label class="control-label" for="candidato-sexo">
									<font color="#FF0000">*</font>
									<b>Sexo:</b>
								</label>
								<div id="candidato-sexo" role="radiogroup"
									style="display: flex; align-content:center; gap: 20px; max-width: 100%; flex-wrap: wrap;">
									<div class="icheck-primary d-inline">
										<input type="radio" id="Sexo" name="candidatoSexo" {{#if (eq sexo 'M')}} checked="true" {{/if}}>
										<label for="Sexo"> Masculino</label>
									</div>

									<div class="icheck-primary d-inline">
										<input type="radio" id="Sexo2" name="candidatoSexo"  {{#if (eq sexo 'F')}} checked="true" {{/if}}>
										<label for="Sexo2">Feminino</label>
									</div>

								</div>
							</div>

						</div>

						<div class="form-group row">
							<div class="col-md-6 campo-candidato-nomesocial">
								<label class="control-label" for="candidato-nomesocial">
									<b>Nome Social:</b>
								</label>
								<input id="candidato-nomesocial" class="form-control" type="text" name="Candidato[nomesocial]"
									maxlength="60" value="{{nomeSocial}}" />
								<div class="help-block"></div>
							</div>

							<div class="col-md-3 campo-candidato-cep">
								<label class="control-label" for="candidato-cep">
									<font color="#FF0000">*</font>
									<b>CEP:</b>
								</label>
								<input id="candidato-cep" class="form-control" type="text" name="candidatoCep" data-plugin-inputmask=""
									value="{{cep}}" oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
								<div class="invalid-feedback"></div>
								<div class="help-block"></div>
							</div>

							<div class="col-md-3 campo-candidato-uf">
								<label class="control-label" for="candidato-uf">
									<font color="#FF0000">*</font>
									<b>Estado:</b>
								</label>
								<select id="candidato-uf" class="custom-select" name="candidatoUf">
									<option value="">Selecione UF:</option>
									<option value="AC">AC</option>
									<option value="AL">AL</option>
									<option value="AM">AM</option>
									<option value="AP">AP</option>
									<option value="BA">BA</option>
									<option value="CE">CE</option>
									<option value="DF">DF</option>
									<option value="ES">ES</option>
									<option value="GO">GO</option>
									<option value="MA">MA</option>
									<option value="MG">MG</option>
									<option value="MS">MS</option>
									<option value="MT">MT</option>
									<option value="PA">PA</option>
									<option value="PB">PB</option>
									<option value="PE">PE</option>
									<option value="PI">PI</option>
									<option value="PR">PR</option>
									<option value="RJ">RJ</option>
									<option value="RN">RN</option>
									<option value="RO">RO</option>
									<option value="RR">RR</option>
									<option value="RS">RS</option>
									<option value="SC">SC</option>
									<option value="SE">SE</option>
									<option value="SP">SP</option>
									<option value="TO">TO</option>
								</select>
								<div class="help-block"></div>
							</div>

						</div>

						<div class="form-group row">
							<div class="col-md-6 field-candidato-endereco">
								<label class="control-label" for="candidato-endereco">
									<font color="#FF0000">*</font> <b>Endereço:</b>
								</label>
								<input type="text" id="candidato-endereco" class="form-control" name="candidatoEndereco" maxlength="160"
									value="{{endereco}}">
								<div class="help-block"></div>
							</div>

							<div class="col-md-3 field-candidato-cidade has-error">
								<label class="control-label" for="candidato-cidade">
									<font color="#FF0000">*</font> <b>Cidade:</b>
								</label>
								<input type="text" id="candidato-cidade" class="form-control" name="candidatoCidade" maxlength="40"
									aria-invalid="true" value="{{cidade}}">
							</div>

							<div class="col-md-3 field-candidato-bairro">
								<label class="control-label" for="candidato-bairro">
									<font color="#FF0000">*</font> <b>Bairro:</b>
								</label>
								<input type="text" id="candidato-bairro" class="form-control" name="candidatoBairro" maxlength="50"
									value="{{bairro}}">
								<div class="help-block"></div>
							</div>
						</div>

						<div class="row form-group">
							<div class="col-md-3 field-candidato-nacionalidade">
								<label for="candidato-sexo" class="control-label">
									<font color="#FF0000">*</font> <b>Nacionalidade:</b>
								</label>

								<div id="candidato-sexo" role="radiogroup" style="display: flex; align-content:center; gap: 20px;">
									<div class="icheck-primary d-inline">
										<input type="radio" id="Nacionalidade1" name="candidatoNacionalidade" 
										{{#if (eq nacionalidade 'Brasileira')}} checked {{/if}}>
										<label for="Nacionalidade1"> Brasileira</label>
									</div>

									<div class="icheck-primary d-inline">
										<input type="radio" id="Nacionalidade2" name="candidatoNacionalidade" 
										{{#if (eq nacionalidade 'Estrangeira')}} checked {{/if}}>
										<label for="Nacionalidade2"> Estrangeira</label>
									</div>
								</div>
							</div>
						</div>
						<div class="row form-group" id="row-nacionalidade-brasileiro" {{#if (eq nacionalidade 'Estrangeira')}}hidden{{/if}}>
							<div class="col-md-3">
								<label class="control-label" for="cpf"></label>
									<font color="#FF0000">*</font> <b>CPF:</b>
								</label>
								<input type="text" id="cpf" class="form-control cpf" name="cpf" value="{{cpf}}">
								<div class="help-block"></div>
							</div>
						</div>
						<div class="row form-group" id="row-nacionalidade-estrangeiro" {{#if (eq nacionalidade 'Brasileira')}}hidden{{/if}}>
							<div class="col-md-6">
								<label class="control-label" for="pais"></label>
									<font color="#FF0000">*</font> <b>País:</b>
								</label>
								<input type="text" id="pais" class="form-control" name="pais" value="{{pais}}">
								<div class="help-block"></div>
							</div>
							<div class="col-md-6">
								<label class="control-label" for="passaporte"></label>
									<font color="#FF0000">*</font> <b>Passaporte:</b>
								</label>
								<input type="text" id="passaporte" class="form-control" name="passaporte" value="{{passaporte}}" maxlength="9">
								<div class="help-block"></div>
							</div>
						</div>
					</div>
				</div>

				<div class="card card-primary">
					<div class="card-header">
						<h3 class="card-title">Telefones para Contato</h3>
					</div>

					<div class="card-body">
						<div class="row">
							<div class="form-group col-md-3  col-sm-6">
								<label class="control-label" for="candidato-telresidencial">
									<font color="#FF0000">*</font> <b>Telefone Principal:</b>
								</label>
								<input type="text" id="candidato-telresidencial" class="form-control" name="candidatoTelresidencial"
									value="{{telefone}}" oninput="this.value = this.value.replace(/[^0-9]/g, '');">
								<div class="help-block"></div>
							</div>

							<div class="form-group col-md-3 col-sm-6">
								<label class="control-label" for="candidato-telcelular">Telefone Alternativo:</label>
								<input type="text" id="candidato-telcelular" class="form-control" name="Candidato[telcelular]"
									value="{{telefoneSecundario}}" oninput="this.value = this.value.replace(/[^0-9]/g, '');">

								<div class="help-block"></div>
							</div>
						</div>
					</div>
				</div>


				<div class="card card-primary">
					<div class="card-header">
						<h3 class="card-title">Como soube do Edital?</h3>
					</div>

					<div class="card-body">
						<div class="row form-group col-sm-6">
							<div>
								<label>
									<font color="#FF0000">*</font> <b>Como você soube do edital de seleção?</b>
								</label>
								<select id="como-soube" class="custom-select" name="comoSoube">
									<option value="">Selecione como soube:</option>
									<option value="Facebook">Facebook</option>
									<option value="Instagram">Instagram</option>
									<option value="LinkedIn">LinkedIn</option>
									<option value="Email">Por mensagem de email</option>
									<option value="PPGI">Através da página Web do PPGI</option>
									<option value="IComp">Através da página Web do IComp</option>
									<option value="ProprioIcomp">No próprio IComp (secretaria, colegas, professores)</option>
									<option value="Outro">Outro</option>
								</select>
							</div>
						</div>
					</div>
				</div>

				<div class="card card-primary">
					<div class="card-header">
						<h3 class="card-title">Dados da Inscrição</h3>
					</div>
					<div class="card-body">
						<div class="row form-group">
							<div class="form-group col-md-5">
								<label class="control-label">
									<font color="#FF0000">*</font> <b>Curso Desejado:</b>
								</label>

								<div id="cadidato-curso" role="radiogroup">
									<div class="icheck-primary d-inline">
										<input type="radio" id="Curso1" name="candidatoCurso"  {{#if (eq cursoDesejado 'Mestrado')}} checked="true" {{/if}}>
										<label for="Curso1" style="margin-right: 20px;"> Mestrado
										</label>
									</div>

									<div class="icheck-primary d-inline">
										<input type="radio" id="Curso2" name="candidatoCurso" {{#if (eq cursoDesejado 'Doutorado')}} checked="true" {{/if}}>
										<label for="Curso2"> Doutorado
										</label>
									</div>
								</div>
							</div>

							<div class="col-md-12">
								<label class="control-label">
									<font color="#FF0000">*</font>
									 <b>Regime de Dedicação: (Obs: alunos candidatos a bolsa devem optar pelo regime integral):</b>
								</label>

								<input type="hidden" name="candidatoRegime" value="">
								<div id="candidato-regime" role="radiogroup">
									<div class="icheck-primary d-inline">
										<input type="radio" id="Regime1" name="candidatoRegime" {{#if (eq regime 'Integral')}} checked="true" {{/if}}>
										<label for="Regime1" style="margin-right: 20px;"> Integral </label>
									</div>
									<div class="icheck-primary d-inline">
										<input type="radio" id="Regime2" name="candidatoRegime" {{#if (eq regime 'Parcial')}} checked="true" {{/if}}>
										<label for="Regime2"> Parcial </label>
									</div>
								</div>
								<div class="help-block"></div>
							</div>
						</div>

						<div id="cotista-div" class="row form-group">
							<div class="col-md-5 form-group">
								<div>
									<label for="cotista">
										<font color="#FF0000">*</font> Cotista?
									</label>
								</div>

								<div>
									<input type="checkbox" id="cotista" name="cotista" data-bootstrap-switch-cotista
										data-off-color="danger" data-on-color="success" data-on-text="Sim" data-off-text="Não">
								</div>

							</div>

							<div id="cota" class="col-md-6">
								<label class="control-label" for="tipo-cota">
									<font color="#FF0000">*</font> <b>Tipo de Cota:</b>
								</label>

								<select id="tipo-cota" class="custom-select" name="tipo-cota">
									<option value="">Selecione a cota:</option>
									<option value="indigena">Índigena</option>
									<option value="negro">Negro</option>
									<option value="pardo">Pardo</option>
									<option>Pessoa com deficiência(PCD)</option>
								</select>  
							</div>
						</div>

						<div id="deficiencia-div" class="row form-group">
							<div class="col-md-5 form-group">

								<label for="candidato-deficiencia1">
									<font color="#FF0000">*</font> <b>Possui algum tipo de problema de saúde física ou psiquiátrica?
									</b>
								</label>

								<div>
									<input type="checkbox" id="candidato-deficiencia1" name="deficiencia"
										data-bootstrap-switch-deficiencia data-off-color="danger" data-on-color="success" data-on-text="Sim"
										data-off-text="Não">

								</div>
							</div>
							<div id="condicao" class=" col-md-6">
								<label class="control-label" for="candidato-condicao">
									<font color="#FF0000">*</font> <b>Qual:</b>
								</label>
								<input type="text" id="candidato-condicao" class="form-control" name="candidatoCondicao"
									data-plugin-inputmask="inputmask_32e8983f" value="{{condicaoTipo}}">
							</div>
						</div>

						<div class="row">
							<div class="col-md-5">
								<label for="candidato-bolsa">
									<font color="#FF0000">*</font> <b>Solicita Bolsa de Estudo? (Obs: somente poderão solicitar bolsa alunos sem vínculo empregatício e que não possuam outro tipo de bolsa)
									</b>
								</label>

								<input type="checkbox" id="candidato-bolsa" name="bolsa" data-bootstrap-switch-bolsa
									data-off-color="danger" data-on-color="success" data-on-text="Sim" data-off-text="Não">
							</div>
						</div>
					</div>

					<div class="card-footer">
						<div class="col">
							<button id="btn-save-continue" type="submit" class="btn btn-success float-right" >
								Salvar e Continuar
								<span class="spinner-border spinner-border-sm " hidden="true" role="status" aria-hidden="true"></span>
							</button>
							<button id="btn-save" type="button" class=" btn btn-secondary float-right" style="margin-right: 1rem;"> 
								Salvar
								<span class="spinner-border spinner-border-sm " hidden="true" role="status" aria-hidden="true"></span>
							</button>
						</div>
					</div>
			</form>
		</div>
	</section>
</div>
</div>

<script>
	function FormAdicionarPage() {
		$(document).ready(function () {
			const comoSoubeValue = document.getElementById("ComoSoubeObj").value;
			$("#como-soube").val(comoSoubeValue);
		});

		var cotistaValue = document.getElementById("CotistaObj").value;
		var cotistaTipoValue = document.getElementById("CotistaTipoObj").value;
		
		var select = document.getElementById("tipo-cota");
		for (var i = 0; i < select.options.length; i++) {
			if (select.options[i].value === cotistaTipoValue) {
				select.selectedIndex = i;
				break;
			}
		}

		var ufValue = document.getElementById('UFObj').value;
		var selectElement = document.getElementById('candidato-uf');
		for (var i = 0; i < selectElement.options.length; i++) {
			if (selectElement.options[i].value === ufValue) {
				selectElement.options[i].selected = true;
				break;
			}
		}

		{{#if condicao}} document.getElementById("candidato-deficiencia1").checked = true;{{/if}}
		{{#if cotista}} document.getElementById("cotista").checked = true; {{/if}}
		{{#if bolsista}} document.getElementById("candidato-bolsa").checked = true;{{/if}}
		
		$(document).ready(function () {
			var condicaoInicial = $("#candidato-deficiencia1").prop("checked");

