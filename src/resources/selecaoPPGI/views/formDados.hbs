<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.1/build/css/intlTelInput.css">
<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.1/build/js/intlTelInput.min.js"></script>
<script>
	$(document).ready(() => {

    const inputFilesConfig = {
      Cota: {
        input: "#comprovante-cota",
        buttons: "#buttons-cota",
        containerInput: "#input-comprovante-cota",
        name: "#name-cota",
        btnChange: "#btn-change-cota",
        btnDelete: "#btn-delete-cota",
        aDownload: "#url-cota",
        hasFileSave: {{hasComprovanteCota}}
      },
      Autodeclaracao: {
        input: "#comprovante-autodeclaracao",
        buttons: "#buttons-autodeclaracao",
        containerInput: "#input-autodeclaracao",
        name: "#name-autodeclaracao",
        btnChange: "#btn-change-autodeclaracao",
        btnDelete: "#btn-delete-autodeclaracao",
        aDownload: "#url-autodeclaracao",
        hasFileSave: {{hasAutodeclaracao}}
      },
      VideoAutodeclaracao: {
        input: "#comprovante-autodeclaracao-video",
        buttons: "#buttons-autodeclaracao-video",
        containerInput: "#input-autodeclaracao-video",
        name: "#name-autodeclaracao-video",
        btnChange: "#btn-change-autodeclaracao-video",
        btnDelete: "#btn-delete-autodeclaracao-video",
        aDownload: "#url-autodeclaracao-video",
        hasFileSave: {{hasVideoAutodeclaracao}}
      }
    }

    function changeFile(idInput) {
      $(idInput).click();
    }

    function actionDeleteFile(idInput, idButtons, idContainerInput){
      $(idInput).val('');
      $(idButtons).hide();
      $(idContainerInput).show();
      $(idInput).next('label').text('{{__ "ppgi.form.chooseFile"}}');
    }

    function changeFileInput(event, aLink, idButtons, idContainerInput, idName) {
      const input = $(event.target);
      if (!input.valid()) {
        input.next('label').text('{{__ "ppgi.form.chooseFile"}}');
        return;
      }
      const file = event.target.files[0];
      const fileName = file.name;
      const url = URL.createObjectURL(file);
      $(idContainerInput).hide();
      $(idButtons).css('display', 'flex');
      $(idName).html(`<b>${fileName}</b>`);

      $(aLink)
        .attr('href', url)
        .attr('download', fileName);
    }

    Object.keys(inputFilesConfig).forEach(key => {
      const inputConfig = inputFilesConfig[key];
      const input = inputConfig.input;
      const buttons = inputConfig.buttons;
      const containerInput = inputConfig.containerInput;
      const name = inputConfig.name;
      const btnChange = inputConfig.btnChange;
      const btnDelete = inputConfig.btnDelete;
      const aDownload = inputConfig.aDownload;

      $(input).change(function (event) {
        inputFilesConfig[key].hasFileSave = true;
        changeFileInput(event, aDownload, buttons, containerInput, name);
      });

      $(btnChange).click(function () {
        changeFile(input);
      });

      $(btnDelete).click(function () {
        inputFilesConfig[key].hasFileSave = false;
        actionDeleteFile(input, buttons, containerInput);
      });
    });

    const basePath = "{{basePath}}";
    const comoSoubeValue = document.getElementById("ComoSoubeObj").value;

		$("#como-soube").val(comoSoubeValue);

    {{#if dataNascimento}}
      const nascimentoValue = new Date("{{dataNascimento}}").toISOString();
      const formattedDate = moment(nascimentoValue).format("DD/MM/YYYY");
      $("#data-nascimento").val(formattedDate);
      $('#candidato-datanascimento').datetimepicker({
        format: 'DD/MM/YYYY',
      });
    {{/if}}

    const input = document.querySelector("#phone");
    const inputPhone =  window.intlTelInput(input, {
      initialCountry: "br",
      customPlaceholder: (selectedCountryPlaceholder, selectedCountryData) => "e.x. " + selectedCountryPlaceholder,
      loadUtils: () => import("https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.1/build/js/utils.js"),
      i18n: {
        "selectedCountryAriaLabel": "{{__ "intlTel.selectedCountryAriaLabel"}}",
        "noCountrySelected": "{{__ "intlTel.noCountrySelected"}}",
        "countryListAriaLabel": "{{__ "intlTel.countryListAriaLabel"}}",
        "searchPlaceholder": "{{__ "intlTel.searchPlaceholder"}}",
        "zeroSearchResults": "{{__ "intlTel.zeroSearchResults"}}",
        "oneSearchResult": "{{__ "intlTel.oneSearchResult"}}",
        "multipleSearchResults": "{{__ "intlTel.multipleSearchResults"}}",
        "ac": "{{__ "intlTel.ac"}}",
        "xk": "{{__ "intlTel.xk"}}",
      },
      separateDialCode: true,
      countryOrder: ["br", "us", "gb"],
      strictMode: true,
      validationNumberTypes: null
    });
    input.addEventListener("countrychange", function () {
      input.value = "";
    });
    const input2 = document.querySelector("#phone2");
    const inputPhone2 =  window.intlTelInput(input2, {
      initialCountry: "br",
      customPlaceholder: (selectedCountryPlaceholder, selectedCountryData) => "e.x. " + selectedCountryPlaceholder,
      loadUtils: () => import("https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.1/build/js/utils.js"),
      i18n: {
        "selectedCountryAriaLabel": "{{__ "intlTel.selectedCountryAriaLabel"}}",
        "noCountrySelected": "{{__ "intlTel.noCountrySelected"}}",
        "countryListAriaLabel": "{{__ "intlTel.countryListAriaLabel"}}",
        "searchPlaceholder": "{{__ "intlTel.searchPlaceholder"}}",
        "zeroSearchResults": "{{__ "intlTel.zeroSearchResults"}}",
        "oneSearchResult": "{{__ "intlTel.oneSearchResult"}}",
        "multipleSearchResults": "{{__ "intlTel.multipleSearchResults"}}",
        "ac": "{{__ "intlTel.ac"}}",
        "xk": "{{__ "intlTel.xk"}}",
      },
      separateDialCode: true,
      countryOrder: ["br", "us", "gb"],
      strictMode: true,
      validationNumberTypes: null
    });
    input2.addEventListener("countrychange", function () {
      input.value = "";
    });

    const cotistaTipoValue = document.getElementById('CotistaTipoObj').value;

    const select = document.getElementById('tipo-cota');
    for (let i = 0; i < select.options.length; i++) {
      if (select.options[i].value === cotistaTipoValue) {
        select.selectedIndex = i;
        break;
      }
    }
    const ufValue = document.getElementById('UFObj').value;
    const selectElement = document.getElementById('candidato-uf');
    for (let i = 0; i < selectElement.options.length; i++) {
      if (selectElement.options[i].value === ufValue) {
        selectElement.options[i].selected = true;
        break;
      }
    }

    {{#if condicao}} document.getElementById("candidato-deficiencia1").checked = true;{{/if}}
    {{#if cotista}} document.getElementById("cotista").checked = true; {{/if}}
    {{#if bolsista}} document.getElementById("candidato-bolsa").checked = true;{{/if}}
    {{#if tae}} document.getElementById("candidato-tae").checked = true;{{/if}}
    {{#if cotistaTipo}}
      const cotistaTipo = '{{cotistaTipo}}'

      const shouldBeComprovante =
        cotistaTipo === 'indigena' ||
        cotistaTipo === 'pcd';
      const shouldBeAutodeclaracao =
        cotistaTipo === 'negro' || cotistaTipo === 'pardo';

      if (shouldBeAutodeclaracao){
        $("#row-cota").slideUp();
        $("#row-autodeclaracao").slideDown();
        $("#row-autodeclaracao-video").slideDown();
      } else if (shouldBeComprovante){
        $("#row-cota").slideDown();
        $("#row-autodeclaracao").slideUp();
        $("#row-autodeclaracao-video").slideUp();
      } else {
        $("#row-cota").slideUp();
        $("#row-autodeclaracao").slideUp();
        $("#row-autodeclaracao-video").slideUp();
      }
    {{else}}
      $("#row-cota").slideUp();
      $("#row-autodeclaracao").slideUp();
      $("#row-autodeclaracao-video").slideUp();
    {{/if}}

    $('#candidato-datanascimento').datetimepicker({
      format: 'DD/MM/YYYY',
      locale: 'pt-br',
    });

    $("#tipo-cota").change(function (el) {
      switch (el.target.value) {
        case 'indigena':
        case 'pcd':
          $("#row-cota").slideDown();
          $("#row-autodeclaracao").slideUp();
          $("#row-autodeclaracao-video").slideUp();
          break;
        case 'negro':
        case 'pardo':
          $("#row-cota").slideUp();
          $("#row-autodeclaracao").slideDown();
          $("#row-autodeclaracao-video").slideDown();
          break;
        default:
          $("#row-cota").slideUp();
          $("#row-autodeclaracao").slideUp();
          $("#row-autodeclaracao-video").slideUp();
          break;
      }
    });

    $("input[data-bootstrap-switch-cotista]").each(function () {
      $(this).bootstrapSwitch('state', $(this).prop('checked'));
      if (!$(this).prop('checked')) {
        $("#cota").slideUp();
      }
      $(this).bootstrapSwitch('onSwitchChange', () => {
        if ($(this).is(":checked")) {
          $("#cota").slideDown();
        } else {
          $("#tipo-cota").val('')
          $("#cota").slideUp();
          $("#row-cota").slideUp();
          $("#row-autodeclaracao").slideUp();
          $("#row-autodeclaracao-video").slideUp();
        }
      });
    });

    $("input[data-bootstrap-switch-deficiencia]").each(function () {
      $(this).bootstrapSwitch('state', $(this).prop('checked'));
      if (!$(this).prop('checked')) {
        $("#condicao").slideUp();
      }
      $(this).bootstrapSwitch('onSwitchChange', () => {
        if ($(this).is(":checked")) {
          $("#condicao").slideDown();
          $("#deficiencia-div").css("height", "auto");
        } else {
          $("#condicao").slideUp();
          $("#deficiencia-div").css("height", "auto");
        }
      })
    })
    $("input[data-bootstrap-switch-tae]").each(function () {
      $(this).bootstrapSwitch('state', $(this).prop('checked'));
    });

    $("input[data-bootstrap-switch-bolsa]").each(function () {
      $(this).bootstrapSwitch('state', $(this).prop('checked'));
      $(this).bootstrapSwitch('onSwitchChange', () => {
        if ($(this).is(":checked")) {
          $("#Regime1").prop("checked", true);
          $("#Regime2").prop("checked", false).prop("disabled", true);
        } else {
          $("#Regime2").prop("disabled", false);
        }
      });
    });

    $('.bootstrap-switch.bootstrap-switch-wrapper').each(function (index, element){
      $(element).attr('tabindex',0)
        .on('focus', function () {
          $(this).addClass('bootstrap-switch-focussed');
        })
        .on('blur', function () {
          $(this).removeClass('bootstrap-switch-focussed');
        })
        .on('keyup', function (e) {
          if(e.which===32){
            $(this).find('input').bootstrapSwitch('toggleState');
          }
        });
    })


    function getSelectedNacionalidade() {
      let brasileiraRadio = document.getElementById("Nacionalidade1");
      let estrangeiraRadio = document.getElementById("Nacionalidade2");
      let selectedNacionalidade = "";
      if (brasileiraRadio.checked) {
        selectedNacionalidade = "Brasileira";
      } else if (estrangeiraRadio.checked) {
        selectedNacionalidade = "Estrangeira";
      }
      return selectedNacionalidade;
    }

    function getSelectedComoSoube() {
      let selectComoSoube = document.getElementById("como-soube");
      return selectComoSoube.options[selectComoSoube.selectedIndex].value;
    }

    function getSelectedCurso() {
      let MestradoRadio = document.getElementById("Curso1");
      let DoutoradoRadio = document.getElementById("Curso2");
      let selectedCurso = "";
      if (MestradoRadio.checked) {
        selectedCurso = "Mestrado";
      } else if (DoutoradoRadio.checked) {
        selectedCurso = "Doutorado";
      }
      return selectedCurso;
    }

    function getSelectedRegime() {
      let IntegralRadio = document.getElementById("Regime1");
      let ParcialRadio = document.getElementById("Regime2");
      let selectedRegime = "";
      if (IntegralRadio.checked) {
        selectedRegime = "Integral";
      } else if (ParcialRadio.checked) {
        selectedRegime = "Parcial";
      }
      return selectedRegime;
    }

    function getSelectedCota() {
      let cotista = document.getElementById("cotista").checked;
      if (!cotista) {
        return null;
      }
      let selectCota = document.getElementById("tipo-cota");
      return selectCota.options[selectCota.selectedIndex].value;
    }

    function getCondicao() {
      let deficiencia = document.getElementById("candidato-deficiencia1").checked;
      if (!deficiencia) {
        return null;
      }
      return document.getElementById("candidato-condicao").value;
    }

    // function getBolsa() {
    //   let bolsa = document.getElementById("candidato-bolsa").checked;
    //   return Boolean(bolsa);
    // }

    function getTae() {
      return Boolean(document.getElementById("candidato-tae").checked)
    }

    function checkCondicao() {
      let deficiencia = document.getElementById("candidato-deficiencia1").checked;
      let condicaoInput = document.getElementById("candidato-condicao");
      if (!deficiencia) {
        condicaoInput.value = "";
      }
      return Boolean(deficiencia);
    }

    function checkCotista() {
      let cotista = document.getElementById("cotista").checked;
      let cotistaCota = document.getElementById("tipo-cota");
      if (!cotista) {
        cotistaCota.value = "";
      }
      return Boolean(cotista);
    }

    function getValueFromForm() {
      const data = new FormData()
      data.append('nome',document.getElementById('candidato-nome').value);
      data.append('dataNascimento',  document.getElementById('data-nascimento').value);
      data.append('sexo', document.getElementById('candidato-sexo').value);
      data.append('nomeSocial', document.getElementById('candidato-nomesocial').value);
      data.append('cep',  document.getElementById('candidato-cep').value);
      data.append('uf', document.getElementById('candidato-uf').value);
      data.append('endereco', document.getElementById('candidato-endereco').value);
      data.append('cidade',  document.getElementById('candidato-cidade').value);
      data.append('bairro', document.getElementById('candidato-bairro').value);
      data.append('nacionalidade', getSelectedNacionalidade());
      // data.append('telefone', document.getElementById('candidato-telresidencial').value);
      // data.append('telefoneSecundario',document.getElementById('candidato-telcelular').value);
      data.append('comoSoube', getSelectedComoSoube());
      data.append('cursoDesejado', getSelectedCurso());
      data.append('regime', getSelectedRegime());
      data.append('cotista', checkCotista());
      data.append('cotistaTipo', getSelectedCota());
      data.append('condicao', checkCondicao());
      data.append('condicaoTipo', getCondicao());
      // data.bolsista = getBolsa()
      data.append('tae', getTae());
      data.append('cpf', document.getElementById('cpf').value);
      data.append('pais', document.getElementById('pais').value);
      data.append('passaporte', document.getElementById('passaporte').value);
      if (inputPhone && inputPhone.isValidNumber()) {
        const countryData = inputPhone.getSelectedCountryData();

        let phoneToSave;
        if (countryData.iso2 === 'br') {
          phoneToSave = inputPhone.getNumber(2);
        } else {
          phoneToSave = inputPhone.getNumber();
        }
