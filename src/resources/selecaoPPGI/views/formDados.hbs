    function pesquisarCep() {
      const cep = $('#candidato-cep').val();
      const cepInput = $('#candidato-cep')[0];
      const invalidFeedback = document.querySelector('.campo-candidato-cep .invalid-feedback');

      const enderecoInput = document.getElementById('candidato-endereco');
      const cidadeInput = document.getElementById('candidato-cidade');
      const bairroInput = document.getElementById('candidato-bairro');
      const ufInput = document.getElementById('candidato-uf');

      const cepValido = /^[0-9]{5}-[0-9]{3}$/.test(cep);



      if (cep.length === 0) return;

      if (!cepValido) {
        cepInput.classList.add('is-invalid');
        invalidFeedback.textContent = "{{__ "ppgiForm1.validacao.candidatoCep.cepInvalido"}}";
        return;
      }

      cepInput.classList.remove('is-invalid');

      // Desabilita campos de endereço durante a requisição
      enderecoInput.disabled = true;
      cidadeInput.disabled = true;
      bairroInput.disabled = true;
      ufInput.disabled = true;

    const url = `https://viacep.com.br/ws/${cep}/json/`;

    fetch(url)
    .then(response => {
      if (!response.ok) {
        throw new Error("{{__ "ppgiForm1.cepNotFound"}}");
      }
      return response.json();
    })
    .then(data => {
      if (data.erro) {
        throw new Error("{{__ "ppgiForm1.cepNotFound"}}");
      }
      enderecoInput.value = data.logradouro;
      cidadeInput.value = data.localidade;
      bairroInput.value = data.bairro;
      ufInput.value = data.uf;

    })
    .catch(error => {
      cepInput.classList.add('is-invalid');
      invalidFeedback.textContent = error.message;
    }).finally(()=>{
      enderecoInput.disabled = false;
      cidadeInput.disabled = false;
      bairroInput.disabled = false;
      ufInput.disabled = false;
    });
    }
