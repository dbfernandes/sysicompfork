    $.validator.addMethod("cpf", (value, element) => {
      value = value.replace(/[.\-]/g, "");
      if (value.length !== 11 || /^(\d)\1+$/.test(value)) {
        return false;
      }

      let sum = 0;
      let remainder;

      // Valida o primeiro dígito verificador
      for (var i = 1; i <= 9; i++) {
        sum = sum + parseInt(value.substring(i - 1, i)) * (11 - i);
      }
      remainder = (sum * 10) % 11;
      if ((remainder == 10) || (remainder == 11)) {
        remainder = 0;
      }
      if (remainder != parseInt(value.substring(9, 10))) {
        return false;
      }

      sum = 0;

      // Valida o segundo dígito verificador
      for (var i = 1; i <= 10; i++) {
        sum = sum + parseInt(value.substring(i - 1, i)) * (12 - i);
      }
      remainder = (sum * 10) % 11;
      if ((remainder == 10) || (remainder == 11)) {
        remainder = 0;
      }
      if (remainder != parseInt(value.substring(10, 11))) {
        return false;
      }

      return true;
    }, "Por favor, insira um CPF válido.");

