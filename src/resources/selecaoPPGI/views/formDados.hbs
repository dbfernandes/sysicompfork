    function showToast(message, alertClass) {
      const toastElement = $('#myToast');
      const toastBody = toastElement.find('.alert');

      // Remove qualquer classe de alerta existente
      toastBody.removeClass('alert-primary alert-success alert-warning alert-danger alert-info');
      // Adiciona a classe de alerta apropriada
      toastBody.addClass(alertClass);
      // Define a mensagem do toast
      $('#toastMessage').text(message);
      // Inicializa e configura o delay do toast
      const toast = new bootstrap.Toast(toastElement[0], {
        delay: 5000 // Tempo em milissegundos (por exemplo, 5000 ms = 5 segundos)
      });
      toast.show();
    }

    function pesquisarCep() {
      const cep = $('#candidato-cep').val();
      const cepInput = $('#candidato-cep')[0];
      const invalidFeedback = document.querySelector('.campo-candidato-cep .invalid-feedback');

      const cepValido = /^[0-9]{5}-[0-9]{3}$/.test(cep);

      if (!cepValido) {
        cepInput.classList.add('is-invalid');
        invalidFeedback.textContent = "{{__ "ppgiForm1.validacao.candidatoCep.cepInvalido"}}";
        return;
      }

      cepInput.classList.remove('is-invalid');

      const url = `https://viacep.com.br/ws/${cep}/json/`;

      fetch(url)
        .then(response => {
          if (!response.ok ) {
            throw new Error("{{__ "ppgiForm1.cepNotFound"}}");
          }
          return response.json();
        })
        .then(data => {
          if (data.erro) {
            throw new Error("{{__ "ppgiForm1.cepNotFound"}}");
          }
          document.getElementById('candidato-endereco').value = data.logradouro;
          document.getElementById('candidato-cidade').value = data.localidade;
          document.getElementById('candidato-bairro').value = data.bairro;
          document.getElementById('candidato-uf').value = data.uf;
        })
        .catch(error => {
          cepInput.classList.add('is-invalid');
          invalidFeedback.textContent = error.message;
        });
    }
  });
</script>