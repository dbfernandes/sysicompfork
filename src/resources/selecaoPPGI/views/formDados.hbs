{{ setTitle title="Dados Pessoais" }}

<style>
	.toast-container {
		top: 0;
    	right: 0;
    	position: fixed;
   	 	margin-top: 3.5rem;
		margin-right: 1rem;
		z-index: 1050;
	}

	.alert {
		display: flex;
   		gap: 1rem;
   		align-items: center;
	}

	.radio-group {
		margin-bottom: 8px;
	}

  .iti__tel-input {
    padding-top: 5px;
    padding-bottom: 5px;
    box-sizing: border-box;
    border: 1px solid #ced4da;
    border-radius: .25rem;
  }
  .iti__tel-input:focus {
    outline: none;
    color: #495057;
    background-color: #fff;
    border-color: #80bdff;
    outline: 0;
    box-shadow: inset 0 0 0 transparent;
  }

  .iti { width: 100%; }
  .iti__tel-input { width: 100%; }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/css/intlTelInput.css">

<link href="https://cdn.rawgit.com/bantikyan/icheck-bootstrap/master/icheck-bootstrap.min.css" rel="stylesheet">
<!-- -->
<!-- Conteúdo principal da página -->
<main class="forms-page">
  <!-- Cabeçalho -->
  <header>
    <div class="container d-flex justify-content-between align-items-center px-3">
      <h1 class="header-title">{{__ "ppgi.header.title"}}</h1>
      <div class="options">
        {{> ppgi/selectLanguageHeader}}
        <button class="p-0" id="btn_logout">{{__ "ppgi.header.logoutButton"}}</button>
      </div>
    </div>
  </header>

  <!-- Área de notificações (toast) -->
  <div class="toast-container position-fixed">
    <div
      id="myToast"
      class="toast"
      role="alert"
      aria-live="assertive"
      aria-atomic="true"
    >
      <div class="alert alert-primary mb-0" role="alert">
				<span id="toastMessage">
					This is a primary alert with
					<a href="#" class="alert-link">an example link</a>.
					Give it a click if you like.
				</span>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Conteúdo da página (formulário) -->
  <section class="content container">
    <!-- Navegação (pode ser um <nav> se for menu) -->
    {{> ppgi/nav indexSelect="1" progress="25"}}

    <div class="container-fluid">
      <!-- Agrupamos o formulário em um <article> para indicar uma seção independente -->
      <article>
        <form id="candidato-formulario" >
          <!-- Tokens e inputs ocultos -->
          <input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}" />
          <input id="email" type="hidden" value="{{email}}" />
          <input id="editalPosicao" type="hidden" value="{{editalPosicao}}" />
          <input id="ComoSoubeObj" type="hidden" value="{{comoSoube}}" />
          <input id="UFObj" type="hidden" value="{{uf}}" />
          <input id="CotistaObj" type="hidden" value="{{cotista}}" />
          <input id="CotistaTipoObj" type="hidden" value="{{cotistaTipo}}" />
          <input id="CondicaoObj" type="hidden" value="{{condicao}}" />
          <input id="CondicaoTipoObj" type="hidden" value="{{condicaoTipo}}" />

          <!-- Card 1: Identificação do Candidato -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">
                {{__ "ppgiForm1.identificacaoCandidato.title"}}
              </h3>
            </div>
            <div class="card-body">
              <div class="row">
                <!-- Nome -->
                <div class="form-group col-md-6">
                  <label for="candidato-nome">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.nome"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-nome"
                    type="text"
                    name="nome"
                    maxlength="60"
                    placeholder="{{__ "ppgiForm1.identificacaoCandidato.nomePlaceholder"}}"
                    value="{{nome}}"
                    autofocus
                  />
                </div>

                <!-- Data de nascimento -->
                <div class="col-md-3 campo-candidato-datanascimento form-group">
                  <label for="data-nascimento" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.dataNascimento"}}:</b>
                  </label>
                  <div class="input-group" id="candidato-datanascimento" data-target-input="nearest">
                    <input
                      type="text"
                      class="form-control datetimepicker-input"
                      id="data-nascimento"
                      name="dataNascimento"
                      data-target="#candidato-datanascimento"
                    />
                    <div
                      class="input-group-append"
                      data-target="#candidato-datanascimento"
                      data-toggle="datetimepicker"
                    >
                      <div class="input-group-text">
                        <i class="fa fa-calendar"></i>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Sexo -->
                <div class="col-md-3 form-group" role="radiogroup" aria-label="Sexo">
                  <label for="candidato-sexo" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.sexo"}}:</b>
                  </label>
                  <div

                    class="d-flex align-content-center radio-group"
                    style="column-gap: 20px; max-width: 100%; flex-wrap: wrap; row-gap: 4px;"
                  >
                    <select id="candidato-sexo" name="candidato-sexo" class="custom-select">
                      <option value="">{{__ "ppgiForm1.identificacaoCandidato.notInform"}}</option>
                      <option {{#if (eq sexo 'M')}}selected{{/if}} value="M">{{__ "ppgiForm1.identificacaoCandidato.masculino"}}</option>
                      <option {{#if (eq sexo 'F')}}selected{{/if}} value="F">{{__ "ppgiForm1.identificacaoCandidato.feminino"}}</option>
                    </select>

                    <!--                    <div class="icheck-primary d-inline">-->
<!--                      <input-->
<!--                        type="radio"-->
<!--                        id="Sexo"-->
<!--                        name="candidatoSexo"-->
<!--                        {{#if (eq sexo 'M')}}checked{{/if}}-->
<!--                      />-->
<!--                      <label for="Sexo">-->
<!--                        {{__ "ppgiForm1.identificacaoCandidato.masculino"}}-->
<!--                      </label>-->
<!--                    </div>-->

<!--                    <div class="icheck-primary d-inline">-->
<!--                      <input-->
<!--                        type="radio"-->
<!--                        id="Sexo2"-->
<!--                        name="candidatoSexo"-->
<!--                        {{#if (eq sexo 'F')}}checked{{/if}}-->
<!--                      />-->
<!--                      <label for="Sexo2">-->
<!--                        {{__ "ppgiForm1.identificacaoCandidato.feminino"}}-->
<!--                      </label>-->
<!--                    </div>-->
                  </div>
                </div>
              </div>

              <div class="row">
                <!-- Nome Social -->
                <div class="col-md-6 campo-candidato-nomesocial form-group">
                  <label for="candidato-nomesocial" class="control-label">
                    <b>{{__ "ppgiForm1.identificacaoCandidato.nomeSocial"}}:</b>
                  </label>
                  <input
                    id="candidato-nomesocial"
                    class="form-control"
                    type="text"
                    name="Candidato[nomesocial]"
                    maxlength="60"
                    value="{{nomeSocial}}"
                  />
                </div>

                <!-- CEP -->
                <div class="col-md-3 campo-candidato-cep form-group">
                  <label for="candidato-cep" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.cep"}}:</b>
                  </label>
                  <input
                    id="candidato-cep"
                    class="form-control"
                    type="text"
                    name="candidatoCep"
                    data-plugin-inputmask=""
                    value="{{cep}}"
                    oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                  />
                  <div class="invalid-feedback"></div>
                </div>

                <!-- UF -->
                <div class="col-md-3 campo-candidato-uf form-group">
                  <label for="candidato-uf" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.estado"}}:</b>
                  </label>
                  <select
                    id="candidato-uf"
                    class="custom-select"
                    name="candidatoUf"
                  >
                    <option value="">
                      {{__ "ppgiForm1.identificacaoCandidato.selectEstado"}}:
                    </option>
                    <option value="AC">AC</option>
                    <option value="AL">AL</option>
                    <option value="AM">AM</option>
                    <option value="AP">AP</option>
                    <option value="BA">BA</option>
                    <option value="CE">CE</option>
                    <option value="DF">DF</option>
                    <option value="ES">ES</option>
                    <option value="GO">GO</option>
                    <option value="MA">MA</option>
                    <option value="MG">MG</option>
                    <option value="MS">MS</option>
                    <option value="MT">MT</option>
                    <option value="PA">PA</option>
                    <option value="PB">PB</option>
                    <option value="PE">PE</option>
                    <option value="PI">PI</option>
                    <option value="PR">PR</option>
                    <option value="RJ">RJ</option>
                    <option value="RN">RN</option>
                    <option value="RO">RO</option>
                    <option value="RR">RR</option>
                    <option value="RS">RS</option>
                    <option value="SC">SC</option>
                    <option value="SE">SE</option>
                    <option value="SP">SP</option>
                    <option value="TO">TO</option>
                  </select>
                </div>
              </div>

              <div class="row">
                <!-- Endereço -->
                <div class="col-md-6 field-candidato-endereco form-group">
                  <label for="candidato-endereco" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.endereco"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="candidato-endereco"
                    class="form-control"
                    name="candidatoEndereco"
                    maxlength="160"
                    value="{{endereco}}"
                  />
                </div>

                <!-- Cidade -->
                <div class="col-md-3 field-candidato-cidade form-group">
                  <label for="candidato-cidade" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.cidade"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="candidato-cidade"
                    class="form-control"
                    name="candidatoCidade"
                    maxlength="40"
                    value="{{cidade}}"
                    aria-invalid="true"
                  />
                </div>

                <!-- Bairro -->
                <div class="col-md-3 field-candidato-bairro form-group">
                  <label for="candidato-bairro" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.bairro"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="candidato-bairro"
                    class="form-control"
                    name="candidatoBairro"
                    maxlength="50"
                    value="{{bairro}}"
                  />
                </div>
              </div><!-- /row -->

              <div class="row ">
                <!-- Nacionalidade -->
                <div class="col-md-3 field-candidato-nacionalidade form-group">
                  <label for="candidatoNacionalidade" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.nacionalidade.title"}}:</b>
                  </label>
                  <div
                    role="radiogroup"
                    aria-label="Nacionalidade"
                    class="radio-group d-flex align-content-center"
                    style="gap: 20px;"
                  >
                    <div class="icheck-primary d-inline">
                      <input
                        type="radio"
                        id="Nacionalidade1"
                        name="candidatoNacionalidade"
                        {{#if (eq nacionalidade 'Brasileira')}}checked{{/if}}
                      />
                      <label for="Nacionalidade1">
                        {{__ "ppgiForm1.identificacaoCandidato.nacionalidade.brasileira"}}
                      </label>
                    </div>

                    <div class="icheck-primary d-inline">
                      <input
                        type="radio"
                        id="Nacionalidade2"
                        name="candidatoNacionalidade"
                        {{#if (eq nacionalidade 'Estrangeira')}}checked{{/if}}
                      />
                      <label for="Nacionalidade2">
                        {{__ "ppgiForm1.identificacaoCandidato.nacionalidade.estrangeira"}}
                      </label>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Brasileiro -->
              <div
                class="row"
                id="row-nacionalidade-brasileiro"
                {{#if (ne nacionalidade 'Brasileira')}}hidden{{/if}}
              >
                <div class="col-md-6 form-group">
                  <label for="cpf" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.nacionalidade.cpf"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="cpf"
                    class="form-control cpf"
                    name="cpf"
                    value="{{cpf}}"
                  />
                </div>
              </div>

              <!-- Estrangeiro -->
              <div
                class="row"
                id="row-nacionalidade-estrangeiro"
                {{#if (ne nacionalidade 'Estrangeira')}}hidden{{/if}}
              >
                <!-- País -->
                <div class="col-md-6 form-group">
                  <label for="pais" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.nacionalidade.pais"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="pais"
                    class="form-control"
                    name="pais"
                    value="{{pais}}"
                  />
                </div>
                <!-- Passaporte -->
                <div class="col-md-6 form-group">
                  <label for="passaporte" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.identificacaoCandidato.nacionalidade.passaporte"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="passaporte"
                    class="form-control"
                    name="passaporte"
                    value="{{passaporte}}"
                    maxlength="9"
                  />
                </div>
              </div>

            </div><!-- /card-body -->
          </div><!-- /card Identificação -->

          <!-- Card 2: Contato -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">{{__ "ppgiForm1.contato.title"}}</h3>
            </div>
            <div class="card-body">
              <div class="row">
                <!-- Telefone Principal -->
                <div class="form-group col-md-6 col-sm-6">
                  <label for="candidato-telresidencial" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.contato.telefonePrincipal"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="candidato-telresidencial"
                    class="form-control telefone"
                    name="candidatoTelresidencial"
                    value="{{telefone}}"
                  />
                </div>

                <!-- Telefone Alternativo -->
                <div class="form-group col-sm-6">
                  <label for="candidato-telcelular" class="control-label">
                    {{__ "ppgiForm1.contato.telefoneAlternativo"}}:
                  </label>
                  <input
                    type="text"
                    id="candidato-telcelular"
                    class="form-control telefone"
                    name="Candidato[telcelular]"
                    value="{{telefoneSecundario}}"
                  />
                </div>
               

              </div><!-- /row -->
            </div>

          </div><!-- /card Contato -->

          <!-- Card 3: Edital (como soube) -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">{{__ "ppgiForm1.edital.title"}}</h3>
            </div>
            <div class="card-body">
              <!-- Como soube -->
              <div class="row form-group col-sm-6">
                <div>
                  <label for="como-soube">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.edital.label"}}</b>
                  </label>
                  <select
                    id="como-soube"
                    class="custom-select"
                    name="comoSoube"
                  >
                    <option value="">
                      {{__ "ppgiForm1.edital.placeholder"}}:
                    </option>
                    <option value="Facebook">
                      {{__ "ppgiForm1.edital.options.facebook"}}
                    </option>
                    <option value="Instagram">
                      {{__ "ppgiForm1.edital.options.instagram"}}
                    </option>
                    <option value="LinkedIn">
                      {{__ "ppgiForm1.edital.options.linkedin"}}
                    </option>
                    <option value="Email">
                      {{__ "ppgiForm1.edital.options.email"}}
                    </option>
                    <option value="PPGI">
                      {{__ "ppgiForm1.edital.options.ppgi"}}
                    </option>
                    <option value="IComp">
                      {{__ "ppgiForm1.edital.options.icomp"}}
                    </option>
                    <option value="ProprioIcomp">
                      {{__ "ppgiForm1.edital.options.proprioIcomp"}}
                    </option>
                    <option value="Outro">
                      {{__ "ppgiForm1.edital.options.outro"}}
                    </option>
                  </select>
                </div>
              </div><!-- /row -->
            </div>
          </div><!-- /card Edital -->

          <!-- Card 4: Inscrição -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">{{__ "ppgiForm1.inscricao.title"}}</h3>
            </div>
            <div class="card-body">
              <div class="row ">
                <!-- Curso Desejado -->
                <div class="form-group col-md-5">
                  <label class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.inscricao.cursoDesejado"}}:</b>
                  </label>
                  <div
                    id="cadidato-curso"
                    role="radiogroup"
                    class="radio-group"
                    aria-label="{{__ 'ppgiForm1.inscricao.cursoDesejado'}}"
                  >
                    <div class="icheck-primary d-inline">
                      <input
                        type="radio"
                        id="Curso1"
                        name="candidatoCurso"
                        {{#if (eq cursoDesejado 'Mestrado')}}checked{{/if}}
                      />
                      <label for="Curso1" style="margin-right: 20px;">
                        {{__ "ppgiForm1.inscricao.mestrado"}}
                      </label>
                    </div>

                    <div class="icheck-primary d-inline">
                      <input
                        type="radio"
                        id="Curso2"
                        name="candidatoCurso"
                        {{#if (eq cursoDesejado 'Doutorado')}}checked{{/if}}
                      />
                      <label for="Curso2">
                        {{__ "ppgiForm1.inscricao.doutorado"}}
                      </label>
                    </div>
                  </div>
                </div>

                <!-- Regime -->
                <div class="col-md-12 form-group">
                  <label class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.inscricao.regime"}}</b>
                  </label>
                  <input type="hidden" name="candidatoRegime" value="" />
                  <div
                    id="candidato-regime"
                    role="radiogroup"
                    class="radio-group"
                    aria-label="{{__ 'ppgiForm1.inscricao.regime'}}"
                  >
                    <div class="icheck-primary d-inline">
                      <input
                        type="radio"
                        id="Regime1"
                        name="candidatoRegime"
                        {{#if (eq regime 'Integral')}}checked{{/if}}
                      />
                      <label for="Regime1" style="margin-right: 20px;">
                        {{__ "ppgiForm1.inscricao.integral"}}
                      </label>
                    </div>
                    <div class="icheck-primary d-inline">
                      <input
                        type="radio"
                        id="Regime2"
                        name="candidatoRegime"
                        {{#if (eq regime 'Parcial')}}checked{{/if}}
                      />
                      <label for="Regime2">
                        {{__ "ppgiForm1.inscricao.parcial"}}
                      </label>
                    </div>
                  </div>
                </div>
              </div><!-- /row -->

              <!-- Cotista -->
              <div id="cotista-div" class="row">
                <div class="col-md-5 form-group form-switch">
                  <div>
                    <label for="cotista">
                      <span class="text-danger">*</span>
                      {{__ "ppgiForm1.inscricao.cotista"}}?
                    </label>
                  </div>

                    <input
                      type="checkbox"
                      id="cotista"
                      name="cotista"
                      role="switch"
                      data-bootstrap-switch-cotista
                      data-off-color="danger"
                      data-on-color="success"
                      data-on-text="{{__ "ppgi.yesOption"}}"
                      data-off-text="{{__ "ppgi.noOption"}}"
                      wrapperClass="teste"
                    />

                </div>
                <!-- Tipo de Cota -->
                <div id="cota" class="col-md-6 form-group">
                  <label for="tipo-cota" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.inscricao.tipoCota"}}:</b>
                  </label>
                  <select
                    id="tipo-cota"
                    class="custom-select"
                    name="tipo-cota"
                  >
                    <option value="">
                      {{__ "ppgiForm1.inscricao.placeholderTipoCota"}}:
                    </option>
                    <option value="indigena">
                      {{__ "ppgiForm1.inscricao.optionCota.indigena"}}
                    </option>
                    <option value="negro">
                      {{__ "ppgiForm1.inscricao.optionCota.negro"}}
                    </option>
                    <option value="pardo">
                      {{__ "ppgiForm1.inscricao.optionCota.pardo"}}
                    </option>
                    <option>
                      {{__ "ppgiForm1.inscricao.optionCota.pcd"}}
                    </option>
                  </select>
                </div>
              </div>

              <!-- Deficiência / Condição Especial -->
              <div id="deficiencia-div" class="row">
                <div class="col-md-5 form-group">
                  <label for="candidato-deficiencia1">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.inscricao.saude"}}?</b>
                  </label>
                  <div>
                    <input
                      type="checkbox"
                      id="candidato-deficiencia1"
                      name="deficiencia"
                      data-bootstrap-switch-deficiencia
                      data-off-color="danger"
                      data-on-color="success"
                      data-on-text="{{__ "ppgi.yesOption"}}"
                      data-off-text="{{__ "ppgi.noOption"}}"
                    />
                  </div>
                </div>
                <!-- Condição -->
                <div id="condicao" class="col-md-6 form-group">
                  <label for="candidato-condicao" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.inscricao.condicao"}}:</b>
                  </label>
                  <input
                    type="text"
                    id="candidato-condicao"
                    class="form-control"
                    name="candidatoCondicao"
                    value="{{condicaoTipo}}"
                  />
                </div>
              </div>

              <!-- Bolsa -->
              <div class="row">
                <div class="col-md-5 form-group">
                  <label for="candidato-bolsa">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm1.inscricao.bolsa"}}</b>
                  </label>
                  <input
                    type="checkbox"
                    id="candidato-bolsa"
                    name="bolsa"
                    data-bootstrap-switch-bolsa
                    data-off-color="danger"
                    data-on-color="success"
                    data-on-text="{{__ "ppgi.yesOption"}}"
                    data-off-text="{{__ "ppgi.noOption"}}"
                  />
                </div>
              </div>
            </div><!-- /card-body -->

            <div class="card-footer">
              <div class="col p-0">
                <button
                  id="btn-save-continue"
                  type="submit"
                  class="btn btn-success float-right"
                >
                  {{__ "ppgi.form.saveAndContinue"}}
                  <span
