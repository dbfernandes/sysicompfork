                  <b>{{__ "ppgiForm2.curriculumVittae.pdf"}}:</b>
                </label>

                <div id="buttons-curriculum" class="col-12 flex-row align-items-center mb-4" style="display: {{#if (not hasCurriculum)}}none{{else}}flex{{/if}}; gap: 16px"  >
                  <div class="container-buttons-icon ">
                    <img src="/public/img/pdf-logo.png" alt="pdf" width="50" height="50" />
                    <figcaption id="name-curriculum" style="word-break: break-word;"><b>Curriculum.pdf</b></figcaption>
                  </div>
                  <div class="d-flex flex-row align-items-center flex-wrap" style="gap: 4px">
                    <a id="url-curiculum" href="/download/arquivo/Curriculum.pdf" class="btn btn-primary" download style="flex-grow: 1;">
                      <i class="fa fa-download mr-2" aria-hidden="true" ></i>
                       {{__ "ppgi.form.btnDownload"}}</a>
                    <button type="button" class="btn btn-success" id="btn-change-curriculum" style="flex-grow: 1;">
                      <i class="fa fa-retweet mr-2" aria-hidden="true"></i>
                       {{__ "ppgi.form.btnChange"}}</button>
                    <button type="button" class="btn btn-danger" id="btn-delete-curriculum" style="flex-grow: 1;">
                      <i class="fa fa-trash mr-2" aria-hidden="true"></i>
                       {{__ "ppgi.form.btnDelete"}}</button>
                  </div>
                </div>
                <div id="input-curriculum" class="custom-file mb-4 col-md-6 form-group" {{#if hasCurriculum}}style="display: none;"{{/if}}>
                  <input
                    type="file"
                    class="custom-file-input"
                    id="vittaepdf"
                    name="Curriculum"
                    accept="application/pdf"
                    data-msg-accept="{{__ "ppgi.form.onlyPdf"}}"/>
                  <label class="custom-file-label" for="vittaepdf">{{__ "ppgi.form.chooseFile"}}</label>
                </div>

                <!-- XML do currículo -->
                <label for="vittaexml" class="control-label col-12">
                  <b>{{__ "ppgiForm2.curriculumVittae.xml"}}:</b><br>
                  <span style="font-weight: normal">({{__ "ppgiForm2.curriculumVittae.doubtXml"}}, <a href="/public/files/instrucoes-lattes.pdf" target="_blank">{{__ "ppgiForm2.curriculumVittae.doubtXmlInstructions"}}</a>)</span>
                </label>
                <div id="buttons-vittae" class="col-12 flex-row align-items-center mb-4" style="display: {{#if (not hasVitaeXML)}}none{{else}}flex{{/if}}; gap: 16px"  >
                  <div class="container-buttons-icon ">
                    <img src="/public/img/xml-logo.png" alt="pdf" width="50" height="50" />
                    <figcaption id="name-vittae" style="word-break: break-word;"><b>VitaeXML.xml</b></figcaption>
                  </div>
                  <div class="d-flex flex-row align-items-center flex-wrap" style="gap: 4px">
                    <a id="url-vittae" href="/download/arquivo/VitaeXML.xml" class="btn btn-primary" download style="flex-grow: 1;">
                      <i class="fa fa-download mr-2" aria-hidden="true" ></i>
                      {{__ "ppgi.form.btnDownload"}}</a>
                    <button type="button" class="btn btn-success" id="btn-change-vittae" style="flex-grow: 1;">
                      <i class="fa fa-retweet mr-2" aria-hidden="true"></i>
                      {{__ "ppgi.form.btnChange"}}</button>
                    <button type="button" class="btn btn-danger" id="btn-delete-vittae" style="flex-grow: 1;">
                      <i class="fa fa-trash mr-2" aria-hidden="true"></i>
                      {{__ "ppgi.form.btnDeletePublications"}} </button>
                  </div>
                </div>
                <div id="input-vittae" class="custom-file mb-4 col-md-6 form-group" {{#if hasVitaeXML}}style="display: none;"{{/if}}>
                  <input
                    type="file"
                    class="custom-file-input"
                    id="vittaexml"
                    name="VitaeXML"
                    accept="text/xml"
                    data-msg-accept="{{__ "ppgi.form.onlyXml"}}"
                  />
                  <label class="custom-file-label" for="vittaexml">
                    {{__ "ppgi.form.chooseFile"}}
                  </label>
                </div>
              </div>
              <div id="publicacoes-container">
                {{!-- conteúdo inicial gerado pelo servidor (igual ao trecho antigo) --}}
                {{> ppgi/publicacoes}}
              </div>
            </div>
          </div><!-- /card Currículo Vitae -->

