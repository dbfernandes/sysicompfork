<!-- Scripts utilitários da aplicação -->
<script src="/public/js/xml2json.js"></script>
<script src="/public/js/lattesExtractor.js"></script>
<script>
  $(document).ready(function () {
    const basePath = "{{basePath}}";

    const inputFilesConfig = {
      Curriculum: {
        input: "#vittaepdf",
        buttons: "#buttons-curriculum",
        containerInput: "#input-curriculum",
        name: "#name-curriculum",
        btnChange: "#btn-change-curriculum",
        btnDelete: "#btn-delete-curriculum",
        aDownload: "#url-curiculum",
        hasFileSave: {{hasCurriculum}}
      },
      Prova: {
        input: "#candidato-prova",
        buttons: "#buttons-prova",
        containerInput: "#input-prova",
        name: "#name-prova",
        btnChange: "#btn-change-prova",
        btnDelete: "#btn-delete-prova",
        aDownload: "#url-prova",
        hasFileSave: {{hasProvaAnterior}}
      }
    }

    function changeYear(event) {
      const year = event.target.value;
      if (year.length === 4) {
        const currentYear = new Date().getFullYear();
        if (year > currentYear) {
          $(event.target).addClass("is-invalid");
        } else {
          $(event.target).removeClass("is-invalid");
        }
      }
    }

    function changeFile(idInput) {
      $(idInput).click();
    }

    function actionDeleteFile(idInput, idButtons, idContainerInput){
      $(idInput).val('');
      $(idButtons).hide();
      $(idContainerInput).show();
      $(idInput).next('label').text('{{__ "ppgi.form.chooseFile"}}');
    }

    function changeFileInput(event, aLink, idButtons, idContainerInput, idName) {
      const input = $(event.target);
      if (!input.valid()) {
        input.next('label').text('{{__ "ppgi.form.chooseFile"}}');
        return;
      }
      const file = event.target.files[0];
      const fileName = file.name;
      const url = URL.createObjectURL(file);
      $(idContainerInput).hide();
      $(idButtons).css('display', 'flex');
      $(idName).html(`<b>${fileName}</b>`);

      $(aLink)
        .attr('href', url)
        .attr('download', fileName);
    }

    Object.keys(inputFilesConfig).forEach(key => {
      const inputConfig = inputFilesConfig[key];
      const input = inputConfig.input;
      const buttons = inputConfig.buttons;
      const containerInput = inputConfig.containerInput;
      const name = inputConfig.name;
      const btnChange = inputConfig.btnChange;
      const btnDelete = inputConfig.btnDelete;
      const aDownload = inputConfig.aDownload;

      $(input).change(function (event) {
        inputFilesConfig[key].hasFileSave = true;
        changeFileInput(event, aDownload, buttons, containerInput, name);
      });

      $(btnChange).click(function () {
        changeFile(input);
      });

      $(btnDelete).click(function () {
        inputFilesConfig[key].hasFileSave = false;
        actionDeleteFile(input, buttons, containerInput);
      });
    });



    $("#btn_logout").click(function () {
      $.ajax({
        url: `${basePath}/logout`,
        type: "POST",
        data: {
          _csrf: $("#csrfToken").val()
        },
        success: function (data) {
          window.location.replace(`${basePath}/entrar`);
        },
        error: function (xhr) {
          if (xhr.status === 401){
            window.location.replace(`${basePath}/entrar`);
            return
          }
        }
      });
    });
    $("#btn_inicio").click(function () {
      $.ajax({
        url: `${basePath}/voltarInicio`,
        type: "POST",
        data: {
          _csrf: $("#csrfToken").val()
        },
        success: function () {
          window.location.href = `${basePath}/formulario`;
        },
        error: function (xhr) {
          if (xhr.status === 401){
            document.location.href = `${basePath}/entrar?expired=true`;
            return
          }
        }
      });
    });
    $("#voltarForm").click(() => {
      const btnVoltar = $("#voltarForm");
      btnVoltar.attr("disabled", true);
      btnVoltar.find("span").prop("hidden", false);
      const csrfToken = $("#csrfToken").val();
      const id = $("#idCandidato").val();

      $.ajax({
        url:`${basePath}/voltar`,
        type: 'POST',
        data: {
          _csrf: csrfToken,
          id: id
        }, success: function (data) {
          window.location.href = `${basePath}/formulario`;
          window.location.reload(true);
        },
        error: function (xhr) {
          btnVoltar.attr("disabled", false);
          btnVoltar.find("span").prop("hidden", true);
          if (xhr.status === 401){
            document.location.href = `${basePath}/entrar?expired=true`;
            return
          }
        }
      });
    });

    $("#limparSelecao").on("click", function (e) {
      e.preventDefault()
      $("#candidato-curso-tipo input[type='radio']").prop("checked", false);
      $('#candidato-curso-pos').val('');
      $('#candidato-instituicao-pos').val('');
      $('#candidato-ano-pos').val('');
      const validator = $('#candidato-formulario2').validate();

      ['#candidato-curso-pos', '#candidato-instituicao-pos', '#candidato-ano-pos'].forEach(sel => {
        validator.element(sel); // força revalidação; agora estão vazios mas válidos
      });
      validator.element("#Tipo1"); // o plugin trata o grupo de radios pelo primeiro id
    });

    $("#candidato-ano-pos").change(changeYear);
    $("#candidato-ano").change(changeYear);

    $(".accordion").on("show.bs.collapse", function () {
      $(this).find(".collapse").slideDown(20000);
    });

    $(".accordion").on("hide.bs.collapse", function () {
      $(this).find(".collapse").slideUp(20000);
    });

    $('#btn-change-vittae').click(function () {
      changeFile('#vittaexml');
    });

    $('#btn-delete-vittae').click(function () {
      $.ajax({
        url: `${basePath}/formulario/publicacoes?_csrf={{csrfToken}}`,
        type: "DELETE",
        success: function (data /*, textStatus, jqXHR */) {
          /* 1. Substitui o bloco de publicações pelo HTML parcial vazio/atualizado */
          $("#publicacoes-container").html("");
          $('[data-card-widget="collapse"]').CardWidget();   // reativa ícones (caso venha lista)

          /* 2. Referências fixas ao input, botões e container do currículo */
          const $fileInput    = $("#vittaexml");     // input[type=file]
          const $buttonsGroup = $("#buttons-vittae"); // div de botões
          const $inputGroup   = $("#input-vittae");   // div do custom-file

          /* 3. Limpa e reseta UI */
          $fileInput.val("");                                      // limpa valor do input
          $fileInput.next(".custom-file-label")                    // texto do label
            .text('{{__ "ppgi.form.chooseFile"}}');
          $buttonsGroup.hide();    // esconde botões (download / trocar / deletar)
          $inputGroup.show();      // mostra novamente o input para escolher arquivo

        },
        error: function (xhr) {
          if (xhr.status === 401){
            document.location.href = `${basePath}/entrar?expired=true`;
            return
          }
          $(document).Toasts('create', {
            icon: 'success',
            class: "bg-danger",
            autohide: true,
            delay: 10000,
            title: 'Ocorreu um problema!',
            body: 'As informações não foram deletadas.'
          })
        }
      });
    });

    $('#vittaexml').change(function(data){
      const file = data.target.files[0];
      if (file && file.type === "text/xml") {
        const formData = new FormData($('#candidato-formulario2')[0]);

        if (data.target.files.length) {
          const vitaeInput = document.getElementById("vittaexml");
          vitaeInput.setAttribute("disabled", true);
          getCompleteData(formData, GetDataPubli)
        }
      }
    })

    function GetDataPubli(data) {
      const formData = new FormData();
      const file = $('#vittaexml')[0].files[0];
      file && formData.append('VitaeXML', file);
      data.publicacoes && formData.append('publicacoes', JSON.stringify(data.publicacoes));

      $.ajax({
        url: `${basePath}/formulario/publicacoes?_csrf={{csrfToken}}`,
        type: "POST",
        data: formData,
        success: function (htmlParcial /*, textStatus, jqXHR */) {
          const vitaeInput = document.getElementById("vittaexml");
          vitaeInput.removeAttribute("disabled");
          /* 1. Atualiza o bloco de publicações e reativa os cards */
          $("#publicacoes-container").html(htmlParcial);
          $('[data-card-widget="collapse"]').CardWidget();   // AdminLTE

          /* 2. Referências fixas dos elementos do currículo XML */
          const $fileInput        = $("#vittaexml");          // input[type=file]
          const $inputGroup       = $("#input-vittae");       // div com o custom-file
          const $buttonsGroup     = $("#buttons-vittae");     // div com download / trocar / deletar
          const $fileNameDisplay  = $("#name-vittae");        // <figcaption>
          const $downloadLink     = $("#url-vittae");         // <a download>

          /* 3. Se o arquivo não passou pela validação do jQuery-Validate */
          if (!$fileInput.valid()) {
            $fileInput.next(".custom-file-label")
              .text('{{__ "ppgi.form.chooseFile"}}');
            return;
          }

          /* 4. Pega o arquivo selecionado e prepara UI */
          const file = $fileInput[0].files[0];
          if (!file) return;     // segurança

          const fileName = file.name;
          const blobURL  = URL.createObjectURL(file);

          // esconde o input, mostra o grupo de botões
          $inputGroup.hide();
          $buttonsGroup.css("display", "flex");

          // atualiza nome e link de download
          $fileNameDisplay.html(`<b>${fileName}</b>`);
          $downloadLink.attr({ href: blobURL, download: fileName });
        },
        error: function (xhr) {
          if (xhr.status === 401){
            document.location.href = `${basePath}/entrar?expired=true`;
            return
          }
          $(document).Toasts('create', {
            icon: 'success',
            class: "bg-danger",
            autohide: true,
            delay: 10000,
            title: 'Ocorreu um problema!',
            body: 'As informações não poderam ser salvas.'
          })
          const vitaeInput = document.getElementById("vittaexml");
          vitaeInput.removeAttribute("disabled");
        },
        contentType: false,
        processData: false,
      })
    }

    $.validator.addMethod(
      "conjuntoPreenchido",
      function (value, element) {
        // IDs dos três inputs de texto do grupo Pós
        const grupoTextos = [
          "#candidato-curso-pos",
          "#candidato-instituicao-pos",
          "#candidato-ano-pos"
        ];

        // Radios do tipo de curso
        const grupoRadios = ["#Tipo1", "#Tipo2", "#Tipo3"];

        // 1. Há algum campo (texto ou radio) já preenchido?
        const algumOutroPreenchido = grupoTextos
            .filter(sel => sel !== "#" + element.id)          // exclui o campo que está sendo testado
            .some(sel => ($(sel).val() || "").trim() !== "")  // texto não vazio
          ||
          grupoRadios.some(sel => $(sel).is(":checked"));   // radio marcado

        // 2. Campo atual está vazio?
        const campoAtualVazio = (value || "").trim() === "";

        // 3. Regra: erro somente se campo atual vazio *e* outro já preenchido
        return !(campoAtualVazio && algumOutroPreenchido);
      },
      "Preencha Curso, Instituição, Ano de Egresso e Tipo juntos ou deixe todos vazios."
    );

    $.validator.addMethod("anoValido", function (value, element) {
      if (!/^\d{4}$/.test(value)) {
        return false;
      }

      const anoAtual = new Date().getFullYear();
      const anoMinimo = 1900;
      const anoInserido = parseInt(value);
      return anoInserido <= anoAtual + 4 && anoInserido >= anoMinimo;
    }, "Ano inválido");

    $.validator.addMethod("fileSize", function(value, element, param) {
      if (element.files.length === 0) {
        return true;
      }
      return element.files[0].size <= param;
    }, "O arquivo deve ter no máximo {0} bytes.");


    $.validator.addMethod("anoPosValido", function (value, element) {
      if (value.trim() === "") {
        return true;
      }
      if (!/^\d{4}$/.test(value)) {
        return false;
      }
      const anoAtual = new Date().getFullYear();
      const anoMinimo = 1850;
      const anoInserido = parseInt(value);
      return anoInserido <= anoAtual && anoInserido >= anoMinimo;
    }, "Ano inválido");

    $("#candidato-formulario2").validate({
      errorElement: 'span',
      errorPlacement: function (error, element) {
        error.addClass('invalid-feedback');
        if (element.is(":radio")) {
          error.insertAfter(element.closest('.radio-group'));
          return
        }
        element.closest('div').append(error);
      },
      highlight: function (element, errorClass, validClass) {
        if ($(element).is(":radio")) {
          $(element).closest('.radio-group').find('label').addClass('text-danger');
        } else {
          $(element).addClass('is-invalid');
        }
      },
      unhighlight: function (element, errorClass, validClass) {
        if ($(element).is(":radio")) {
          $(element).closest('.radio-group').find('label').removeClass('text-danger');
        } else {
          $(element).removeClass('is-invalid');
        }
      },
      rules: {
        "cursoGraduacao": {
          required: true
        },
        "instituicaoGraduacao": {
          required: true
        },
        "anoEgressoGraduacao": {
          required: true,
          anoValido: true

        },
        'Curriculum': {
          required: function(){
            return !inputFilesConfig.Curriculum.hasFileSave
          },
          fileSize: 30 * 1024 * 1024 // Tamanho máximo em bytes (por exemplo, 30MB = 30 * 1024 * 1024 bytes)
        },
        'ProvaAnterior': {
          fileSize: 30 * 1024 * 1024 // Tamanho máximo em bytes (por exemplo, 30MB = 30 * 1024 * 1024 bytes)
        },
        "cursoPos": {
          conjuntoPreenchido: true
        },
        "instituicaoPos": {
          conjuntoPreenchido: true
        },
        "anoEgressoPos": {
          conjuntoPreenchido: true,
          anoPosValido: true
        },
        "tipoPos": {
          conjuntoPreenchido: true,
        }
      },
      messages: {
        "cursoGraduacao": {
          required: "{{__ "ppgiForm2.validation.required"}}"
        },
        "instituicaoGraduacao": {
          required: "{{__ "ppgiForm2.validation.required"}}"
        },
        "anoEgressoGraduacao": {
          required: "{{__ "ppgiForm2.validation.required"}}"
        },

        "cursoPos": {
          conjuntoPreenchido: "{{__ "ppgiForm2.validation.conjuntoPreenchido"}}"
        },
        "instituicaoPos": {
          conjuntoPreenchido: "{{__ "ppgiForm2.validation.conjuntoPreenchido"}}"
        },
        "anoEgressoPos": {
          conjuntoPreenchido: "{{__ "ppgiForm2.validation.conjuntoPreenchido"}}"
        },
        "tipoPos": {
          conjuntoPreenchido: "{{__ "ppgiForm2.validation.conjuntoPreenchido"}}"
        },
        "Curriculum": {
          required: "{{__ "ppgiForm2.validation.required"}}",
          fileSize: "{{__ "ppgi.validation.fileSize"}}"
        },
        "ProvaAnterior": {
          fileSize: "{{__ "ppgi.validation.fileSize"}}"
        },
      },

      submitHandler: (form, e) => {
        e.preventDefault()

        const btnSubmit = $("#btn-submit");
        btnSubmit.attr("disabled", true);
        btnSubmit.find("span").prop("hidden", false);

        const formData = new FormData($('#candidato-formulario2')[0]);
        formData.append('csrfToken', $("#csrfToken").val());

        const csrfToken = $("#csrfToken").val();
        $.ajax({
          url: `${basePath}/formulario/2?_csrf=${csrfToken}`,
          type: "PUT",
          data: formData,
          contentType: false,
          processData: false,
          success: function (response) {
            window.location.href = `${basePath}/formulario`;
            window.location.reload();
          },
          error: function (xhr, status, error) {
            if (xhr.status === 401){
              document.location.href = `${basePath}/entrar?expired=true`;
              return
            }
            toastr.error('Atualize a página e tente novamente', 'Erro ao salvar informações.');
            btnSubmit.attr("disabled", false);
            btnSubmit.find("span").prop("hidden", true);
          }
        });
      },

      onfocusout: function (element) {
      // Campos que fazem parte do conjunto "cursoPos / instituiçãoPos / anoPos / Tipo"
      const grupoPos = '#candidato-curso-pos, #candidato-instituicao-pos, #candidato-ano-pos, #Tipo1, #Tipo2, #Tipo3';

      // Se o elemento fizer parte do grupo, não valida agora (só no submit)
      if ($(element).is(grupoPos)) {
        return;
      }
      // Caso contrário, mantém o comportamento padrão
      this.element(element);
    }
    });

    function mostrarPeriodicos() {
      const accordion = $('#accordion');
      if (accordion.hasClass("show")) {
        accordion.collapse("hide");
      } else {
        accordion.collapse("show");
      }
    }

    document.addEventListener("DOMContentLoaded", function () {
      const addButton = document.getElementById("add-experiencia-button");
      const experienciaContainer = document.getElementById("experiencia-container");
      const exemploRow = document.querySelector(".experiencia-row");

      const experiencias = experienciaContainer.getElementsByClassName("experiencia-row");
      if (experiencias.length >= 1) {
        for (const experiencia of experiencias) {
          const deleteButton = experiencia.querySelector(".delete-experiencia-button");

          deleteButton.addEventListener("click", function () {
            experienciaContainer.removeChild(experiencia);
          });
        }
      }
      addButton.addEventListener("click", function (e) {
        e.preventDefault();
        const newExperienciaRow = exemploRow.cloneNode(true);

        const inputs = newExperienciaRow.querySelectorAll("input");
        inputs.forEach(input => input.value = "");

        experienciaContainer.appendChild(newExperienciaRow);

        const experiencias = experienciaContainer.getElementsByClassName("experiencia-row");
        if (experiencias.length > 1) {
          for (const experiencia of experiencias) {
            const deleteButton = experiencia.querySelector(".delete-experiencia-button");
            deleteButton.style.display = "inline-block";
            deleteButton.addEventListener("click", function () {
              experienciaContainer.removeChild(experiencia);
              if (experiencias.length === 1) {
                const experiencia = experiencias[0];
                const deleteButton = experiencia.querySelector(".delete-experiencia-button");
                deleteButton.style.display = "none";
              }
            });
          }
        } else {
          const experiencia = experiencias[0];
          const deleteButton = experiencia.querySelector(".delete-experiencia-button");
          deleteButton.style.display = "none";
        }
      });
    });
  });
</script>