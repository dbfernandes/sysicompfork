{{ setTitle title="Histórico" }}

{{#section "head"}}
<!--  Links Histórico-->
<link href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css" rel="stylesheet">
{{/section}}

<main class="forms-page">
  <!-- Cabeçalho / Header -->
  <header>
    <div class="container d-flex justify-content-between align-items-center px-3">

      <h1 class="header-title">PPGI</h1>
      <div class="options">
        {{> ppgi/selectLanguageHeader}}
        <button class="p-0" id="btn_inicio">{{__ "ppgi.header.initButton"}}</button>
        <button class="p-0" id="btn_logout">{{__ "ppgi.header.logoutButton"}}</button>
      </div>
    </div>
  </header>

  <!-- Seção de conteúdo principal -->
  <section class="content container px-3">
    <!-- Possível nav (dependendo de como seu partial é estruturado) -->
    {{> ppgi/infoEdital editalNome=edital.id dataFimInscricao=edital.dataFim  link=edital.documento }}
    {{> ppgi/nav active="historico" indexSelect="2" progress="50"}}

    <div class="container-fluid p-0">
      <!-- Formulário de histórico  -->
      <article>
        <form id="candidato-formulario2" novalidate>
          <!-- Inputs escondidos de controle -->
          <input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}" />
          <input id="email" type="hidden" value="{{email}}" />
          <input id="idCandidato" type="hidden" value="{{id}}" />
          <input id="idCandidato" type="hidden" value="{{message}}" />
          <p>{{message}}</p>

          <!-- Card 1: Curso de Graduação -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">{{__ "ppgiForm2.cursoGraduacao.title"}}</h3>
            </div>

            <div class="card-body">
              <div class="row">
                <!-- Curso de Graduação -->
                <div class="form-group col-md-6">
                  <label for="candidato-curso">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm2.cursoGraduacao.curso"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-curso"
                    type="text"
                    name="cursoGraduacao"
                    maxlength="50"
                    placeholder="{{__ "ppgiForm2.cursoGraduacao.curso"}}"
                    value="{{cursoGraduacao}}"
                    autofocus
                  />
                </div>

                <!-- Instituição de Graduação -->
                <div class="col-md-6 form-group">
                  <label for="candidato-instituicao" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm2.cursoGraduacao.instituicao"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-instituicao"
                    type="text"
                    name="instituicaoGraduacao"
                    maxlength="50"
                    placeholder="{{__ "ppgiForm2.cursoGraduacao.instituicaoPlaceholder"}}"
                    value="{{instituicaoGraduacao}}"
                  />
                </div>
              </div>

              <div class="row">
                <!-- Ano de Egresso Graduação -->
                <div class="col-md-3 form-group">
                  <label for="candidato-ano" class="control-label">
                    <span class="text-danger">*</span>
                    <b>{{__ "ppgiForm2.cursoGraduacao.anoEgresso"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-ano"
                    type="number"
                    name="anoEgressoGraduacao"
                    value="{{anoEgressoGraduacao}}"
                    placeholder="{{__ "ppgiForm2.cursoGraduacao.anoEgressoPlaceholder"}}"
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Card 2: Curso de Pós-Graduação -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">{{__ "ppgiForm2.cursoPos.title"}}</h3>
            </div>

            <div class="card-body">
              <div class="row">
                <!-- Curso de Pós -->
                <div class="form-group col-md-6">
                  <label for="candidato-curso-pos">
                    <b>{{__ "ppgiForm2.cursoPos.curso"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-curso-pos"
                    type="text"
                    name="cursoPos"
                    maxlength="50"
                    value="{{cursoPos}}"
                  />
                </div>

                <!-- Tipo do Curso de Pós -->
                <div class="col-md-6 form-group">
                  <label for="candidato-curso-tipo" class="control-label">
                    <b>{{__ "ppgiForm2.cursoPos.tipo"}}:</b>
                  </label>
                  <!-- Um único container com role="radiogroup" -->
                  <div
                    id="candidato-curso-tipo"
                    role="radiogroup"
                    aria-label="Tipo de Curso Pós-Graduação"
                    style="display: flex; align-content:center; gap: 20px; flex-wrap: wrap;"
                    class="radio-group"
                  >
                    <div class="icheck-primary d-inline" style="margin-right: 20px;">
                      <input
                        type="radio"
                        id="Tipo1"
                        name="tipoPos"
                        value="Mestrado Acadêmico"
                        {{#if (eq "Mestrado Acadêmico" tipoPos)}}checked{{/if}}
                      />
                      <label for="Tipo1">
                        {{__ "ppgiForm2.cursoPos.optionTipo.mestradoAcademico"}}
                      </label>
                    </div>

                    <div class="icheck-primary d-inline" style="margin-right: 20px;">
                      <input
                        type="radio"
                        id="Tipo2"
                        name="tipoPos"
                        value="Mestrado Profissional"
                        {{#if (eq "Mestrado Profissional" tipoPos)}}checked{{/if}}
                      />
                      <label for="Tipo2">
                        {{__ "ppgiForm2.cursoPos.optionTipo.mestradoProfissional"}}
                      </label>
                    </div>

                    <div class="icheck-primary d-inline" style="margin-right: 20px;">
                      <input
                        type="radio"
                        id="Tipo3"
                        name="tipoPos"
                        value="Doutorado"
                        {{#if (eq "Doutorado" tipoPos)}}checked{{/if}}
                      />
                      <label for="Tipo3">
                        {{__ "ppgiForm2.cursoPos.optionTipo.doutorado"}}
                      </label>
                    </div>

                    <button
                      type="button"
                      id="limparSelecao"
                      class="btn btn-block btn-primary"
                      style="width:50%;"
                    >
                      {{__ "ppgiForm2.cursoPos.limparSelecao"}}
                    </button>
                  </div>
                </div>
              </div>

              <div class="row">
                <!-- Instituição de Pós -->
                <div class="col-md-6 form-group">
                  <label for="candidato-instituicao-pos" class="control-label">
                    <b>{{__ "ppgiForm2.cursoPos.instituicao"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-instituicao-pos"
                    type="text"
                    name="instituicaoPos"
                    maxlength="50"
                    value="{{instituicaoPos}}"
                  />
                </div>

                <!-- Ano de Egresso Pós -->
                <div class="col-md-3 form-group">
                  <label for="candidato-ano-pos" class="control-label">
                    <b>{{__ "ppgiForm2.cursoPos.anoEgresso"}}:</b>
                  </label>
                  <input
                    class="form-control"
                    id="candidato-ano-pos"
                    type="number"
                    name="anoEgressoPos"
                    value="{{anoEgressoPos}}"
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Card 3: Currículo Vitae -->
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">{{__ "ppgiForm2.curriculumVittae.title"}}</h3>
            </div>

            <div class="card-body">
              <div class="row">
                <!-- PDF do currículo -->
                <label for="vittaepdf" class="control-label col-12">
