{{ setTitle title="Confirmação" }}
<style>
  .container-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    margin-top: 3rem;
    gap: 2rem;
  }

  .container-message .message-footer {
    align-self: flex-end;
  }

  .container-message .message-buttons {
    font-weight: bold;
    color: #222;
    text-align: center;
    margin-top: 1rem;
  }

  .container-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .container-button {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    flex-direction: column;
    margin-top: 1rem;
    max-width: 150px;
    text-align: center;
  }

  .link-file {
    font-weight: bold;
  }



</style>

<main class="forms-page">
  <header>
    <div class="container d-flex justify-content-between align-items-center px-3">
      <h1 class="header-title">PPGI</h1>
      <div class="options">
        {{> ppgi/selectLanguageHeader}}
        <button class="p-0" type="button" id="btn_logout">{{__ "ppgi.header.logoutButton"}}</button>

      </div>
    </div>
  </header>

  <section class="content container px-3">
    <input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}" />


    {{> ppgi/nav indexSelect="5" progress="100"}}

    <main class="container-message">
      <h2>{{__ "ppgiForm4.title"}}</h2>
      <p>
        {{__ "ppgiForm4.message"}}
      </p>
      <span class="message-footer">
        {{__ "ppgiForm4.greeting"}}
      </span>

      <p class="message-buttons">
        {{__ "ppgiForm4.titleButtons"}}
      </p>

      <div class="container-buttons">
        <div class="container-button">
          <img
            src="/public/img/edit_f2.png"
            alt="{{__ 'ppgiForm4.alt_registrationForm'}}"
            width="50"
          />
          <a
            class="link-file"
            href="/download/arquivo/Inscricao.pdf"
          >
            {{__ "ppgiForm4.button.registrationForm"}}
          </a>
        </div>

        <div class="container-button">
          <img
            src="/public/img/trabalho.png"
            alt="{{__ 'ppgiForm4.alt_proposal'}}"
            width="50"
          />
          <a
            class="link-file"
            href="/download/arquivo/PropostaTrabalho.pdf"
          >
            {{__ "ppgiForm4.button.proposol"}}
          </a>
        </div>

        {{#if hasCartaAceiteOrientador}}
          <div class="container-button">
            <img
              src="/public/img/historico.gif"
              alt="{{__ 'ppgiForm4.alt_letter'}}"
              width="50"
            />
            <a
              class="link-file"
              href="/download/arquivo/CartaAceiteOrientador.pdf"
            >
              {{__ "ppgiForm4.button.letter"}}
            </a>
          </div>
        {{/if}}

        <div class="container-button">
          <img
            src="/public/img/curriculum.gif"
            alt="{{__ 'ppgiForm4.alt_curriculum'}}"
            width="50"
          />
          <a
            class="link-file"
            href="/download/arquivo/Curriculum.pdf"
          >
            {{__ "ppgiForm4.button.curriculum"}}
          </a>
        </div>

        <div class="container-button">
          <img
            src="/public/img/pagamento.png"
            alt="{{__ 'ppgiForm4.alt_payment'}}"
            width="50"
          />
          <a
            class="link-file"
            href="/download/arquivo/ComprovantePagamento.pdf"
          >
            {{__ "ppgiForm4.button.payment"}}
          </a>
        </div>
        <!--COMPROVANTE COTA-->
        {{#if hasComprovanteCota}}
          <div class="container-button">
            <img
                  src="/public/img/autoDeclaracao.png"
                  alt="{{__ 'ppgiForm4.alt_payment'}}"
                  width="50"
            />
            <a
                  class="link-file"
                  href="/download/arquivo/ComprovanteCota.pdf"
            >
              {{__ "ppgiForm4.button.quotaReceipt"}}
            </a>
          </div>
        {{/if}}

        <!--COMPROVANTE AUTODECLARAÇÃO-->
        {{#if hasAutodeclaracao}}
          <div class="container-button">
            <img
              src="/public/img/autoDeclaracao.png"
              alt="{{__ 'ppgiForm4.alt_payment'}}"
              width="50"
            />
            <a
                  class="link-file"
                  href="/download/arquivo/AutodeclaracaoCiencia.pdf"
                >
              {{__ "ppgiForm4.button.selfDeclaration"}}
            </a>
          </div>
        {{/if}}
        <!--COMPROVANTE VIDEO-->
        {{#if hasVideoAutodeclaracao}}
          <div class="container-button">
            <img
                    src="/public/img/video.png"
                    alt="{{__ 'ppgiForm4.alt_payment'}}"
                    width="50"
            />
            <a
                    class="link-file"
                    href="/download/arquivo/VideoAutodeclaracao.mp4"
            >
              {{__ "ppgiForm4.button.videoSelfDeclaration"}}
            </a>
          </div>
        {{/if}}
      </div>
    </main>

  </section>
  {{> ppgi/footer}}

</main>

<script>
  $(document).ready(function () {
    const basePath = "{{basePath}}";

    // --- SCRIPT DO CONTADOR ADICIONADO ---
    const countdownElement = $("#countdown");
    const deadline = countdownElement.data("deadline");

    if (deadline) {
      const countdownInterval = setInterval(function() {
        const finalDate = new Date(deadline).getTime();
        const now = new Date().getTime();
        const distance = finalDate - now;

        if (distance < 0) {
          clearInterval(countdownInterval);
          countdownElement.text("Prazo Esgotado");
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        let result = "";
        if (days > 0) result += days + "d ";
        if (hours > 0 || days > 0) result += hours + "h ";
        if (minutes > 0 || hours > 0 || days > 0) result += minutes + "m ";
        result += seconds + "s";

        countdownElement.text(result);

      }, 1000);
    } else {
      countdownElement.text("Data não definida");
    }
    // --- FIM DO SCRIPT DO CONTADOR ---

    $("#btn_logout").click(function () {
      $.ajax({
        url: `${basePath}/logout`,
        type: "POST",
        data: {
          _csrf: $("#csrfToken").val()
        },
        success: function (data) {
          window.location.href = `${basePath}`;
        },
        error: function (data) {
          console.error(data);
        }
      });
    });

    $("#voltarForm").on("click", function (e) {
      const csrfToken = $("#csrfToken").val();
      // Se esses ids existirem no form, inclua
      const id = $("#idCandidato").val();
      const editalPosicao = $("#editalPosicao").val();

      $.ajax({
        url: `${basePath}/voltar`,
        type: 'POST',
        data: {
          _csrf: csrfToken,
          editalPosicao: editalPosicao,
          id: id
        },
        success: function (data) {
          window.location.href = `${basePath}/formulario`;
          window.location.reload(true);
        },
        error: function (data) {
          console.error(data);
        }
      });
    });
  });
</script>