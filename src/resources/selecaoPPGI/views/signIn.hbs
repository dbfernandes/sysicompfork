{{ setTitle title="Login - PPGI/UFAM" }}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css" />
<div class="login-box">
	<div class="login-logo container-cards">
		<img src="/public/img/logo-icomp.png" alt="">
    		<img src="/public/img/logo-ufam.png" alt="">
  	</div>
	<div class="card">
		<div class="card-body login-card-body">
     		<div class="login-logo">
				<b>{{__ "ppgiSignIn.title"}}</b>
			</div>
			<div id="error-msg" class="alert alert-danger" hidden="true"></div>
			<p class="sub-title">{{__ "ppgiSignIn.subTitle"}}</p>
			<form id="loginform">
				<input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}">
				<div class="form-group">
					<input type="email" class="form-control" name="email" id="email" aria-describedby="email"
						placeholder="{{__ "ppgiSignIn.emailPlaceholder"}}">
					<div class="help-block"></div>
				</div>
				<div class="form-group">
					<div class="input-group mb-3">
						<input type="password" class="form-control" name="password" id="password" aria-describedby="senha"
							placeholder="{{__ "ppgiSignIn.passwordPlaceholder"}}">
					 	<div class="input-group-append" >
   					 		<span  id="togglePassword" class="input-group-text"style="color: transparent;" id="basic-addon2">====
								<i  class="bi bi-eye-slash icon-input" style="color: gray;" id="togglePasswordIcon"></i>
							</span>
  						</div>
					</div>
					<div class="help-block"></div>
					<div class="col-md-6">
                    	<div class="form-group">
                        	<a href="/selecaoppgi/recuperarSenha">{{__ "ppgiSignIn.forgotPassword"}}</a>
                    	</div>
                	</div>
				</div>
				<div class="form-group">
					<select class="form-control" name="edital" id="edital">
						<option value="">{{__ "ppgiSignIn.selectNotice"}}</option>
						{{#each editais}}
							<option value="{{id}}">{{editalCodigo}}</option>
						{{/each}}
					</select>
					<div class="help-block"></div>
				</div>
				<button type="submit" name="logar" id="login-btn" class="btn btn-primary btn-block">
					{{__ "ppgiSignIn.continueButton"}}
					<span class="spinner-border spinner-border-sm " hidden="true" role="status" aria-hidden="true"></span>
				</button>
				<button name="voltar" type="button" id="voltar" class="btn btn-block  btn-default" role="button">
					{{__ "ppgiSignIn.backButton"}}
				</button>
			</form> 
		</div>
	</div>
	{{> ppgi/selectLanguage}}
</div>

<script>
	$("#voltar").click(() => {
		if (window.history.length > 1) {
  			window.history.back();
		} else {
  			window.location.href = "{{url}}/selecaoppgi";
		}
	});

	$("#togglePassword").click(function() {
		const typeActual = $("#password").attr("type");
		if (typeActual === "password") {
			$("#password").attr("type", "text");
			$(this).children().toggleClass("bi-eye-slash bi-eye");
		} else {
			$("#password").attr("type", "password");
			$(this).children().toggleClass("bi-eye bi-eye-slash");
		}
	});

  	$("#loginform input").on("input",() => {
        const divError = $("#error-msg");
        if (!divError.prop("hidden")) {
            divError.prop("hidden", true);
        }
    });

	$("#loginform").validate({
		ignore: ':hidden',
		rules: {
			email: {
				required: true,
				email: true
			},
			password: {
				required: true,
				minlength: 6
			},
			edital: {
				required: true
			}
		},
		messages: {
			email: {
				required: "{{__ "ppgiSignIn.validation.emailRequired"}}",
				email: "{{__ "ppgiSignIn.validation.emailInvalid"}}"
			},
			password: {
				required: "{{__ "ppgiSignIn.validation.passwordRequired"}}",
				minlength: "{{__ "ppgiSignIn.validation.passwordMinLength"}}"
			},
			edital: {
				required: "{{__ "ppgiSignIn.validation.noticeRequired"}}"
			},
		},
		errorElement: 'span',
		errorPlacement: function (error, element) {
			error.addClass('invalid-feedback');
			element.closest('div').append(error);
		},

		highlight: function (element, errorClass, validClass) {
			$(element).addClass('is-invalid');
		},
		unhighlight: function (element, errorClass, validClass) {
			$(element).removeClass('is-invalid');
		},
		submitHandler: function (form, e) {
			e.preventDefault();
			const buttonLogin = $("#login-btn");
			buttonLogin.attr("disabled", true);
			buttonLogin.find("span").prop("hidden", false);

			const email = $("#email").val();
			const senha = $("#password").val();
			const editalId = $("#edital").val();
			const csrfToken = $("#csrfToken").val();

			$.ajax({
				url: `{{url}}/selecaoppgi/entrar?_csrf=${csrfToken}`,
				type: "POST",
				data: {
					email,
					senha,
					editalId,
				},
				success: function (data) {
					window.location.href = "{{url}}/selecaoppgi/formulario";
				 	}, 
				error: function (res, status, error) {
					buttonLogin.attr("disabled", false);
					buttonLogin.find("span").prop("hidden", true);
					if(res.status === 422){
						const divError = $("#error-msg");
						divError.prop("hidden", false);
						divError.text("{{__ "ppgiSignIn.errorIncomplete"}}");
					} else if(res.status === 401){
						const divError = $("#error-msg");
						divError.prop("hidden", false);
						divError.text("{{__ "ppgiSignIn.errorIncorrect"}}");
					} else if (res.status === 403){
						const divError = $("#error-msg");
						divError.prop("hidden", false);
						divError.text("{{__ "ppgiSignIn.errorAlreadySubmitted"}}");
					}
				}
			})
		}
	})
</script>