<style>
  .forms-page {
    height: 100vh;
    display: block;
    justify-content: center;
    align-items: center;
    background-color: #fff;
    overflow-y: auto;
  }

  .forms-page header {
    width: 100%;
    position: sticky;
    top: 0;
    left: 0;
    height: 50px;
    background-color: #222;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    padding: 10px 45px;
    z-index: 10;
  }

  .forms-page header h1 {
    font-size: 1.4rem;
    color: #dbdbdb;
    cursor: pointer;
  }

  .forms-page header h1:hover {
    color: #fff;
  }

  @media screen and (max-width: 720pt) {
    .forms-page header {
      padding: 10px 15px;
    }
  }

  .forms-page header .options {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .forms-page header .options button {
    background-color: transparent;
    border: none;
    cursor: pointer;
    color: #c7c7c7;
    transition: all .3s;
  }

  .forms-page header .options button:hover {
    color: #fff;
  }

  .forms-page section {
    display: flex;
    flex-direction: column;
    width: 90%;
    margin: auto;
    margin-top: 2%;
    min-height: 100vh;
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow-y: auto;
    color: #222;
  }

  .forms-page section h1 {
    font-size: 1.4rem;
    color: #222;
    margin-bottom: 10px;
  }

  .forms-page section .line {
    width: 100%;
    height: 1px;
    background-color: #c2c2c2;
    margin-bottom: 10px;
  }

  .forms-page section .info {
    width: 100%;
    height: 100%;
  }

  .forms-page section form {
    width: 100%;
    padding: 0 5%;
  }

  .forms-page section button {
    position: relative;
    bottom: 0;
  }

  .forms-page footer {
    width: 100%;
    height: 50px;
    position: fixed;
    bottom: 0;
    left: 0;
    background-color: #000;
  }

  .custom-button {
    margin-right: 10px;
    margin-bottom: 10px;
  }

  .remove-btn {
    color: white;
    background-color: red;
    border: none;
    padding: 5px 10px;
    cursor: pointer;
    margin-left: 5px;
  }

  #add-btn {
    margin-top: 10px;
  }



.custom-file-container .custom-file-input {
  padding: 10px;
}

/* Adicione a seguinte regra se necessário, para ajustar a largura do label associado */
.custom-file-container .custom-file-label {
    white-space: nowrap;
    overflow: hidden; 
    text-overflow: ellipsis;
    margin-left: 5px;
    margin-right: 5px;
}
</style>
<link href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css" rel="stylesheet">
<div class="modal fade" id="confirm-register" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
      <div class="modal-dialog" role="document">
          <div class="modal-content">
              <div class="modal-body">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
               <p>Finalizar a sua inscrição? Após esse passo seus dados serão submetidos para avaliação e não poderão ser alterados.</p>
              </div>
              <div class="modal-footer">
                  <a type="button" class="btn btn-secondary color-white" data-dismiss="modal">Cancelar</a>
                  <a id="deleteButton" type="button" class="btn btn-warning color-white" onclick="deletarAT()">Confirmar</a>
              </div>
              <form name="postDelete" id="finish-register" method="POST">
                  <input type="hidden" name="_csrf" value="{{csrfToken}}"> 
              </form>
          </div>
      </div>
</div>
<div class="forms-page">
	<header>
		<h1>PPGI</h1>
		<div class="options">
			<button id="btn_inicio">Início</button>
			<button id="btn_logout">Sair</button>
		</div>
	</header>



  {{!-- ALTERAÇÃO PARA NOVO FORMULARIO --}}

  <section class="content">
    <nav>
      <ul>
        <li>
          <i class="nav-icon fas fa-user active"></i>
          Dados
        </li>
        <li>
          <i class="nav-icon fas fa-history active"></i>
          Histórico
        </li>
        <li>
          <i class="nav-icon fas fa-project-diagram active"></i>
          Proposta de Projeto
        </li>
        <li>
          <i class="nav-icon fas fa-check"></i>
          Confirmação
        </li>
      </ul>
      <div class="progress">
        <div class="progress-bar progress-bar-striped progress-bar-animated pbar-3" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
        </div>
      </div>
    </nav>
    <div class="container-fluid">
      <form id="candidato-formulario">
        <input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}">
        <input id="email" type="hidden" value="{{email}}">
        <input id="editalPosicao" type="hidden" value="{{editalPosicao}}">
        <input id="idCandidato" type="hidden" value="{{id}}">

        <div class="card card-primary">
          <div class="card-header">
            <h3 class="card-title">Proposta do Candidato</h3>
          </div>

          <div class="card-body">
            <div class="row">
              <div class="form-group col-md-5">
                <label for="candidato-curso">
                  <font color="#FF0000">*</font>
                  <b>Linha de Pesquisa:</b>
                </label>
                <select  id="candidato-pesquisa" class="custom-select" name="linhaPesquisa">
                  <option value="" >Selecione uma Linha de Pesquisa:</option>
                  {{#each linhasPesquisa}}
                    <option value="{{id}}" {{#if (eq id ../idLinhaPesquisa)}}selected{{/if}}>{{nome}}</option>
                  {{/each}}
                </select>
              </div>

              <div class="col-md-7 ">
                <label class="control-label" for="candidato-instituicao">
                  <font color="#FF0000">*</font>
                  <b>Titulo da Proposta: </b>
                </label>
                <input class="form-control" id="candidato-titulo-proposta" type="text" name="tituloProposta"  maxlength="60" value="{{tituloProposta}}">
              </div>
            </div>

          </div>
        </div>

        <div class="card card-primary">
          <div class="card-header">
            <h3 class="card-title">Orientador:</h3>
          </div>


          <div class="card-body">
            <p>Caso o tema da proposta tenha sido definido em conjunto com algum orientador do PPGI, favor informar o
              nome dele no campo abaixo.</p>
            <div class="row">
              <div class="form-group col-12">
                <label for="candidato-curso-pos">
                  <b>Nome do orientador:</b>
                </label>
                <input class="form-control" id="candidato-orientador" type="text" name="nomeOrientador"  maxlength="60" value={{nomeOrientador}} >
              </div>
            </div>

          </div>
        </div>
        {{#if (eq edital.cartaRecomendacao 1)}}
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Carta de Recomendação</h3>
            </div>

            <div class="card-body">
              <p>Você precisa apenas preencher corretamente o nome e email das pessoas que devem fornecer as cartas de
                recomendação. Feito isso, assim que você finalizar e submeter sua inscrição os indicados receberão um
                email com as instruções de como preencher de forma online sua carta de recomendação. Ao menos 2 nomes são
                obrigatórios.</p>

              <div class="row">
                <div class="col-md-5 ">
                  <label class="control-label" for="candidato-instituicao">
                    <font color="#FF0000">*</font>
                    <b>Nome:</b>
                  </label>
                  <input class="form-control" id="candidatoNomeRecomendacao1" type="text" name="recomendacaoNome[]" value="" maxlength="60">
                </div>

                <div class="col-md-5 ">
                  <label class="control-label" for="candidato-instituicao">
                    <font color="#FF0000">*</font>
                    <b>Email:</b>
                  </label>
                  <input  class="form-control" id="candidatoEmailRecomendacao1" type="email" name="recomendacaoEmail[]" value="" maxlength="60">
                </div>
              </div>
              <div class="row">
                <div class="col-md-5 ">
                  <label class="control-label" for="candidato-instituicao">
                    <font color="#FF0000">*</font>
                    <b>Nome:</b>
                  </label>
                  <input class="form-control" id="candidatoNomeRecomendacao2" type="text" name="recomendacaoNome[]" value="" maxlength="60">
                </div>

                <div class="col-md-5 ">
                  <label class="control-label" for="candidato-instituicao">
                    <font color="#FF0000">*</font>
                    <b>Email:</b>
                  </label>
                  <input class="form-control" id="candidatoEmailRecomendacao2" type="email" name="recomendacaoEmail[]" value="" maxlength="60">
                </div>
              </div>

              <div id="dynamic-inputs">
                <!-- Novos campos serão adicionados aqui -->
              </div>

              <button id="add-btn" class="btn btn-success">+</button>
            </div>
          </div>
        {{/if}}
        <div class="card card-primary">
          <div class="card-header">
            <h3 class="card-title">Motivos e documentação</h3>
          </div>

          <div class="card-body">
            <div class="row">
              <div class="col-md-12">
                <div class="form-group">
                  <label class="control-label" for="candidato-Motivo">
                    Descreva os motivos que o levaram a se candidatar ao curso
                    (<span id="charCount">1000</span> Caracteres Restantes):
                  </label>
                  <textarea class="form-control" rows="3" id="candidato-Motivo" name="motivos" maxlength="1000">{{motivos}}</textarea>
                </div>
              </div>
            </div>

            {{#if (eq edital.cartaOrientador 1)}}
              <div class="row ">
                  <div class="col-md-5 custom-file form-group custom-file-container mb-4">
                    <input type="file" class="custom-file-input" id="CartaAceiteOrientador" name="CartaAceiteOrientador">
                    <label class=" form-control custom-file-label" for="CartaAceiteOrientador"> Carta de Aceite do Orientador (obrigatório para doutorado)</label>
                  </div>
              </div>
            {{/if}}
            <div class="row">
                <div class="col-md-5 custom-file form-group custom-file-container mb-4">
                  <input type="file" class="custom-file-input" id="PropostaTrabalho" name="PropostaTrabalho">
                  <label class="form-control custom-file-label" for="PropostaTrabalho">Proposta de Trabalho (obrigatório)</label>
                </div>
            </div>

            <div class="row">
                <div class="col-md-5 custom-file form-group custom-file-container mb-4">
                  <input type="file" class="custom-file-input" id="ComprovantePagamento" name="ComprovantePagamento">
                  <label class=" form-control custom-file-label" for="ComprovantePagamento">Comprovante de Pagamento (obrigatório)</label>
               </div>
            </div>

          </div>



          <div class="card-footer">
            <div class="col">
              <button class="btn btn-success float-right custom-button">
                Salvar e Continuar
                <span class="spinner-border spinner-border-sm" hidden="true" role="status" aria-hidden="true"></span>
              </button>
              <button class="btn btn-warning float-right custom-button" type="button" id="voltarForm">
                Passo Anterior
                <span class="spinner-border spinner-border-sm" hidden="true" role="status" aria-hidden="true"></span>
              </button>
            </div>
          </div>
        </div>
      </form>
    </div>
  </section>
</div>

<footer>
</footer>

<script>
  function deletarAT(event){
        // document.postDelete.submit();
        const linhaDePesquisaId = $("#candidato-pesquisa").val();
        const formData = new FormData($("#candidato-formulario")[0]);
        formData.append('idLinhaPesquisa', linhaDePesquisaId);
        $.ajax({
          headers: {
            'X-CSRF-TOKEN': $("#csrfToken").val()
          },
          url: '/selecaoppgi/formulario/3',
          type: 'PUT',
          data: formData,
          contentType: false,
          processData: false,
          success: function (data) {
            window.location.href = '/selecaoppgi/formulario';
            window.location.reload(true);
          },
          error: function (data) {
            console.error(data);
          }
        });
    }
  
  $(document).ready(function () {
    let recomendacaoCounter = 1;

		$("#btn_logout").click(function () {

			$.ajax({
				url: "/selecaoppgi/logout",
				type: "POST",
				data: {
					_csrf: $("#csrfToken").val()
				},
				success: function (data) {
					window.location.href = "/selecaoppgi";
				},
				error: function (data) {
					console.error(data);
				}
			});
		});
		$("#btn_inicio").click(function () {
			$.ajax({
				url: "/selecaoppgi/voltarInicio",
				type: "POST",
				data: {
					_csrf: $("#csrfToken").val()
				},
				success: function (data) {
					window.location.href = "/selecaoppgi/formulario";
				},
				error: function (data) {
					console.error(data);
				}
			});
		});
	
    $("#voltarForm").on("click", function (e) {
        const btnVoltar = $("#voltarForm");
        btnVoltar.prop("disabled", true);
        btnVoltar.find("span").prop("hidden", false);
        const csrfToken = $("#csrfToken").val();
        const id = $("#idCandidato").val();
        const editalPosicao = $("#editalPosicao").val();

        $.ajax({    
          url: '/selecaoppgi/voltar',
          type: 'POST',
          data: {
            _csrf: csrfToken,
            editalPosicao: editalPosicao, 
            id: id
          }, success: function (data) {
            window.location.href = '/selecaoppgi/formulario';
            window.location.reload(true);
          },
          error: function (data) {
            console.error(data)
            btnVoltar.prop("disabled", false);
            btnVoltar.find("span").prop("hidden", true);
          }
        });
      });
 
    $("#add-btn").click(function (e) {
      e.preventDefault();
      var newInput = '<div class="row">' +
        '<div class="col-md-5">' +
        '<label class="control-label" for="candidato-Nome-Recomendacao">' +
        '<font color="#FF0000">*</font>' +
        '<b>Nome:</b>' +
        '</label>' +
        '<input class="form-control" type="text" name="recomendacaoNome[]" value="" maxlength="60">' +
        '</div>' +
        '<div class="col-md-5">' +
        '<label class="control-label" for="candidato-Email-Recomendacao">' +
        '<font color="#FF0000">*</font>' +
        '<b>Email:</b>' +
        '</label>' +
        '<input class="form-control" type="text" name="recomendacaoEmail[]" value="" maxlength="60">' +
        '</div>' +
        '<div class="col-md-2 align-self-end">' +
        '<button class="remove-btn" onclick="$(this).closest(\'.row\').remove();">X</button>' + '</div>' +
        '</div>';

      $("#dynamic-inputs").append(newInput);
    });

    $("#candidato-Motivo").on("input", function () {
      var maxLength = 1000;
      var currentLength = $(this).val().length;
      var charactersRemaining = maxLength - currentLength;
      $("#charCount").text(charactersRemaining);
    });
  });

  $.validator.prototype.checkForm = function() {
    this.prepareForm();
    for (var i = 0, elements = (this.currentElements = this.elements()); elements[i]; i++) {
        if (this.findByName(elements[i].name).length != undefined && this.findByName(elements[i].name).length > 1) {
            for (var cnt = 0; cnt < this.findByName(elements[i].name).length; cnt++) {
                this.check(this.findByName(elements[i].name)[cnt]);
            }
        } else {
            this.check(elements[i]);
        }
    }
    return this.valid();
  }
 
  $("#candidato-formulario").validate({
      errorElement: 'span',
      errorPlacement: function (error, element) {
        error.addClass('invalid-feedback');
        element.closest('div').append(error);
      },
      highlight: function (element, errorClass, validClass) {
        $(element).addClass('is-invalid');
      },
      unhighlight: function (element, errorClass, validClass) {
        $(element).removeClass('is-invalid');
      },
      rules: {
        "linhaPesquisa": {
          required: true
        },
        "tituloProposta": {
          required: true
        },
        "recomendacaoNome[]": {
          required: false
        },
        "recomendacaoEmail[]": {
          required: false,
          email: true 
        },
        "PropostaTrabalho": {
          required: true
        },
        "ComprovantePagamento": {
          required: true
        },
        "CartaAceiteOrientador": {
          required: {{#if (eq cursoDesejado 'Doutorado')}}true{{else}}false{{/if}}
        },
      },
      messages: {
        "linhaPesquisa": {
          required: "Linha de Pesquisa é obrigatória",
        },
        "tituloProposta": {
          required: "Título da Proposta é obrigatório",
        },
        "recomendacaoNome[]": {
          required: "Nome é obrigatório",
        },
        "recomendacaoEmail[]": {
          required: "Email é obrigatório",
          email: "Por favor, insira um endereço de email válido"
        },
        "PropostaTrabalho": {
          required: "Proposta de Trabalho é obrigatória",
        },
        "ComprovantePagamento": {
          required: "Comprovante de Pagamento é obrigatório",
        },
        "CartaAceiteOrientador": {
          required: "Carta de Aceite do Orientador é obrigatória para doutorado",
        },
      },
      submitHandler: (form, e) => {
        e.preventDefault();
        $('#confirm-register').modal()
      }
    });
</script>