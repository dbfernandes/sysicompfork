{{ setTitle title="Recuperar Senha - PPGI/UFAM" i18nKey="ppgi.titles.selecao.recuperarSenha"}}

<!-- Container principal da página -->
<main class="login-box">
  <!-- Cabeçalho com as logos -->
  <header class="login-logo container-cards">
    <img
      src="/public/img/logo-icomp.png"
      alt="{{__ 'ppgiRecPass.alt_logo_icomp'}}"
    >
    <img
      src="/public/img/logo-ufam.png"
      alt="{{__ 'ppgiRecPass.alt_logo_ufam'}}"
    >
  </header>

  <!-- Cartão de recuperação de senha -->
  <article class="card">
    <div class="card-body login-card-body d-flex flex-column" style="gap: 8px;">
      <!-- Título principal (h1) -->
      <h2 class="title text-center">
        {{__ "ppgiRecPass.title"}}
      </h2>

      <!-- Alertas de erro e sucesso (role="alert" + aria-live="assertive") -->
      <div
        id="error-msg"
        class="alert alert-danger"
        hidden="true"
        role="alert"
        aria-live="assertive"
      ></div>
      <div
        id="success-msg"
        class="alert alert-success"
        hidden="true"
        role="alert"
        aria-live="assertive"
      ></div>

      <!-- Subtítulo ou instrução -->
      <p class="sub-title  text-center">
        {{__ "ppgiRecPass.subTitle"}}
      </p>


      <!-- Formulário de recuperação de senha -->
      <form id="form-recuperar-senha">
        <!-- Token CSRF -->
        <input
          type="hidden"
          name="_csrf"
          value="{{csrfToken}}"
        >

        <!-- E-mail -->
        <div class="form-group">
          <label for="email" class="sr-only">
            {{__ "ppgiRecPass.emailPlaceholder"}}
          </label>
          <input
            type="email"
            class="form-control"
            name="email"
            id="email"
            placeholder="{{__ "ppgiRecPass.emailPlaceholder"}}"
            autofocus
          >
          <div class="help-block"></div>
        </div>

        <!-- Edital -->
        <div class="form-group">
          <label for="editalId" class="sr-only">
            {{__ "ppgiRecPass.noticePlaceholder"}}
          </label>
          <select
            class="form-control"
            name="editalId"
            id="editalId"
          >
            <option value="">
              {{__ "ppgiRecPass.noticePlaceholder"}}
            </option>
            {{#each editais}}
              <option value="{{id}}">{{id}}</option>
            {{/each}}
          </select>
          <div class="help-block"></div>
        </div>

        <!-- Botões -->
        <button
          id="btn-form-submit"
          type="submit"
          class="btn btn-primary btn-block"
        >
          {{__ "ppgiRecPass.submitButton"}}
          <span
            class="spinner-border spinner-border-sm"
            hidden="true"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
        <button
          type="button"
          name="voltar"
          class="btn btn-default btn-block"
          role="button"
          id="voltar"
        >
          {{__ "ppgiRecPass.backButton"}}
        </button>
      </form>
    </div>
  </article>

  <!-- Seletor de idioma (pode ser <footer> ou <nav> dependendo do contexto) -->
  {{> ppgi/selectLanguage}}
</main>

<script>
  const basePath = "{{basePath}}";

  $("#voltar").click(() => {
      window.location.href = `${basePath}/entrar`;
  });

  // Esconde a mensagem de erro ao digitar
  $("#form-recuperar-senha input").on("input", function() {
    const divError = $("#error-msg");
    if (!divError.prop("hidden")) {
      divError.prop("hidden", true);
    }
  });

  // Validação do formulário
  $("#form-recuperar-senha").validate({
    ignore: ':hidden',
    rules: {
      email: {
        required: true,
        email: true
      },
      editalId: {
        required: true
      }
    },
    messages: {
      email: {
        required: "{{__ 'ppgiRecPass.validation.emailRequired'}}",
        email: "{{__ 'ppgiRecPass.validation.emailInvalid'}}"
      },
      editalId: {
        required: "{{__ 'ppgiRecPass.validation.noticeRequired'}}"
      },
    },
    errorElement: 'span',
    errorPlacement: function (error, element) {
      error.addClass('invalid-feedback');
      element.closest('div').append(error);
    },
    highlight: function (element) {
      $(element).addClass('is-invalid');
    },
    unhighlight: function (element) {
      $(element).removeClass('is-invalid');
    },
    submitHandler: function (form, e) {
      e.preventDefault();
      const buttonLogin = $("#btn-form-submit");
      const formData = new FormData(form);

      buttonLogin.attr("disabled", true);
      buttonLogin.find("span").prop("hidden", false);

      $.ajax({
        url: `${basePath}/recuperarSenha?_csrf={{csrfToken}}`,
        type: "POST",
        data: {
          email: formData.get("email"),
          editalId: formData.get("editalId")
        },
        success: function () {
          const divSuccess = $("#success-msg");
          const divError = $("#error-msg");

          divError.prop("hidden", true);
          divSuccess.prop("hidden", false);
          divSuccess.text("{{__ 'ppgiRecPass.successMessage'}}");

          buttonLogin.attr("disabled", false);
          buttonLogin.find("span").prop("hidden", true);
        },
        error: function (res) {
          const divError = $("#error-msg");
          const divSuccess = $("#success-msg");

          buttonLogin.attr("disabled", false);
          buttonLogin.find("span").prop("hidden", true);

          divSuccess.prop("hidden", true);
          divError.prop("hidden", false);

          if (res.status === 400) {
            divError.text("{{__ 'ppgiRecPass.errorIncomplete'}}");
          } else if (res.status === 404) {
            divError.text("{{__ 'ppgiRecPass.errorNotFound'}}");
          } else if (res.status === 422) {
            divError.text("{{__ 'ppgiRecPass.errorIncomplete'}}");
          }
        }
      });
    }
  });
</script>
