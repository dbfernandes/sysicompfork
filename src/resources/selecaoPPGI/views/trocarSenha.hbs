{{ setTitle title="Trocar Senha - PPGI/UFAM" i18nKey="ppgi.titles.selecao.trocarSenha"}}

<!-- Container principal -->
<main class="login-box">

  <!-- Cabeçalho com as logos -->
  <header class="login-logo container-cards">
    <img
      src="/public/img/logo-icomp.png"
      alt="{{__ 'ppgiChangePass.alt_logo_icomp'}}"
    />
    <img
      src="/public/img/logo-ufam.png"
      alt="{{__ 'ppgiChangePass.alt_logo_ufam'}}"
    />
  </header>

  <!-- Cartão de troca de senha -->
  <article class="card">
    <div class="card-body login-card-body">
      <!-- Título principal (h1) -->
      <h1 class="login-logo">
        <b>{{__ "ppgiChangePass.title"}}</b>
      </h1>

      <!-- Mensagem de erro (exibe se 'error' estiver presente, mas sempre com role="alert") -->
      <div
        id="error-msg"
        class="alert alert-danger"
        role="alert"
        aria-live="assertive"
        {{#unless error}}hidden{{/unless}}
      >
        {{#if error}}
          {{{error}}}
        {{/if}}
      </div>

      <!-- Mensagem de sucesso -->
      <div
        id="success-msg"
        class="alert alert-success"
        hidden
        role="alert"
        aria-live="assertive"
      ></div>

      <!-- Subtítulo -->
      <p class="login-box-msg">
        {{__ "ppgiChangePass.subTitle"}}
      </p>

      <!-- Formulário de troca de senha -->
      <form id="form-recuperar-senha">
        <!-- Token CSRF -->
        <input
          type="hidden"
          name="_csrf"
          value="{{csrfToken}}"
        />

        <!-- Senha -->
        <div class="form-group">
          <label
            for="password"
            class="sr-only"
          >
            {{__ "ppgiChangePass.passwordPlaceholder"}}
          </label>
          <input
            type="password"
            class="form-control"
            name="password"
            id="password"
            placeholder="{{__ "ppgiChangePass.passwordPlaceholder"}}"
            {{#if error}}disabled{{/if}}
          />
          <div class="help-block"></div>
        </div>

        <!-- Confirmar Senha -->
        <div class="form-group">
          <label
            for="confirmPassword"
            class="sr-only"
          >
            {{__ "ppgiChangePass.confirmPasswordPlaceholder"}}
          </label>
          <input
            type="password"
            class="form-control"
            name="confirmPassword"
            id="confirmPassword"
            placeholder="{{__ "ppgiChangePass.confirmPasswordPlaceholder"}}"
            {{#if error}}disabled{{/if}}
          />
          <div class="help-block"></div>
        </div>

        <!-- Botões -->
        <button
          id="btn-form-submit"
          type="submit"
          class="btn btn-primary btn-block"
          {{#if error}}disabled{{/if}}
        >
          {{__ "ppgiChangePass.submitButton"}}
          <span
            class="spinner-border spinner-border-sm"
            hidden="hidden"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
        <button
          type="button"
          name="voltar"
          class="btn btn-default btn-block"
          role="button"
          id="voltar"
        >
          {{__ "ppgiChangePass.backButton"}}
        </button>
      </form>
    </div>
  </article>

  <!-- Seletor de idioma -->
  {{> ppgi/selectLanguage}}

</main>

<script>
  const basePath = "{{basePath}}";

  $("#voltar").click(() => {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      window.location.href = `${basePath}/`;
    }
  });

  // Esconde mensagem de erro ao digitar algo
  $("#form-recuperar-senha input").on("input", function() {
    const divError = $("#error-msg");
    if (!divError.prop("hidden")) {
      divError.prop("hidden", true);
    }
  });

  // Validação do formulário
  $("#form-recuperar-senha").validate({
    ignore: ':hidden',
    rules: {
      password: {
        required: true,
        minlength: 6
      },
      confirmPassword: {
        required: true,
        equalTo: "#password"
      }
    },
    messages: {
      password: {
        required: "{{__ 'ppgiChangePass.validation.passwordRequired'}}",
        minlength: "{{__ 'ppgiChangePass.validation.passwordMinLength'}}"
      },
      confirmPassword: {
        required: "{{__ 'ppgiChangePass.validation.confirmPasswordRequired'}}",
        equalTo: "{{__ 'ppgiChangePass.validation.confirmPasswordMismatch'}}"
      }
    },
    errorElement: 'span',
    errorPlacement: function (error, element) {
      error.addClass('invalid-feedback');
      element.closest('div').append(error);
    },
    highlight: function (element) {
      $(element).addClass('is-invalid');
    },
    unhighlight: function (element) {
      $(element).removeClass('is-invalid');
    },
    submitHandler: function (form, e) {
      e.preventDefault();
      const formData = new FormData(form);
      const senha = formData.get("password");
      const btnSubmit = $("#btn-form-submit");
      const divError = $("#error-msg");

      btnSubmit.attr("disabled", true);
      btnSubmit.find("span").prop("hidden", false);

      $.ajax({
        url: `${basePath}/trocarSenha?_csrf={{csrfToken}}`,
        type: "PUT",
        data: {
          senha,
          token: "{{token}}"
        },
        success: function () {
          window.location.href = `${basePath}/entrar`;
        },
        error: function (res) {
          btnSubmit.attr("disabled", false);
          btnSubmit.find("span").prop("hidden", true);

          if (res.responseJSON && res.responseJSON.message) {
            divError.text(res.responseJSON.message);
          } else {
            divError.text("{{__ 'ppgiChangePass.errorIncomplete'}}");
          }

          divError.prop("hidden", false);
        }
      });
    }
  });
</script>
