{{ setTitle title="Carta de Recomendação para de Inscrição no Mestrado/Doutorado no PPGI/UFAM" }}
<style>
	.forms-page {
		height: 100vh;
		display: block;
		justify-content: center;
		align-items: center;
		background-color: #fff;
		overflow-y: auto;
	}
	.forms-page header {
		width: 100%;
		position: sticky;
		top: 0;
		left: 0;
		z-index: 1;
		height: 50px;
		background-color: #222;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-weight: bold;
		padding: 10px 45px;
		z-index: 9999;
	}

	.forms-page header h1 {
		font-size: 1.4rem;
		color: #dbdbdb;
		cursor: pointer;
	}

	.forms-page header h1:hover {
		color: #fff;
	}

	@media screen and (max-width: 720pt) {
		.forms-page header {
			padding: 10px 15px;
		}
	}

	.forms-page header .options {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.forms-page header .options button {
		background-color: transparent;
		border: none;
		cursor: pointer;
		color: #c7c7c7;
		transition: all .3s;
	}

	.forms-page header .options button:hover {
		color: #fff;
	}


	.forms-page section {
		display: flex;
		flex-direction: column;
		width: 90%;
		margin: auto;
		margin-top: 2%;
		min-height: 100vh;
		display: flex;
		justify-content: space-between;
		align-items: center;
		overflow-y: auto;
		color: #222;
	}

	.forms-page section h1 {
		font-size: 1.4rem;
		color: #222;
		margin-bottom: 10px;
	}

	.forms-page section .line {
		width: 100%;
		height: 1px;
		background-color: #c2c2c2;
		margin-bottom: 10px;
	}

	.forms-page section .info {
		width: 100%;
		height: 100%;
	}


	@media (max-width: 576px) {
	.forms-page section form {
		padding: 0;
	}
	}

	.forms-page section button {
		position: relative;
		bottom: 0;
	}

	.forms-page footer {
		width: 100%;
		height: 50px;
		position: fixed;
		bottom: 0;
		left: 0;
		background-color: #000;
	}

	.toast-container {
		top: 0;
    	right: 0;
    	position: fixed;
   	 	margin-top: 3.5rem;
		margin-right: 1rem;
		z-index: 1050;
	}

	.alert {
		display: flex;
   		gap: 1rem;
   		align-items: center;
	}
</style>


<div class="forms-page">
	<header>
    <div class="container">
      <h1 class="header-title">PPGI</h1>
		  <div class="options">
			  <button id="btn_inicio">Início</button>
			  <button id="btn_logout">Sair</button>
		  </div>
    </div>
	</header>
    <div class="toast-container position-fixed ">
        <div id="myToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="alert alert-primary mb-0" role="alert">
                <span id="toastMessage">This is a primary alert with <a href="#" class="alert-link">an example link</a>. Give it a click if you like.</span>
                 <button type="button" class="close" data-dismiss="alert" aria-label="Close">
    				<span aria-hidden="true">&times;</span>
  				</button>
            </div>
        </div>
    </div>
</div>

