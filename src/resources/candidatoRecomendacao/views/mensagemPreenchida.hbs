{{ setTitle title="Formulário preenchido" }}

<div class="forms-page">
  <!-- Cabeçalho -->
  <header>
    <div class="container d-flex justify-content-between align-items-center py-3">
      <h1 class="header-title">{{__ "ppgi.header.title"}}</h1>
      <div class="options">
        {{> ppgi/selectLanguageHeader}}
      </div>
    </div>
  </header>

  <!-- Conteúdo principal -->
  <main class="content container container-main">
    <div class="alert alert-success">
      <h5>
        <i class="icon fas fa-check-circle"></i>
        {{__ "ppgiRecomendacao.filledLetter.title"}}
      </h5>
      {{__ "ppgiRecomendacao.filledLetter.message"}}

      <div class="container-fluid p-0">
        <p class="col-12 p-0 mb-0 mx-0 mt-2 " style="text-align: right">
          {{__ "ppgiRecomendacao.filledLetter.footer"}}
        </p>
      </div>
    </div>
  </main>

  <!-- Rodapé -->
  {{> ppgi/footer}}
</div>