{{> header}}

{{> sidebar module='edital' page='edital-listar'}}
{{ setTitle title=(concat "Edital " edital.id) }}
<div id="modalPlanilha" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="modalPlanilhaLabel">
  <div class="modal-dialog" role="document">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="modalPlanilhaLabel">Gerar planilha de avaliação</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>

      <div class="modal-body">
        <div class="form-group ">
          <label class="mb-2">A planilha vai ter prova?</label>
          <div class="custom-control custom-radio">
            <input class="custom-control-input" type="radio" id="planilhaProvaSim" name="planilhaProva" value="1">
            <label for="planilhaProvaSim" class="custom-control-label">Sim</label>
          </div>

          <div class="custom-control custom-radio">
            <input class="custom-control-input" type="radio" id="planilhaProvaNao" name="planilhaProva" value="0" checked>
            <label for="planilhaProvaNao" class="custom-control-label">Não</label>
          </div>

        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-success" onclick="confirmarGeracaoPlanilha()">
          <i class="fas fa-download"></i>
          Gerar planilha
        </button>
      </div>

    </div>
  </div>
</div>

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap gap-1 mb-4">
                <div>
                    <h1>Edital: {{edital.id}} </h1>
                </div>
                <div>
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item active"><a href="/inicio">Página Inicial</a></li>
                        <li class="breadcrumb-item"><a href="/edital/listEdital">Editais de Seleção do PPGI</a></li>
                        <li class="breadcrumb-item active">Detalhes de edital</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">

                <div class="col-sm-12">
                    <a class="btn btn-warning color-white" id="voltarBtnView">
                        <i class="fa fa-arrow-left"></i>
                        Voltar
                    </a>
                    <a class="btn btn-primary" href="/edital/updateEdital/{{edital.id}}">
                        <i class="fas fa-edit color-white"></i>
                        Editar
                    </a>
                    <a id="btn-{{edital.id}}" class="btn
                        {{#ifEqual edital.status '1'}}btn-success{{else}}btn-danger{{/ifEqual}}"
                        onclick="abrirModal()">
                        <i id="icone-{{edital.id}}" class="fa color-white
                            {{#ifEqual edital.status 1}}fa-lock-open{{else}}fa-lock{{/ifEqual}}">
                        </i>
                        {{#ifEqual edital.status 1}}Não Suspenso{{else}}Suspenso{{/ifEqual}}
                    </a>
                    {{!-- Editar aqui --}}
                    <a id="test" class="btn btn-info" href="/edital/listEditalCandidates/{{edital.id}}">
                        <i class="fas fa-list color-white"></i>
                        Lista de Inscritos
                    </a>
                  <a class="btn bg-success" href="javascript:void(0)" onclick="abrirModalPlanilha()">
                    <i class="fas fa-file-csv color-white"></i>
                    Planilha Excel para Avaliação (Excel)
                  </a>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">

                        <!-- /.card-header -->
                        <div class="card-body">
                            <table id="example2" class="table table-striped table-bordered table-hover">

                                </thead>
                                <tbody>

                                    <tr>
                                        <td>Nº edital</td>
                                        <td>{{edital.id}}</td>
                                    </tr>

                                    <tr>
                                        <td>Status</td>
                                        <td id="labelStatus"> </td>
                                    </tr>

                                    <tr>
                                        <td>Data início</td>
                                        <td>{{formataData edital.dataInicio}}</td>
                                    </tr>

                                    <tr>
                                        <td>Data fim</td>
                                        <td>{{formataData edital.dataFim}}</td>
                                    </tr>

                                    <tr>
                                        <td>Nº de Inscrições Iniciadas</td>
                                        <td> {{quantidadeInscricaoAndamento}}</td>
                                    </tr>

                                    <tr>
                                        <td>Nº de Inscrições Encerradas</td>
                                        <td> {{quantidadeInscricaoFinalizada}}</td>
                                    </tr>

                                    <tr>
                                        <td>Carta de Recomendação</td>
                                        <td>{{#ifEqual edital.cartaRecomendacao '1'}}Sim{{else}}Não{{/ifEqual}}</td>
                                    </tr>

                                    <tr>
                                        <td>Carta do Orientador</td>
                                        <td>{{#ifEqual edital.cartaOrientador '1'}}Sim{{else}}Não{{/ifEqual}}</td>
                                    </tr>
                                    <tr>
                                      <td>Projeto de Pesquisa</td>
                                      <td>{{#if edital.projetoPesquisa}}Sim{{else}}Não{{/if}}</td>
                                    </tr>
                                    <tr>
                                        <td>Curso</td>
                                        <td id="curso"> </td>
                                    </tr>

                                    <tr>
                                        <td>Vagas para Mestrado</td>
                                        <td>REG: {{edital.vagasMestrado}} / SUP: {{edital.cotasMestrado}}  / TAE:  {{edital.taesMestrado}}</td>
                                    </tr>

                                    <tr>
                                        <td>Vagas para Doutorado</td>
                                        <td>REG: {{edital.vagasDoutorado}} / SUP: {{edital.cotasDoutorado}} / TAE:  {{edital.taesDoutorado}}</td>
                                    </tr>

                                    <tr>
                                        <td>Edital em PDF</td>
                                        <td>
                                            <a href='{{edital.documento}}' target="_blank">
                                                Baixar
                                            </a>
                                        </td>
                                    </tr>

                            </table>
                        </div>
                        <!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.col -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container-fluid -->
        <div id="modalArquivar" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="modalArquivarLabel">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalArquivarLabel">Status do Edital</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body" id="modalArquivarBody">
                        <!-- mensagem -->
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                        <button type="button" id="confirmButton" onclick="arquivarEdital()">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- /.content -->
</div>

<script>
  function abrirModalPlanilha() {
    $('#modalPlanilha').modal('show');
  }

  function confirmarGeracaoPlanilha() {
    const prova = document.querySelector('input[name="planilhaProva"]:checked')?.value ?? "0"; // "1" ou "0"

    // Exemplo de URL com querystring (recomendado)
    // Você ajusta o backend para ler ?etapa=1&prova=1
    const url = `/edital/geraPlanilha/${id}?prova=${encodeURIComponent(prova)}`;

    $('#modalPlanilha').modal('hide');
    window.location.href = url;
  }

  let status = "{{edital.status}}";

  const regMestrado = "{{edital.vagaMestrado}}";
  const supMestrado = "{{edital.cotasMestrado}}";

  const regDoutorado = "{{edital.vagaDoutorado}}";
  const supDoutorado = "{{edital.cotasDoutorado}}";

  let curso;

  if ((regMestrado > 0 || supMestrado > 0) && (regDoutorado > 0 || supDoutorado > 0)) {
    curso = 'Mestrado e  Doutorado';
  }
  else if ((regMestrado == 0 && supMestrado == 0) && (regDoutorado > 0 || supDoutorado > 0)) {
    curso = 'Doutorado';
  }
  else {
    curso = 'Mestrado';
  }

  document.getElementById("curso").innerText = curso;

  /* Fuso horário oficial da UFAM  */
  const TZ = "America/Manaus";

  /* Datas do edital (strings vindas do template) → Moment   */
  const dataInicio = moment.tz("{{edital.dataInicio}}", TZ).startOf("day");
  const dataFim    = moment.tz("{{edital.dataFim}}",    TZ).endOf("day");

  /* Data de hoje em Manaus                                    */
  const hoje = moment.tz(TZ).startOf("day");

  /* Cálculo do rótulo */
  let labelStatus;

  if (status === "1") {                // 1 = edital ativo
    if (hoje.isBefore(dataInicio)) {
      labelStatus = "Não Iniciado";    // inscrições ainda não começaram
    } else if (hoje.isAfter(dataFim)) {
      labelStatus = "Encerrado";       // inscrições já terminaram
    } else {
      labelStatus = "Aberto";          // dentro do período
    }
  } else {
    labelStatus = "Suspenso";          // status diferente de 1
  }

  document.getElementById("labelStatus").innerText = labelStatus;

  let csrfToken = "{{csrfToken}}";
  let id = "{{edital.id}}";

  function abrirModal() {
    if (status == '1') {
      $('#modalArquivarBody').html("Você realmente deseja encerrar o edital com ID " + id + "?");
      $('#confirmButton').removeClass('btn btn-success').addClass('btn btn-danger');
    } else {
      $('#modalArquivarBody').html("Você realmente deseja abrir o edital com ID " + id + "?");
      $('#confirmButton').removeClass('btn btn-danger').addClass('btn btn-success');
    }
    $('#modalArquivar').modal('show');
  }

  function arquivarEdital() {
    let novoStatus = (status == '1' ? '0' : '1');

    const dataFromForm = {
      status: novoStatus,
      _csrf: csrfToken
    };

    // Fechar o modal
    $('#modalArquivar').modal('hide');

    $.ajax({
      url: `/edital/arquivarEdital/${id}`,
      type: 'PUT',
      data: dataFromForm,
      success: function (data) {
        const mensagem = "Status do Edital alterado no sistema com sucesso";
        const expirationTime = new Date(new Date().getTime() + 5000);
        document.cookie = `showToast=true; expires=${expirationTime.toUTCString()}`;
        document.cookie = `mensagem=${mensagem}; expires=${expirationTime.toUTCString()}`;

        window.location.href = '/edital/listEdital';

      },
      error: function (data) {
        $(document).Toasts('create', {
          icon: 'error',
          class: "bg-danger",
          autohide: true,
          delay: 3000,
          title: 'Erro!',
          body: 'Erro: ' + data.responseJSON.error
        });
      }
    });

    function abrirModal() {
      if (status == '1') {
        $('#modalArquivarBody').html("Você realmente deseja encerrar o edital com ID " + id + "?");
        $('#confirmButton').removeClass('btn btn-success').addClass('btn btn-danger');
      } else {
        $('#modalArquivarBody').html("Você realmente deseja abrir o edital com ID " + id + "?");
        $('#confirmButton').removeClass('btn btn-danger').addClass('btn btn-success');
      }

      $('#modalArquivar').modal('show');
    }

    function arquivarEdital() {
      let novoStatus = (status == '1' ? '0' : '1');
      const dataFromForm = {
        status: novoStatus,
        _csrf: csrfToken
      };

      // Fechar o modal
      $('#modalArquivar').modal('hide');

      $.ajax({
        url: `/edital/arquivarEdital/${id}`,
        type: 'PUT',
        data: dataFromForm,
        success: function (data) {
          const mensagem = "Status do Edital alterado no sistema com sucesso";
          const expirationTime = new Date(new Date().getTime() + 5000);
          document.cookie = `showToast=true; expires=${expirationTime.toUTCString()}`;
          document.cookie = `mensagem=${mensagem}; expires=${expirationTime.toUTCString()}`;
          window.location.href = '/edital/listEdital';

        },
        error: function (data) {
          $(document).Toasts('create', {
            icon: 'error',
            class: "bg-danger",
            autohide: true,
            delay: 3000,
            title: 'Erro!',
            body: 'Erro: ' + data.responseJSON.error
          });
        }
      });
    }
  }

  document.getElementById("voltarBtnView").addEventListener("click", function () {
    window.history.back();
  });
</script>

{{> footer}}