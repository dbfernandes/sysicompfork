<tr>
  <td style="padding: 20px; font-family: Arial, sans-serif; color: #333333;">
    <p style="font-size: 16px; line-height: 1.5;">
      Caro(a) {{recomendacao.nome}},
    </p>
    <p style="font-size: 16px; line-height: 1.5;">
