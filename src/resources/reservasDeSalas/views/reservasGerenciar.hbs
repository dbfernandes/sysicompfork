{{> header}}
{{> sidebar module='reservas' page='reservas-gerenciar'}}


{{#section "head"}}
  <!-- Select2 -->
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.css">
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/toastr/toastr.css"/>
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/select2/css/select2.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css" />

  <style>
    .dataTables_length  { flex:1; }
    .dataTables_length label { margin: 0; }
    .dataTables_info{ padding: 0 !important; margin-right: 8px; }
    .gap-table{ gap: 8px; } /* NOVO */
    .min-width-button{ min-width: 210px; }
  </style>
{{/section}}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
  <!-- Content Header (Page header) -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-full mb-3 align-items-center flex-wrap justify-content-between" style="gap: 8px; white-space: nowrap;">
        <div><h1>Lista de Reservas</h1></div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item active">Listagem de Reservas</li>
          </ol>
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-sm-2 col-md-3 col-lg-2 min-width-button">
          <a type="button" class="btn btn-block btn-primary" href="/reservas/adicionar">
            <i class="fas fa-user-plus color-white"></i> Reservar Sala
          </a>
        </div>
      </div>
    </div><!-- /.container-fluid -->
  </section>

  <!-- NOVO: Card de Filtros (acima da tabela) -->
  <section class="content pt-0">
    <div class="container-fluid">
      <div class="card mb-3">

        <div class="card-body">
          <div class="form-row align-items-end" style="gap: 8px;">
            <!-- NOVO: Pesquisa geral -->
            <div class="col-12 col-md-4 col-lg-3">
              <label for="inputPesquisaGeral" class="mb-1">Pesquisar</label>
              <div class="input-group">
                <input
                  type="text"
                  id="inputPesquisaGeral"
                  class="form-control"
                  placeholder="Busque por solicitante, atividade, tipo, etc."
                  aria-label="Pesquisar reservas"
                />
                <div class="input-group-append">
                  <span class="input-group-text"><i class="fa fa-search"></i></span>
                </div>
              </div>
            </div>
            <!-- Filtro de Sala (sempre visível) -->
            <div class="col-12 col-md-8 col-lg-4">
              <label for="filtroSalas" class="mb-1">Filtrar por Sala(s)</label>
              <select id="filtroSalas" class="form-control" multiple>
                {{#each salasGrouped}}
                  <optgroup label="{{@key}}">
                    {{#each this}}
                      <option value="{{id}}" {{#if (eq ../../salaId id)}}selected{{/if}}>
                        {{nome}} - {{bloco}} - {{andar}}º andar
                      </option>
                    {{/each}}
                  </optgroup>
                {{/each}}
              </select>
            </div>
            <!-- NOVO: Somente futuras/atuais -->
            <div class="col-auto d-flex align-items-center">
              <div class="icheck-primary">
                <input  {{#if salaId}} {{else}}checked{{/if}} class="form-check-input" type="checkbox" id="chkSomenteFuturas" />
                <label class="form-check-label" for="chkSomenteFuturas" title="Mostra reservas cujo término é no futuro ou agora">
                  Somente futuras/atuais
                </label>
              </div>
            </div>
            <!-- Botões -->
            <div class="col-auto d-flex" style="gap: 8px;">
              <button id="btnToggleMaisFiltros" type="button" class="btn btn-outline-primary">
                Mais filtros
              </button>
              <button id="btnLimparFiltros" type="button" class="btn btn-outline-secondary">
                Limpar filtros
              </button>
            </div>
          </div>

          <!-- Área colapsável: datas/horas -->
          <div id="maisFiltros" class="mt-3" style="display: none;">
            <div class="form-row" style="gap: 8px;">
              <!-- Data inicial -->
              <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label class="mb-1" for="filtroDataIniInput">A partir de</label>
                <div class="input-group date" id="filtroDataIni" data-target-input="nearest">
                  <input type="text" class="form-control datetimepicker-input" data-target="#filtroDataIni"  id="filtroDataIniInput"/>
                  <div class="input-group-append" data-target="#filtroDataIni" data-toggle="datetimepicker">
                    <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                  </div>
                </div>
              </div>

              <!-- Data final -->
              <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label class="mb-1" for="filtroDataFimInput">Até</label>
                <div class="input-group date" id="filtroDataFim" data-target-input="nearest">
                  <input type="text" class="form-control datetimepicker-input" data-target="#filtroDataFim" id="filtroDataFimInput" />
                  <div class="input-group-append" data-target="#filtroDataFim" data-toggle="datetimepicker">
                    <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                  </div>
                </div>
              </div>

              <!-- Hora inicial -->
              <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label class="mb-1" for="filtroHoraIniInput">Hora inicial</label>
                <div class="input-group date" id="filtroHoraIni" data-target-input="nearest">
                  <input type="text" class="form-control datetimepicker-input" data-target="#filtroHoraIni" id="filtroHoraIniInput" />
                  <div class="input-group-append" data-target="#filtroHoraIni" data-toggle="datetimepicker">
                    <div class="input-group-text"><i class="fa fa-clock"></i></div>
                  </div>
                </div>
              </div>

              <!-- Hora final -->
              <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label class="mb-1" for="filtroHoraFimInput">Hora final</label>
                <div class="input-group date" id="filtroHoraFim" data-target-input="nearest">
                  <input type="text" class="form-control datetimepicker-input" data-target="#filtroHoraFim" id="filtroHoraFimInput" />
                  <div class="input-group-append" data-target="#filtroHoraFim" data-toggle="datetimepicker">
                    <div class="input-group-text"><i class="fa fa-clock"></i></div>
                  </div>
                </div>
              </div>
            </div><!-- /.form-row -->
          </div><!-- /#maisFiltros -->
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="content pt-0">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <div class="card">
            <!-- REMOVIDO: antigo card-header com filtros -->
            <div class="card-body" style="overflow-x:auto;">
              <table id="example2" class="table table-striped table-bordered table-hover w-100">
                <thead>
                <tr style="text-align: center;">
                  <th style="text-align: center;">Sala</th>
                  <th style="text-align: center;">Solicitante</th>
                  <th style="text-align: center;">Atividade</th>
                  <th style="text-align: center;">Tipo</th>
                  <th style="text-align: center;">Data</th>
                  <th style="text-align: center;">Horário</th>
                  <th style="text-align: center;">Dias da semana</th>
                  <th style="text-align: center;"></th>
                </tr>
                <!-- REMOVIDO: linha de filtros por coluna -->
                </thead>
                <tbody>
                {{#each reservas}}
                  <!-- ALTERADO: adicionados atributos data-* com ISO para facilitar o filtro -->
                  <tr style="text-align: center;"
                      data-sala-id="{{sala.id}}"
                      data-inicio-iso="{{dataInicio}}T{{horaInicio}}"
                      data-fim-iso="{{dataFim}}T{{horaFim}}">
                    <td>{{sala.nome}} - {{sala.bloco}} - {{sala.andar}} andar</td>
                    <td>{{usuario.nomeCompleto}}</td>
                    <td>{{atividade}}</td>
                    <td>{{tipo}}</td>
                    <td>
                      {{dataInicio}}
                      {{#if (eq dataInicio dataFim)}}
                      {{else}} - {{dataFim}}
                      {{/if}}
                    </td>
                    <td>{{horaInicio}} - {{horaFim}}</td>
                    {{#if dias}}
                      <td>{{dias}}</td>
                    {{else}}
                      <td> - </td>
                    {{/if}}
                    <td style="text-align: center; white-space: nowrap">
                      <a class='fa fa-calendar' style="color: blue;" title="Visualizar" href="/salas/detalhes/{{sala.id}}?reservaId={{id}}"></a> &nbsp
                      <a class='fa fa-solid fa-pen' style="color: blue;" title="Editar"
                         href="/reservas/editar/{{id}}"></a> &nbsp
                      <a class="fa fa-solid fa-trash" id="{{id}}" data-toggle="modal" title="Remover"
                         style="color: red;" data-target="#removerUsuario"
                         onclick="addLink(event)" href="#"></a>
                    </td>
                  </tr>
                {{/each}}
                </tbody>
              </table>
            </div>
          </div>
          <!-- /.card -->
        </div>
      </div>
    </div>
  </section>

  <!-- Modal Remoção -->
  <div class="modal fade" id="removerUsuario" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
       aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="tituloModal"></h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-footer">
          <a type="button" class="btn btn-secondary color-white" data-dismiss="modal">Não</a>
          <a id="deleteButton" type="button" class="btn btn-warning color-white" onclick="deleteUserAjax()">Sim</a>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/script-adminlte/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
<script src="/script-adminlte/plugins/moment/locale/pt-br.js"></script>
<script src="/script-adminlte/plugins/toastr/toastr.min.js"></script>
<script src="/script-adminlte/plugins/select2/js/select2.full.min.js"></script>

<script>
  toastr.options = {
    closeButton: true, debug: false, newestOnTop: false, progressBar: true,
    positionClass: "toast-top-right", preventDuplicates: true,
    showDuration: "1000", hideDuration: "1000", timeOut: "5000",
    extendedTimeOut: "1000", showEasing: "swing", hideEasing: "linear",
    showMethod: "fadeIn", hideMethod: "fadeOut"
  };

  let datatable = null;
  let filtroSalaIdsSelecionadas = [];

  // utilitário simples de debounce
  function debounce(fn, wait) {
    let t;
    return function(...args) {
      clearTimeout(t);
      t = setTimeout(() => fn.apply(this, args), wait);
    };
  }

  // ------- Utilitários de data/hora (sem moment, usando Date) -------
  function parseISO(iso) {
    // Formato esperado: "DD/MM/YYYYTHH:mm"
    const m = moment(iso, "DD/MM/YYYYTHH:mm", true);
    return m.isValid() ? m.toDate() : null;
  }

  function onlyTimeToMinutes(str) {
    // 'HH:mm' => minutos desde 00:00
    if (!str) return null;
    const m = String(str).match(/^(\d{1,2}):(\d{2})$/);
    if (!m) return null;
    return Number(m[1]) * 60 + Number(m[2]);
  }

  // Valores de filtro atuais
  const filtros = {
    salaIds: [],
    dataIni: null, // Date (00:00)
    dataFim: null, // Date (23:59)
    horaIniMin: null, // minutos
    horaFimMin: null,  // minutos
    somenteFuturas: {{#if salaId}}false {{else}}true{{/if}}, // NOVO
  };


  // Carregue o moment antes:


  const FMT_COM_HORA = "DD/MM/YYYYTHH:mm";
  const FMT_SEM_HORA = "DD/MM/YYYY";

  function temHora(str) {
  return /T\d{2}:\d{2}$/.test(String(str || ""));
  }

  // Filtro DataTables combinando Sala + intervalo Data + intervalo Hora (robusto com moment)
  function filtroCombinado(settings, data, dataIndex) {
    if (settings.nTable.id !== 'example2') return true;

    const rowNode  = settings.aoData[dataIndex].nTr;
    const salaId   = rowNode.getAttribute('data-sala-id');
    const inicioISO = rowNode.getAttribute('data-inicio-iso'); // ex: 14/09/2025T10:00 ou 14/09/2025
    const fimISO    = rowNode.getAttribute('data-fim-iso');    // ex: 14/09/2025T12:00 ou 14/09/2025

    // 1) Filtro por Sala
    if (filtros.salaIds.length && !filtros.salaIds.includes(String(salaId))) {
      return false;
    }

    // 2) Parse das datas da linha (aceita com/sem hora)
    const mIniRaw = inicioISO ? moment(inicioISO, [FMT_COM_HORA, FMT_SEM_HORA], true) : null;
    const mFimRaw = fimISO    ? moment(fimISO,    [FMT_COM_HORA, FMT_SEM_HORA], true) : null;

    // Se ambos inválidos, não bloqueia a linha
    if ((!mIniRaw || !mIniRaw.isValid()) && (!mFimRaw || !mFimRaw.isValid())) {
      return true;
    }

    // Se só um lado existe, espelha para o outro
    const mIni = (mIniRaw && mIniRaw.isValid())
      ? mIniRaw
      : (mFimRaw && mFimRaw.isValid() ? mFimRaw.clone() : null);

    const mFim = (mFimRaw && mFimRaw.isValid())
      ? mFimRaw
      : (mIniRaw && mIniRaw.isValid() ? mIniRaw.clone() : null);
    if (!mIni || !mFim) return true; // segurança

    // 0) “Somente futuras/atuais”: fim >= agora
    if (filtros.somenteFuturas) {
      if (mFim.isBefore(moment())) return false;
    }

    // 3) Filtro de Data (ignora horas — compara por dia)
    if (filtros.dataIni || filtros.dataFim) {
      const rowStart = mIni.clone().startOf('day');
      const rowEnd   = mFim.clone().endOf('day');


      // filtros.dataIni/Fim são Date nativos → convertemos para moment
      const filterStart = filtros.dataIni ? moment(filtros.dataIni).startOf('day') : null;
      const filterEnd   = filtros.dataFim ? moment(filtros.dataFim).endOf('day')   : null;

      // Intersecção de intervalos:
      // - só início: pega tudo a partir de filterStart
      // - só fim:    pega tudo até filterEnd
      // - ambos:     interseção entre [rowStart,rowEnd] e [filterStart,filterEnd]
      if (filterStart && filterEnd) {
        if (rowEnd.isBefore(filterStart) || rowStart.isAfter(filterEnd)) return false;
      } else if (filterStart) {
        if (rowStart.isBefore(filterStart)) return false;
      } else if (filterEnd) {
        if (rowStart.isAfter(filterEnd)) return false;
      }
    }

    // 4) Filtro de Hora (compara apenas HH:mm em minutos)
    if (filtros.horaIniMin !== null || filtros.horaFimMin !== null) {
      const hasIniTime = temHora(inicioISO);
      const hasFimTime = temHora(fimISO);

      // Se a linha não tiver hora, considera 00:00 para início e 23:59 para fim
      const rowIniMin = hasIniTime ? (mIni.hours() * 60 + mIni.minutes()) : 0;
      const rowFimMin = hasFimTime ? (mFim.hours() * 60 + mFim.minutes()) : (24 * 60 - 1);

      // Filtros: só início => a partir de fIni; só fim => até fFim
      const fIni = (filtros.horaIniMin != null) ? filtros.horaIniMin : 0;
      const fFim = (filtros.horaFimMin != null) ? filtros.horaFimMin : (24 * 60 - 1);

      // Intersecção [rowIni,rowFim] x [fIni,fFim]
      if (rowFimMin < fIni || rowIniMin > fFim) return false;
    }

    return true;
  }
  document.addEventListener('DOMContentLoaded', function () {
    // Registra filtro global do DataTables

    if ($.fn?.dataTable?.ext?.search) {
      $.fn.dataTable.ext.search.push(filtroCombinado);
    } else {
      $(document).one('init.dt', function () {
        if ($.fn.dataTable.ext && $.fn.dataTable.ext.search) {
          $.fn.dataTable.ext.search.push(filtroCombinado);
        }

      });
    }

    // Inicializa tabela
    datatable = $('#example2').DataTable({
      language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
      dom: "t<'dt-bottom d-flex flex-wrap justify-content-start align-items-center gap-table'lip>",
      responsive: true,
      columns: [
        { responsivePriority: 1, orderable: false },
        { responsivePriority: 6, orderable: false },
        { responsivePriority: 3, orderable: false },
        { responsivePriority: 4, orderable: false },
        { responsivePriority: 5, orderable: true },  // Data ✅
        { responsivePriority: 7, orderable: true  },
        { responsivePriority: 2, orderable: false },
        { responsivePriority: 8, orderable: false },
      ],
      order: [[4, 'asc']],
      // 🔽 NOVO: chave de ordenação baseada na primeira data do texto
      columnDefs: [{
        targets: 4, // coluna "Data"
        render: function (data, type, row, meta) {
          // data é o HTML/texto da célula, ex: "14/09/2025" ou "14/09/2025 - 16/09/2025"
          if (type === 'sort') {
            const txt = (data || '').toString();
            const m = txt.match(/(\d{2}\/\d{2}\/\d{4})/); // pega a 1ª data
            if (m && m[1]) {
              const mom = moment(m[1], 'DD/MM/YYYY', true);
              if (mom.isValid()) return mom.format('YYYY-MM-DD'); // chave de ordenação estável
            }
            return txt; // fallback
          }
          return data; // display, filter etc. não mudam
        }
      }],
    });

    // Pesquisa global (DataTables)
    const onSearchGlobal = debounce(function (value) {
      datatable.search(value || '').draw();
    }, 250);

    $('#inputPesquisaGeral').on('input', function () {
      onSearchGlobal(this.value);
    });

    // opcional: Enter força a busca imediata
    $('#inputPesquisaGeral').on('keypress', function (e) {
      if (e.which === 13) {
        e.preventDefault();
        datatable.search(this.value || '').draw();
      }
    });

    // NOVO: checkbox "Somente futuras/atuais"
    $('#chkSomenteFuturas').on('change', function () {
      filtros.somenteFuturas = $(this).is(':checked');
      datatable.draw();
    });

    // Select2 do filtro de Salas
    $('#filtroSalas').select2({
      theme: 'bootstrap4',
      placeholder: 'Selecione uma ou mais salas',
      width: '100%',
      allowClear: true,
    });

    // Propaga sala selecionada
    $('#filtroSalas').on('change', function () {
      filtros.salaIds = ($(this).val() || []).map(String);
      datatable.draw();
    });

    // Se veio salaId do backend, aplica
    const salaIdInicial = "{{salaId}}";
    if (salaIdInicial) {
      $('#filtroSalas').val([salaIdInicial]).trigger('change');
      filtros.salaIds = [String(salaIdInicial)];
      datatable.draw();
    }

    // Toggle Mais/Menos filtros
    $('#btnToggleMaisFiltros').on('click', function () {
      const box = document.getElementById('maisFiltros');
      const isHidden = box.style.display === 'none';
      box.style.display = isHidden ? 'block' : 'none';
      this.textContent = isHidden ? 'Menos filtros' : 'Mais filtros';
    });

    // Inicialização dos datetimepickers (se sua stack usa Tempus Dominus/Moment em AdminLTE)
    try {
      // Datas
      $('#filtroDataIni').datetimepicker({
        locale: 'pt-br',useCurrent: false,
        format: 'L', allowInputToggle: true,
        buttons: {
          showToday: true,
          showClear: true,   // 👈 habilita o botão de limpar
        }});
      $('#filtroDataFim').datetimepicker({
        locale: 'pt-br',useCurrent: false,
        format: 'L', allowInputToggle: true,
        buttons: {
          showToday: true,
          showClear: true,   // 👈 habilita o botão de limpar
        }});

      // Vincula limites
      $("#filtroDataIni").on("change.datetimepicker", function (e) {
        $('#filtroDataFim').datetimepicker('minDate', e.date);
      });
      $("#filtroDataFim").on("change.datetimepicker", function (e) {
        $('#filtroDataIni').datetimepicker('maxDate', e.date);
      });

      // Horas
      $('#filtroHoraIni').datetimepicker({ format: 'LT',useCurrent: false,
        locale: 'pt-br', allowInputToggle: true,
        buttons: {
          showToday: true,
          showClear: true,   // 👈 habilita o botão de limpar
        }});
      $('#filtroHoraFim').datetimepicker({ format: 'LT', useCurrent: false,
        locale: 'pt-br', allowInputToggle: true,
        buttons: {
          showToday: true,
          showClear: true,   // 👈 habilita o botão de limpar
        }});

      // Eventos de alteração -> atualiza filtros + draw
      $('#filtroDataIni').on('change.datetimepicker', function (e) {
        filtros.dataIni = e.date ? e.date.toDate() : null;
        datatable.draw();
      });
      $('#filtroDataFim').on('change.datetimepicker', function (e) {
        filtros.dataFim = e.date ? e.date.toDate() : null;
        datatable.draw();
      });
      $('#filtroHoraIni').on('change.datetimepicker', function (e) {
        const m = e.date ? e.date.format('HH:mm') : null;
        filtros.horaIniMin = m ? onlyTimeToMinutes(m) : null;
        datatable.draw();
      });
      $('#filtroHoraFim').on('change.datetimepicker', function (e) {
        const m = e.date ? e.date.format('HH:mm') : null;
        filtros.horaFimMin = m ? onlyTimeToMinutes(m) : null;
        datatable.draw();
      });
    } catch(err) {
      console.warn('Datetimepicker não inicializado:', err);
    }

    // Botão limpar
    $('#btnLimparFiltros').on('click', function () {
      // salas
      $('#filtroSalas').val(null).trigger('change');
      filtros.salaIds = [];

      $('#inputPesquisaGeral').val('');
      $('#chkSomenteFuturas').prop('checked', false);
      filtros.somenteFuturas = false;

      // datas
      try {
        $('#filtroDataIni').datetimepicker('clear');
        $('#filtroDataFim').datetimepicker('clear');
        $('#filtroHoraIni').datetimepicker('clear');
        $('#filtroHoraFim').datetimepicker('clear');
      } catch(_) {
        // fallback se não houver datetimepicker
        $('#filtroDataIni input').val('');
        $('#filtroDataFim input').val('');
        $('#filtroHoraIni input').val('');
        $('#filtroHoraFim input').val('');
      }
      filtros.dataIni = null;
      filtros.dataFim = null;
      filtros.horaIniMin = null;
      filtros.horaFimMin = null;

      datatable.search('').columns().search('').draw();
    });
  });

  // Exclusão via AJAX (inalterado)
  let reservaIdParaExcluir = null;
  function addLink(event) {
    reservaIdParaExcluir = event.target.id;
    document.getElementById("tituloModal").innerHTML = "Deseja realmente excluir a Reserva da Sala?";
    $("#removerUsuario").modal("show");
  }
  async function deleteUserAjax() {
    if (!reservaIdParaExcluir) return;
    $.ajax({
      url: `/reservas/excluir/${reservaIdParaExcluir}`,
      method: "POST",
      success: function () {
        $("#removerUsuario").modal("hide");
        toastr.success("Reserva excluída com sucesso!");
        const $row = $(`a.fa-trash#${reservaIdParaExcluir}`).closest('tr');
        datatable.row($row).remove().draw(false);
      },
      error: function () {
        $("#removerUsuario").modal("hide");
        toastr.error("Ocorreu um erro ao excluir a reserva.");
      }
    });
  }
</script>

