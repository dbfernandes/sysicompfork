{{> header}}
{{> sidebar module='reservas' page='reservas-gerenciar'}}

{{#section "head"}}
  <!-- Select2 -->
  <link rel="stylesheet" href="/script-adminlte/plugins/select2/css/select2.min.css" />
  <link rel="stylesheet" href="/script-adminlte/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css" />
{{/section}}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
          <div class="d-flex flex-row w-full mb-3 align-items-center flex-wrap justify-content-between"  style="gap: 8px; white-space: nowrap;">
            <div>
              <h1>Lista de Reservas</h1>
            </div>
            <div>
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
                <li class="breadcrumb-item active">Listagem de Reservas</li>
              </ol>
            </div>
          </div>
            <div class="row mb-2">
                <div class="col-sm-2 col-md-3 col-lg-2 min-width-button">
                    <a type="button" class="btn btn-block btn-primary" href="/reservas/adicionar">
                        <i class="fas fa-user-plus color-white"></i>
                        Reservar Sala
                    </a>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                      <div class="card-header">
                        <div class="form-row align-items-end" style="gap: 8px;">
                          <div class="col-12 col-md-6 col-lg-4">
                            <label for="filtroSalas" class="mb-1">Filtrar por Sala(s)</label>
                            <select id="filtroSalas" class="form-control" multiple>
                              {{#each salasGrouped}}
                                <optgroup label="{{@key}}">
                                  {{#each this}}
                                    <option value="{{id}}" {{#if (eq ../../salaId id)}}selected{{/if}}>{{nome}} - {{bloco}} - {{andar}}º andar</option>
                                  {{/each}}
                                </optgroup>
                              {{/each}}
                            </select>
                            <small class="text-muted">Selecione uma ou mais salas para filtrar</small>
                          </div>

                          <div class="col-auto">
                            <button id="btnLimparFiltros" type="button" class="btn btn-outline-secondary">
                              Limpar filtros
                            </button>
                          </div>
                        </div>
                      </div>

                        <!-- /.card-header -->
                        <div class="card-body" style="overflow-x:auto;">
                            <table id="example2" class="table table-striped table-bordered table-hover w-100">
                                <thead>
                                    <tr style="text-align: center;">
                                        <th style="text-align: center;">Sala</th>
                                        <th style="text-align: center;">Solicitante</th>
                                        <th style="text-align: center;">Atividade</th>
                                        <th style="text-align: center;">Tipo</th>
                                        <th style="text-align: center;">Data</th>
                                        <th style="text-align: center;">Horário</th>
                                        <th style="text-align: center;">Dias da semana</th>
                                        <th style="text-align: center;">Ativa?</th>
                                        <th style="text-align: center;"> </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each reservas}}
                                      <tr style="text-align: center;" data-sala-id="{{sala.id}}">
                                        <td> {{sala.nome}} - {{sala.bloco}} - {{sala.andar}} andar </td>
                                        <td> {{usuario.nomeCompleto}} </td>
                                        <td> {{atividade}} </td>
                                        <td> {{tipo}} </td>
                                        <td> {{dataInicio}}
                                          {{#if (eq dataInicio dataFim)}}

                                          {{else}}
                                            - {{dataFim}}
                                          {{/if}}
                                          </td>
                                        <td> {{horaInicio}} - {{horaFim}} </td>
                                        {{#if dias}}

                                        <td>{{dias}}</td>
                                        {{else}}
                                        <td> - </td>
                                        {{/if}}
                                        <td>
                                            {{#if terminou}}
                                            Sim
                                            {{else}}
                                            Não
                                            {{/if}}
                                        </td> <!-- Nova célula -->

                                        <td style="text-align: center;">

                                          <a class='fa fa-calendar' style="color: blue;" title="Visualizar"
                                             href="/salas/detalhes/{{sala.id}}?reservaId={{id}}">
                                          </a> &nbsp
                                          <a class='fa fa-solid fa-pen' style="color: blue;" title="Editar"
                                             href="/reservas/editar/{{id}}">
                                          </a> &nbsp
                                          <a class="fa fa-solid fa-trash" id="{{id}}" data-toggle="modal" title="Remover"
                                             style="color: red;" data-target="#removerUsuario"
                                             onclick="addLink(event)" href="#">
                                          </a>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>

                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.col -->
        </div>
        <!-- /.row -->
        <!-- /.container-fluid -->
    </section>
    <!-- /.content -->

    <div class="modal fade" id="removerUsuario" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="tituloModal"></h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-footer">
                    <a type="button" class="btn btn-secondary color-white" data-dismiss="modal">Não</a>
                    <a id="deleteButton" type="button" class="btn btn-warning color-white"
                        onclick="deleteUserAjax()">Sim</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="/script-adminlte/plugins/select2/js/select2.full.min.js"></script>

<script>
  toastr.options = {
    "closeButton": true,
    "debug": false,
    "newestOnTop": false,
    "progressBar": true,
    "positionClass": "toast-top-right",
    "preventDuplicates": true,
    "showDuration": "1000",
    "hideDuration": "1000",
    "timeOut": "5000",
    "extendedTimeOut": "1000",
    "showEasing": "swing",
    "hideEasing": "linear",
    "showMethod": "fadeIn",
    "hideMethod": "fadeOut"
  };

  let datatable = null;
  let filtroSalaIdsSelecionadas = [];

  // define o filtro, mas só registra quando DataTables estiver disponível
  function filtroPorSala(settings, data, dataIndex) {
    if (settings.nTable.id !== 'example2') return true;   // só nessa tabela
    if (!filtroSalaIdsSelecionadas.length) return true;   // sem filtro => tudo

    const rowNode = settings.aoData[dataIndex].nTr;       // TR real
    const salaId = rowNode.getAttribute('data-sala-id');
    return filtroSalaIdsSelecionadas.includes(String(salaId));
  }

  document.addEventListener('DOMContentLoaded', function () {
    // <<< GARDA: só registra se DataTables estiver carregado
    if ($.fn && $.fn.dataTable && $.fn.dataTable.ext && $.fn.dataTable.ext.search) {
      $.fn.dataTable.ext.search.push(filtroPorSala);
    } else {
      console.warn('DataTables ainda não disponível. Registrando filtro após init.');
      // fallback: registra no primeiro init (ainda funciona, pois você inicializa a tabela logo abaixo)
      $(document).one('init.dt', function () {
        if ($.fn.dataTable.ext && $.fn.dataTable.ext.search) {
          $.fn.dataTable.ext.search.push(filtroPorSala);
        }
      });
    }

    // Agora sim, inicializa a tabela
    datatable = $('#example2').DataTable({
      language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
      responsive: true,
      columns: [
        { responsivePriority: 1, orderable: false },
        { responsivePriority: 6, orderable: false },
        { responsivePriority: 3, orderable: false },
        { responsivePriority: 4, orderable: false },
        { responsivePriority: 5, orderable: true  },
        { responsivePriority: 7, orderable: true  },
        { responsivePriority: 2, orderable: false },
        { responsivePriority: 8, orderable: false },
        { responsivePriority: 9, orderable: false },
      ],
      order: [[7, 'desc']]
    });

    // Select2 (mantém seu código)
    $('#filtroSalas').select2({
      theme: 'bootstrap4',
      placeholder: 'Selecione uma ou mais salas',
      width: '100%',
      allowClear: true,
    });

    $('#filtroSalas').on('change', function () {
      filtroSalaIdsSelecionadas = ($(this).val() || []).map(String);
      datatable.draw();
    });
    // Se veio uma salaId do
    // backend, aplica no filtro
    const salaIdInicial = "{{salaId}}"; // Handlebars injeta string ou vazio
    if (salaIdInicial) {
      $('#filtroSalas').val([salaIdInicial]).trigger('change');
      filtroSalaIdsSelecionadas = [String(salaIdInicial)];
      datatable.draw();
    }

    $('#btnLimparFiltros').on('click', function () {
      $('#filtroSalas').val(null).trigger('change');
      filtroSalaIdsSelecionadas = [];
      datatable.search('').columns().search('').draw();
    });
  });

  // Exclusão via AJAX (mantida)
  let reservaIdParaExcluir = null;
  function addLink(event) {
    reservaIdParaExcluir = event.target.id;
    document.getElementById("tituloModal").innerHTML = "Deseja realmente excluir a Reserva da Sala?";
    $("#removerUsuario").modal("show");
  }
  async function deleteUserAjax() {
    if (!reservaIdParaExcluir) return;
    $.ajax({
      url: `/reservas/excluir/${reservaIdParaExcluir}`,
      method: "POST",
      success: function () {
        $("#removerUsuario").modal("hide");
        toastr.success("Reserva excluída com sucesso!");
        const $row = $(`a.fa-trash#${reservaIdParaExcluir}`).closest('tr');
        datatable.row($row).remove().draw(false);
      },
      error: function () {
        $("#removerUsuario").modal("hide");
        toastr.error("Ocorreu um erro ao excluir a reserva.");
      }
    });
  }
</script>


{{> footer}}