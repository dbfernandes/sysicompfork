{{> header}}
{{> sidebar module='reservas' page='reservas-adicionar'}}
{{#section "head"}}
  <link rel="stylesheet" href="/script-adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/toastr/toastr.min.css"/>
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
{{/section}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
      <div class="container-fluid">
        <div class="d-flex flex-row w-full mb-3 align-items-center flex-wrap justify-content-between"  style="gap: 8px; white-space: nowrap;">
          <div>
            <h1>Adicionar Reserva</h1>
          </div>
          <div>
            <ol class="breadcrumb ">
              <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
              <li class="breadcrumb-item"><a href="/reservas/gerenciar">Listagem de reservas</a></li>
              <li class="breadcrumb-item active">Adicionar</li>
            </ol>
          </div>
        </div>
        <div class="row mb-2">
          <div class="col-sm-4 col-md-3 col-lg-1 min-width-button">
            <a type="button" class="btn btn-warning color-white" href="/reservas/gerenciar">
              <i class="fa fa-arrow-left color-white"></i>
              Voltar
            </a>
          </div>
        </div>
      </div><!-- /.container-fluid -->
    </section>

    <section class="content">
      <div class="row">
        <div class="col">
          <div class="card card-primary" style="width: 50%;">
            <div class="card-header">
              <h3 class="card-title"><b>Dados da Reserva</b></h3>
              <!-- Ícone de expandir -->
              <button class="expand-btn"
                      style="position: absolute; top: 10px; right: 10px; background: none; border: none; outline: none;">
                <i class="fas fa-expand" style="color:white"></i>
              </button>
            </div>

            <div class="container-fluid">
              <form id="formAdicionarSala" method="POST" action="/reservas/adicionar">
                <input type="hidden" id="usuarioId" name="usuarioId" value="{{usuarioId}}" />
                <div class="card-body ">
                  <div class="row">
                    <div class="form-group col-md-6 ">
                      <label for="atividade">
                        <span style="color: #FF0000; ">*</span> Atividade:
                      </label>
                      <input type="text" class="form-control" id="atividade" name="atividade"
                             placeholder="Ex: Seminários ">
                    </div>
                    <div class="form-group col-md-6 ">
                      <label for="tipo">
                        <span style="color: #FF0000; ">*</span> Tipo:
                      </label>
                      <select class="form-control" id="tipo" name="tipo" required>
                        <option value="Aula">Aula</option>
                        <option value="Defesa">Defesa</option>
                        <option value="Exame">Exame</option>
                        <option value="Reunião">Reunião</option>
                      </select>
                    </div>
                  </div>
                  <div class="form-group ">
                    <label for="salaId">
                      <span style="color: #FF0000; ">*</span> Sala:
                    </label>
                    <select class="form-control" id="salaId" name="salaId" required >
                      {{#each salas}}
                        <option value="{{id}}"  {{#if (eq id ../salaId)}}selected{{/if}}>{{nome}} - {{bloco}} - {{andar}}</option>
                        <di>{{salas}}</di>
                      {{/each}}
                    </select>
                  </div>

                  <div class="row">
                    <div class="form-group ">
                      <label for="multiple">
                        <span style="color: #FF0000; "></span> &nbsp&nbsp &nbspEssa Reserva se repete?
                        &nbsp&nbsp
                      </label>
                    </div>
                    <div class="form-group ">
                      <input type="checkbox" name="multiple" data-bootstrap-switch
                             data-off-color="danger" checked data-on-color="success" data-on-text="Sim"
                             data-off-text="Não" value="1" id="multiple">
                    </div>
                  </div>
                  <div class="form-group " id="conditionalInput">
                    <label class="control-label" id="dia" for="candidato-nome">
                      <span style="color: #FF0000; "> &nbsp&nbsp</span>
                      <b>Dias da semana:</b>
                    </label>
                    <div class="d-flex flex-row flex-wrap align-items-start">
                      <div class="icheck-primary">
                        <input type="checkbox" id="segunda" name="dia" value="Segunda">
                        <label class="checkbox-inline ml-2" for="segunda">
                          Segunda
                        </label>
                      </div>
                      <div class="icheck-primary">
                        <input type="checkbox" id="terca" name="dia" value="Terça">
                        <label class="checkbox-inline ml-4" for="terca">
                          Terça
                        </label>
                      </div>
                      <div class="icheck-primary">
                        <input type="checkbox" id="quarta" name="dia" value="Quarta">
                        <label class="checkbox-inline ml-4" for="quarta">
                          Quarta
                        </label>
                      </div>
                      <div class="icheck-primary">
                        <input type="checkbox" id="quinta" name="dia" value="Quinta">
                        <label class="checkbox-inline ml-4" for="quinta">
                          Quinta
                        </label>
                      </div>
                      <div class="icheck-primary">
                        <input type="checkbox" id="sexta" name="dia" value="Sexta">
                        <label class="checkbox-inline ml-4" for="sexta">
                          Sexta
                        </label>
                      </div>
                      <div class="icheck-primary">
                        <input type="checkbox" id="sabado" name="dia" value="Sábado">
                        <label class="checkbox-inline ml-4" for="sabado">
                          Sábado
                        </label>
                      </div>
                    </div>
                  </div>
                  <div class="row">
                    <div class="form-group col-md-6">
                      <label for="dataInicio" id="dataInicioLabel">
                        <span style="color: #FF0000; ">*</span> Data Inicial:
                      </label>
                      <div class="input-group date" data-target-input="nearest">
                        <div class="input-group date" id="datetimepicker2" data-target-input="nearest">
                          <input type="text" name="dataInicio" id="dataInicio" placeholder="dd/mm/YYYY"
                                 data-target="#datetimepicker2" required class="form-control datetimepicker-input">
                          <div class="input-group-append" data-target="#datetimepicker2" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                          </div>
                        </div>

                        <div class="invalid-feedback" id="dataInicioError">Data inválida. Por favor, insira datas válidas.</div>
                      </div>
                    </div>

                    <div class="form-group col-md-6" id="conditionalInput2">
                      <label for="dataFim">
                        <span style="color: #FF0000; ">*</span> Data Término:
                      </label>
                      <div class="input-group date" data-target-input="nearest">
                        <div class="input-group date" id="datepickerfim" data-target-input="nearest">
                          <input type="text" class="form-control datetimepicker-input" name="dataFim"  id="dataFim"
                                 data-target="#datepickerfim" placeholder="dd/mm/yyyy">
                          <div class="input-group-append" data-target="#datepickerfim" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="row">
                    <div class="form-group  col-md-6 ">
                      <label for="horaInicio">
                        <span style="color: #FF0000; ">*</span> Hora Inicial:
                      </label>
                      <div class="input-group date" data-target-input="nearest">
                        <div class="input-group date" id="timepickerinicio" data-target-input="nearest">
                          <input type="text" class="form-control datetimepicker-input" id="horaInicio" name="horaInicio"
                                 data-target="#timepickerinicio" placeholder='HH:mm'>
                          <div class="input-group-append" data-target="#timepickerinicio" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fa fa-clock"></i></div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="form-group col-md-6 ">
                      <label for="horaFim">
                        <span style="color: #FF0000; ">*</span> Hora Término:
                      </label>
                      <div class="input-group date" data-target-input="nearest">
                        <div class="input-group date" id="timepickerfim" data-target-input="nearest">
                          <input type="text" class="form-control datetimepicker-input"  id="horaFim" name="horaFim"
                                 data-target="#timepickerfim" placeholder='HH:mm'>
                          <div class="input-group-append" data-target="#timepickerfim" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fa fa-clock"></i></div>
                          </div>
                        </div>
                      </div>
                    </div>

                  </div>
                </div>

                <div class="card-footer pr-0">
                  <div style="margin-right: auto;" class="d-flex justify-content-end">
                    <button id="btn-create" type="submit" class="btn btn-success float-right">
                      Adicionar Reserva
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
        <!-- /.card -->
      </div>
    </section>
</div>

<script src="/script-adminlte/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
<script src="/script-adminlte/plugins/moment/locale/pt-br.js"></script>
<script src="/script-adminlte/plugins/toastr/toastr.min.js"></script>

<script>
    toastr.options = {
        "closeButton": true,
        "debug": false,
        "newestOnTop": false,
        "progressBar": true,
        "positionClass": "toast-top-right",
        "preventDuplicates": true,
        "showDuration": "300",
        "hideDuration": "1000",
        "timeOut": "5000",
        "extendedTimeOut": "1000",
        "showEasing": "swing",
        "hideEasing": "linear",
        "showMethod": "fadeIn",
        "hideMethod": "fadeOut"
    }

    $(document).ready(function () {
        const dataInicioLabel = document.querySelector('#dataInicioLabel');
        const conditionalInput = document.getElementById('conditionalInput');
        const conditionalInput2 = document.getElementById('conditionalInput2');
        const today = moment().startOf('day');

        // Se já tinha instância criada antes, destrua para evitar conflito
        $('#datetimepicker2').data('datetimepicker')?.destroy();
        $('#datepickerfim').data('datetimepicker')?.destroy();

        $('#datetimepicker2').datetimepicker({
          locale: 'pt-br',
          format: 'L',
          useCurrent: false,
          allowInputToggle: true,
          minDate: today
        });
        $('#datepickerfim').datetimepicker({
          locale: 'pt-br',
          format: 'L',
          useCurrent: false,
          allowInputToggle: true,
          minDate: today
        });
        $('#timepickerinicio').datetimepicker({
          locale: 'pt-br',
          format: 'LT',
          stepping: 5,
          useCurrent: false,
          allowInputToggle: true,
        });
        $('#timepickerfim').datetimepicker({
          locale: 'pt-br',
          format: 'LT',
          stepping: 5,
          useCurrent: false,
          allowInputToggle: true,
        });

        $('#datetimepicker2').on('change.datetimepicker', function (e) {
          $('#datepickerfim').datetimepicker('minDate', e.date);
        });
        $('#datepickerfim').on('change.datetimepicker', function (e) {
          $('#datetimepicker2').datetimepicker('maxDate', e.date);
        });

        $('#timepickerinicio').on('change.datetimepicker', function (e) {
          const hi = $('#horaInicio').val();
          const hf = $('#horaFim').val();

          if (hi && hf && hi >= hf) {
            // se igual/maior, empurra fim para +5 min
            const m = moment(hi, 'HH:mm').add(5, 'minutes');
            $('#timepickerfim').datetimepicker('date', m);
          }
        });

        // Inicialize o switch
        $("input[data-bootstrap-switch]").each(function () {
            $(this).bootstrapSwitch('state', $(this).is(':checked'));
        });

        // lógica do switch
        $("#multiple").on('switchChange.bootstrapSwitch', function (event, state) {
            const multiple = $("#multiple").prop('checked');
            if (multiple) {
                dataInicioLabel.innerHTML = '<span style="color: #FF0000; ">*</span> Data Inicial:'
                conditionalInput.style.display = 'block';
                conditionalInput2.style.display = 'block';
            } else {
                dataInicioLabel.innerHTML = '<span style="color: #FF0000; ">*</span> Data:';
                conditionalInput.style.display = 'none';
                conditionalInput2.style.display = 'none';
            }
        });


      // Métodos custom:
      $.validator.addMethod("dateBR", function (value, element) {
        if (!value) return false;
        return moment(value, 'L', true).isValid();
      }, "Data inválida.");

      $.validator.addMethod("minToday", function (value, element) {
        if (!value) return false;
        const m = moment(value, 'L', true);
        return m.isValid() && !m.isBefore(moment().startOf('day'), 'day');
      }, "A data deve ser hoje ou posterior.");

      $.validator.addMethod("timeHHmm", function (value, element) {
        if (!value) return false;
        return moment(value, 'HH:mm', true).isValid();
      }, "Hora inválida.");

      $.validator.addMethod("greaterThanTime", function (value, element, selector) {
        const start = $(selector).val();
        if (!value || !start) return true; // outra regra marca required
        const mStart = moment(start, 'HH:mm', true);
        const mEnd   = moment(value, 'HH:mm', true);
        if (!mStart.isValid() || !mEnd.isValid()) return true;
        return mEnd.isAfter(mStart);
      }, "A hora de término deve ser posterior à de início.");

      $.validator.addMethod("diasRequiredWhenRepeat", function (_value, element) {
        const repete = $("#multiple").prop("checked");
        if (!repete) return true;
        const qtd = ['#segunda','#terca','#quarta','#quinta','#sexta','#sabado']
          .filter(id => $(id).prop("checked")).length;
        return qtd > 0;
      }, "Escolha ao menos um dia da semana.");

      // Aplique uma classe nas checkboxes para validar em grupo
      $('#segunda,#terca,#quarta,#quinta,#sexta,#sabado').addClass('dia-semana');
      $("#formAdicionarSala").validate({
        ignore: [], // valida inputs escondidos (dataFim quando mostrar)
        rules: {
          atividade: { required: true },
          tipo:      { required: true },
          salaId:    { required: true },
          dataInicio:{ required: true, dateBR: true, minToday: true },
          dataFim:   {
            required: {
              depends: function () { return $("#multiple").prop("checked"); } // repete?
            },
          },
          horaInicio:{ required: true, timeHHmm: true },
          horaFim:   { required: true, timeHHmm: true, greaterThanTime: "#horaInicio" },
          // truque: valide o grupo de dias com um input “fantasma” (o próprio label id="dia")
          dia: { diasRequiredWhenRepeat: true }
        },
        messages: {
          atividade: "Informe a atividade.",
          tipo: "Informe o tipo.",
          salaId: "Escolha a sala.",
          dataInicio: { required: "Informe a data inicial." },
          dataFim:    { required: "Informe a data de término." },
          horaInicio: { required: "Informe a hora inicial." },
          horaFim:    { required: "Informe a hora término." }
        },
        errorElement: "div",
        errorClass: "invalid-feedback",
        highlight: function (el) {
          $(el).addClass("is-invalid");
        },
        unhighlight: function (el) {
          $(el).removeClass("is-invalid");
        },
        errorPlacement: function (error, element) {
          if (element.closest(".form-group").length) {
            element.closest(".form-group").append(error);
          } else {
            error.insertAfter(element);
          }
        },

        // === SUBMIT AJAX com checagem de conflito ===
        submitHandler: async function (form, e) {
          e.preventDefault();
          const btnSave = $("#btn-create");
          btnSave.find("span").prop("hidden", false);
          btnSave.prop("disabled", true);
          const salaId = '{{salaId}}'
          try {
            const dados = pegaDados();
            // tudo ok → envia via AJAX
            await $.ajax({
              url: $(form).attr("action"),
              method: "POST",
              data: dados,
              dataType: "json" // ajuste conforme seu backend (pode ser html)
            });
            // sucesso: toast + redireciona
            localStorage.setItem("toastMessage", "Reserva adicionada com sucesso!");
            localStorage.setItem("toastType", "success");
            // // redirecione (ajuste a rota se quiser voltar para a sala específica)
            if(salaId === dados.salaId){
              window.location.href = `/salas/detalhes/${salaId}`;
            } else {
              window.location.href = "/reservas/gerenciar";
            }
          } catch (err) {
            if(err.status === 409) {
              if(err.responseJSON && err.responseJSON.message) {
                toastr.error(err.responseJSON.message);
              } else {
                toastr.error("Existe um conflito com as reservas existentes nesse horário!");
              }
              $("#dataInicio, #dataFim, #horaInicio, #horaFim").addClass("is-invalid");
              $("#dataInicioError").text("Existe um conflito com as reservas existentes nesse horário.");
            } else {

              toastr.error("Não foi possível salvar a reserva. Tente novamente.");
            }
          } finally {
            btnSave.find("span").prop("hidden", true);
            btnSave.prop("disabled", false);
          }
          return false;
        }
      });
    });

    function diasSemana() {
      const dias = [];

      if ($("#segunda").prop("checked")) dias.push("Segunda");
      if ($("#terca").prop("checked"))   dias.push("Terça");
      if ($("#quarta").prop("checked"))  dias.push("Quarta");
      if ($("#quinta").prop("checked"))  dias.push("Quinta");
      if ($("#sexta").prop("checked"))   dias.push("Sexta");
      if ($("#sabado").prop("checked"))  dias.push("Sábado");

      return dias; // ex.: ["Segunda", "Quarta", "Sexta"]
    }

    function pegaDados() {
      const multiple = $("#multiple").prop("checked");
      const salaId = $("#salaId").val();

      const pickerInicio = $('#datetimepicker2').data("datetimepicker");
      const pickerFim    = $('#datepickerfim').data("datetimepicker");

      // Usa o moment interno do picker
      const mInicio = pickerInicio && pickerInicio.date();
      const mFim    = pickerFim && pickerFim.date();

      // Converte para YYYY-MM-DD (ou null se vazio)
      const dataInicio = mInicio ? mInicio.format("YYYY-MM-DD") : null;
      // Se não repete, dataFim = dataInicio
      const dataFim    = multiple ? (mFim ? mFim.format("YYYY-MM-DD") : null) : dataInicio;

      const horaInicio = $("#horaInicio").val() + ":00";
      const horaFim = $("#horaFim").val() + ":00";
      const tipo = $("#tipo").val()
      const atividade = $("#atividade").val();
      const usuarioId = $("#usuarioId").val()
      let dia = diasSemana()

      //verificacao do caso data multiple
      if (!multiple) {
        const valor = document.getElementById("dataInicio").value; // ex: "27/09/2025"
        const [diaStr, mesStr, anoStr] = valor.split("/");
        const diaNum = parseInt(diaStr, 10);
        const mesNum = parseInt(mesStr, 10) - 1; // mês começa em 0 no JS
        const anoNum = parseInt(anoStr, 10);

        const data = new Date(anoNum, mesNum, diaNum);
        const diaDaSemana = data.getDay();

        const nomesDosDias = ["Domingo","Segunda","Terça","Quarta","Quinta","Sexta","Sábado"];
        dia = nomesDosDias[diaDaSemana];
      }

      return {
        salaId,
        dataInicio,
        atividade,
        dataFim,
        horaInicio,
        horaFim,
        dia,
        tipo,
        usuarioId
      };
    }

    document.querySelector('.expand-btn').addEventListener('click', function () {
      const card = document.querySelector('.card');

      if (card.style.width !== "100%") {
        card.style.width = "100%";
      } else {
        card.style.width = "50%"; // ou qualquer tamanho padrão que você deseja
      }
    });
</script>

{{> footer}}