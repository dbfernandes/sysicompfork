  <!-- Main content -->
  <section class="content">
    <div class="container-fluid">

      <!-- Cards -->
      <div class="row">
        {{#if processos.length}}
          {{#each processos}}
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 d-flex align-items-stretch">
              <div class="card card-outline m-1 w-100" data-processo-id="{{id}}">
                <div class="card-header">
                  <h3 class="card-title text-truncate" title="{{titulo}}">{{titulo}}</h3>
                </div>

                <div class="card-body p-2">
                  <div class="mb-2" style="height: 140px; overflow: hidden; border-radius: 6px; background: #f8f9fa;">
                    {{#if previewPath}}
                      <img src="/processos/{{id}}/preview" alt="preview" class="img-fluid" style="width:100%; height: 100%;object-fit: contain;"/>
                    {{else}}
                      <div class="d-flex h-100 w-100 align-items-center justify-content-center text-muted">
                        <i class="far fa-image mr-1"></i> sem preview
                      </div>
                    {{/if}}
                  </div>

                  <p class="text-muted small mb-2" style="min-height: 40px;">
                    {{descricao }}
                  </p>

                  <!-- Tags -->
                  <div class="mb-2">
                    {{#if tags.length}}
                      {{#each tags}}
                        <span class="badge badge-info mr-1" title="{{this.nome}}">{{this.nome}}</span>
                      {{/each}}
                    {{else}}
                      <span class="text-muted small">Sem tags</span>
                    {{/if}}
                  </div>

                  <dl class="row mb-0 small">
                    <dt class="col-5">Criado por:</dt>
                    <dd class="col-7 text-truncate" title="{{criadoPor.nomeCompleto}}">{{criadoPor.nomeCompleto}}</dd>

                    <dt class="col-5">Atualizado:</dt>
                    <dd class="col-7">{{dataToLocaleString updatedAt}}</dd>
                  </dl>
                </div>

                <div class="card-footer w-full d-flex justify-content-between">
                  <a href="/processos/{{id}}" class="btn  btn-outline-primary">
                    <i class="fas fa-eye"></i> Abrir
                  </a>
                  <div>
<!--                    <a href="/processos/{{id}}/editar" class="btn  btn-outline-secondary" title="Editar">-->
<!--                      <i class="fas fa-edit"></i>-->
<!--                    </a>-->
                    <a href="/processos/{{id}}/xml" download class="btn btn-outline-info" title="Baixar XML">
                      <i class="fas fa-file-download"></i>
                    </a>
                    <a href="/processos/{{id}}/preview" download class="btn btn-outline-primary" title="Baixar SVG">
                      <i class="fas fa-file-image"></i>
                    </a>
                    <button
                      data-id="{{id}}"
                      data-title="{{titulo}}"
                      class="btn btn-outline-danger js-delete"
                      title="Excluir"
                    >
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          {{/each}}
        {{else}}
          <div class="col-12">
            <div class="alert alert-light border">
              Nenhum processo encontrado.
            </div>
          </div>
        {{/if}}
      </div>

      <!-- Paginação -->
