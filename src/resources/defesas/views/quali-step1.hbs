{{> header}}
{{> sidebar module='defesas' page='defesas-gerenciar'}}

<div class="content-wrapper">
  <!-- Cabeçalho -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Qualificação — Etapa 1</h1>
          <small class="text-muted">Informações iniciais</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Qualificação — Etapa 1</li>
          </ol>
        </div>
      </div>

      <!-- Stepper simples -->
      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 14%;" aria-valuenow="14" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span><strong>1.</strong> Dados iniciais</span>
            <span>2. Local</span>
            <span>3. Trabalho</span>
            <span>4. Presidente</span>
            <span>5. Membros</span>
            <span>6. Suplentes</span>
            <span>7. Proposta/Artigos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Conteúdo -->
  <section class="content">
    <div class="container-fluid">
      <!-- Mensagens -->
      {{#if errors}}
        <div class="alert alert-danger">
          <ul class="mb-0">
            {{#each errors}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}
      {{#if messages}}
        <div class="alert alert-success">
          <ul class="mb-0">
            {{#each messages}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}

      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Informações da qualificação</h3>
            </div>

            <form id="formStep1" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step1">

              <div class="card-body">
                <div class="form-group">
                  <label for="tituloTrabalho">Título do trabalho <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="tituloTrabalho" name="tituloTrabalho"
                         maxlength="500" placeholder="Digite o título do trabalho"
                         value="{{defesa.tituloTrabalho}}">
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Tipo / Nível</label>
                    <div>
                      <span class="badge badge-info mr-2">{{defesa.tipo}}</span>
                      <span class="badge badge-secondary">{{defesa.nivel}}</span>
                    </div>
                    <small class="form-text text-muted">Definido na criação da defesa.</small>
                  </div>

                  <div class="form-group col-md-6">
                    <label for="dataHora">Data e hora da qualificação <span class="text-danger">*</span></label>
                    <!-- Usamos datetime-local para UX; converteremos para ISO no submit -->
                    <input type="datetime-local" class="form-control"
                           id="dataHoraLocal" data-iso="{{defesa.dataHora}}">
                    <input type="hidden" name="dataHora" id="dataHora"> <!-- receberá o ISO -->
                    <small class="form-text text-muted">Ajuste a data/hora no fuso local.</small>
                  </div>
                </div>

                <div class="form-group">
                  <label class="d-block">Modalidade <span class="text-danger">*</span></label>
                  <div class="custom-control custom-radio d-inline-block mr-3">
                    <input class="custom-control-input" type="radio" id="modalPres" name="modalidade" value="PRESENCIAL"
                           {{#ifEqual defesa.modalidade 'PRESENCIAL'}}checked{{/ifEqual}}>
                    <label for="modalPres" class="custom-control-label">Presencial</label>
                  </div>
                  <div class="custom-control custom-radio d-inline-block">
                    <input class="custom-control-input" type="radio" id="modalOn" name="modalidade" value="ONLINE"
                           {{#ifEqual defesa.modalidade 'ONLINE'}}checked{{/ifEqual}}>
                    <label for="modalOn" class="custom-control-label">Online</label>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Nome do(a) candidato(a)</label>
                    <input type="text" class="form-control" value="{{candidatoNome}}">
                  </div>
                  <div class="form-group col-md-6">
                    <label>Nome do(a) orientador(a)</label>
                    <input type="text" class="form-control" value="{{orientadorNome}}" >
                  </div>
                </div>

                <div class="form-group">
                  <div class="form-group col-md-6">
                    <label>Nome do(a) coorientador(a) (se houver)</label>
                    <input type="text" class="form-control" value="{{orientadorNome}}" >
                  </div>

                  <small class="form-text text-muted">Opcional.</small>
                </div>

              </div><!-- ./card-body -->

              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/listar" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>
                  <button type="submit" class="btn btn-primary" name="action" value="next">
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <!-- Lateral: dicas -->
        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Requisitos desta etapa</h3>
            </div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Título do trabalho</li>
                <li>Data e hora da qualificação</li>
                <li>Modalidade (Presencial/Online)</li>
                <li>Coorientador é opcional</li>
              </ul>
              <hr>
              <p class="text-muted mb-0">
                As demais informações (local, resumo, banca etc.) serão preenchidas nas próximas etapas.
              </p>
            </div>
          </div>
        </div>
      </div><!-- ./row -->
    </div><!-- ./container-fluid -->
  </section>
</div>

<script>
  // Helper: converte ISO -> valor aceitável por datetime-local
  function isoToLocalInputValue(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '';
    const off = d.getTimezoneOffset();
    const local = new Date(d.getTime() - off * 60000);
    return local.toISOString().slice(0, 16); // "YYYY-MM-DDTHH:mm"
  }

  // Preenche datetime-local a partir do ISO da defesa, se houver
  (function initDateInput() {
    const inputLocal = document.getElementById('dataHoraLocal');
    const hiddenIso  = document.getElementById('dataHora');
    const iso = inputLocal.getAttribute('data-iso');
    const val = isoToLocalInputValue(iso);
    if (val) inputLocal.value = val;

    // Ao submeter, converte de volta para ISO UTC
    document.getElementById('formStep1').addEventListener('submit', function(e) {
      const v = inputLocal.value; // "YYYY-MM-DDTHH:mm"
      if (v) {
        const d = new Date(v);
        // Normaliza para ISO em UTC (o backend espera ISO)
        hiddenIso.value = d.toISOString();
      } else {
        hiddenIso.value = '';
      }
    });
  })();
</script>

{{> footer}}
