{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}
{{#section "head"}}
  <!-- Select2 -->
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
{{/section}}
<div class="content-wrapper">
  <!-- Cabeçalho -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Qualificação — Etapa 1</h1>
          <small class="text-muted">Informações iniciais</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Qualificação — Etapa 1</li>
          </ol>
        </div>
      </div>

      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 14%;" aria-valuenow="14" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span><strong>1.</strong> Dados iniciais</span>
            <span>2. Local</span>
            <span>3. Trabalho</span>
            <span>4. Presidente</span>
            <span>5. Membros</span>
            <span>6. Suplentes</span>
            <span>7. Proposta/Artigos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Conteúdo -->
  <section class="content">
    <div class="container-fluid">
      <!-- Mensagens -->
      {{#if errors}}
        <div class="alert alert-danger">
          <ul class="mb-0">
            {{#each errors}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}
      {{#if messages}}
        <div class="alert alert-success">
          <ul class="mb-0">
            {{#each messages}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}

      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Informações da qualificação</h3>
            </div>

            <form id="formStep1" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step1">
              <div class="card-body">
                <div class="form-group">
                  <label for="tituloTrabalho">Título do trabalho <span class="text-danger">*</span></label>
                  <input
                    type="text"
                    class="form-control"
                    id="tituloTrabalho"
                    name="tituloTrabalho"
                    maxlength="191"
                    placeholder="Digite o título do trabalho"
                    value="{{defesa.tituloTrabalho}}"
                  >
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Tipo / Nível</label>
                    <div>
                      <span class="badge badge-info mr-2">{{defesa.tipo}}</span>
                      <span class="badge badge-secondary">{{defesa.nivel}}</span>
                    </div>
                    <small class="form-text text-muted">Definido na criação da defesa.</small>
                  </div>

                  <div class="form-group col-md-6">
                    <label for="dataHoraLocal">Data e hora da qualificação <span class="text-danger">*</span></label>
                    <input
                      type="datetime-local"
                      class="form-control"
                      id="dataHoraLocal"
                      name="dataHoraLocal"
                      data-iso="{{defesa.dataHora}}"
                    >
                    <input type="hidden" name="dataHora" id="dataHora">
                    <small class="form-text text-muted">Ajuste a data/hora no fuso local.</small>
                  </div>
                </div>

                <div class="form-group">
                  <label class="d-block">Modalidade <span class="text-danger">*</span></label>

                  <!-- radio-group para o errorPlacement funcionar -->
                  <div class="radio-group">
                    <div class="icheck-primary">
                      <input type="radio" id="modalPres" name="modalidade" value="PRESENCIAL"
                             {{#ifEqual defesa.modalidade 'PRESENCIAL'}}checked{{/ifEqual}}>
                      <label for="modalPres" >Presencial</label>
                    </div>
                    <div class="icheck-primary">
                      <input  type="radio" id="modalOn" name="modalidade" value="ONLINE"
                             {{#ifEqual defesa.modalidade 'ONLINE'}}checked{{/ifEqual}}>
                      <label for="modalOn">Online</label>
                    </div>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label for="candidatoNome">Candidato(a) <span class="text-danger">*</span></label>
                    <input
                      type="text"
                      class="form-control"
                      id="candidatoNome"
                      name="candidatoNome"
                      maxlength="200"
                      placeholder="Digite o nome do candidato"
                      value="{{defesa.candidatoNome}}"
                    >
                  </div>

                  <div class="form-group col-md-6">
                    <label for="orientadorId">Orientador(a) <span class="text-danger">*</span></label>
                    <select class="form-control" id="orientadorId" name="orientadorId">
                      <option value="">Selecione...</option>
                      {{#each docentes}}
                        <option value="{{this.id}}" {{#ifEqual this.id ../defesa.orientadorId}}selected{{/ifEqual}}>
                          {{this.nomeCompleto}}
                        </option>
                      {{/each}}
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="d-block">Coorientador(a) (se houver)</label>

                  <div class="d-flex" style="flex-wrap: wrap; gap: 16px;">
                    <div class="icheck-primary">
                      <input type="radio" name="coorientadorTipo" id="coorientadorNenhum" value="NENHUM"
                        {{#unless defesa.coorientadorId}}{{#unless defesa.coorientadorExternoNome}}checked{{/unless}}{{/unless}}>
                      <label for="coorientadorNenhum">Nenhum</label>
                    </div>

                    <div class="icheck-primary">
                      <input type="radio" name="coorientadorTipo" id="coorientadorInterno" value="INTERNO"
                             {{#if defesa.coorientadorId}}checked{{/if}}>
                      <label for="coorientadorInterno">Interno (UFAM)</label>
                    </div>

                    <div class="icheck-primary">
                      <input type="radio" name="coorientadorTipo" id="coorientadorExterno" value="EXTERNO"
                             {{#if defesa.coorientadorExternoNome}}checked{{/if}}>
                      <label for="coorientadorExterno">Externo</label>
                    </div>
                  </div>

                </div>

                <div id="coorientadorInternoDiv" class="form-group" style="display: none;">
                  <label for="coorientadorIdSelect">Selecione o professor da UFAM</label>
                  <select class="form-control" id="coorientadorIdSelect" name="coorientadorId">
                    <option value="">Selecione...</option>
                    {{#each docentes}}
                      <option value="{{this.id}}" {{#ifEqual this.id ../defesa.coorientadorId}}selected{{/ifEqual}}>
                        {{this.nomeCompleto}}
                      </option>
                    {{/each}}
                  </select>
                </div>

                <div id="coorientadorExternoDiv" style="display: none;">
                  <div class="form-group">
                    <label for="coorientadorExternoNome">Nome do Coorientador Externo</label>
                    <input
                      type="text"
                      class="form-control"
                      id="coorientadorExternoNome"
                      name="coorientadorExternoNome"
                      placeholder="Nome completo"
                      maxlength="191"
                      value="{{defesa.coorientadorExternoNome}}"
                    >
                  </div>

                  <div class="form-group">
                    <label for="coorientadorExternoInstituicao">Instituição do Coorientador Externo</label>
                    <input
                      type="text"
                      class="form-control"
                      id="coorientadorExternoInstituicao"
                      name="coorientadorExternoInstituicao"
                      placeholder="Nome da instituição de origem"
                      maxlength="191"
                      value="{{defesa.coorientadorExternoInstituicao}}"
                    >
                  </div>
                </div>
              </div>

              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/listar" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>

                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save" id="btnSave">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>

                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuar" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Requisitos desta etapa</h3>
            </div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Título do trabalho</li>
                <li>Data e hora da qualificação</li>
                <li>Modalidade (Presencial/Online)</li>
                <li>Coorientador é opcional</li>
              </ul>
              <hr>
              <p class="text-muted mb-0">
                As demais informações (local, resumo, banca etc.) serão preenchidas nas próximas etapas.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

{{> footer}}

<script>
  function isoToLocalInputValue(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '';
    const off = d.getTimezoneOffset();
    const local = new Date(d.getTime() - off * 60000);
    return local.toISOString().slice(0, 16);
  }

  $(document).ready(function () {
    const $form = $('#formStep1');
    const $btnContinuar = $('#btnContinuar');
    const $dataHoraLocal = $('#dataHoraLocal');
    const $dataHoraHidden = $('#dataHora');

    let hasTriedSubmit = false; // <-- chave do comportamento

    // 1) Inicializa datetime-local com ISO do backend
    (function initDateInput() {
      const iso = $dataHoraLocal.attr('data-iso');
      const val = isoToLocalInputValue(iso);
      if (val) $dataHoraLocal.val(val);
    })();

    // 2) Mantém hidden dataHora sincronizado em ISO
    function syncDataHoraHidden() {
      const v = $dataHoraLocal.val();
      if (v) $dataHoraHidden.val(new Date(v).toISOString());
      else $dataHoraHidden.val('');
    }
    $dataHoraLocal.on('change input', syncDataHoraHidden);
    syncDataHoraHidden();

    // 3) Toggle dos blocos de coorientador
    function toggleCoorientadorFields() {
      const selection = $('input[name="coorientadorTipo"]:checked').val();

      if (selection === 'INTERNO') {
        $('#coorientadorInternoDiv').show();
        $('#coorientadorExternoDiv').hide();
      } else if (selection === 'EXTERNO') {
        $('#coorientadorInternoDiv').hide();
        $('#coorientadorExternoDiv').show();
      } else {
        $('#coorientadorInternoDiv').hide();
        $('#coorientadorExternoDiv').hide();
      }
    }
    toggleCoorientadorFields();

    // 4) Validator
    const validator = $form.validate({
      ignore: ':hidden:not(#dataHora)',

      rules: {
        tituloTrabalho: { required: true, minlength: 3, maxlength: 191 },
        dataHoraLocal: { required: true },
        modalidade: { required: true },
        candidatoNome: { required: true, minlength: 3, maxlength: 200 },
        orientadorId: { required: true },

        coorientadorId: {
          required: function () {
            return $('input[name="coorientadorTipo"]:checked').val() === 'INTERNO';
          }
        },
        coorientadorExternoNome: {
          required: function () {
            return $('input[name="coorientadorTipo"]:checked').val() === 'EXTERNO';
          },
          minlength: 3,
          maxlength: 191
        },
        coorientadorExternoInstituicao: {
          required: function () {
            return $('input[name="coorientadorTipo"]:checked').val() === 'EXTERNO';
          },
          minlength: 2,
          maxlength: 191
        }
      },

      messages: {
        tituloTrabalho: {
          required: 'Informe o título do trabalho.',
          minlength: 'O título deve ter pelo menos 3 caracteres.',
          maxlength: 'O título pode ter no máximo 191 caracteres.'
        },
        dataHoraLocal: { required: 'Informe a data e hora da qualificação.' },
        modalidade: { required: 'Selecione a modalidade (Presencial/Online).' },
        candidatoNome: {
          required: 'Informe o nome do(a) candidato(a).',
          minlength: 'O nome deve ter pelo menos 3 caracteres.',
          maxlength: 'O nome pode ter no máximo 200 caracteres.'
        },
        orientadorId: { required: 'Selecione o(a) orientador(a).' },
        coorientadorId: { required: 'Selecione o(a) coorientador(a) interno.' },
        coorientadorExternoNome: {
          required: 'Informe o nome do(a) coorientador(a) externo.',
          minlength: 'O nome deve ter pelo menos 3 caracteres.',
          maxlength: 'O nome pode ter no máximo 191 caracteres.'
        },
        coorientadorExternoInstituicao: {
          required: 'Informe a instituição do(a) coorientador(a) externo.',
          minlength: 'A instituição deve ter pelo menos 2 caracteres.',
          maxlength: 'A instituição pode ter no máximo 191 caracteres.'
        }
      },

      errorElement: 'span',
      errorPlacement: function (error, element) {
        error.addClass('invalid-feedback');

        if (element.is(':radio')) {
          const $group = element.closest('.radio-group');
          if ($group.length) error.insertAfter($group);
          else error.insertAfter(element.closest('.form-group'));
          return;
        }

        element.closest('.form-group').append(error);
      },

      highlight: function (element) {
        const $el = $(element);
        if ($el.is(':radio')) {
          $el.closest('.radio-group').find('label').addClass('text-danger');
          return;
        }
        $el.addClass('is-invalid');
      },

      unhighlight: function (element) {
        const $el = $(element);
        if ($el.is(':radio')) {
          $el.closest('.radio-group').find('label').removeClass('text-danger');
          return;
        }
        $el.removeClass('is-invalid');
      },

      // ✅ Antes do primeiro submit: sem validação em tempo real
      onkeyup: false,
      onfocusout: false,
      onclick: false,

      // ✅ Não mostrar erros antes do primeiro submit
      showErrors: function (errorMap, errorList) {
        if (!hasTriedSubmit) return;
        this.defaultShowErrors();
      },

      // ✅ Quando o usuário tenta enviar e está inválido:
      invalidHandler: function () {
        if (!hasTriedSubmit) {
          hasTriedSubmit = true;

          // A partir daqui: valida em tempo real
          validator.settings.onkeyup = function (element) {
            $(element).valid();
            updateButtonState();
          };
          validator.settings.onfocusout = function (element) {
            $(element).valid();
            updateButtonState();
          };
          validator.settings.onclick = function (element) {
            $(element).valid();
            updateButtonState();
          };
        }

        updateButtonState();
      },

      submitHandler: function (form, e) {
        e.preventDefault();

        // garante ISO antes de enviar
        syncDataHoraHidden();

        // marca que tentou enviar e passa a mostrar/validar em tempo real
        if (!hasTriedSubmit) hasTriedSubmit = true;

        // valida e mostra erros agora
        if (!validator.form()) {
          updateButtonState();
          return;
        }

        form.submit();
      }
    });

    function updateButtonState() {
      // Antes do submit: NÃO mostra erros (checkForm)
      // Depois do submit: tanto faz, pode usar form/valid; aqui uso checkForm sempre.
      const ok = validator.checkForm();
      $btnContinuar.prop('disabled', !ok);
    }

    // Mudou coorientadorTipo: alterna campos e, se já tentou enviar, revalida em tempo real.
    $('input[name="coorientadorTipo"]').on('change', function () {
      toggleCoorientadorFields();

      if (hasTriedSubmit) {
        validator.element('[name="coorientadorId"]');
        validator.element('[name="coorientadorExternoNome"]');
        validator.element('[name="coorientadorExternoInstituicao"]');
      }

      updateButtonState();
    });

    // Enquanto não submeteu, só controla botão; depois, o validator já faz tempo real.
    $('#tituloTrabalho, #candidatoNome').on('input', updateButtonState);
    $('#orientadorId').on('change', updateButtonState);
    $('input[name="modalidade"]').on('change', updateButtonState);
    $('[name="coorientadorId"], [name="coorientadorExternoNome"], [name="coorientadorExternoInstituicao"]').on('input change', updateButtonState);

    // estado inicial do botão sem mostrar erros
    updateButtonState();
  });
</script>