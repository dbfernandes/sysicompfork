{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <!-- Cabeçalho -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Qualificação — Etapa 1</h1>
          <small class="text-muted">Informações iniciais</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Qualificação — Etapa 1</li>
          </ol>
        </div>
      </div>

      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 14%;" aria-valuenow="14" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span><strong>1.</strong> Dados iniciais</span>
            <span>2. Local</span>
            <span>3. Trabalho</span>
            <span>4. Presidente</span>
            <span>5. Membros</span>
            <span>6. Suplentes</span>
            <span>7. Proposta/Artigos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Conteúdo -->
  <section class="content">
    <div class="container-fluid">
      <!-- Mensagens -->
      {{#if errors}}
        <div class="alert alert-danger">
          <ul class="mb-0">
            {{#each errors}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}
      {{#if messages}}
        <div class="alert alert-success">
          <ul class="mb-0">
            {{#each messages}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}

      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Informações da qualificação</h3>
            </div>

            <form id="formStep1" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step1">

              <div class="card-body">
                <div class="form-group">
                  <label for="tituloTrabalho">Título do trabalho <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="tituloTrabalho" name="tituloTrabalho"
                         maxlength="500" placeholder="Digite o título do trabalho"
                         value="{{defesa.tituloTrabalho}}">
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Tipo / Nível</label>
                    <div>
                      <span class="badge badge-info mr-2">{{defesa.tipo}}</span>
                      <span class="badge badge-secondary">{{defesa.nivel}}</span>
                    </div>
                    <small class="form-text text-muted">Definido na criação da defesa.</small>
                  </div>

                  <div class="form-group col-md-6">
                    <label for="dataHora">Data e hora da qualificação <span class="text-danger">*</span></label>
                    <input type="datetime-local" class="form-control"
                           id="dataHoraLocal" data-iso="{{defesa.dataHora}}">
                    <input type="hidden" name="dataHora" id="dataHora">
                    <small class="form-text text-muted">Ajuste a data/hora no fuso local.</small>
                  </div>
                </div>

                <div class="form-group">
                  <label class="d-block">Modalidade <span class="text-danger">*</span></label>
                  <div class="custom-control custom-radio d-inline-block mr-3">
                    <input class="custom-control-input" type="radio" id="modalPres" name="modalidade" value="PRESENCIAL"
                           {{#ifEqual defesa.modalidade 'PRESENCIAL'}}checked{{/ifEqual}}>
                    <label for="modalPres" class="custom-control-label">Presencial</label>
                  </div>
                  <div class="custom-control custom-radio d-inline-block">
                    <input class="custom-control-input" type="radio" id="modalOn" name="modalidade" value="ONLINE"
                           {{#ifEqual defesa.modalidade 'ONLINE'}}checked{{/ifEqual}}>
                    <label for="modalOn" class="custom-control-label">Online</label>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                      <label for="candidatoId">Candidato(a) <span class="text-danger">*</span></label>
                      <select class="form-control" id="candidatoId" name="candidatoId" style="width: 100%;">
                        {{#if defesa.candidato}}
                          <option value="{{defesa.candidatoId}}" selected="selected">{{defesa.candidato.nome}}</option>
                        {{/if}}
                      </select>
                      </div>
                    <div class="form-group col-md-6">
                      <label for="orientadorId">Orientador(a) <span class="text-danger">*</span></label>
                      <select class="form-control" id="orientadorId" name="orientadorId">
                        <option value="">Selecione...</option>
                        {{#each docentes}}
                          <option value="{{this.id}}" {{#ifEqual this.id ../defesa.orientadorId}}selected{{/ifEqual}}>
                            {{this.nomeCompleto}}
                          </option>
                        {{/each}}
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="d-block">Coorientador(a) (se houver)</label>
                    
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="coorientadorTipo" id="coorientadorNenhum" value="NENHUM" {{#unless defesa.coorientadorId}}{{#unless defesa.coorientadorExternoNome}}checked{{/unless}}{{/unless}}>
                      <label class="form-check-label" for="coorientadorNenhum">Nenhum</label>
                    </div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="coorientadorTipo" id="coorientadorInterno" value="INTERNO" {{#if defesa.coorientadorId}}checked{{/if}}>
                      <label class="form-check-label" for="coorientadorInterno">Interno (UFAM)</label>
                    </div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="coorientadorTipo" id="coorientadorExterno" value="EXTERNO" {{#if defesa.coorientadorExternoNome}}checked{{/if}}>
                      <label class="form-check-label" for="coorientadorExterno">Externo</label>
                    </div>
                  </div>

                  <div id="coorientadorInternoDiv" class="form-group" style="display: none;">
                    <label for="coorientadorId">Selecione o professor da UFAM</label>
                    <select class="form-control" name="coorientadorId">
                      <option value="">Selecione...</option>
                      {{#each docentes}}
                        <option value="{{this.id}}" {{#ifEqual this.id ../defesa.coorientadorId}}selected{{/ifEqual}}>
                          {{this.nomeCompleto}}
                        </option>
                      {{/each}}
                    </select>
                  </div>

                  <div id="coorientadorExternoDiv" style="display: none;">
                    <div class="form-group">
                      <label for="coorientadorExternoNome">Nome do Coorientador Externo</label>
                      <input type="text" class="form-control" name="coorientadorExternoNome" placeholder="Nome completo" value="{{defesa.coorientadorExternoNome}}">
                    </div>
                    <div class="form-group">
                      <label for="coorientadorExternoInstituicao">Instituição do Coorientador Externo</label>
                      <input type="text" class="form-control" name="coorientadorExternoInstituicao" placeholder="Nome da instituição de origem" value="{{defesa.coorientadorExternoInstituicao}}">
                    </div>
                  </div>

              </div>

              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/listar" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuar" disabled> {{!-- Adicionado id e disabled --}}
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Requisitos desta etapa</h3>
            </div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Título do trabalho</li>
                <li>Data e hora da qualificação</li>
                <li>Modalidade (Presencial/Online)</li>
                <li>Coorientador é opcional</li>
              </ul>
              <hr>
              <p class="text-muted mb-0">
                As demais informações (local, resumo, banca etc.) serão preenchidas nas próximas etapas.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  function isoToLocalInputValue(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '';
    const off = d.getTimezoneOffset();
    const local = new Date(d.getTime() - off * 60000);
    return local.toISOString().slice(0, 16);
  }

  (function initDateInput() {
    const inputLocal = document.getElementById('dataHoraLocal');
    const hiddenIso  = document.getElementById('dataHora');
    const iso = inputLocal.getAttribute('data-iso');
    const val = isoToLocalInputValue(iso);
    if (val) inputLocal.value = val;

    document.getElementById('formStep1').addEventListener('submit', function(e) {
      const v = inputLocal.value;
      if (v) {
        const d = new Date(v);
        hiddenIso.value = d.toISOString();
      } else {
        hiddenIso.value = '';
      }
    });
  })();
</script>

{{> footer}}

<script>
  $(document).ready(function() {
    $('#candidatoId').select2({
      theme: 'bootstrap4',
      placeholder: "Digite para buscar um candidato...",
      minimumInputLength: 2,
      language: {
        inputTooShort: function () {
          return "Digite 2 ou mais caracteres para buscar";
        },
        noResults: function () {
          return "Nenhum resultado encontrado";
        },
        searching: function () {
          return "Buscando...";
        }
      },
      ajax: {
        url: '/api/candidatos/search',
        dataType: 'json',
        delay: 250, // 
        data: function (params) {
          return {
            q: params.term
          };
        },
        processResults: function (data) {
          return {
            results: data.results
          };
        },
        cache: true
      }
    });
  });
</script>
<script>
  $(document).ready(function() {
    function toggleCoorientadorFields() {
      const selection = $('input[name="coorientadorTipo"]:checked').val();
      
      if (selection === 'INTERNO') {
        $('#coorientadorInternoDiv').show();
        $('#coorientadorExternoDiv').hide();
      } else if (selection === 'EXTERNO') {
        $('#coorientadorInternoDiv').hide();
        $('#coorientadorExternoDiv').show();
      } else {
        $('#coorientadorInternoDiv').hide();
        $('#coorientadorExternoDiv').hide();
      }
    }

    toggleCoorientadorFields();

    $('input[name="coorientadorTipo"]').on('change', toggleCoorientadorFields);
  });
</script>
<script>
  $(document).ready(function() {
    const tituloInput = $('#tituloTrabalho');
    const dataHoraInput = $('#dataHoraLocal'); 
    const modalidadeRadios = $('input[name="modalidade"]');
    const candidatoSelect = $('#candidatoId'); 
    const orientadorSelect = $('#orientadorId');
    const btnContinuar = $('#btnContinuar');

    function checkFormValidity() {
      const tituloVal = tituloInput.val()?.trim() ?? ''; 
      const dataHoraVal = dataHoraInput.val() ?? '';
      const modalidadeVal = $('input[name="modalidade"]:checked').val(); 
      const candidatoVal = candidatoSelect.val() ?? ''; 
      const orientadorVal = orientadorSelect.val() ?? ''; 

      return tituloVal !== '' && 
             dataHoraVal !== '' && 
             modalidadeVal && 
             candidatoVal !== '' && 
             orientadorVal !== '';
    }

    function updateButtonState() {
      const isValid = checkFormValidity();
      btnContinuar.prop('disabled', !isValid); 
    }

    tituloInput.on('input keyup', updateButtonState); 
    dataHoraInput.on('change input', updateButtonState); 
    modalidadeRadios.on('change', updateButtonState);
    candidatoSelect.on('change', updateButtonState); 
    orientadorSelect.on('change', updateButtonState);

    updateButtonState(); 
  });
</script>