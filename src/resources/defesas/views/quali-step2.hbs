{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Qualificação — Etapa 2</h1>
          <small class="text-muted">Local da defesa</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Qualificação — Etapa 2</li>
          </ol>
        </div>
      </div>

      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 28%;" aria-valuenow="28" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span>1. Dados iniciais</span>
            <span><strong>2. Local</strong></span>
            <span>3. Trabalho</span>
            <span>4. Presidente</span>
            <span>5. Membros</span>
            <span>6. Suplentes</span>
            <span>7. Proposta/Artigos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}
        <div class="alert alert-danger">
          <ul class="mb-0">
            {{#each errors}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}

      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Local da Qualificação</h3>
            </div>

            <form id="formStep2" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step2">

              <div class="card-body">
                <div class="form-group">
                  {{#ifEqual defesa.modalidade 'PRESENCIAL'}}
                    <label for="local">Local da defesa <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="local" name="local" 
                           placeholder="Ex: Auditório 1, Sala 02" value="{{defesa.localOuLink}}">
                    <small class="form-text text-muted">Digite o local da defesa presencial (ex: nome da sala, auditório).</small>
                  {{else}}
                    <label for="local">Link da reunião <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="local" name="local" 
                           placeholder="https://meet.google.com/..." value="{{defesa.localOuLink}}">
                    <small class="form-text text-muted">Cole o link da reunião online (Google Meet, Teams, etc.).</small>
                  {{/ifEqual}}
                </div>
              </div><div class="card-footer d-flex justify-content-between">
                <a href="/defesas/editar/{{defesa.id}}/qualificacao/step1" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuarStep2" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Requisitos desta etapa</h3>
            </div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Informar o local (sala/auditório) ou o link da reunião para a defesa.</li>
              </ul>
              <hr>
              <p class="text-muted mb-0">
                Esta informação é necessária para a geração da ata de qualificação e para a divulgação pública.
              </p>
            </div>
          </div>
        </div>
      </div></div></section>
</div>
{{> footer}}
<script>
  $(document).ready(function () {
    const $form = $('#formStep2');
    const $btnContinuar = $('#btnContinuarStep2');
    const $local = $('#local');

    // vem do servidor (handlebars). Se estiver PRESENCIAL, não exige URL.
    const modalidade = '{{defesa.modalidade}}';
    const isOnline = modalidade === 'ONLINE';
    let hasTriedSubmit = false;

    $.validator.addMethod(
      'urlHttp',
      function (value, element) {
        const v = (value || '').trim();

        // se não for online, não valida URL
        if (!isOnline) return true;

        if (this.optional(element)) return true;
        return /^https?:\/\/\S+$/i.test(v);
      },
      'Informe um link válido (comece com http:// ou https://).'
    );

    const validator = $form.validate({
      ignore: ':hidden',

      rules: {
        local: {
          required: true,
          maxlength: 191,
          urlHttp: true
        }
      },

      messages: {
        local: {
          required: isOnline
            ? 'Informe o link da reunião.'
            : 'Informe o local da defesa.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        }
      },

      errorElement: 'span',
      errorPlacement: function (error, element) {
        error.addClass('invalid-feedback');
        element.closest('.form-group').append(error);
      },

      highlight: function (element) {
        $(element).addClass('is-invalid');
      },

      unhighlight: function (element) {
        $(element).removeClass('is-invalid');
      },

      // Antes do 1º submit: sem validação em tempo real
      onkeyup: false,
      onfocusout: false,
      onclick: false,

      // Não mostrar erros antes do 1º submit
      showErrors: function () {
        if (!hasTriedSubmit) return;
        this.defaultShowErrors();
      },

      // Se tentou enviar e estava inválido, liga tempo real a partir daí
      invalidHandler: function () {
        if (!hasTriedSubmit) {
          hasTriedSubmit = true;

          validator.settings.onkeyup = function (element) {
            $(element).valid();
            updateButtonState();
          };
          validator.settings.onfocusout = function (element) {
            $(element).valid();
            updateButtonState();
          };
          validator.settings.onclick = function (element) {
            $(element).valid();
            updateButtonState();
          };
        }

        updateButtonState();
      },

      submitHandler: function (form, e) {
        e.preventDefault();

        // marca tentativa
        if (!hasTriedSubmit) hasTriedSubmit = true;

        // valida e mostra erros agora
        if (!validator.form()) {
          updateButtonState();
          return;
        }

        form.submit();
      }
    });

    function updateButtonState() {
      // checkForm() não exibe erros
      const ok = validator.checkForm();
      $btnContinuar.prop('disabled', !ok);
    }

    // Atualiza botão conforme digita, mas sem exibir erro antes do submit
    $local.on('input change keyup', updateButtonState);

    // estado inicial do botão
    updateButtonState();
  });
</script>