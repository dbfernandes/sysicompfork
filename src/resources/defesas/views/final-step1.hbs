{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div><h1>Defesa Final — Etapa 1</h1><small class="text-muted">Informações iniciais</small></div>
        <div><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Página inicial</a></li><li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li><li class="breadcrumb-item active">Defesa Final — Etapa 1</li></ol></div>
      </div>
      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" role="progressbar" style="width: 16%;" aria-valuenow="16" aria-valuemin="0" aria-valuemax="100"></div></div>
          <div class="d-flex justify-content-between mt-1 small text-muted"><span><strong>1.</strong> Dados iniciais</span><span>2. Local</span><span>3. Trabalho</span><span>4. Membros</span><span>5. Suplentes</span><span>6. Documentos</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}<div class="alert alert-danger"><ul class="mb-0">{{#each errors}}<li>{{this}}</li>{{/each}}</ul></div>{{/if}}
      {{#if defesa.correcaoSolicitada}}
      <div class="alert alert-warning" role="alert">
        <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
        <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
        <hr>
        <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
      </div>
    {{/if}}
      <div class="row">
        
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header"><h3 class="card-title">Informações da Defesa Final</h3></div>
            <form id="formFinalStep1" method="POST" action="/defesas/editar/{{defesa.id}}/final/step1">
              <div class="card-body">

                {{!-- Título do Trabalho --}}
                <div class="form-group">
                  <label for="tituloTrabalho">Título do trabalho <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="tituloTrabalho" name="tituloTrabalho" maxlength="500" placeholder="Digite o título do trabalho" value="{{defesa.tituloTrabalho}}">
                </div>

                {{!-- Linha de Pesquisa --}}
                <div class="form-group">
                  <label for="linhaPesquisaId">Linha de Pesquisa <span class="text-danger">*</span></label>
                  <select class="form-control" id="linhaPesquisaId" name="linhaPesquisaId">
                    <option value="">Selecione...</option>
                    {{#each linhasDePesquisa}}
                      <option value="{{this.id}}" {{#ifEqual this.id ../defesa.linhaPesquisaId}}selected{{/ifEqual}}>
                        {{this.nome}}
                      </option>
                    {{/each}}
                  </select>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label for="candidatoNome">Nome completo do candidato <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="candidatoNome" name="candidatoNome" maxlength="200"
                           placeholder="Digite o nome do candidato" value="{{defesa.candidatoNome}}">
                  </div>
                  <div class="form-group col-md-6">
                    <label for="orientadorId">Nome completo do orientador <span class="text-danger">*</span></label>
                    <select class="form-control" id="orientadorId" name="orientadorId">
                      <option value="">Selecione...</option>
                      {{#each docentes}}<option value="{{this.id}}" {{#ifEqual this.id ../defesa.orientadorId}}selected{{/ifEqual}}>{{this.nomeCompleto}}</option>{{/each}}
                    </select>
                  </div>
                </div>

                {{!-- Linha: Data/Hora e Modalidade --}}
                <div class="form-row align-items-end">
                  <div class="form-group col-md-6">
                    <label for="dataHoraLocal">Data e hora da defesa <span class="text-danger">*</span></label>
                    <input type="datetime-local" class="form-control" id="dataHoraLocal" data-iso="{{defesa.dataHora}}">
                    <input type="hidden" name="dataHora" id="dataHora">
                    <small class="form-text text-muted">Ajuste a data e hora no fuso local.</small>
                  </div>
                   <div class="form-group col-md-6">
                    <label class="d-block">Modalidade <span class="text-danger">*</span></label>
                    <div class="custom-control custom-radio d-inline-block mr-3">
                      <input class="custom-control-input" type="radio" id="modalPres" name="modalidade" value="PRESENCIAL" {{#ifEqual defesa.modalidade 'PRESENCIAL'}}checked{{/ifEqual}}>
                      <label for="modalPres" class="custom-control-label">Presencial</label>
                    </div>
                    <div class="custom-control custom-radio d-inline-block">
                      <input class="custom-control-input" type="radio" id="modalOn" name="modalidade" value="ONLINE" {{#ifEqual defesa.modalidade 'ONLINE'}}checked{{/ifEqual}}>
                      <label for="modalOn" class="custom-control-label">Online</label>
                    </div>
                  </div>
                </div>

              </div>
              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/listar" class="btn btn-default"><i class="fas fa-chevron-left"></i> Voltar</a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">Salvar rascunho</button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuarFinalStep1" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div> 

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Requisitos desta etapa</h3>
            </div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Título do trabalho</li>
                <li>Linha de pesquisa</li>
                <li>Nome do candidato</li>
                <li>Nome do orientador</li>
                <li>Data e hora da defesa</li>
                <li>Modalidade (Presencial/Online)</li>
              </ul>
              <hr>
              <p class="text-muted mb-0">
                As demais informações (local, resumo, banca etc.) serão preenchidas nas próximas etapas.
              </p>
            </div>
          </div>
        </div> 

      </div> 
    </div>
  </section>
</div>

{{> footer}}

<script>(function initDateInput(){const i=document.getElementById("dataHoraLocal"),t=document.getElementById("dataHora");function a(e){if(!e)return"";const n=new Date(e);if(isNaN(n.getTime()))return"";const o=n.getTimezoneOffset();return new Date(n.getTime()-6e4*o).toISOString().slice(0,16)}const e=i.getAttribute("data-iso"),n=a(e);n&&(i.value=n);document.getElementById("formFinalStep1")?.addEventListener("submit",function(a){const e=i.value;e?t.value=new Date(e).toISOString():t.value=""})})();</script>

<script>
  $(document).ready(function() {
    const tituloInput = $('#tituloTrabalho');
    const linhaPesquisaSelect = $('#linhaPesquisaId');
    const candidatoSelect = $('#candidatoNome');
    const orientadorSelect = $('#orientadorId');
    const dataHoraInput = $('#dataHoraLocal');
    const modalidadeRadios = $('input[name="modalidade"]');
    const btnContinuar = $('#btnContinuarFinalStep1');

    function checkFormValidity() {
      const tituloVal = tituloInput.val()?.trim() ?? '';
      const linhaPesquisaVal = linhaPesquisaSelect.val() ?? '';
      const candidatoVal = candidatoSelect.val() ?? '';
      const orientadorVal = orientadorSelect.val() ?? '';
      const dataHoraVal = dataHoraInput.val() ?? '';
      const modalidadeVal = $('input[name="modalidade"]:checked').val();

      return tituloVal !== '' &&
             linhaPesquisaVal !== '' &&
             candidatoVal !== '' &&
             orientadorVal !== '' &&
             dataHoraVal !== '' &&
             modalidadeVal;
    }

    function updateButtonState() {
      btnContinuar.prop('disabled', !checkFormValidity());
    }

    tituloInput.on('input keyup', updateButtonState);
    linhaPesquisaSelect.on('change', updateButtonState);
    candidatoSelect.on('change', updateButtonState);
    orientadorSelect.on('change', updateButtonState);
    dataHoraInput.on('change input', updateButtonState);
    modalidadeRadios.on('change', updateButtonState);

    updateButtonState();
  });
</script>