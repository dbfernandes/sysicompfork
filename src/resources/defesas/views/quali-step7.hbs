{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}
{{#section "head"}}
  <!-- Select2 -->
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
{{/section}}
<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap">
        <div><h1>Qualificação — Etapa 7</h1><small class="text-muted">Proposta e Artigos</small></div>
        <div><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Página inicial</a></li><li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li><li class="breadcrumb-item active">Qualificação — Etapa 7</li></ol></div>
      </div>
      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div></div>
          <div class="d-flex justify-content-between mt-1 small text-muted"><span>1. Dados iniciais</span><span>2. Local</span><span>3. Trabalho</span><span>4. Presidente</span><span>5. Membros</span><span>6. Suplentes</span><span><strong>7. Proposta/Artigos</strong></span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}<div class="alert alert-danger"><ul class="mb-0">{{#each errors}}<li>{{this}}</li>{{/each}}</ul></div>{{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}
      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header"><h3 class="card-title">Proposta e Documentação Final</h3></div>
            <form id="formStep7" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step7" enctype="multipart/form-data">
              <div class="card-body">

                <div class="form-group">
                  <label for="propostaPdf">Anexar o arquivo da proposta em .pdf (tamanho máximo 100MB) <span class="text-danger">*</span></label>
                  <input type="file" class="form-control-file" id="propostaPdf" name="propostaPdf"                   accept="application/pdf">
                  {{#if propostaAnexada}}
                    <small class="form-text text-success">
                      Arquivo atual: {{propostaAnexada.originalName}} ({{formatBytes propostaAnexada.size}})
                      <span class="text-muted ml-2">(Enviar um novo arquivo substituirá o atual)</span>
                    </small>
                  {{else}}
                    <small class="form-text text-muted">Faça upload de 1 arquivo aceito: PDF. O tamanho máximo é de 100 MB.</small>
                  {{/if}}
                </div>
                <hr>

                {{#ifEqual defesa.nivel 'DOUTORADO'}}
                  <h4>Documentação de Doutorado</h4>
                  <div class="icheck-primary">
                    <input type="checkbox" id="doutoradoArtigoComprovado" name="doutoradoArtigoComprovado" value="true" {{#if defesa.quali.doutoradoArtigoComprovado}}checked{{/if}}>
                    <label for="doutoradoArtigoComprovado">Declaro que o aluno tem pelo menos um journal de estrato superior submetido ou aceito (A1, A2, A3, A4) como primeiro autor.</label>
                    <small class="form-text text-muted">Consulte as regras em <a href="https://drive.google.com/file/d/1Mn4R5cyw1v1DWKIHAFwh7v2yhpQKeqqn/view?usp=sharing" target="_blank" rel="noopener noreferrer">Qualis 2017-2020</a>.</small>

                  </div>

                  <div class="form-group">
                    <label for="artigoTitulo">Título do artigo</label>
                    <input type="text" class="form-control" id="artigoTitulo" name="artigoTitulo" value="{{defesa.quali.artigoTitulo}}" maxlength="191">
                  </div>
                  <div class="form-group">
                    <label for="artigoVeiculoOuDoi">Veículo de publicação (link) ou DOI</label>
                    <input type="text" class="form-control" id="artigoVeiculoOuDoi" name="artigoVeiculoOuDoi" value="{{defesa.quali.artigoVeiculoOuDoi}}" maxlength="191">
                  </div>
                  <hr>
                {{/ifEqual}}

                <h4>Declaração de Autoavaliação <span class="text-danger">*</span></h4>
                <div class="icheck-primary">
                  <input type="checkbox" id="autoavaliacaoPreenchida" name="autoavaliacaoPreenchida" value="true" {{#if defesa.quali.autoavaliacaoPreenchida}}checked{{/if}}>
                  <label  for="autoavaliacaoPreenchida">Declaro que o(a) orientador(a) e o(a) discente preenchemos o formulário de autoavaliação do programa do ano 2024.</label>

                </div>

                <div class="mt-2">
                  <p class="mb-1 small text-muted">Se ainda não preencheu, utilize sua conta @icomp nos links abaixo:</p>
                  <ul class="list-unstyled small">
                    <li><a href="https://forms.gle/ZrzyWhkP4Piq7sr3A" target="_blank" rel="noopener noreferrer">Link para Discentes</a></li>
                    <li><a href="https://forms.gle/z2SQ399HK1iKUSRf8" target="_blank" rel="noopener noreferrer">Link para Docentes</a></li>
                  </ul>
                </div>

              </div>
              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/editar/{{defesa.id}}/qualificacao/step6" class="btn btn-default"><i class="fas fa-chevron-left"></i> Voltar</a>
                <div>
                  <button type="submit" class="btn btn-primary" name="action" value="submit" id="btnSubmitFinal" disabled>
                    <i class="fas fa-check"></i> Finalizar e Submeter para Validação
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header"><h3 class="card-title">Requisitos desta etapa</h3></div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Anexar o arquivo da proposta em PDF.</li>
                {{#ifEqual defesa.nivel 'DOUTORADO'}}
                  <li>Declarar o artigo submetido/aceito (Doutorado).</li>
                  <li>Preencher os dados do artigo (Doutorado).</li>
                {{/ifEqual}}
                <li>Confirmar o preenchimento da autoavaliação.</li>
              </ul>
              <hr/>
              <p class="text-muted mb-0">Esta é a última etapa. Ao clicar em "Finalizar", a defesa será enviada para validação da coordenação.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
{{> footer}}
<script>
  $(document).ready(function () {
    const $form = $('#formStep7');
    const $btnSubmit = $('#btnSubmitFinal');
    const $propostaInput = $('#propostaPdf');
    const $autoavaliacaoCheck = $('#autoavaliacaoPreenchida');

    const isDoutorado = {{#ifEqual defesa.nivel 'DOUTORADO'}}true{{else}}false{{/ifEqual}};
    const $artigoCheck = $('#doutoradoArtigoComprovado');
    const $artigoTituloInput = $('#artigoTitulo');
    const $artigoVeiculoInput = $('#artigoVeiculoOuDoi');

    const hasExistingFile = {{#if propostaAnexada}}true{{else}}false{{/if}};
    const MAX_FILE_SIZE = 100 * 1024 * 1024;

    let hasTriedSubmit = false;

    $.validator.addMethod(
      'pdfFile',
      function (value, element) {
        const files = element.files;

        if (!files || files.length === 0) {
          return true;
        }

        const file = files[0];
        const fileName = (file.name || '').toLowerCase();
        const fileType = (file.type || '').toLowerCase();

        return fileName.endsWith('.pdf') || fileType === 'application/pdf';
      },
      'Envie um arquivo PDF válido.'
    );

    $.validator.addMethod(
      'maxFileSize',
      function (value, element, param) {
        const files = element.files;

        if (!files || files.length === 0) {
          return true;
        }

        const file = files[0];
        return file.size <= param;
      },
      'O arquivo deve ter no máximo 100 MB.'
    );

    $.validator.addMethod(
      'linkOuDoi',
      function (value, element) {
        const v = (value || '').trim();

        if (this.optional(element)) return true;

        const isHttpUrl = /^https?:\/\/\S+$/i.test(v);
        const isDoi = /^(10\.\d{4,9}\/[-._;()/:A-Z0-9]+)$/i.test(v);

        return isHttpUrl || isDoi || v.length > 0;
      },
      'Informe um link válido (http/https), DOI ou texto identificador do veículo.'
    );

    const validator = $form.validate({
      ignore: ':hidden',

      rules: {
        propostaPdf: {
          required: function () {
            const files = $propostaInput[0]?.files;
            return !hasExistingFile && (!files || files.length === 0);
          },
          pdfFile: true,
          maxFileSize: MAX_FILE_SIZE
        },

        autoavaliacaoPreenchida: {
          required: true
        },

        artigoTitulo: {
          required: {
            depends: function () {
              return isDoutorado;
            }
          },
          maxlength: 191
        },

        artigoVeiculoOuDoi: {
          required: {
            depends: function () {
              return isDoutorado;
            }
          },
          maxlength: 191,
          linkOuDoi: {
            depends: function () {
              return isDoutorado;
            }
          }
        },

        doutoradoArtigoComprovado: {
          required: {
            depends: function () {
              return isDoutorado;
            }
          }
        }
      },

      messages: {
        propostaPdf: {
          required: 'Anexe o arquivo da proposta em PDF.',
          pdfFile: 'Envie um arquivo PDF válido.',
          maxFileSize: 'O arquivo deve ter no máximo 100 MB.'
        },
        autoavaliacaoPreenchida: {
          required: 'Confirme o preenchimento da autoavaliação.'
        },
        artigoTitulo: {
          required: 'Informe o título do artigo.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        },
        artigoVeiculoOuDoi: {
          required: 'Informe o veículo de publicação, link ou DOI.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.',
          linkOuDoi: 'Informe um link válido (http/https), DOI ou texto identificador do veículo.'
        },
        doutoradoArtigoComprovado: {
          required: 'Confirme a declaração do artigo para doutorado.'
        }
      },

      errorElement: 'span',

      errorPlacement: function (error, element) {
        if (
          element.is(':checkbox') &&
          (element.closest('.custom-control').length || element.closest('.icheck-primary').length)
        ) {
          error.addClass('invalid-feedback d-block');
          element.parent().append(error);
          return;
        }

        if (element.attr('type') === 'file') {
          error.addClass('invalid-feedback d-block');
          element.closest('.form-group').append(error);
          return;
        }

        error.addClass('invalid-feedback');
        element.closest('.form-group').append(error);
      },

      highlight: function (element) {
        $(element).addClass('is-invalid');
      },

      unhighlight: function (element) {
        $(element).removeClass('is-invalid');
      },

      onkeyup: false,
      onfocusout: false,
      onclick: false,

      showErrors: function () {
        if (!hasTriedSubmit) return;
        this.defaultShowErrors();
      },

      invalidHandler: function () {
        hasTriedSubmit = true;
        updateButtonState();
      },

      submitHandler: function (form) {
        hasTriedSubmit = true;
        $btnSubmit.prop('disabled', true);
        form.submit();
      }
    });

    function updateButtonState() {
      const isValid = validator.checkForm();

      if (hasTriedSubmit) {
        validator.showErrors();
      }

      $btnSubmit.prop('disabled', !isValid);
    }

    function validateFieldAndRefresh(element) {
      if (hasTriedSubmit) {
        validator.element(element);
      }
      updateButtonState();
    }

    $propostaInput.on('change', function () {
      validateFieldAndRefresh(this);
    });

    $autoavaliacaoCheck.on('change', function () {
      validateFieldAndRefresh(this);
    });

    if (isDoutorado) {
      $artigoCheck.on('change', function () {
        validateFieldAndRefresh(this);
      });

      $artigoTituloInput.on('input change', function () {
        validateFieldAndRefresh(this);
      });

      $artigoVeiculoInput.on('input change', function () {
        validateFieldAndRefresh(this);
      });
    }

    updateButtonState();
  });
</script>