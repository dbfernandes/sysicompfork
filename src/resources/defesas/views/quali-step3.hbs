{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Qualificação — Etapa 3</h1>
          <small class="text-muted">Detalhes do Trabalho</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Qualificação — Etapa 3</li>
          </ol>
        </div>
      </div>

      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 42%;" aria-valuenow="42" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span>1. Dados iniciais</span>
            <span>2. Local</span>
            <span><strong>3. Trabalho</strong></span>
            <span>4. Presidente</span>
            <span>5. Membros</span>
            <span>6. Suplentes</span>
            <span>7. Proposta/Artigos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}
        <div class="alert alert-danger"><ul class="mb-0">{{#each errors}}<li>{{this}}</li>{{/each}}</ul></div>
      {{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}

      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Detalhes do Trabalho</h3>
            </div>

            <form id="formStep3" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step3">

              <div class="card-body">
                <div class="form-group">
                  <label>Título do trabalho</label>
                  <p class="form-control-plaintext">{{defesa.tituloTrabalho}}</p>
                </div>

                <div class="form-group">
                  <label for="resumoOuAbstract">Resumo do trabalho <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="resumoOuAbstract" name="resumoOuAbstract" rows="8" 
                            placeholder="Cole aqui o resumo do seu trabalho.">{{defesa.quali.resumoOuAbstract}}</textarea>
                </div>

                <div class="form-group">
                  <label for="palavrasChaves"><strong>Palavras-chave</strong> <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="palavrasChaves" name="palavrasChaves"
                         placeholder="Ex: Inteligência Artificial; Redes Neurais; Processamento de Linguagem" value="{{defesa.quali.palavrasChaves}}">
                  <small class="form-text text-muted">Separe as palavras-chave por ponto e vírgula (;).</small>
                </div>

                <div class="form-group">
                  <label class="d-block">O candidato já possui a quantidade mínima de créditos para qualificar? <span class="text-danger">*</span></label>
                  <div class="custom-control custom-radio">
                    <input class="custom-control-input" type="radio" id="creditosSim" name="creditosMinimosOk" value="true" 
                            {{#ifEqual defesa.quali.creditosMinimosOk true}}checked{{/ifEqual}}>
                    <label for="creditosSim" class="custom-control-label">Sim</label>
                  </div>
                  <div class="custom-control custom-radio">
                    <input class="custom-control-input" type="radio" id="creditosNao" name="creditosMinimosOk" value="false"
                            {{#ifEqual defesa.quali.creditosMinimosOk false}}checked{{/ifEqual}}>
                    <label for="creditosNao" class="custom-control-label">Não</label>
                  </div>
                  <small class="form-text text-muted">
                    São desejáveis 12 créditos para mestrado e 16 créditos para doutorado, incluindo as disciplinas obrigatórias.
                  </small>
                  </div>

              </div><div class="card-footer d-flex justify-content-between">
                <a href="/defesas/editar/{{defesa.id}}/qualificacao/step2" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuarStep3" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Requisitos desta etapa</h3>
            </div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Preencher o resumo do trabalho.</li>
                <li>Informar as palavras-chave.</li>
                <li>Informar se os créditos mínimos para qualificção foram alcançados.</li>
              </ul>
            </div>
          </div>
        </div>
      </div></div></section>
</div>

<script>
  $(document).ready(function() {
    const resumoInput = $('#resumoOuAbstract');
    const palavrasInput = $('#palavrasChaves');
    const creditosRadios = $('input[name="creditosMinimosOk"]');
    const btnContinuar = $('#btnContinuarStep3');

    function checkFormValidity() {
      const resumoVal = resumoInput.val()?.trim() ?? '';
      const palavrasVal = palavrasInput.val()?.trim() ?? '';
      const creditosVal = $('input[name="creditosMinimosOk"]:checked').val();
      
      return resumoVal !== '' && palavrasVal !== '' && creditosVal;
    }

    function updateButtonState() {
      btnContinuar.prop('disabled', !checkFormValidity());
    }

    resumoInput.on('input keyup', updateButtonState);
    palavrasInput.on('input keyup', updateButtonState);
    creditosRadios.on('change', updateButtonState);
    updateButtonState(); 
  });
</script>

{{> footer}}