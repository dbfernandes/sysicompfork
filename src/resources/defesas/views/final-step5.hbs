{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap">
        <div><h1>Defesa Final — Etapa 5</h1><small class="text-muted">Banca Examinadora (Suplentes)</small></div>
        <div><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Página inicial</a></li><li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li><li class="breadcrumb-item active">Defesa Final — Etapa 5</li></ol></div>
      </div>
      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" role="progressbar" style="width: 83%;" aria-valuenow="83" aria-valuemin="0" aria-valuemax="100"></div></div>
          <div class="d-flex justify-content-between mt-1 small text-muted"><span>1. Dados iniciais</span><span>2. Local</span><span>3. Trabalho</span><span>4. Membros</span><span><strong>5. Suplentes</strong></span><span>6. Documentos</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}<div class="alert alert-danger"><ul class="mb-0">{{#each errors}}<li>{{this}}</li>{{/each}}</ul></div>{{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}
      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header"><h3 class="card-title">Banca Examinadora (Suplentes)</h3></div>

            <form id="formFinalStep5" method="POST" action="/defesas/editar/{{defesa.id}}/final/step5">
              <div class="card-body">
                <p class="text-muted">Informe os dados para os dois membros suplentes da banca.</p>
                
                {{!-- Suplente 1 (Obrigatório) --}}
                <div class="card card-primary">
                  <div class="card-header"><h3 class="card-title">1º Suplente <span class="text-danger">*</span></h3></div>
                  <div class="card-body">
                    <div class="form-row">
                      <div class="form-group col-md-12"><label>Nome</label><input type="text" name="suplentes[0][nome]" class="form-control" placeholder="Nome completo" value="{{suplentes.[0].nome}}"></div>
                      <div class="form-group col-md-6"><label>E-mail</label><input type="email" name="suplentes[0][email]" class="form-control" placeholder="E-mail" value="{{suplentes.[0].email}}"></div>
                      <div class="form-group col-md-6"><label>Instituição</label><input type="text" name="suplentes[0][instituicao]" class="form-control" placeholder="ICOMP/UFAM, Outro PPGI/UFAM, Externa" value="{{suplentes.[0].instituicao}}"></div>
                      <div class="form-group col-md-12"><label class="d-block">Interno ou externo?<span class="text-danger">*</span></label>
                        <div class="form-check form-check-inline"><input class="form-check-input" type="radio" name="suplentes[0][vinculo]" id="sup0Interno" value="INTERNO" {{#ifEqual suplentes.[0].vinculo 'INTERNO'}}checked{{/ifEqual}}><label class="form-check-label" for="sup0Interno">Interno</label></div>
                        <div class="form-check form-check-inline"><input class="form-check-input" type="radio" name="suplentes[0][vinculo]" id="sup0Externo" value="EXTERNO" {{#ifEqual suplentes.[0].vinculo 'EXTERNO'}}checked{{/ifEqual}}><label class="form-check-label" for="sup0Externo">Externo</label></div>
                      </div>
                    </div>
                  </div>
                </div>

                {{!-- Suplente 2 (Obrigatório) --}}
                <div class="card card-primary">
                  <div class="card-header"><h3 class="card-title">2º Suplente <span class="text-danger">*</span></h3></div>
                  <div class="card-body">
                     <div class="form-row">
                      <div class="form-group col-md-12"><label>Nome</label><input type="text" name="suplentes[1][nome]" class="form-control" placeholder="Nome completo" value="{{suplentes.[1].nome}}"></div>
                      <div class="form-group col-md-6"><label>E-mail</label><input type="email" name="suplentes[1][email]" class="form-control" placeholder="E-mail" value="{{suplentes.[1].email}}"></div>
                      <div class="form-group col-md-6"><label>Instituição</label><input type="text" name="suplentes[1][instituicao]" class="form-control" placeholder="ICOMP/UFAM, Outro PPGI/UFAM, Externa" value="{{suplentes.[1].instituicao}}"></div>
                       <div class="form-group col-md-12"><label class="d-block">Interno ou externo?<span class="text-danger">*</span></label>
                        <div class="form-check form-check-inline"><input class="form-check-input" type="radio" name="suplentes[1][vinculo]" id="sup1Interno" value="INTERNO" {{#ifEqual suplentes.[1].vinculo 'INTERNO'}}checked{{/ifEqual}}><label class="form-check-label" for="sup1Interno">Interno</label></div>
                        <div class="form-check form-check-inline"><input class="form-check-input" type="radio" name="suplentes[1][vinculo]" id="sup1Externo" value="EXTERNO" {{#ifEqual suplentes.[1].vinculo 'EXTERNO'}}checked{{/ifEqual}}><label class="form-check-label" for="sup1Externo">Externo</label></div>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/editar/{{defesa.id}}/final/step4" class="btn btn-default"><i class="fas fa-chevron-left"></i> Voltar</a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">Salvar rascunho</button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuarFinalStep5" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header"><h3 class="card-title">Regras para Suplentes</h3></div>
            <div class="card-body">
              <p>São necessários <strong>dois</strong> membros suplentes.</p>
               <p>Regra sugerida: um interno e um externo, ou dois externos.</p>
              <hr>
              <p class="text-muted mb-0">Link p/ externos: <a href="https://forms.gle/SCrwhfM8rVoVH6ks8" target="_blank" rel="noopener noreferrer">Formulário Membros Externos</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

{{> footer}}


<script>
  $(document).ready(function() {
    const btnContinuar = $('#btnContinuarFinalStep5');
    let requiredFields = [];
    // Sempre 2 suplentes obrigatórios
    for (let i = 0; i < 2; i++) {
      requiredFields.push(`input[name="suplentes[${i}][nome]"]`);
      requiredFields.push(`input[name="suplentes[${i}][email]"]`);
      requiredFields.push(`input[name="suplentes[${i}][instituicao]"]`);
      requiredFields.push(`input[name="suplentes[${i}][vinculo]"]`);
    }
    const allRequiredSelectors = requiredFields.join(', ');

    function checkFormValidity() { 
       let isValid = true;
       $(allRequiredSelectors).each(function() {
         if ($(this).is(':radio')) { 
            const groupName = $(this).attr('name');
            if ($(`input[name="${groupName}"]:checked`).length === 0) { isValid = false; return false; }
         } else { 
           if (($(this).val()?.trim() ?? '') === '') { isValid = false; return false; }
         }
       });
       return isValid;
    }
    function updateButtonState() { btnContinuar.prop('disabled', !checkFormValidity()); }
    $(document).on('input keyup change', allRequiredSelectors, updateButtonState);
    updateButtonState(); 
  });
</script>