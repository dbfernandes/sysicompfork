{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Qualificação — Etapa 6</h1>
          <small class="text-muted">Membros da banca (suplentes)</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Qualificação — Etapa 6</li>
          </ol>
        </div>
      </div>

      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 85%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span>1. Dados iniciais</span>
            <span>2. Local</span>
            <span>3. Trabalho</span>
            <span>4. Presidente</span>
            <span>5. Membros</span>
            <span><strong>6. Suplentes</strong></span>
            <span>7. Proposta/Artigos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}
        <div class="alert alert-danger"><ul class="mb-0">{{#each errors}}<li>{{this}}</li>{{/each}}</ul></div>
      {{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}

      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Membros da Banca (Suplentes)</h3>
            </div>

            <form id="formStep6" method="POST" action="/defesas/editar/{{defesa.id}}/qualificacao/step6">
              <div class="card-body">
                <p class="text-muted">Informe os dados para os dois membros suplentes da banca.</p>

                <div class="card card-primary">
                  <div class="card-header">
                    <h3 class="card-title">1º Suplente <span class="text-danger">*</span></h3>
                  </div>
                  <div class="card-body">
                    <div class="form-row">
                      <div class="form-group col-md-12">
                        <label>Nome</label>
                        <input
                          type="text"
                          name="suplentes[0][nome]"
                          class="form-control"
                          placeholder="Nome completo do suplente"
                          value="{{suplentes.[0].nome}}"
                        >
                      </div>
                      <div class="form-group col-md-6">
                        <label>E-mail</label>
                        <input
                          type="email"
                          name="suplentes[0][email]"
                          class="form-control"
                          placeholder="E-mail para contato"
                          value="{{suplentes.[0].email}}"
                        >
                      </div>
                      <div class="form-group col-md-6">
                        <label>Instituição</label>
                        <input
                          type="text"
                          name="suplentes[0][instituicao]"
                          class="form-control"
                          placeholder="ICOMP/UFAM, Outro PPGI/UFAM, Externa"
                          value="{{suplentes.[0].instituicao}}"
                        >
                      </div>
                    </div>
                  </div>
                </div>

                <div class="card card-primary">
                  <div class="card-header">
                    <h3 class="card-title">2º Suplente <span class="text-danger">*</span></h3>
                  </div>
                  <div class="card-body">
                    <div class="form-row">
                      <div class="form-group col-md-12">
                        <label>Nome</label>
                        <input
                          type="text"
                          name="suplentes[1][nome]"
                          class="form-control"
                          placeholder="Nome completo do suplente"
                          value="{{suplentes.[1].nome}}"
                        >
                      </div>
                      <div class="form-group col-md-6">
                        <label>E-mail</label>
                        <input
                          type="email"
                          name="suplentes[1][email]"
                          class="form-control"
                          placeholder="E-mail para contato"
                          value="{{suplentes.[1].email}}"
                        >
                      </div>
                      <div class="form-group col-md-6">
                        <label>Instituição</label>
                        <input
                          type="text"
                          name="suplentes[1][instituicao]"
                          class="form-control"
                          placeholder="ICOMP/UFAM, Outro PPGI/UFAM, Externa"
                          value="{{suplentes.[1].instituicao}}"
                        >
                      </div>
                    </div>
                  </div>
                </div>

              </div>

              <div class="card-footer d-flex justify-content-between">
                <a href="/defesas/editar/{{defesa.id}}/qualificacao/step5" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuarStep6" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header">
              <h3 class="card-title">Regras para Suplentes</h3>
            </div>
            <div class="card-body">
              <p>Os suplentes devem ser <strong>um interno e um externo</strong>, ou <strong>dois externos</strong>.</p>
              <p class="text-muted">
                Os participantes externos devem ser cadastrados no Sucupira, então precisamos dos dados pessoais dos membros. Resolução 033/2014.
              </p>
              <hr>
              <p class="text-muted mb-0">
                Para convidados externos, por favor envie o link a seguir para que preencham seus dados e a documentação possa ser gerada:
                <a href="https://forms.gle/SCrwhfM8rVoVH6ks8" target="_blank" rel="noopener noreferrer">Formulário para Membros Externos</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  $(document).ready(function () {
    const $form = $('#formStep6');
    const $btnContinuar = $('#btnContinuarStep6');

    let hasTriedSubmit = false;

    const validator = $form.validate({
      ignore: ':hidden',

      rules: {
        'suplentes[0][nome]': {
          required: true,
          maxlength: 191
        },
        'suplentes[0][email]': {
          email: true,
          maxlength: 191
        },
        'suplentes[0][instituicao]': {
          maxlength: 191
        },

        'suplentes[1][nome]': {
          required: true,
          maxlength: 191
        },
        'suplentes[1][email]': {
          email: true,
          maxlength: 191
        },
        'suplentes[1][instituicao]': {
          maxlength: 191
        }
      },

      messages: {
        'suplentes[0][nome]': {
          required: 'Informe o nome do 1º suplente.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        },
        'suplentes[0][email]': {
          email: 'Informe um e-mail válido.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        },
        'suplentes[0][instituicao]': {
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        },

        'suplentes[1][nome]': {
          required: 'Informe o nome do 2º suplente.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        },
        'suplentes[1][email]': {
          email: 'Informe um e-mail válido.',
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        },
        'suplentes[1][instituicao]': {
          maxlength: 'O campo pode ter no máximo 191 caracteres.'
        }
      },

      errorElement: 'span',
      errorPlacement: function (error, element) {
        error.addClass('invalid-feedback');
        element.closest('.form-group').append(error);
      },

      highlight: function (element) {
        $(element).addClass('is-invalid');
      },

      unhighlight: function (element) {
        $(element).removeClass('is-invalid');
      },

      onkeyup: false,
      onfocusout: false,
      onclick: false,

      showErrors: function () {
        if (!hasTriedSubmit) return;
        this.defaultShowErrors();
      },

      invalidHandler: function () {
        if (!hasTriedSubmit) {
          hasTriedSubmit = true;

          validator.settings.onkeyup = function (element) {
            $(element).valid();
            updateButtonState();
          };

          validator.settings.onfocusout = function (element) {
            $(element).valid();
            updateButtonState();
          };

          validator.settings.onclick = function (element) {
            $(element).valid();
            updateButtonState();
          };
        }

        updateButtonState();
      },

      submitHandler: function (form, e) {
        const actionValue =
          $(document.activeElement).attr('name') === 'action'
            ? $(document.activeElement).val()
            : null;

        if (actionValue === 'save') {
          form.submit();
          return;
        }

        e.preventDefault();

        if (!hasTriedSubmit) hasTriedSubmit = true;

        if (!validator.form()) {
          updateButtonState();
          return;
        }

        form.submit();
      }
    });

    function updateButtonState() {
      const isValid = validator.checkForm();
      $btnContinuar.prop('disabled', !isValid);
    }

    $form.find('input').on('input keyup change', updateButtonState);

    updateButtonState();
  });
</script>

{{> footer}}