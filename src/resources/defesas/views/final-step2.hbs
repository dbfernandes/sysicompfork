{{> header}}
{{> sidebar module='defesas' page='defesas-listar'}}

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-100 align-items-center justify-content-between flex-wrap" style="gap:8px; white-space:nowrap;">
        <div>
          <h1>Defesa Final — Etapa 2</h1> 
          <small class="text-muted">Local da defesa</small>
        </div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/defesas/listar">Defesas</a></li>
            <li class="breadcrumb-item active">Defesa Final — Etapa 2</li> {{!-- Breadcrumb Atualizado --}}
          </ol>
        </div>
      </div>

      <div class="row mt-2">
        <div class="col-12">
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 33%;" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100"></div> {{!-- Progresso Atualizado --}}
          </div>
          <div class="d-flex justify-content-between mt-1 small text-muted">
            <span>1. Dados iniciais</span>
            <span><strong>2. Local</strong></span>
            <span>3. Trabalho</span>
            <span>4. Membros</span>
            <span>5. Suplentes</span>
            <span>6. Documentos</span> 
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      {{#if errors}}<div class="alert alert-danger"><ul class="mb-0">{{#each errors}}<li>{{this}}</li>{{/each}}</ul></div>{{/if}}
      {{#if defesa.correcaoSolicitada}}
        <div class="alert alert-warning" role="alert">
          <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correção Solicitada pela Secretaria</h5>
          <p>A sua solicitação de defesa foi retornada para correção. Por favor, revise os itens abaixo, faça os ajustes necessários e submeta novamente (na última etapa):</p>
          <hr>
          <p class="mb-0" style="white-space: pre-wrap;">{{defesa.correcaoSolicitada}}</p>
        </div>
      {{/if}}
      <div class="row">
        <div class="col-md-8">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title">Local da Defesa Final</h3>
            </div>

            <form id="formFinalStep2" method="POST" action="/defesas/editar/{{defesa.id}}/final/step2">
              <div class="card-body">
                <div class="form-group">
                  {{#ifEqual defesa.modalidade 'PRESENCIAL'}}
                    <label for="local">Local da defesa <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="local" name="local" 
                           placeholder="Ex: Auditório Rio Negro, ICOMP" value="{{defesa.localOuLink}}">
                    <small class="form-text text-muted">Digite o local da defesa presencial (ex: nome da sala, auditório).</small>
                  {{else}}
                    <label for="local">Link da reunião <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="local" name="local" 
                           placeholder="https://meet.google.com/..." value="{{defesa.localOuLink}}">
                    <small class="form-text text-muted">Cole o link da reunião online (Google Meet, Teams, etc.).</small>
                  {{/ifEqual}}
                </div>
              </div><div class="card-footer d-flex justify-content-between">
                <a href="/defesas/editar/{{defesa.id}}/final/step1" class="btn btn-default">
                  <i class="fas fa-chevron-left"></i> Voltar
                </a>
                <div>
                  <button type="submit" class="btn btn-secondary mr-2" name="action" value="save">
                    <i class="fas fa-save"></i> Salvar rascunho
                  </button>
                  <button type="submit" class="btn btn-primary" name="action" value="next" id="btnContinuarFinalStep2" disabled>
                    Continuar <i class="fas fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card card-outline card-info">
            <div class="card-header"><h3 class="card-title">Requisitos desta etapa</h3></div>
            <div class="card-body">
              <ul class="mb-0">
                <li>Informar o local (sala/auditório) ou o link da reunião para a defesa.</li>
              </ul>
              <hr>
              <p class="text-muted mb-0">Esta informação é necessária para a geração da ata e para a divulgação pública.</p>
            </div>
          </div>
        </div>
      </div></div></section>
</div>

{{> footer}}


<script>
  $(document).ready(function() {
    const localInput = $('#local');
    const btnContinuar = $('#btnContinuarFinalStep2'); 

    function checkFormValidity() {
      const localVal = localInput.val()?.trim() ?? '';
      return localVal !== '';
    }

    function updateButtonState() {
      btnContinuar.prop('disabled', !checkFormValidity());
    }

    localInput.on('input keyup', updateButtonState);
    updateButtonState(); 
  });
</script>