{{> numerosIcomp/navbar page="docentes"}}
<div class="flex-wrapper bg-primary">
  <section class="mb-3">
    <div class="container">
      <div class="card card-body mx-3 mx-md-4 mt-n6">
        <div class="row gx-4 mb-4">
          <div class="nav-wrapper position-relative end-0">
            <ul class="nav nav-pills nav-fill p-1" role="tablist">
              <li class="nav-item">
                <a id="profile-tab" class="nav-link mb-0 px-0" href="/docentes/{{professor.id}}?lng={{lng}}" aria-controls="profile" role="tab" aria-selected="true">
                  <i class="material-icons position-relative">person</i>
                  <span class="ms-1">{{__ 'profile.perfil'}}</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link mb-0 px-0 " href="/docentes/{{professor.id}}/publicacoes?lng={{lng}}" aria-controls="public" role="tab" aria-selected="false">
                  <i class="material-icons position-relative">description</i>
                  <span class="ms-1">{{__ 'profile.publicacoes'}}</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link mb-0 px-0 active" href="/docentes/{{professor.id}}/projetos?lng={{lng}}" role="tab" aria-controls="code" aria-selected="false">
                  <i class="material-icons text-lg position-relative">search</i>
                  <span class="ms-1">{{__ 'profile.projetosDePesquisa'}}</span>
                </a>
              </li>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle mb-0 px-0 " data-bs-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                  <i class="material-icons text-lg position-relative">account_circle</i>
                  <span class="ms-1">{{__ 'profile.orientacoes'}}</span>
                </a>
                <div class="dropdown-menu w-100 text-center">
                  <a class="dropdown-item" href="/docentes/{{professor.id}}/orientacoes/graduacao?lng={{lng}}">{{__ 'profile.graduacao'}}</a>
                  <a class="dropdown-item" href="/docentes/{{professor.id}}/orientacoes/mestrado?lng={{lng}}">{{__ 'profile.mestrado'}}</a>
                  <a class="dropdown-item" href="/docentes/{{professor.id}}/orientacoes/doutorado?lng={{lng}}">{{__ 'profile.doutorado'}}</a>
                </div>
              </li>
              <li class="nav-item">
                <a class="nav-link mb-0 px-0" href="/docentes/{{professor.id}}/premios?lng={{lng}}" role="tab" aria-controls="code" aria-selected="false">
                  <i class="material-icons text-lg position-relative">military_tech</i>
                  <span class="ms-1">{{__ 'profile.premios'}}</span>
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div class="tab-content" id="myTabContent">
          <div class="tab-pane fade show active" id="research" role="tabpanel" aria-labelledby="research-tab">
            <div class="card mb-3">
              <div class="card-body p-3" >
                <div class="w-100 text-center">
                  <h4 class="mb-4">
                    {{professor.nomeCompleto}}
                  </h4>
                </div>
                <div class="chart mb-4" style="height: 220px">
                  <canvas id="line-chart-3" class="chart-canvas" ></canvas>
                </div>
                <div class="nav-wrapper position-relative end-0 pt-3">
                  <ul class="nav nav-tabs p-1" role="tablist">
                    <li class="nav-item">
                      <a class="nav-link px-3" id="research-tab" data-bs-toggle="tab" href="#research-content" role="tab" aria-controls="research-content" aria-selected="true">{{__ 'profile.projetosDePesquisa'}} ({{projetosLen}})</a>
                    </li>
                  </ul>
                </div>
                <div class="tab-content" id="myTabContent2">
                  <div class="tab-pane fade show" id="research-content" role="tabpanel" aria-labelledby="research-tab">
                    <ol class="mt-3 text-dark" style="font-size: 14px;">
                      {{#if projetos}}
                        {{#each projetos}}
                          <li><strong>{{inicio}}-{{#if fim}}{{fim}}{{else}}{{__ 'profile.atual'}}{{/if}}.</strong> <i>{{titulo}}.</i> ({{papel}})
                            <br><br>
                            <strong>{{__ 'profile.descricao'}}: </strong>{{descricao}}
                            <br>
                            <br>
                            <strong>{{__ 'profile.integrantes'}}: </strong> {{integrantes}}.
                            <br>
                            <br>
                            <strong>{{__ 'profile.financiadores'}}: </strong> {{financiadores}}.
                          </li><br>
                        {{/each}}
                      {{else}}
                        {{__ 'profile.naoHaProjetos'}} {{professor.nomeCompleto}}.
                      {{/if}}
                    </ol>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
<script>
    // Line chart
    var ctx3 = document.getElementById("line-chart-3").getContext("2d");
    var labels = [{{anos}}]

    

    new Chart(ctx3, {
        type: "line",
        data: {
            labels,
            datasets: [{
                label: "{{__ 'profile.projetos'}}",
                tension: 0,
                borderWidth: 0,
                pointRadius: 5,
                pointBackgroundColor: "#18bc9c",
                borderColor: "#18bc9c",
                borderWidth: 3,
                backgroundColor: 'transparent',
                data: [{{graficoProjetos}}],
                maxBarThickness: 6
            },
            ],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
            legend: {
                display: false,
            },
            title: {
                fullsize: true,
                color: '#344767',
                display: true,
                text: '{{__ "profile.projetosDePesquisa"}}',
                font: {
                    size: 24
                },
            }
            },
            interaction: {
            intersect: false,
            mode: 'index',
            },
            scales: {
            y: {
                grid: {
                drawBorder: false,
                display: true,
                drawOnChartArea: true,
                drawTicks: false,
                borderDash: [5, 5]
                },
                ticks: {
                display: true,
                padding: 10,
                color: 'gray',
                font: {
                    size: 14,
                    family: "Open Sans",
                    style: 'normal',
                    lineHeight: 2
                },
                }
            },
            x: {
                grid: {
                drawBorder: false,
                display: true,
                drawOnChartArea: true,
                drawTicks: true,
                borderDash: [5, 5]
                },
                ticks: {
                display: true,
                color: 'gray',
                padding: 10,
                font: {
                    size: 14,
                    family: "Open Sans",
                    style: 'normal',
                    lineHeight: 2
                },
                }
            },
            },
        },
    });
</script>
{{> numerosIcomp/footer}}
</div>