<div class="page-container">
    <style>
        .page-container {
            position: relative;
            min-height: 100vh;
        }
        .content-wrapper {
            padding-bottom: 2.5em;
        }
        footer {
            position: absolute;
            bottom: 0;
            width: 100%;
        }
    </style>
    <div class="content-wrapper">

    
        {{> numerosIcomp/navbar}}
        <header class="text-center">

            <div class="page-header" style="background: #18bc9c; min-height: 600px;">
                <div class="container">
                    <div class="row">
                        <div class="col-md-12">
                            <div>
                                    <img class="img-fluid me-5 mb-3" src="/public/img/logo-icomp.png" alt="" width="320px">
                                    <img class="img-fluid mb-3" src="/public/img/logo-ufam.png" alt="" width="136">
                            </div>
                            <span class="text-white mb-4 mt-sm-3 header-title">{{__ "error.titulo"}}</span>
                        </div>
                        
                    </div>
                </div>
                </div>
        </header>
        <div class="mt-5 site-error text-center">
            <div class="alert alert-danger">
                <h1 class="">{{__ "error.naoEncontrada"}}. (404)</h1>
            </div>

        </div>
    
    </div>
    {{> numerosIcomp/footer}}
</div>