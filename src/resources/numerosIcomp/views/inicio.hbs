                        </div>
                    </div>
                </div>
                
                
            </div>
        </div>
    </section>

    <section id="publicacoes" class="pt-6 pb-9">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-12 text-center">
                <h3>{{__ "landing.conferenciaEPublicacoes"}}</h3>
                <span class="mt-2">{{__ "landing.verifiqueArtigos"}}</span>
                <hr style="border-top: 3px solid; border-top-color: #000; border-color: #000;">
                </div>
            </div>
            <div class="chart" style="height: 400px">
                <canvas id="line-chart" class="chart-canvas" ></canvas>
            </div>
        </div>
    </section>

    <script>
            // Line chart
    
    var labels = [{{contagemPublicacoes.anos}}]
    var ctx1 = document.getElementById("line-chart")
    if(ctx1){
        const chart = new Chart(ctx1.getContext("2d"), {
            type: "bar",
            data: {
                labels: labels,
                datasets: [
                    {
                        label: "{{__ 'landing.publicacoesEmPeriodicos'}}",
                        backgroundColor: "#18bc9c",
                        stack: 'Stack 0',
                        data: [{{contagemPublicacoes.contagemTotal.Periodico}}],
                    },
                    {
                        label: "{{__ 'landing.publicacoesEmConferencias'}}",
                        backgroundColor: "#344767",
                        stack: 'Stack 0',
                        data: [{{contagemPublicacoes.contagemTotal.Conferencia}}],
                    },
                ],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        color: '#344767',
                        font: {
                            size: 24
                        },
                    },
                    title: {
                        fullsize: true,
                        color: '#344767',
                        display: true,
                        text: '{{__ "landing.historicoDePublicacoes"}}',
                        font: {
                            size: 24
                        },
                    }
                },
                onHover: function(e, chartElement) {
                    e.native.target.style.cursor = 
                        chartElement.length > 0 ? "pointer" : "default"
                },
                scales: {
                    y: {
                        stacked: true,
                        ticks: {
                            display: true,
                            padding: 10,
                            color: '#344767',
                            font: {
                                size: 15,
                                family: "Open Sans",
                                style: 'normal',
                                lineHeight: 2
                            },
                        }
                    },
                    x: {
                        stacked: true,
                        ticks: {
                            display: true,
                            color: '#344767',
                            padding: 10,
                            font: {
                                size: 15,
                                family: "Open Sans",
                                style: 'normal',
                                lineHeight: 2
                            },
                        }
                    },
                },
            },
        });
        ctx1.onclick = (evt) => {
        const res = chart.getElementsAtEventForMode(
            evt,
            'nearest',
            { intersect: true },
            true
        );
        if (res.length === 0) {
            return;
        }
        // Alerts "You clicked on A" if you click the "A" chart
        const ano = chart.data.labels[res[0].index]
        window.location.href = `/publicacoes?ano=${ano}`;
        };
    }

    
    </script>

    {{> numerosIcomp/footer}}

</div>