{{> header}}
{{> sidebar module='linhasDePesquisa' page='linhasDePesquisa-criar'}}


<div class="content-wrapper">
	<section class="content-header">
		<div class="container-fluid">

			<div class="row mb-2">
				<div class="col-sm-9">
					<h1>Adicionar Linhas de Pesquisa</h1>
				</div>
				<div class="col-sm-3">
					<ol class="breadcrumb float-sm-right">
						<li class="breadcrumb-item"><a href="/">Página Inicial</a></li>
						<li class="breadcrumb-item"><a href="/linhasdepesquisa/listar">Listar Pesquisas</a></li>
						<li class="breadcrumb-item active">Adicionar Pesquisa</li>
					</ol>
				</div>
			</div>
			{{#if error}}
			<div id="toastsContainerTopRight" class="toasts-top-right fixed">
				<div class="toast bg-danger fade show" role="alert" aria-live="assertive" aria-atomic="true">
					<div class="toast-header"><strong class="mr-auto">Alerta</strong></div>
					<div class="toast-body">{{error}}</div>
				</div>
			</div>
			{{/if}}
			<div class="row mb-2">
				<div class="text-nowrap col-sm-3 col-md-2 col-lg-1 min-width-button mt-4">
					<a class="btn btn-warning color-white" onclick="history.go(-1);">
						<i class="fa fa-arrow-left"></i>
						Voltar
					</a>
					<a type="button" class="btn btn-primary" href="/linhasdepesquisa/listar">
						<i class="fa fa-list color-white"></i>
						Listar Usuários
					</a>
				</div>
			</div>

		</div>
	</section>

	<section class="content">
		<div class="container-fluid">
			<div class="row">
				<div class="col-12">
					<div style="text-align:left">
						<font color="#FF0000">*</font> Campos Obrigatórios
					</div>
					<div class="card card-primary">
						<div class="card-header">
							<h3 class="card-title">Dados da Linha de Pesquisa</h3>
						</div>
						<div class="card-body">
							<form action="/linhasDePesquisa/criar" method="POST" id="linhaDePesquisaForm">
								<input type="hidden" name="_csrf" id="_csrf" value="{{csrfToken}}">
								<div class="form-group">
									<label for="inputNome">
										<font color="#FF0000">*</font> Nome da Pesquisa:
									</label>
									<input type="text" name="nome" class="form-control" id="nome"
										placeholder="Nome da Linha de Pesquisa..." required>
								</div>
								<div class="form-group">
									<label for="inputSigla">
										<font color="#FF0000">*</font> Siglas da Pesquisa:
									</label>
									<input type="text" name="sigla" class="form-control" id="sigla"
										placeholder="Siglas..." required>
								</div>

						</div>
						<div class="card-footer">
							<div class="col">
								<input type="submit" value="Criar nova Pesquisa" class="btn btn-success float-right">
							</div>
						</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</section>

</div>

<script>

	function defineColor() {
		const colorFields = document.querySelectorAll('.color-field');

		colorFields.forEach((element) => {
			const color = element.classList.item(1);

			element.style.backgroundColor = color;
		});
	}

	window.onload = defineColor;

	function pesquisaCriarPage() {

		$('#linhaDePesquisaForm').validate({
			rules: {
				nome: {
					required: true,
				},
				sigla: {
					required: true,
				},
			},
			messages: {
				nome: {
					required: '"Nome de Pesquisa" não pode ficar em branco."'
				},
				sigla: {
					required: '"Siglas da Pesquisa" não pode ficar em branco.'
				},
			},
			errorElement: 'span',
			errorPlacement: function (error, element) {
				error.addClass('invalid-feedback');
				element.closest('div').append(error);
			},
			highlight: function (element, errorClass, validClass) {
				$(element).addClass('is-invalid');
			},
			unhighlight: function (element, errorClass, validClass) {
				$(element).removeClass('is-invalid');
			}
		});
	}
	$(document).ready(function () {
		setTimeout(function () {
			$('.toast').removeClass('show');
		}, 7000);
	});
</script>
{{> footer}}