<style>
  .error {
    color: red
  }

  .success {
    color: green;
  }

	 form i {
            margin-left: -30px;
            cursor: pointer;
        }

		.input-password {
			position: relative;
		}

		.input-password i {
			position: absolute;
			top: 10px;
			right: 10px;
			cursor: pointer;
		}
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css" />

<div class="login-box"> 
  <div class="login-logo container-cards">
    <img src="/public/img//logo-icomp.png" alt="">
    <img src="/public/img//logo-ufam.png" alt="">
  </div>
  <div class="card">
    <div class="card-body login-card-body">
      <div class="login-logo">
       <b>Login</b>
      </div>
      <!-- /.login-logo -->
      <p class="login-box-msg">Insira suas credenciais para realizar login</p>
      {{#if message}}
      <div class="alert alert-{{type}}">
        {{{message}}}
      </div>
      {{/if}} 

      <form action="/login" method="post" id="loginForm">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="form-group">
          <label for="cpfInput">CPF</label>
          <input id="cpfInput" name="cpf" type="text" autocomplete="off" class="form-control cpf" placeholder="___.___.___-__">
        </div>
        <div class="form-group"> 
      
        <label for="password">Senha</label>
        <div class="form-group input-group ">
          <input id="senhaInput" name="senha" type="password" class="form-control" placeholder="*********">
          <div class="input-group-append" >
   				  <span  id="togglePassword" class="input-group-text"style="color: transparent;" id="basic-addon2">===
					    <i  class="bi bi-eye-slash" style="color: gray;" id="togglePasswordIcon"></i>
					  </span>
  				</div>
        </div>
        <div class="row">
          <div class="col-md-8">
            <div class="checkbox icheck">
              <label>
                <input id="remember" name="remember" type="checkbox"> Lembrar Usuário
              </label>
            </div>
          </div>
          <!-- /.col -->
          <div class="col-md-4">
            <button type="submit" class="btn btn-primary btn-block">Entrar</button>
          </div>
          <!-- /.col -->
        </div>
      </form>

      <a href="/recuperarSenha">Esqueci minha senha</a><br>
    </div>
  </div>

  <!-- /.login-box-body -->
</di>
<!-- /.login-box -->

<script>
  function loginPage() {
    $("#togglePassword").click(function() {
		  const typeActual = $("#senhaInput").attr("type");
        if (typeActual === "password") {
			    $("#senhaInput").attr("type", "text");
          $(this).children().toggleClass("bi-eye-slash bi-eye");
        } else {
			    $("#senhaInput").attr("type", "password");
			    $(this).children().toggleClass("bi-eye bi-eye-slash");
		    }
	    });

    $.validator.addMethod("cpfLength", function (el) {
      const cpfValue = $('#cpfInput')[0].value.split('.').join('').split('-').join('').split('_').join('')
      return cpfValue.length === 11
    })

    $.validator.setDefaults({
      onfocusout: function (el) {
        this.element(el);
      },
    });

    $('#loginForm').validate({
      rules: {
        cpf: {
          required: true,
          cpfLength: true,
        },
        senha: {
          required: true,
          minlength: 6,
        },
      },
      messages: {
        cpf: {
          required: '"CPF (Digite somente números)" não pode ficar em branco.',
          cpfLength: '"CPF" deve ter 11 dígitos.',
        },
        senha: {
          required: '"Senha" não pode ficar em branco',
          minlength: '"Senha" deve conter pelo menos 6 caracteres'
        },
      },
      errorElement: 'span',
      errorPlacement: function (error, element) {
        error.addClass('invalid-feedback');
        element.closest('div').append(error);
      },
      highlight: function (element, errorClass, validClass) {
        $(element).addClass('is-invalid');
      },
      unhighlight: function (element, errorClass, validClass) {
        $(element).removeClass('is-invalid');
      }
    });
  }
</script>