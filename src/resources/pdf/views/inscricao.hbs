<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        font-family: system-ui, sans-serif;
        width: 100%;
        padding: 0;
        margin: 0;
        font-size: 16px;
      }

      .line-strok {
        width: 100%;
        height: 2px;
        background-color: black;
        border: 0;
      }

      h4 {
        text-align: center;
        font-size: 17px;
        text-transform: uppercase;
        width: 100%;
        margin: 0;
        padding: 8px 0;
      }

      .text-item {
        padding: 0;
        margin: 0;
        font-weight: normal;
        font-size: 16px;
      }

      .absolute-center {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
      }

      .table-info {
        width: 100%;
        border-collapse: collapse;
      }
      .page-break {
        page-break-before: always;
      }

      .container-motivos {
        border: 2px solid black;
        min-height: 150px;
        padding: 4px;
        margin: 4px 0 0;
      }
    </style>
</head>
<body>
    <!-- Content -->
    <div style="display:block">
      <table style="width: 100%; position:relative;">
        <td class="absolute-center" >
          <h4>COMPROVANTE DE INSCRIÇÃO</h4>
        </td>
        <td style="text-align: end; width: 100%;" >
          <p class="text-item"><strong>Hora: {{finishData}}</strong></p>
          <p class="text-item"><strong>Data: {{finishTime}}</strong></p>
        </td>
      </table>
      <hr class="line-strok">
      <p style="margin-bottom: 8px;"><strong>Dados Pessoais</strong></p>
      <table class="table-info">
        <tr>
          <td colspan="2" class="full-width"><strong>Número da inscrição:</strong> {{registrationNumber}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Nome:</strong> {{name}}</td>
          <td style="width: 50%;"><strong>Nome Social:</strong> {{socialName}}</td>
        </tr>
        <tr>
          <td colspan="2" class="full-width"><strong>Endereço:</strong> {{address}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>CEP:</strong> {{cep}}</td>
          <td style="width: 50%;"><strong>Bairro:</strong> {{neighborhood}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Cidade:</strong> {{city}}</td>
          <td style="width: 50%;"><strong>País:</strong> {{country}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Data de Nascimento:</strong> {{birthDate}}</td>
          <td style="width: 50%;">Sexo: Masculino</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Nacionalidade:</strong> {{nacionality}}</td>
          {{#if cpf}}
            <td style="width: 50%;"><strong>CPF:</strong> {{cpf}}</td>
          {{/if}}
          {{#if passport}}
            <td style="width: 50%;"><strong>Passaporte:</strong> {{passport}}</td>
          {{/if}}
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Telefone Principal:</strong> {{mainPhone}}</td>
          <td style="width: 50%;"><strong>Telefone Alternativo:</strong> {{secondaryPhone}}</td>
        </tr>
      </table>

      <hr>
      <h4>Formação acadêmica</h4>
      <hr>
      <p style="margin-bottom: 8px;"><strong>Curso de Graduação</strong></p>
      <table class="table-info">
        <tr>
          <td colspan="2" class="full-width"><strong>Curso:</strong> {{undergrateCourse}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Instituição: </strong> {{undergrateInstitution}}</td>
          <td style="width: 50%;"><strong>Ano Egresso: </strong> {{undergrateYear}}</td>
        </tr>
      </table>
      <p style="margin-bottom: 8px;"><strong>Curso de Pos-Graduação Stricto-Senso</strong></p>
      <table class="table-info">
        <tr>
          <td colspan="2" class="full-width"><strong>Curso: </strong> {{postgrateCourse}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Instituição:</strong> {{postgrateInstitution}}</td>
          <td style="width: 50%;"><strong>Tipo:</strong> {{postgrateType}} <strong>Ano Egresso:</strong> {{postgrateYear}}</td>
        </tr>
      </table>
      <p style="margin-bottom: 8px;"><strong>Publicações</strong></p>
      <table class="table-info">
        <tr>
          <td style="width: 50%;"><strong>Em Periódicos:</strong> {{numberPeriodicos}}</td>
          <td style="width: 50%;"><strong>Em Conferências:</strong> {{numberConferencias}}</td>
        </tr>
      </table>
      <p style="margin-bottom: 8px;"><strong>Experiência Acadêmica</strong></p>
      {{#if academicExperiences}}
        <div style="width: 100%; display:flex; margin-bottom: 8px; padding-left: 4px;">
          <p style="width: 33%;" class="text-item"><strong>Instituição</strong></p>
          <p style="width: 33%;" class="text-item"><strong>Atividade/Cargo</strong></p>
          <p style="width: 34%;" class="text-item"><strong>Período</strong></p>
        </div>
        {{#each academicExperiences}}
          <div style="width: 100%; display: flex; margin-bottom: 8px; border-left: 2px solid black; border-radius: 2px; padding-left: 4px;">
            <p style="width: 33%;" class="text-item">{{instituicao}}</p>
            <p style="width: 33%;" class="text-item">{{atividade}}</p>
            <p style="width: 34%;" class="text-item">{{periodo}}</p>
          </div>
        {{/each}}
      {{else}}
        <p class="text-item">Nenhuma experiência acadêmica cadastrada</p>
      {{/if}}
      <h4 class="page-break" >Proposta de trabalho</h4>
      <hr >
      <p class="text-item" style="padding-top: 8px;"><strong>Título da proposta:</strong> {{proposalTitle}}</p>
      <p class="text-item" style="padding-bottom: 16px;"><strong>Linha de pesquisa:</strong> {{lineResearch}}</p>

      <table class="table-info" style="padding-top: 12px;">

        <tr>
          <td style="width: 50%;"><strong>Curso Desejado:</strong> {{desiredCourse}}</td>
          <td style="width: 50%;"><strong>Regime de Dedicação:</strong> {{regime}}</td>
        </tr>
        <tr>
          <td style="width: 50%;"><strong>Solicita Bolsa de Estudos?</strong> {{scholarship}}</td>
          <td style="width: 50%;"><strong>Regime de Cotas?</strong> {{quota}}</td>
        </tr>
        <tr>
          <td colspan="2" class="full-width"><strong>Possui algum tipo de problema de saúde física ou psiquiátrica?</strong>
            {{deficiency}}</td>
        </tr>
      </table>
      <p class="text-item" style="padding-top: 16px;"><strong>Exposição de motivos</strong> (exponha resumidamente os motivos que o(a) levaram a se candidatar):</p>
      <p class="container-motivos">{{reasons}}</p>

      {{#if hasRecommendations}}
        <p style="margin-bottom: 8px;"><strong>Cartas de Recomendação</strong></p>
        {{#if recommendations}}
          <div style="width: 100%; display:flex; margin-bottom: 8px; padding-left: 4px;">
            <p style="width: 50%;" class="text-item"><strong>Nome</strong></p>
            <p style="width: 50%;" class="text-item"><strong>Email</strong></p>
          </div>
          {{#each recommendations}}
            <div style="width: 100%; display: flex; margin-bottom: 8px; border-left: 2px solid black; border-radius: 2px; padding-left: 2px;">
              <p style="width: 50%;" class="text-item">{{nome}}</p>
              <p style="width: 50%;" class="text-item">{{email}}</p>
            </div>
          {{/each}}
        {{else}}
          <p class="text-item">Nenhuma recomendação cadastrada</p>
        {{/if}}
      {{/if}}

      {{#if periodicals}}
        <h2 class="page-break" >PERIÓDICOS</h2>
        <hr>
        {{#each periodicals}}
          <p class="text-item" style="padding: 8px 0;">{{this}}</p>
          <hr>
        {{/each}}
      {{/if}}
      {{#if conferences}}
        <h2 class="page-break" >CONFERÊNCIAS</h2>
        <hr>
        {{#each conferences}}
          <p class="text-item" style="padding: 8px 0;">{{this}}</p>
          <hr>
        {{/each}}
      {{/if}}
    </div>
</body>
</html>