{{> header}}
{{> sidebar module='afastamentoTemporario' page='solicitar-afastamento'}}
{{#section "head"}}
  <link rel="stylesheet" href="/script-adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/toastr/toastr.min.css"/>
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
{{/section}}
<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="d-flex mb-2 flex-row justify-content-between">
                <div >
                    <h1>Solicitação de afastamento temporário</h1>
                </div>
                <div >
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
                        <li class="breadcrumb-item">
                            <a href="/afastamentoTemporario/listar">Afastamentos</a>
                        </li>
                        <li class="breadcrumb-item active">Novo Afastamento</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">
                    <div class="text-nowrap col-sm-3 col-md-2 col-lg-2 mt-4">
                        <a class="btn btn-warning color-white" onclick="voltarPagina()">
                            <i class="fa fa-arrow-left"></i>
                            Voltar
                        </a>   
                    </div>
            </div>
        </div>


    </section>

    <section class="content">
		<div class="container-fluid">
			<div class="row">
				<div class="col-12">
          <div style="text-align:left">
            <span style="color: #FF0000; ">*</span> Campos Obrigatórios
					</div>
          <form action="/afastamentoTemporario/criar" method="POST" id="afastamentoTemporarioForm">
            <div class="card card-primary">
              <div class="card-header">
                <h3 class="card-title">Informações sobre o Pedido de Afastamento</h3>
              </div>

              <div class="card-body">
                <div class="form-group">
                  <label for="localViagem">
                    <span style="color: #FF0000; ">*</span> Local de Viagem:
                  </label>
                  <input type="text" name="localViagem" class="form-control" id="localViagem"
                         placeholder="Brasilia,DF..." required>
                </div>
                <div class="form-group">
                  <div class="row">
                    <div class="col-sm-12 col-md-6 col-lg-6">
                      <label for="dataSaida">
                        <span style="color: #FF0000; ">*</span> Data de saída:
                      </label>
                      <div class="input-group date" data-target-input="nearest">
                        <div class="input-group date" id="data_picker_saida" data-target-input="nearest">
                          <input type="text" class="form-control datetimepicker-input" name="dataSaida"  id="dataSaida"
                                 data-target="#data_picker_saida" placeholder="dd/mm/yyyy">
                          <div class="input-group-append" data-target="#data_picker_saida" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="col-sm-12 col-md-6 col-lg-6">
                      <label for="dataRetorno">
                        <span style="color: #FF0000; ">*</span> Data de Retorno:
                      </label>
                      <div class="input-group date" data-target-input="nearest">
                        <div class="input-group date" id="data_picker_retorno" data-target-input="nearest">
                          <input type="text" class="form-control datetimepicker-input" name="dataRetorno"  id="dataRetorno"
                                 data-target="#data_picker_retorno" placeholder="dd/mm/yyyy">
                          <div class="input-group-append" data-target="#data_picker_retorno" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="form-group">
                  <div class="row">
                    <div class="col-sm-6 col-sm-6">
                      <label for="justificativa" style="margin-right: 40px;">
                        <span style="color: #FF0000; ">*</span> Justificativa:
                      </label>
                      <textarea class="form-control" rows="3" placeholder="Enter ..." name="justificativa" id="justificativa" required></textarea>
                    </div>
                    <div class="col-sm-6 col-sm-6">
                      <label for="planoReposicao" style="margin-right: 40px;">
                        <span style="color: #FF0000; ">*</span> Plano de Reposição de Aulas:
                      </label>
                      <textarea class="form-control" rows="3" placeholder="Enter ..." name="planoReposicao" id="planoReposicao" required></textarea>
                    </div>
                  </div>
                </div>
                <div class="form-group">
                  <div class="col-xs-8" >
                    <div class="col" style="padding-bottom: 10px;">
                      <label for="tipoViagem" style="margin-right: 100px;">
                        <span style="color: #FF0000; ">*</span> Tipo de Viagem:
                      </label>
                      <div style="padding-top: 5px;">
                        <div class="form-check form-check-inline icheck-primary">
                          <input class="form-check-input" type="radio" name="tipoViagem" id="tipoViagemNacional" value="Nacional" required>
                          <label class="form-check-label" for="tipoViagemNacional">Nacional</label>
                        </div>
                        <div class="form-check form-check-inline icheck-primary">
                          <input class="form-check-input" type="radio" name="tipoViagem" id="tipoViagemInternacional" value="Internacional" required>
                          <label class="form-check-label" for="tipoViagemInternacional">Internacional</label>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="card-footer">
                <div class="col">
                  <button type="submit" class="btn btn-success float-md-right">Fazer Solicitação </button>
                </div>
              </div>
            </div>
          </form>
                    
        </div>
      </div>
    </div>
	</section>
</div>

<script src="/script-adminlte/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
<script src="/script-adminlte/plugins/moment/locale/pt-br.js"></script>
<script src="/script-adminlte/plugins/toastr/toastr.min.js"></script>

<script>
  function voltarPagina() {
    window.history.back();
  }
  $(document).ready(function () {

    const today = moment().startOf('day');

    // Se já tinha instância criada antes, destrua para evitar conflito
    $('#data_picker_saida').data('datetimepicker')?.destroy();
    $('#data_picker_retorno').data('datetimepicker')?.destroy();

    $('#data_picker_saida').datetimepicker({
      locale: 'pt-br',
      format: 'L',
      useCurrent: false,
      allowInputToggle: true,
      minDate: today

    });
    $('#data_picker_retorno').datetimepicker({
      locale: 'pt-br',
      format: 'L',
      useCurrent: false,
      allowInputToggle: true,
      minDate: today

    });
    $('#data_picker_saida').on('change.datetimepicker', function (e) {
      $('#data_picker_retorno').datetimepicker('minDate', e.date);
    });
    $('#data_picker_retorno').on('change.datetimepicker', function (e) {
      $('#data_picker_saida').datetimepicker('maxDate', e.date);
    });
  });
</script>
{{> footer}}