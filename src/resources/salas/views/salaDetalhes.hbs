{{> header}}
{{> sidebar module='salas' page='salas-detalhes'}}
{{#section "head"}}
  <style>
    .highlight-event {
      background-color: #0048fe !important;
      border: 2px solid #cc0000 !important;
      font-weight: bold;
    }
  </style>
{{/section}}

<div class="content-wrapper">
  <!-- Título & breadcrumbs -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="d-flex flex-row w-full mb-3 align-items-center flex-wrap justify-content-between" style="gap: 8px; white-space: nowrap;">
        <div><h1>Sala: {{sala.nome}}</h1></div>
        <div>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Página inicial</a></li>
            <li class="breadcrumb-item"><a href="/salas">Salas</a></li>
            <li class="breadcrumb-item active">{{sala.nome}}</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Conteúdo -->
  <section class="content">
    <div class="container-fluid">
      <div class="row">

        <!-- Sidebar esquerda -->
        <div class="col-12 col-md-4 col-lg-2">
          <div class="card card-outline card-primary">
            <div class="card-header">
              <h3 class="card-title">Sala {{sala.nome}}</h3>
            </div>
            <div class="card-body">
              <dl class="row mb-0">
                <dt class="col-6">Nome</dt>
                <dd class="col-6 text-right">{{sala.nome}}</dd>

                <dt class="col-6">Bloco</dt>
                <dd class="col-6 text-right">{{sala.bloco}}</dd>

                <dt class="col-6">Andar</dt>
                <dd class="col-6 text-right">{{sala.andar}}</dd>

                <dt class="col-6">Número</dt>
                <dd class="col-6 text-right">{{sala.numero}}</dd>

                <dt class="col-6">Capacidade</dt>
                <dd class="col-6 text-right">{{sala.capacidade}}</dd>
              </dl>
            </div>
            <div class="card-footer d-flex flex-column" style="gap: 8px;">
              <a class="btn btn-primary btn-block" href="/salas/editar/{{sala.id}}">
                <i class="fas fa-edit"></i> Editar Sala
              </a>
              <a class="btn btn-success btn-block" href="/reservas/adicionar?salaId={{sala.id}}">
              <i class="fas fa-plus"></i> Nova Reserva
              </a>
            </div>
          </div>

          <!-- (Opcional) Resumo rápido -->
          <div class="small-box bg-gradient-info">
            <div class="inner">
              <h3>{{#if sala.reservas}}{{sala.reservas.length}}{{else}}0{{/if}}</h3>
              <p>Reservas cadastradas</p>
            </div>
            <div class="icon"><i class="far fa-calendar-check"></i></div>
            <a href="/reservas/gerenciar?salaId={{sala.id}}" class="small-box-footer">
            Ver listagem <i class="fas fa-arrow-circle-right"></i>
            </a>
          </div>
        </div>

        <!-- Conteúdo principal: Calendário -->
        <div class="col-12 col-md-8 col-lg-10">
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Calendário de Reservas — {{sala.nome}}</h3>
              <div class="card-tools">
                <a class="btn btn-sm btn-outline-primary" href="/reservas/adicionar?salaId={{sala.id}}">
                <i class="fas fa-plus"></i> Nova Reserva
                </a>
              </div>
            </div>
            <div class="card-body">
              <div id="calendar" style="min-height: 720px;"></div>
            </div>
          </div>
        </div>

      </div> <!-- /.row -->
    </div> <!-- /.container-fluid -->
  </section>
</div>

<!-- Modal Detalhes da Reserva -->
<div class="modal fade" id="reservaModal" tabindex="-1" role="dialog" aria-labelledby="reservaModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-md" role="document">
    <div class="modal-content">
      <div class="modal-header bg-primary">
        <h5 class="modal-title" id="reservaModalLabel">Detalhes da reserva</h5>
        <button type="button" class="close color-white" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true" class="color-white">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <dl class="row mb-0">
          <dt class="col-5">Atividade</dt>
          <dd class="col-7 text-right" id="mAtividade">-</dd>

          <dt class="col-5">Tipo</dt>
          <dd class="col-7 text-right" id="mTipo">-</dd>

          <dt class="col-5">Sala</dt>
          <dd class="col-7 text-right" id="mSala">-</dd>

          <dt class="col-5">Período</dt>
          <dd class="col-7 text-right" id="mPeriodo">-</dd>

          <dt class="col-5">Dias</dt>
          <dd class="col-7 text-right" id="mDias">-</dd>

          <dt class="col-5">Horário</dt>
          <dd class="col-7 text-right" id="mHorario">-</dd>
        </dl>
      </div>
      <div class="modal-footer">
        <a id="btnEditarReserva" class="btn btn-primary">
          <i class="fas fa-edit"></i> Editar
        </a>
        <button type="button" class="btn btn-danger" id="btnAbrirExcluir">
          <i class="fas fa-trash"></i> Excluir
        </button>
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal confirmação de exclusão -->
<div class="modal fade" id="excluirReservaModal" tabindex="-1" role="dialog" aria-labelledby="excluirReservaLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header bg-danger">
        <h5 class="modal-title" id="excluirReservaLabel">Excluir reserva</h5>
        <button type="button" class="close color-white" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true" class="color-white">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        Tem certeza que deseja excluir esta reserva?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Não</button>
        <button type="button" class="btn btn-danger" id="btnConfirmarExcluir">Sim, excluir</button>
      </div>
    </div>
  </div>
</div>
{{> footer}}

<!-- FullCalendar -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@6.1.19/index.global.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
  // ========= Helpers =========
  function toLocalISO(dateStr, timeStr) {
    const t = (timeStr || '00:00').padStart(5, '0');
    return `${dateStr}T${t}`;
  }

  function parseDiasToDaysOfWeek(diasStr) {
    if (!diasStr) return null;
    const map = {
      'dom':0,'domingo':0,
      'seg':1,'segunda':1,'segunda-feira':1,
      'ter':2,'terça':2,'terca':2,'terça-feira':2,'terca-feira':2,
      'qua':3,'quarta':3,'quarta-feira':3,
      'qui':4,'quinta':4,'quinta-feira':4,
      'sex':5,'sexta':5,'sexta-feira':5,
      'sab':6,'sáb':6,'sábado':6,'sabado':6
    };
    return diasStr
      .split(/[,\|]/)
      .map(s => s.trim().toLowerCase())
      .map(s => map[s])
      .filter(n => Number.isInteger(n));
  }

  const sala = {{{ safeJson sala }}};
  const reservasRaw = sala?.reservas || [];
  const reservaId = {{#if reservaId}}{{reservaId}}{{else}}null{{/if}};
  function pad2(n){ return String(n).padStart(2, '0'); }

  function dateOnlyLocal(isoOrDate) {
    // Converte "2025-08-26T17:36:37.393Z" => (local) "YYYY-MM-DD"
    return moment(isoOrDate).local().format('YYYY-MM-DD');
  }

  function hhmm(s) {
    if (!s) return '00:00';
    const m = moment(s, ['HH:mm', 'HH:mm:ss'], true);
    return m.isValid() ? m.format('HH:mm') : '00:00';
  }

  function dateOnlyUTC(isoString) {
    // cria em UTC e formata só a parte da data
    return moment.utc(isoString).format('YYYY-MM-DD');
  }

  function buildFcEvents(reservas, sala) {
    if (!reservas || !reservas.length) return [];
    const events = [];

    reservas.forEach(r => {
      const title = r.atividade || 'Reserva';
      const inicioDia = moment.utc(r.dataInicio).format('YYYY-MM-DD');
      const fimDia    = moment.utc(r.dataFim || r.dataInicio).format('YYYY-MM-DD');
      const isRange   = inicioDia !== fimDia;
      const hIni = moment(r.horaInicio, ['HH:mm','HH:mm:ss'], true).format('HH:mm');
      const hFim = moment(r.horaFim || r.horaInicio, ['HH:mm','HH:mm:ss'], true).format('HH:mm');

      const diasOfWeek = parseDiasToDaysOfWeek(r.dias);
      const tooltip = `Atividade: ${r.atividade || '-'}\nTipo: ${r.tipo || '-'}\nHorário: ${hIni} - ${hFim}`;

      if (diasOfWeek && diasOfWeek.length && isRange) {
        events.push({
          id: r.id,
          title,
          daysOfWeek: diasOfWeek,
          startTime: hIni,
          endTime:   hFim,
          startRecur: inicioDia,
          endRecur:   moment(fimDia).add(1,'day').format('YYYY-MM-DD'),
          allDay: false,
          display: 'block',
          classNames: [
            reservaId && String(reservaId) === String(r.id) ? "highlight-event" : ""
          ],
          extendedProps: {
            tooltip,
            raw: {
              ...r,
              dataInicio: inicioDia,
              dataFim: fimDia,
              horaInicio: hIni,
              horaFim: hFim
            },
            sala
          }
        });
      } else {
        const start = `${inicioDia}T${hIni}`;
        const end   = `${fimDia}T${hFim}`;
        events.push({
          id: r.id,
          title,
          start,
          end,
          allDay: false,
          display: 'block',
          classNames: [
            reservaId && String(reservaId) === String(r.id) ? "highlight-event" : ""
          ],
          extendedProps: {
            tooltip,
            raw: {
              ...r,
              dataInicio: inicioDia,
              dataFim: fimDia,
              horaInicio: hIni,
              horaFim: hFim
            },
            sala
          }
        });
      }
    });

    return events;
  }

  document.addEventListener('DOMContentLoaded', function () {
    const sala = {
      id: {{sala.id}},
      nome: "{{sala.nome}}",
      bloco: "{{sala.bloco}}",
      andar: "{{sala.andar}}",
      numero: "{{sala.numero}}",
    };

    const calendarEl = document.getElementById('calendar');
    const calendar = new FullCalendar.Calendar(calendarEl, {
      themeSystem: 'bootstrap',
      schedulerLicenseKey: 'CC-Attribution-NonCommercial-NoDerivatives',
      locale: 'pt-br',
      initialView: 'timeGridWeek',
      timeZone: 'local',
      slotMinTime: '07:00:00',
      slotMaxTime: '22:30:00',
      nowIndicator: true,
      selectable: false,
      selectMirror: true,
      businessHours: { daysOfWeek: [1,2,3,4,5], startTime: '08:00', endTime: '18:00' },
      headerToolbar: {
        left: 'prev,next today',
        center: 'title',
        right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
      },
      events: buildFcEvents(reservasRaw, sala),
      // events: 'https://fullcalendar.io/api/demo-feeds/events.json?overload-day',
      dayMaxEvents: true, // allow "more" link when too many events

      eventDidMount(info) {
        if (info.event.extendedProps?.tooltip) {
          info.el.setAttribute('title', info.event.extendedProps.tooltip);
        }
        // Link direto para edição da reserva ao dar double-click (opcional)
        info.el.addEventListener('dblclick', () => {
          window.location.href = `/reservas/editar/${info.event.id}?detailsId={{sala.id}}`;
        });
      },

      eventClick(info) {
        const ev = info.event;
        const raw = ev.extendedProps?.raw || {};
        const salaInfo = ev.extendedProps?.sala || {};

        // Título do modal
        document.getElementById('reservaModalLabel').textContent =
          `Reserva #${ev.id} — ${raw.atividade || ev.title || 'Reserva'}`;

        // Sala
        const salaTexto = salaInfo?.nome
          ? `${salaInfo.nome} — ${salaInfo.bloco || ''} ${salaInfo.andar ? `— ${salaInfo.andar}º andar` : ''}`.trim()
          : `Sala ${sala?.nome || ''}`.trim();

        // Período
        // eventos recorrentes usam startRecur/endRecur (end exclusivo -1 dia)
        let periodo = '-';
        if (ev.startRecur || ev.endRecur) {
          const ini = ev.startRecur || raw.dataInicio;
          const fimExc = ev.endRecur || moment(raw.dataFim).add(1,'day').format('YYYY-MM-DD');
          const fimInc = moment(fimExc, 'YYYY-MM-DD').subtract(1, 'day').format('YYYY-MM-DD');
          periodo = `${moment(ini, 'YYYY-MM-DD').format('DD/MM/YYYY')} a ${moment(fimInc, 'YYYY-MM-DD').format('DD/MM/YYYY')}`;
        } else {
          const ini = raw.dataInicio;
          const fim = raw.dataFim;
          periodo = (ini === fim)
            ? moment(ini, 'YYYY-MM-DD').format('DD/MM/YYYY')
            : `${moment(ini, 'YYYY-MM-DD').format('DD/MM/YYYY')} a ${moment(fim, 'YYYY-MM-DD').format('DD/MM/YYYY')}`;
        }

        // Dias
        const diasStr = Array.isArray(raw.dias) ? raw.dias.join(', ') : (raw.dias || '-');

        // Horário
        const horario = `${raw.horaInicio || '-'} - ${raw.horaFim || '-'}`;

        // Preenche campos
        document.getElementById('mAtividade').textContent = raw.atividade || '-';
        document.getElementById('mTipo').textContent = raw.tipo || '-';
        document.getElementById('mSala').textContent = salaTexto || '-';
        document.getElementById('mPeriodo').textContent = periodo;
        document.getElementById('mDias').textContent = diasStr;
        document.getElementById('mHorario').textContent = horario;

        // Botão editar → link direto
        const editarHref = `/reservas/editar/${ev.id}?detailsId={{sala.id}}`;
        document.getElementById('btnEditarReserva').setAttribute('href', editarHref);

        // Botão excluir → abre modal de confirmação e prepara form
        const excluirAction = `/reservas/excluir/${ev.id}`;
        document.getElementById('btnAbrirExcluir').onclick = () => {
          $('#excluirReservaModal').modal('show');
        };

        // Confirmar exclusão → submit form
        document.getElementById('btnConfirmarExcluir').onclick = () => {
          $.ajax({
            url: excluirAction,
            method: "POST",
            success: function () {
              window.location.reload();
            },
            error: function () {
              $("#excluirReservaModal").modal("hide");

              toastr.error(
                "Ocorreu um erro ao excluir a reserva."
              );
            }
          });
        };

        // Abre modal de detalhes
        $('#reservaModal').modal('show');
      },

      select(selection) {
        // cria nova reserva já com salaId e período sugerido
        const q = new URLSearchParams({
          salaId: String(sala.id),
          start: selection.startStr,
          end: selection.endStr
        });
        window.location.href = `/reservas/adicionar?${q.toString()}`;
      },

      expandRows: true,
      stickyHeaderDates: true,
      slotEventOverlap: false
    });


    calendar.render();
    if (reservaId) {
      const id = reservaId
      const ev = calendar.getEventById(id);
      const reserva = reservasRaw.find(e => e.id === id);

      if (!ev || !reserva) return;

      if(ev.start){
        console.log("Não entrou aqui")
        calendar.gotoDate(ev.startRecur);
        const hh = ev.start.getHours().toString().padStart(2, '0');
        const mm = ev.start.getMinutes().toString().padStart(2, '0');
        calendar.scrollToTime(`${hh}:${mm}:00`);
      }
      else if (reserva.dataInicio) {
        calendar.gotoDate(reserva.dataInicio);
        const time = reserva.horaInicio || '08:00';
        const [hh, mm] = time.split(':').map(s => s.padStart(2, '0'));
        calendar.scrollToTime(`${hh}:${mm}:00`);
      }
    }
  });
</script>
