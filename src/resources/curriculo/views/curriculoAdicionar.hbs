{{> header}}
{{> sidebar module='curriculo' page='curriculo-adicionar'}}
{{#section "head"}}
  <link rel="stylesheet" href="/script-adminlte/plugins/select2/css/select2.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css" />
{{/section}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
  <!-- Content Header (Page header) -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="row mb-3">
        <div class="col-sm-9">
          <h1>Upload Currículo Lattes</h1>
        </div>
        <div class="col-sm-3">
          <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item active">Lattes</li>
          </ol>
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-sm-4 col-md-3 col-lg-1 min-width-button">
          <a type="button" class="btn btn-warning color-white" href="/inicio">
            <i class="fa fa-arrow-left"></i>
            Voltar
          </a>
        </div>
      </div>
    </div><!-- /.container-fluid -->
  </section>
  <section class="content">
    <div class="container-fluid">
      <div style="text-align:left">
        <span style="color: #FF0000; ">*</span> Campos Obrigatórios
      </div>
      <form id="formAdicionarLattes">
        <div class="card card-primary w-50">
          <div class="card-header">
            <h3 class="card-title"><b>Currículo Lattes</b></h3>
          </div>
          <div class="card-body ">
            <div class="form-group ">
              <label for="professor">
                <span style="color: #FF0000; ">*</span> Selecione o professor desejado:
              </label>
              <select class="form-control" id="professor" name="professor" onload="selectCurrentUser(this);" required>
                {{#each professores}}
                  <option value={{id}}>{{nomeCompleto}}</option>
                {{/each}}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" ><span style="color: #FF0000; ">*</span> Curriculum Lattes em XML:</label>
              <div class="custom-file">
                <input type="file" class="custom-file-input" accept=".xml" id="vittaexml" name="XML">
                <label class="custom-file-label" for="exampleInputFile">Selecione o arquivo</label>
              </div>
            </div>
            <!--Avatar-->
            <div>
              <div class="form-group">
                <label class="form-label"> <font color="#FF0000">*</font> Escolha uma imagem de perfil: </label>
                <div class="custom-file">
                  <input type="file" name="Image" class="custom-file-input" accept="image/*" id="avatarImage" onchange="displaySelectedImage(event, 'selectedAvatar')">
                  <label id="avatarInputLabel" class="custom-file-label" for="exampleInputFile">Selecione o arquivo</label>
                </div>
              </div>
              <div class="d-flex justify-content-center bg-white">
                <img id="selectedAvatar" src="/public/img/user-profile-generic.png"
                     class="rounded" style="width: 120px; height: 120px; object-fit: cover;" alt="example placeholder" />
              </div>
            </div>
            <!-- /.card-body -->
          </div>
          <div class="card-footer">
            <div style="margin-right: auto;" class="d-flex justify-content-end">
              <button class="btn btn-success float-right">
                Enviar
              </button>
            </div>
          </div>
        </div>
        <!-- /.card -->
      </form>
    </div>
  </section>
</div>
<!-- Scripts utilitários da aplicação -->
<script src="/public/js/xml2json.js"></script>
<script src="/public/js/lattesExtractor.js"></script>
<script src="/script-adminlte/plugins/select2/js/select2.min.js"></script>

<script>
  $(document).ready(function() {
    const selectProfessor = $('#professor').select2({
      theme: 'bootstrap4',
      width: '100%',
    });
    selectProfessor.on('change', function (ev) {
      getAvatar(ev.target.value)
    });
  })

  if({{tipoUsuario.professor}}){
    const sel = document.querySelector(`[id="professor"]`);
    for (var i in sel.options){
      if (sel.options[i].value=={{usuarioId}}){
        sel.selectedIndex = i
        getAvatar({{usuarioId}})
      }
    }
  }

  document.querySelector(`[id="professor"]`).addEventListener("change", (e)=>{
    const select = document.querySelector(`[id="professor"]`)
    getAvatar(select.value)
  })

  $(document).ready(function () {
    bsCustomFileInput.init()
  })

  function displaySelectedImage(event, elementId) {
    const selectedImage = document.getElementById(elementId);
    const fileInput = event.target;
    if (fileInput.files && fileInput.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        selectedImage.src = e.target.result;
      };

      reader.readAsDataURL(fileInput.files[0]);
    }
  }

  function changeAvatarPreview(avatar){
    const selectedImage = document.getElementById("selectedAvatar");
    const sel = document.querySelector(`[id="avatarImage"]`)
    const avatarLabel = document.querySelector("[id='avatarInputLabel']")
    selectedImage.src = avatar == "" ? "/public/img/user-profile-generic.png" : avatar.caminho
    // avatar == "" ? sel.removeAttribute("disabled") : sel.setAttribute("disabled", "")
    sel.value = null
    avatarLabel.textContent = avatar == "" ? "Selecione o arquivo" : avatar.nome
  }

  function getAvatar(id){
    $.ajax({
      type: "GET",
      url: 'lattes/avatar/'+id,
      success: function(data) {
        changeAvatarPreview(data)
      },
      error: function(err) {
        $(document).Toasts('create', {
          icon: 'success',
          class: "bg-danger",
          autohide: true,
          delay: 7000,
          title: 'Ocorreu um problema na exibição da imagem de perfil!',
          body: 'Não foi possível verificar se o usuário já possui uma imagem de perfil cadastrada.'
        })
      }
    });
  }

  $.validator.addMethod("verificarArquivo", function (el) {
    return (document.querySelector("input[type=file]").files.length > 0)
  })

  $.validator.addMethod("verificarImagem", function (el) {
    return (document.querySelector("#avatarImage").files.length > 0)
  })
    
  $.validator.addMethod("verificarTamanho", function (el) {
    return (document.querySelector("#avatarImage").files[0].size < 5 * 1024 * 1024) // Aceita imagens de até 5MB
  })

  $.validator.setDefaults({
    submitHandler: function () {
      FormSubmit()
    },
  });

  function reqAjax(data){
    $.ajax({
      type: "POST",
      url: 'lattes/upload',
      data,
      cache: false,
      contentType: false,
      processData: false,
      success: function(data) {
        $(document).Toasts('create', {
          icon: 'success',
          class: "bg-success",
          autohide: true,
          delay: 10000,
          title: 'Currículo adiconado com sucesso!',
          body: 'O arquivo XML do currículo foi adicionado corretamente.'
        })
      },
      error: function(err) {
        $(document).Toasts('create', {
          icon: 'success',
          class: "bg-danger",
          autohide: true,
          delay: 10000,
          title: 'Ocorreu um problema!',
          body: 'O arquivo XML do currículo não pôde ser adicionado ao sistema.'
        })
      }
    });
  }

  function FormSubmit(){
    const professorId = $("#professor").val();
    const [image] = $('#avatarImage').prop('files');
    const data = new FormData()
    data.append("professorId", professorId)
    data.append("file", image)

    getCompleteFormData(data, reqAjax)
  }

  const formValidation = $('#formAdicionarLattes').validate({
    rules: {
      professor: {
        required: true,
      },
      XML: {
        verificarArquivo: true,
        accept: "text/xml",
      },
      Image: {
        verificarImagem: true,
        verificarTamanho: true,
        accept: "image/*",
      }
    },
    messages: {
      professor: {
        required: 'Você deve escolher um professor.',
      },
      XML: {
        verificarArquivo: 'É necessário submeter um arquivo XML.',
      },
      Image: {
        verificarImagem: 'É necessário submeter uma imagem.',
        verificarTamanho: 'Tamanho máximo de arquivo excedido. Envie uma imagem de até 5MB.',
      },
    },
    errorElement: 'span',
    errorPlacement: function (error, element) {
      error.addClass('invalid-feedback');
      element.closest('div').append(error);
    },
    highlight: function (element, errorClass, validClass) {
      $(element).addClass('is-invalid');
    },
    unhighlight: function (element, errorClass, validClass) {
      $(element).removeClass('is-invalid');
    },
  });

  $('#avatarImage').on('change', function(evt){
    formValidation.element('#avatarImage')
  })
</script>

{{> footer}}