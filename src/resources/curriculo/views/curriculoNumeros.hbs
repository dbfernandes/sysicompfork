<style>
  .grid-cards {
    display: flex;
   flex-direction: row;
    flex-wrap: wrap;
    gap: 1rem
  }
  .info-card {
    flex: 1 1 calc(25% - 1rem);
    min-width: 200px;
  }

   .dataTables_length  { flex:1; }
  .dataTables_length label { margin: 0; }
  .dataTables_info{ padding: 0 !important; margin-right: 8px; }
  .gap-table{ gap: 8px; } /* NOVO */
  .min-width-button{ min-width: 210px; }

  #table-professors {
    width: 100%;
  }

  /* evita quebra do header */
  #table-professors thead th { white-space: nowrap; }

  #table-professors thead th i {
    margin-left: 4px;
  }

  #table-professors {
    width: 100%;
  }

  /* Não quebrar textos do thead */
  #table-professors thead th {
    white-space: nowrap;
  }

  /* Colunas numéricas: não crescem e ficam alinhadas */
  #table-professors th.col-num,
  #table-professors td.col-num {
    white-space: nowrap;
    text-align: center;
  }

  /* Coluna Nome pode crescer e (opcional) cortar com reticências */
  #table-professors th.col-name,
  #table-professors td.col-name {
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 100px;
  }
</style>
{{/section}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
