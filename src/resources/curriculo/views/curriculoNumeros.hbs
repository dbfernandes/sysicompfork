{{> header}}
{{> sidebar module='curriculo' page='curriculo-numeros'}}
{{#section "head"}}
  <link rel="stylesheet" href="/script-adminlte/plugins/datatables-bs4/css/dataTables.bootstrap4.css" />
  <link rel="stylesheet" href="/script-adminlte/plugins/datatables-buttons/css/buttons.bootstrap4.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css" />

  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/select2/css/select2.min.css" />
  <link rel="stylesheet" type="text/css" href="/script-adminlte/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css" />
<style>
  .grid-cards {
    display: flex;
   flex-direction: row;
    flex-wrap: wrap;
    gap: 1rem
  }
  .info-card {
    flex: 1 1 calc(25% - 1rem);
    min-width: 200px;
  }

   .dataTables_length  { flex:1; }
  .dataTables_length label { margin: 0; }
  .dataTables_info{ padding: 0 !important; margin-right: 8px; }
  .gap-table{ gap: 8px; } /* NOVO */
  .min-width-button{ min-width: 210px; }
</style>
{{/section}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
  <!-- Content Header (Page header) -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="row mb-3">
        <div class="col-sm-9">
          <h1>Números Lattes</h1>
        </div>
        <div class="col-sm-3">
          <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item active">Lattes</li>
            <li class="breadcrumb-item active">Números</li>
          </ol>
        </div>
      </div>
    </div><!-- /.container-fluid -->
  </section>
  <section class="content">
    <div class="container-fluid">
      <div class="grid-cards gx-5">
        <div class="small-box bg-success info-card">
          <div class="inner">
            <h3>{{numberProfessors}}</h3>
            <p>Docentes</p>
          </div>
          <div class="icon">
            <i class="fas fa-users"></i>
          </div>
        </div>
        <div class="small-box bg-success info-card">
          <div class="inner">
            <h3>{{numberUpdated}}</h3>
            <p>Atualizados</p>
          </div>
          <div class="icon">
            <i class="fas fa-check-circle"></i>
          </div>
        </div>
        <div class="small-box bg-warning info-card">
          <div class="inner">
            <h3>{{numberStale}}</h3>
            <p>Desatualizados</p>
          </div>
          <div class="icon">
            <i class="fas fa-minus-circle"></i>
          </div>
        </div>
        <div class="small-box bg-danger info-card">
          <div class="inner">
            <h3>{{numberNoRecords}}</h3>
            <p>Sem registros</p>
          </div>
          <div class="icon">
            <i class="fas fa-exclamation-circle"></i>
          </div>
        </div>
      </div>
      <div class="card card-primary">

        <div class="card-body">
          <div class="d-flex mb-3" style="flex-wrap: wrap; gap: 1rem;">
            <div style="width: 100px;">
              <label>Ano inicial</label>
              <div class="input-group date" id="yearStartPicker" data-target-input="nearest">
                <input type="text" class="form-control datetimepicker-input" data-target="#yearStartPicker" id="filtroDataFimInput" />
                <div class="input-group-append" data-target="#yearStartPicker" data-toggle="datetimepicker">
                  <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                </div>
              </div>
            </div>

            <div style="width: 100px;">
              <label>Ano final</label>
              <div class="input-group date" id="yearEndPicker" data-target-input="nearest">
                <input type="text" class="form-control datetimepicker-input" data-target="#yearEndPicker" id="filtroDataFimInput" />
                <div class="input-group-append" data-target="#yearEndPicker" data-toggle="datetimepicker">
                  <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                </div>
              </div>
            </div>

            <div style="width: 300px;">
              <label for="status-filter" class="form-label">Filtrar por status</label>
              <select id="status-filter" class="form-control form-control-sm">
                <option value="all" selected>Todos</option>
                <option value="ATUALIZADO">Atualizado</option>
                <option value="DESATUALIZADO">Desatualizado</option>
                <option value="SEM_REGISTROS">Sem registros</option>
              </select>
            </div>
          </div>

        </div>
      </div>

      <div class="card">
      <div class="card-body">
        <table id="table-professors" class="table table-striped table-bordered table-hover w-100">
          <thead>
            <tr style="text-align: center;">
              <th style="text-align: center;">Nome</th>
              <th style="text-align: center;">Última atualização</th>
              <th style="text-align: center;">Projetos</th>
              <th colspan="6" style="text-align: center;">Publicações</th>
              <th colspan="3" style="text-align: center;">Orientações</th>
              <th style="text-align: center;">Prêmios</th>
              <th style="text-align: center;">Status</th>
            </tr>
            <tr>
              <th colspan="3"></th>
              <th>
                A.C.
                <span data-toggle="tooltip" data-placement="top" title="Artigos em Conferências">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>
              <th>
                A. P.
                <span data-toggle="tooltip" data-placement="top" title="Artigos em Períodicos">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>
              <th>
                L.
                <span data-toggle="tooltip" data-placement="top" title="Livros">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>
              <th>
                C.L.
                <span data-toggle="tooltip" data-placement="top" title="Capítulos em Livros">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>
              <th>
                T.T.
                <span data-toggle="tooltip" data-placement="top" title="Trabalho Técnico">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              <th>
                P.
                <span data-toggle="tooltip" data-placement="top" title="Prefácio">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>

              <th>TCC</th>
              <th>
                M.
                <span data-toggle="tooltip" data-placement="top" title="Mestrado">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>
              <th>
                D.
                <span data-toggle="tooltip" data-placement="top" title="Doutorado">
                  <i class="fa fa-question-circle"  aria-hidden="true"></i>
                </span>
              </th>
              <th colspan="4"></th>

            </tr>
          </thead>
          <tbody>
            {{#each professores}}
              <tr>
                <td>{{nome}}</td>
                <td>{{formatDate ultimaAtualizacao}}</td>
                <td>{{countArray projetos}}</td>
                <td>{{countArray publicacoes key='tipo' value=1}}</td>
                <td>{{countArray publicacoes key='tipo' value=2}}</td>
                <td>{{countArray publicacoes key='tipo' value=3}}</td>
                <td>{{countArray publicacoes key='tipo' value=4}}</td>
                <td>{{countArray publicacoes key='tipo' value=5}}</td>
                <td>{{countArray publicacoes key='tipo' value=6}}</td>

                <td>{{countArray orientacoes key='tipo' value=1}}</td>
                <td>{{countArray orientacoes key='tipo' value=2}}</td>
                <td>{{countArray orientacoes key='tipo' value=3}}</td>
                <td>{{countArray premios}}</td>
                <td >
                  {{#if (eq status "DESATUALIZADO")}}
                    <span data-status="{{status}}" class="badge bg-warning">
                      Desatualizado
                    </span>
                  {{/if}}
                  {{#if (eq status "SEM_REGISTROS")}}
                    <span data-status="{{status}}" class="badge bg-danger">
                      Sem registros
                    </span>
                  {{/if}}
                  {{#if (eq status "ATUALIZADO")}}
                    <span data-status="{{status}}" class="badge bg-success">
                      Atualizado
                    </span>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      </div>
    </div>
  </section>
</div>
<!--<script src="/script-adminlte/plugins/datatables/jquery.dataTables.min.js"></script>-->
<!--<script src="/script-adminlte/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>-->
<!--<script src="/script-adminlte/plugins/datatables-buttons/js/buttons.bootstrap4.min.js"></script>-->

<!-- Exportação -->
<script defer src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script defer src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

<script defer src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script defer src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap4.min.js"></script>

<script defer src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<script defer src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script defer src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
<script defer src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.colVis.min.js"></script>
<script src="/script-adminlte/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
<script src="/script-adminlte/plugins/moment/locale/pt-br.js"></script>
<script src="/script-adminlte/plugins/select2/js/select2.full.min.js"></script>


<script>
  function renderStatusBadge(status) {
    if (!status) return ''

    switch (status) {
      case 'ATUALIZADO':
        return `
        <span class="badge bg-success" data-status="${status}">
          Atualizado
        </span>
      `

      case 'DESATUALIZADO':
        return `
        <span class="badge bg-warning" data-status="${status}">
          Desatualizado
        </span>
      `

      case 'SEM_REGISTROS':
        return `
        <span class="badge bg-danger" data-status="${status}">
          Sem registros
        </span>
      `

      default:
        return `
        <span class="badge bg-secondary" data-status="${status}">
          Desconhecido
        </span>
      `
    }
  }

  $(function () {
    $('[data-toggle="tooltip"]').tooltip()
  })

  $(document).ready(function() {
    $('#status-filter').select2({
      theme: 'bootstrap4',
      placeholder: '',
      width: '100%',
      minimumResultsForSearch: Infinity,

    });

    $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
      const selectedStatus = $('#status-filter').val()

      if (!selectedStatus || selectedStatus === 'all') {
        return true
      }

      const row = settings.aoData[dataIndex].nTr
      const status = $('span[data-status]', row).data('status')

      return status === selectedStatus
    })

    $('#yearStartPicker').datetimepicker({
      locale: 'pt-br',
      useCurrent: false,
      allowInputToggle: true,
      viewMode: 'years',
      format: 'YYYY',
      buttons: {
        showToday: true,
        showClear: true,
      }});

    $('#yearEndPicker').datetimepicker({
      locale: 'pt-br',
      useCurrent: false,
      viewMode: 'years',
      format: 'YYYY',
      allowInputToggle: true,
      buttons: {
        showToday: true,
        showClear: true,
      }});
    $("#yearStartPicker").on("change.datetimepicker", function (e) {
      $('#yearEndPicker').datetimepicker('minDate', e.date);
    });
    $("#yearEndPicker").on("change.datetimepicker", function (e) {
      $('#yearStartPicker').datetimepicker('maxDate', e.date);
    });
    let professores = {{{safeJson professores}}};
    const datatable = $('#table-professors').DataTable({

      language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
      dom:
        "<'row mb-2'<'col-sm-12 col-md-6'B><'col-sm-12 col-md-6'f>>" +
        " t<'dt-bottom d-flex flex-wrap justify-content-start align-items-center gap-table'lip>",

      responsive: true,
      columns: [
        { responsivePriority: 1, orderable: true },
        { responsivePriority: 2, orderable: true },
        { responsivePriority: 3, orderable: true },
        { responsivePriority: 4, orderable: true },
        { responsivePriority: 5, orderable: true },
        { responsivePriority: 6, orderable: true  },
        { responsivePriority: 7, orderable: true },
        { responsivePriority: 8, orderable: true },
        { responsivePriority: 9, orderable: true },
        { responsivePriority: 10, orderable: true },
        { responsivePriority: 11, orderable: true },
        { responsivePriority: 12, orderable: true },
        { responsivePriority: 13, orderable: true },
        { responsivePriority: 14, orderable: false },
      ],

    });

    $('#status-filter').on('change', function () {
      datatable.draw()
    })

    function compYears(yearActual, yearStart, yearEnd) {
      if (yearStart && yearActual < yearStart) return false
      if (yearEnd && yearActual > yearEnd) return false
      return true
    }
    function renderTable(professoresFiltrados, filters = {}) {
      const yearStart = filters.yearStart || null
      const yearEnd = filters.yearEnd || null
      datatable.clear()

      professoresFiltrados.forEach((p) => {
        datatable.row.add([
          p.nome,
          p.ultimaAtualizacao
            ? moment(p.ultimaAtualizacao).format('DD/MM/YYYY')
            : '-',
          p.projetos.filter(p => compYears(p.dataInicio, yearStart, yearEnd) || compYears(p.dataFim, yearStart, yearEnd)).length,
          p.publicacoes.filter((p) => p.tipo === 1 && compYears(p.ano, yearStart, yearEnd)).length,
          p.publicacoes.filter((p) => p.tipo === 2 && compYears(p.ano, yearStart, yearEnd)).length,
          p.publicacoes.filter((p) => p.tipo === 3 && compYears(p.ano, yearStart, yearEnd)).length,
          p.publicacoes.filter((p) => p.tipo === 4 && compYears(p.ano, yearStart, yearEnd)).length,
          p.publicacoes.filter((p) => p.tipo === 5 && compYears(p.ano, yearStart, yearEnd)).length,
          p.publicacoes.filter((p) => p.tipo === 6 && compYears(p.ano, yearStart, yearEnd)).length,
          p.orientacoes.filter((o) => o.tipo === 1 && compYears(o.ano, yearStart, yearEnd)).length,
          p.orientacoes.filter((o) => o.tipo === 2 && compYears(o.ano, yearStart, yearEnd)).length,
          p.orientacoes.filter((o) => o.tipo === 3 && compYears(o.ano, yearStart, yearEnd)).length,
          p.premios.filter(p => compYears(p.ano, yearStart, yearEnd)).length,
          renderStatusBadge(p.status),
        ])
      })

      datatable.draw()
    }

    function applyFilters() {
      const yearStartMoment = $('#yearStartPicker')
        .datetimepicker('viewDate')

      const yearEndMoment = $('#yearEndPicker')
        .datetimepicker('viewDate')

      // se algum dos dois não foi escolhido, não filtra por ano
      if (!yearStartMoment || !yearEndMoment) {
        renderTable(professores)
        return
      }

      const yearStart = yearStartMoment.year()
      const yearEnd = yearEndMoment.year()

      renderTable(professores, { yearStart, yearEnd })
    }
    $("#yearStartPicker").on("change.datetimepicker", function (e) {
      applyFilters()
    })
    })

</script>

{{> footer}}