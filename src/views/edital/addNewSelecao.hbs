{{> header}}
{{> sidebar module='projetos' page='projetos-adicionar'}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-9">
                    <h1>Adicionar nova Seleção</h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Seleção</a></li>
                        <li class="breadcrumb-item active">Adicionar</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        
        <div class="container-fluid">

            <div class="col-md-12">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Dados da selecao PPGI</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="col-md-12">


                            <!-- /.card-header -->
                            <div class="card-body">
                                <form role="form" id="adicionarSelecaoForm" >
                                    <div class="form-group">
                                        <div class="form-row">
                                            <font color="#FF0000">*</font>  <label> Número do edital:</label>
                                            <input type="text" class="form-control" placeholder="Número do edital" id="numero_edital" required>
                                        </div>
                                    </div>


                                    <div class="form-group" >
                                        <div class="form-row">
                                            <font color="#FF0000">*</font>  <label for="URL">
                                                URL
                                            </label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-globe"></i>
                                                    </span>
                                                </div>
                                                <input type="text" class="form-control" id="URL" placeholder="URL"
                                                    required>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-row">
                                            <!------data de inicio------------>
                                            <div class="col-sm-6">
                                                <font color="#FF0000">*</font>  <label>Data de Início</label>
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">
                                                            <i class="fa fa-calendar"></i>
                                                        </span>
                                                    </div>
                                                    <input type="date" class="form-control" placeholder="Data de Início"
                                                        required
                                                        id="DataInicio">
                                                </div>
                                            </div>

                                            <!------data de fim------------>
                                            <div class="col-sm-6">
                                               <font color="#FF0000">*</font>  <label>Data de Fim</label>
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">
                                                            <i class="fa fa-calendar"></i>
                                                        </span>
                                                    </div>
                                                    <input type="date" class="form-control" placeholder="Data de Fim"
                                                        required
                                                        id="dataFim">
                                                </div>
                                            </div>
                                        </div>
                                    </div>



                                    <div class="form-group">

                                        <div class="form-group">
                                            <div class="form-row">
                                               <font color="#FF0000">*</font>  <label for="Mestrado"> Carta de Recomendação? </label>
                                            </div>
                                            <input type="checkbox" name="administrador" unchecked data-bootstrap-switch
                                                data-off-color="danger" data-on-color="success" data-on-text="Sim"
                                                data-off-text="Não"
                                                id="carta_recomendacao">
                                        </div>

                                        <div class="form-group">
                                            <div class="form-row">
                                              <font color="#FF0000">*</font>   <label for="Mestrado"> Carta Orientador? </label>
                                            </div>
                                            <input type="checkbox" name="administrador" unchecked data-bootstrap-switch
                                                data-off-color="danger" data-on-color="success" data-on-text="Sim"
                                                data-off-text="Não"
                                                id="carta_orientador">
                                        </div>

                                    </div>


                                    <div class="form-group">
                                        <div class="form-row">
                                          <font color="#FF0000">*</font>   <label for="Mestrado"> Mestrado? </label>
                                        </div>
                                        <input type="checkbox" name="administrador" unchecked data-bootstrap-switch
                                            data-off-color="danger" data-on-color="success" data-on-text="Sim"
                                            data-off-text="Não"
                                            id="Mestrado">
                                            
                                    </div>


                                    <div class="form-row">
                                        <div class="col-sm-6">

                                           <font color="#FF0000">*</font>  <label> Vagas Regulares para Mestrado:</label>
                                            <input type="number" class="form-control "
                                                placeholder="Vagas Regulares para Mestrado" required
                                                id="vagas_regulares_mestrado">
                                                
                                        </div>

                                        <div class="col-sm-6">

                                          <font color="#FF0000">*</font>   <label> Vagas Suplementares para Mestrado:</label>
                                            <input type="number" class="form-control "
                                                placeholder="Vagas Regulares para Mestrado" required
                                                id="vaga_suplementar_mestrado">
                                                
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-row">
                                          <font color="#FF0000">*</font>   <label for="Mestrado"> Doutorado? </label>
                                        </div>

                                        <input type="checkbox" name="administrador" unchecked data-bootstrap-switch
                                            data-off-color="danger" data-on-color="success" data-on-text="Sim"
                                            data-off-text="Não"
                                            id="doutorado">
                                            

                                        <div class="form-row">
                                            <div class="col-sm-6">
                                               <font color="#FF0000">*</font>  <label> Vagas Regulares para Doutarado:</label>
                                                <input type="number" class="form-control "
                                                    placeholder="Vagas Regulares para Doutorado" required
                                                    id="vagas_regulares_doutorado"
                                                    >
                                            </div>

                                            <div class="col-sm-6">

                                               <font color="#FF0000">*</font>  <label> Vagas Suplementares para Doutorado:</label>
                                                <input type="number" class="form-control "
                                                    placeholder="Vagas Regulares para Doutorado" required
                                                    id="vaga_suplementar_doutordo"
                                                />
                                            </div>
                                        </div>
                                    </div>



                                    <div class="card-footer">
                                        <div class="col">
                                            <input type="submit" value="Criar novo Edital"
                                                class="btn btn-success float-right"
                                                onclick="submitForm()" >
                                        </div>
                                    </div>
                                </form>
                            </div>
                            <!-- /.col -->
    </section>
    <!-- /.content -->
</div>



<script>
    function usuariosAdicionarPage() {


        $("input[data-bootstrap-switch]").each(function () {
            $(this).bootstrapSwitch('state', $(this).prop('checked'));

        });

       
        //To-do call backend to add User

        $("#usuariosAdicionar").modal("show");
    }
    function getValueFromForm() {
           const dataFromForm = Array.from(document.querySelectorAll('#adicionarSelecaoForm input')).reduce((acc,input)=>({
            ...acc,[input.id]: input.value
            }),{})

        return dataFromForm;    
    }

    function submitForm() {
        const dataFromForm = getValueFromForm();
        return fetch('http://localhost:3000/edital/addEdital', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(dataFromForm)
        }).then(response => {
            if (response.status === 200) {
                $("#usuariosAdicionar").modal("hide");
                console.log("Edital criado com sucesso!");
                
            } else {
                console.log("Erro ao criar Edital!");
            }
        });
    }

</script>




{{> footer}}