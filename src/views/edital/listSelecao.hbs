{{> header}}

{{> sidebar module='edital' page='edital-listar'}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-9">
                    <h1>Lista de Selecoes</h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Selecoes</a></li>
                        <li class="breadcrumb-item active">Listar</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-3 col-md-2 col-lg-1">
                    <button type="button" class="btn btn-block btn-secondary">
                        <i class="fa fa-arrow-left color-white"></i>
                        Voltar
                    </button>
                </div>
                <div class="col-sm-4 col-md-3 col-lg-2">
                    <a type="button" class="btn btn-block btn-primary" href="/edital/adicionar">
                        <i class="fas fa-plus color-white"></i>
                        Adicionar Seleção
                    </a>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Projetos</h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <table id="example2" class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>Nº edital</th>
                                        <th>Início inscrições</th>
                                        <th> Término inscrições</th>
                                        <th>#Inscrições Iniciadas</th>
                                        <th> #Inscrições Encerradas</th>
                                        <th> Vagas Mestrado</th>
                                        <th> Vagas Doutorado</th>
                                        <th> </th>

                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each editais}}
                                    <tr>
                                        <td> {{dataValues.editalId}} </td>
                                        <td> {{dataValues.dataInicio}} </td>
                                        <td> {{dataValues.dataFim}} </td>
                                        <td> {{dataValues.documento}} </td>
                                        <td> {{dataValues.dataFim}} </td>
                                        <td> {{dataValues.vagaMestrado}} </td>
                                        <td> {{dataValues.vagaDoutorado}} </td>
                                        <td>
                                            <div class="col-6">
                                                <a href="">
                                                    <i class="fas fa-download"></i>
                                                </a>
                                            </div>
                                            <div class="col-6">
                                                <a href="/edital/updateEdital/{{dataValues.editalId}}"
                                                    class="btn btn-primary btn-sm">
                                                    <i class="fas fa-edit"></i>
                                                    
                                                </a>
                                            </div>
                                            <div class="col-6">
                                                <a href="/edital/deleteEdital/{{dataValues.editalId}}"
                                                    class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                            <div class="col-6">
                                                <a href="/edital/listEdital/{{dataValues.editalId}}"
                                                    class="btn btn-danger btn-sm">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </div>
                                        </td>

                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                        <!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.col -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container-fluid -->
    </section>
    <!-- /.content -->
</div>

<script>



</script>

{{> footer}}