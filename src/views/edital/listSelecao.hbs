{{> header}}

{{> sidebar module='edital' page='edital-listar'}}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-9">
                    <h1>Editais de Seleção do PPGI</h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Página Inicial </a></li>
                        <li class="breadcrumb-item active">Editais de Seleção do PPGI</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-5 col-md-4 col-lg-4 col-xl-3 mt-4">
                    <a class="btn btn-warning color-white" id="voltarBtn">
                        <i class="fa fa-arrow-left"></i>
                        Voltar
                    </a>
                    <a class="btn btn-primary color-white" href="/edital/addEdital">
                        <i class="fas fa-plus"></i>
                        Novo Edital
                    </a>      
                </div>

                <div class="col-sm-7 col-md-8 col-lg-8 d-flex justify-content-end">
                    <div class="legenda-table">
                        <table class="table table-bordered" style="border-color: black;">
                            <tr style="background-color: #dcdcdc;">
                                <td colspan="2" style="text-align: center; font-size: 15px; padding: 0px 50px; border-color: black;">Legenda</td>
                            </tr>
                            <tr style="background-color: #a0c6e4;">
                                <td style="text-align: center; font-size: 14px; padding: 0px 50px; border-color: black;">REG</td>
                                <td style="text-align: center; font-size: 14px; padding: 0px 50px; border-color: black;">Vagas Regulares</td>
                            </tr>
                            <tr style="background-color: #8fdf7b;">
                                <td style="text-align: center; font-size: 14px; padding: 0px 50px; border-color: black;">SUP</td>
                                <td style="text-align: center; font-size: 14px; padding: 0px 50px; border-color: black;">Vagas Suplementares</td>
                            </tr>
                        </table>
                    </div>
                </div>
               
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Editais</h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <table id="example2" class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th> # </th>
                                        <th> Nº edital</th>
                                        <th> Início inscrições</th>
                                        <th> Término inscrições</th>
                                        <th> Inscrições Iniciadas</th>
                                        <th> Inscrições Encerradas</th>
                                        <th> Vagas Mestrado</th>
                                        <th> Vagas Doutorado</th>
                                        <th> </th>

                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each editais}}
                                    <tr>
                                        <td>{{add @index 1}}</td>
                                        <td> {{dataValues.editalId}} </td>
                                        <td> {{dataValues.dataInicio}} </td>
                                        <td> {{dataValues.dataFim}} </td>
                                        <td>  </td>
                                        <td>  </td>
                                        <td> REG: {{dataValues.vagaMestrado}} / SUP: {{dataValues.cotasMestrado}} </td>
                                        <td> REG: {{dataValues.vagaDoutorado}} / SUP: {{dataValues.cotasDoutorado}} </td>
                                        <td class='links-container'>
                                            <div class="d-flex justify-content-between">

                                                <a  style="margin-right: 2px"
                                                    href='#'
                                                    class='fa fa-solid fa-download'/>
                                                </a>

                                                <a  style="margin-right: 2px"
                                                    href='/edital/listEdital/{{dataValues.editalId}}'
                                                    class='fa fa-solid fa-eye'/>
                                                </a>

                                                <a  class="fa fa-solid fa-trash" data-editalId="{{dataValues.editalId}}" onclick="deleteEdital(this)"
                                                data-toggle="modal" data-target="#removerEdital" onclick="addLink(event)" href="#">
                                                </a>

                                                <a  style="margin-right: 2px"
                                                    href='/edital/updateEdital/{{dataValues.editalId}}'
                                                    class='fa fa-solid fa-pen'/>
                                                </a>

                                            </div>
                                        </td>                                            
                                        
                                            <!-- 
                                                implementado
                                                <a class="fa fa-solid fa-trash" id="removerUser_{{nomeCompleto}}_{{id}}"
                                                data-toggle="modal" data-target="#removerUsuario" onclick="addLink(event)" href="#">
                                                </a>



                                            <a class="btn btn-danger btn-sm" data-editalId="{{dataValues.editalId}}" onclick="deleteEdital(this)">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                            <a href="/edital/updateEdital/{{dataValues.editalId}}" class="btn btn-info btn-sm">
                                                <i class="fas fa-pencil-alt"></i>
                                            </a>
                                            -->
                                      
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                        <!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.col -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container-fluid -->
    </section>
    <!-- /.content -->
</div>

<script>


 function deleteEdital(element){
    var editalId = element.getAttribute("data-editalId");
    console.log(editalId);
    let r = confirm("Deseja realmente excluir o edital com ID " + editalId + "?");
    if (r == true) {
        var url = '/edital/deleteEdital/' + editalId;
        $.ajax({
            url: url,
            type: 'DELETE',
            success: function(result){
                alert('Edital excluído com sucesso!');
                location.reload();
            },
            error: function(result){
                alert('Erro ao excluir edital!');
            }
        });
    }
}

    function addLink(event) {
        const [nomeCompleto, id] = event.target.id.split("_").slice(1);
        document.getElementById("tituloModal").innerHTML = "Deseja realmente excluir o edital " + nome + "?";
        const formDelete = document.getElementById("postDelete")
        formDelete.setAttribute('action', `/usuarios/deletar/${id}`);
    }


 document.getElementById("voltarBtn").addEventListener("click", function() {
        window.history.back();
    });


</script>

{{> footer}}