{{> header}}

{{> sidebar module="edital"}}

<div class="content-wrapper">
    <section class="content-header">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-9">
                    <h1>Candidato {{candidate.id}} - Edital {{candidate.editalId}} </h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Página Inicial </a></li>
                        {{!-- <li class="breadcrumb-item"><a href="/">Edital: {{candidate.editalId}}</a></li> --}}
                        <li class="breadcrumb-item active">Detalhes do Canditado</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-4">
                <div class="text-nowrap col-sm-3 col-md-2 col-lg-2 mt-4">
                    <a class="btn btn-warning color-white" href="/edital/listEditalCandidates/{{candidate.editalId}}">
                        <i class="fa fa-arrow-left"></i>
                        Voltar
                    </a> 
                </div>
            </div>
        </div>
    </section>
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card card-primary">
                        <div class="card-header">
                            <h3 class="card-title
                            "><b>Informações do Candidato</b></h3>
                        </div>
                        <div class="card-body" style="overflow-x:auto;">
                            <table id="example2" class="table table-bordered table-hover">
                                <tbody>
                                <tr>
                                    <th class="col-3">Nome Completo</th>
                                    <td>{{candidate.name}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Data da Inicialização da Inscrição</th>
                                    <td>{{candidate.begin}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Data da Finalização da Inscrição</th>
                                    <td>{{candidate.finish}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Endereço</th>
                                    <td>{{candidate.address}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Bairro</th>
                                    <td>{{candidate.neighborhood}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Cidade</th>
                                    <td>{{candidate.city}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Estado</th>
                                    <td>{{candidate.uf}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">CEP</th>
                                    <td>{{candidate.cep}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">E-mail</th>
                                    <td>{{candidate.email}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Data de nascimento</th>
                                    <td>{{candidate.birthday}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Nacionalidade</th>
                                    <td>{{candidate.nationality}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">País</th>
                                    <td>{{candidate.country}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">CPF</th>
                                    <td>{{candidate.cpf}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Sexo</th>
                                    <td>{{candidate.gender}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Telefone Principal</th>
                                    <td>{{candidate.homePhone}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Telefone Alternativo</th>
                                    <td>{{candidate.cellPhone}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Curso desejado</th>
                                    <td>{{candidate.inscricaoposcomp}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Regime de Dedicação</th>
                                    <td>Parcial</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Incrição poscomp</th>
                                    <td></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Ano poscomp</th>
                                    <td>{{candidate.anoposcomp}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Nota poscomp</th>
                                    <td>{{candidate.notaposcomp}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Solicita Bolsa?</th>
                                    <td>{{candidate.solicitabolsa}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Cotista?</th>
                                    <td>{{candidate.cotas}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Possui algum tipo de problema de saúde física ou psiquiátrica?</th>
                                    <td>{{candidate.status}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Linha de Pesquisa</th>
                                    <td>{{candidate.linhaDePesquisaId}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Título da Proposta</th>
                                    <td>{{candidate.tituloproposta}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Motivos</th>
                                    <td>{{candidate.motivos}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Carta do Orientador (PDF)</th>
                                    <td><span class="{{#if candidate.cartaorientador}}">
                                            <a  style="margin-right: 3px"
                                                href="/gerarCandidatoPDF/{{candidate.id}}?documento=cartaorientador"
                                                class='fa fa-solid fa-download'
                                            />
                                            {{else}}badge bg-warning">Pendente{{/if}}
                                    </span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Proposta de Trabalho (PDF)</th>
                                    <td><span class="{{#if candidate.proposta}}">
                                            <a  style="margin-right: 3px"
                                                href="/gerarCandidatoPDF/{{candidate.id}}?documento=proposta"
                                                class='fa fa-solid fa-download'
                                            />
                                            {{else}}badge bg-warning">Pendente{{/if}}
                                    </span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Curriculum (PDF)</th>
                                    <td><span class="{{#if candidate.curriculum}}">
                                            <a  style="margin-right: 3px"
                                                href="/gerarCandidatoPDF/{{candidate.id}}?documento=curriculum"
                                                class='fa fa-solid fa-download'
                                            />
                                            {{else}}badge bg-warning">Pendente{{/if}}
                                    </span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Prova de seleção anterior para aproveitamento de nota (PDF)</th>
                                    <td><span class="{{#if candidate.prova_anterior}}">
                                            <a  style="margin-right: 3px"
                                                href="/gerarCandidatoPDF/{{candidate.id}}?documento=prova_anterior"
                                                class='fa fa-solid fa-download'
                                            />
                                            {{else}}badge bg-warning">Pendente{{/if}}
                                    </span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Comprovante de Pagamento (PDF)</th>
                                    <td><span class="{{#if candidate.recommendationLetter}}">
                                            <a  style="margin-right: 3px"
                                                href="/gerarCandidatoPDF/{{candidate.id}}?documento=comprovante"
                                                class='fa fa-solid fa-download'
                                            />
                                            {{else}}badge bg-warning">Pendente{{/if}}
                                    </span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Cartas de Recomendação (PDF)</th>
                                    <td>
                                        <span class="{{#if candidate.recommendationLetter}}">
                                            <a  style="margin-right: 3px"
                                                href="/gerarCandidatoPDF/{{candidate.id}}?documento=recommendationLetter"
                                                class='fa fa-solid fa-download'
                                            />
                                            {{else}}badge bg-warning">Pendente{{/if}}
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="col-3">N° de Cartas de Recomendação (Emitidas)</th>
                                    <td>0</td>
                                </tr>
                                <tr>
                                    <th class="col-3">N° de Cartas de Recomendação (Respondidas)</th>
                                    <td>0</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Curso de graduação</th>
                                    <td><span class="{{#if candidato.desiredCourse}}">{{candidate.desiredCourse}}
                                        {{else}}badge bg-danger">Não Registrado{{/if}}

                                    </span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Instituição da graduação</th>
                                    <td>{{candidate.status}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Ano de Egresso na Graduação</th>
                                    <td>{{candidate.anoposcomp}}</td>
                                </tr>
                                <tr>
                                    <th class="col-3">Curso de Pós Graduação</th>
                                    <td><span class="{{#if candidate.status}}">{{candidate.status}}{{else}}badge bg-danger">Não Registrado{{/if}}</span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Tipo de Pós Graduação</th>
                                    <td><span class="{{#if candidate.inscricaoposcomp}}">{{candidate.inscricaoposcomp}}{{else}}badge bg-danger">Não Registrado{{/if}}</span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Instituição da Pós Graduação</th>
                                    <td><span class="{{#if candidate.status}}">{{candidate.status}}{{else}}badge bg-danger">Não Registrado{{/if}}</span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Ano de Egresso na Pós Graduação</th>
                                    <td><span class="{{#if candidate.anoposcomp}}">{{candidate.anoposcomp}}{{else}}badge bg-danger">Não Registrado{{/if}}</span></td>
                                </tr>
                                <tr>
                                    <th class="col-3">Resultado da Avaliação</th>
                                    <td><span class="{{#if candidate.notaposcomp}}">{{candidate.notaposcomp}}{{else}}badge bg-danger">Não Julgado{{/if}}</span></td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

{{> footer}}