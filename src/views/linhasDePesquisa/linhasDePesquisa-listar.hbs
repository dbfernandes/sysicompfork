{{> header}}
{{> sidebar module='linhasDePesquisa' page='linhasDePesquisa-listar'}}
<style>
	/* Style your page here  */
  .links-container {
    display: flex;
    justify-content: space-around;
  }
</style>

<main class="content-wrapper">
	<section class="content-header">
		<div class="container-fluid">

			<div class="row mb-2">
				<div class="col-sm-9">
					<h1>Linhas de Pesquisa</h1>
				</div>
				<div class="col-sm-3">
					<ol class="breadcrumb float-sm-right">
						<li class="breadcrumb-item">Linhas de Pesquisa</li>
						<li class="breadcrumb-item active">Listar</li>
					</ol>
				</div>
			</div>

			<div class="row mb-2">
				<div class="col-sm-3 col-md-2 col-lg-1">
					<buttontype="button" class="btn btn-block btn-secondary" onclick="goHome()">
						<i class="fa fa-arrow-left color-white"></i>
						Voltar
					</button>
				</div>
				<div class="col-sm-4 col-md-3 col-lg-2">
					<a type="button" class="btn btn-block btn-primary" href="/linhasdepesquisa/criar">
						<i class="fas fa-plus color-white"></i>
						Adicionar Linha de Pesquisa
					</a>
				</div>
			</div>

		</div>
	</section>

	<section class="content">
		<div class="container-fluid">
			<div class="row">
				<div class="col-12">
					<div class="card card-primary">
						<div class="card-header">
							<h3 class="card-title">Linhas de Pesquisa Existentes</h3>
						</div>
						<div class="card-body">
							<table id="data-table" class="table table-bordered table-hover display">
								<thead>
									<tr>
										<th>#</th>
										<th>Nome</th>
										<th>Sigla</th>
										<th>Ícone/Cor</th>
									</tr>
								</thead>
								<tbody>
									{{#each linhaDePesquisa}}
									<tr>
										<td>{{id}}</td>
										<td>{{nome}}</td>
										<td>{{sigla}}</td>
										<td class="color-field {{cor}}">
                      <span class="{{icone}}"></span>
                    </td>
                    <td class='links-container'>
                      <a href='/linhasdepesquisa/busca/{{id}}'>
                        <i class='fa fa-solid fa-eye'></i>
                      </a>
                      <a
                        href=""
                        data-toggle="modal"
                        data-target="#modal-danger-{{id}}"
                      >
                        <i class='fa fa-solid fa-trash'></i>
                      </a>
                      <a href='/linhasdepesquisa/editar/{{id}}'>
                        <i class='fa fa-solid fa-pen'></i>
                      </a>
                    </td>
									</tr>
									{{/each}}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
      {{#each linhaDePesquisa}}
      <div class="modal fade" id="modal-danger-{{id}}">
        <div class="modal-dialog">
          <div class="modal-content bg-danger">
            <div class="modal-header">
              <h4 class="modal-title">Deseja continuar ?</h4>
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="modal-body">
              <span>Remover "{{nome}}"?</span>
            </div>
            <div class="modal-footer justify-content-between">
              <button type="button" class="btn btn-outline-light" data-dismiss="modal">Fechar</button>
              <a
                type="button"
                class="btn btn-outline-light"
                href="/linhasdepesquisa/listar/{{id}}"
              >
                Salvar Mudanças
              </a>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
	</section>
</main>
<script>

	function goHome() {
		window.location.href = "{{url}}/inicio";
	}

	function defineColor() {
		const colorFields = document.querySelectorAll('.color-field');

		colorFields.forEach((element) => {
			const color = element.classList.item(1);

			element.style.backgroundColor = color;
		});
	}

	window.onload =	defineColor;

  $(document).ready(function () {
    $('#data-table').DataTable({
      "paging": true,
      "lengthChange": false,
      "searching": false,
      "ordering": true,
      "info": true,
      "autoWidth": false,
      "responsive": true,
    });
  });
</script>
{{> footer}}