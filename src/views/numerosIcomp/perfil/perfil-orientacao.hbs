    {{> numerosIcomp/navbar page="docentes"}}
<div class="flex-wrapper bg-primary">

    <section class="mb-3">
        <div class="container">
                <div class="card card-body mx-3 mx-md-4 mt-n6">
                    <div class="row gx-4 mb-4">
                        <div class="nav-wrapper position-relative end-0">
                            <ul class="nav nav-pills nav-fill p-1" role="tablist">
                            <li class="nav-item">
                                <a id="profile-tab" class="nav-link mb-0 px-0" href="/numerosIcomp/docente/{{professor.id}}" aria-controls="profile" role="tab" aria-selected="true">
                                <i class="material-icons position-relative">person</i>
                                
                                <span class="ms-1">Perfil</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link mb-0 px-0 " href="/numerosIcomp/docente/{{professor.id}}/publicacoes" aria-controls="public" role="tab" aria-selected="false">
                                <i class="material-icons position-relative">description</i>
                                
                                <span class="ms-1">Publicações</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link mb-0 px-0 " href="/numerosIcomp/docente/{{professor.id}}/projetos" role="tab" aria-controls="code" aria-selected="false">
                                <i class="material-icons text-lg position-relative">search</i>
                                <span class="ms-1">Projetos de Pesquisa</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle mb-0 px-0 active " data-bs-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="material-icons text-lg position-relative">account_circle</i>
                                <span class="ms-1">Orientações</span>
                                </a>
                                <div class="dropdown-menu w-100 text-center">
                                    <a class="dropdown-item" href="/numerosIcomp/docente/{{professor.id}}/orientacoes/graduacao">Graduação</a>
                                    <a class="dropdown-item" href="/numerosIcomp/docente/{{professor.id}}/orientacoes/mestrado">Mestrado</a>
                                    <a class="dropdown-item" href="/numerosIcomp/docente/{{professor.id}}/orientacoes/doutorado">Doutorado</a>
                                  </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link mb-0 px-0" href="/numerosIcomp/docente/{{professor.id}}/premios" role="tab" aria-controls="code" aria-selected="false">
                                <i class="material-icons text-lg position-relative">military_tech</i>
                                <span class="ms-1">Prêmios</span>
                                </a>
                            </li>
                            </ul>
                        </div>
                    </div>

            
            <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade show active" id="guidences" role="tabpanel" aria-labelledby="guidences-tab">
                    <div class="card mb-3">
                        <div class="card-body p-3" >
                          {{#if orientacoes.andamento}}
                          <div class="chart" style="height: 220px">
                            <canvas id="line-chart" class="chart-canvas" ></canvas>
                          </div>
                          {{/if}}
                          {{#if orientacoes.concluidas}}
                          <div class="chart-2" style="height: 220px">
                            <canvas id="line-chart-2" class="chart-canvas" style="height: 100px"></canvas>
                          </div>
                          {{/if}}
                          <div class="nav-wrapper position-relative end-0 pt-3">
                          <ul class="nav nav-tabs p-1" role="tablist">
                            {{#if orientacoes.andamento}}
                            <li class="nav-item">
                              <a class="nav-link px-3" id="ongoing-tab" data-bs-toggle="tab" href="#ongoing" role="tab" aria-controls="ongoing" aria-selected="true">Orientações de {{tipo}} em Andamento ({{orientacoesAndamentoLen}})</a>
                            </li>
                            {{/if}}
                            {{#if orientacoes.concluidas}}
                            <li class="nav-item">
                              <a class="nav-link " id="finished-tab" data-bs-toggle="tab" href="#finished" role="tab" aria-controls="finished" aria-selected="false">Orientações de {{tipo}} Concluídas ({{orientacoesConcluidasLen}})</a>
                            </li>
                            {{/if}}
                          </ul>
                        </div>
                          <div class="tab-content" id="myTabContent">
                            <div class="tab-pane fade" id="ongoing" role="tabpanel" aria-labelledby="ongoing-tab">
                                <ol class="mt-3 text-dark" style="font-size: 14px;">
                                    {{#if orientacoes.andamento}}
                                    {{#each orientacoes.andamento}}
                                    <li><strong>{{titulo}}. </strong>{{aluno}}<i>, {{ano}}. </i>{{#if natureza}}{{natureza}}. {{/if}}<b></b></li><br>
                                    {{/each}}
                                    {{else}}
                                    Não há orientações em andamento cadastradas para {{professor.nomeCompleto}}.
                                    {{/if}}
                                </ol>

                            </div>
                            <div class="tab-pane fade" style="font-size: 14px;" id="finished" role="tabpanel" aria-labelledby="finished-tab">
                                <ol class="mt-3 text-dark">
                                    {{#if orientacoes.concluidas}}
                                    {{#each orientacoes.concluidas}}
                                    <li><strong>{{titulo}}. </strong>{{aluno}}<i>, {{ano}}. </i>{{#if natureza}}{{natureza}}. {{/if}}<b></b></li><br>
                                    {{/each}}
                                    {{else}}
                                    Não há orientações concluídas cadastradas para {{professor.nomeCompleto}}.
                                    {{/if}}
                            </div>
                          </div>
                        </div>
                      </div>
                </div>
            </div>        
            
                </div>
            </div>
    </section>
        
<script>
    // Line chart
    
    var labels = [{{anos}}]
    labels[0] = "Até "+labels[1]

    var ctx1 = document.getElementById("line-chart")
    if(ctx1){
        new Chart(ctx1.getContext("2d"), {
            type: "line",
            data: {
                labels: labels,
                datasets: [{
                    label: "Orientações",
                    tension: 0,
                    borderWidth: 0,
                    pointRadius: 5,
                    pointBackgroundColor: "#18bc9c",
                    borderColor: "#18bc9c",
                    borderWidth: 3,
                    backgroundColor: 'transparent',
                    data: [{{graficoOrientacoesAndamento}}],
                    maxBarThickness: 6,
                }
                ],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                legend: {
                    display: false,
                },
                title: {
                    fullsize: true,
                    color: '#000',
                    display: true,
                    text: 'Orientações de {{tipo}} em Andamento',
                    font: {
                        weight: 'bold'
                    },
                }
                },
                interaction: {
                intersect: false,
                mode: 'index',
                },
                scales: {
                y: {
                    grid: {
                    drawBorder: false,
                    display: true,
                    drawOnChartArea: true,
                    drawTicks: false,
                    borderDash: [5, 5]
                    },
                    ticks: {
                    display: true,
                    padding: 10,
                    color: '#b2b9bf',
                    font: {
                        size: 11,
                        family: "Open Sans",
                        style: 'normal',
                        lineHeight: 2
                    },
                    }
                },
                x: {
                    grid: {
                    drawBorder: false,
                    display: true,
                    drawOnChartArea: true,
                    drawTicks: true,
                    borderDash: [5, 5]
                    },
                    ticks: {
                    display: true,
                    color: '#b2b9bf',
                    padding: 10,
                    font: {
                        size: 11,
                        family: "Open Sans",
                        style: 'normal',
                        lineHeight: 2
                    },
                    }
                },
                },
            },
        });
    }
    

    var ctx2 = document.getElementById("line-chart-2");

    if(ctx2){
        new Chart(ctx2.getContext("2d"), {
            type: "line",
            data: {
                labels: labels,
                datasets: [{
                    label: "Orientações",
                    tension: 0,
                    borderWidth: 0,
                    pointRadius: 5,
                    pointBackgroundColor: "#18bc9c",
                    borderColor: "#18bc9c",
                    borderWidth: 3,
                    backgroundColor: 'transparent',
                    data: [{{graficoOrientacoesConcluidas}}],
                    maxBarThickness: 6
                },
                ],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                legend: {
                    display: false,
                },
                title: {
                    fullsize: true,
                    color: '#000',
                    display: true,
                    text: 'Orientações de {{tipo}} Concluídas',
                    font: {
                        weight: 'bold'
                    },
                }
                },
                interaction: {
                intersect: false,
                mode: 'index',
                },
                scales: {
                y: {
                    grid: {
                    drawBorder: false,
                    display: true,
                    drawOnChartArea: true,
                    drawTicks: false,
                    borderDash: [5, 5]
                    },
                    ticks: {
                    display: true,
                    padding: 10,
                    color: '#b2b9bf',
                    font: {
                        size: 11,
                        family: "Open Sans",
                        style: 'normal',
                        lineHeight: 2
                    },
                    }
                },
                x: {
                    grid: {
                    drawBorder: false,
                    display: true,
                    drawOnChartArea: true,
                    drawTicks: true,
                    borderDash: [5, 5]
                    },
                    ticks: {
                    display: true,
                    color: '#b2b9bf',
                    padding: 10,
                    font: {
                        size: 11,
                        family: "Open Sans",
                        style: 'normal',
                        lineHeight: 2
                    },
                    }
                },
                },
            },
        });
    }



</script>
{{> numerosIcomp/footer}}
</div>