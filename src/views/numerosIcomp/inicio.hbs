<div>
        {{> numerosIcomp/navbar page='alunos'}}
    <header class="text-center">

        <div class="page-header" style="background: #18bc9c; min-height: 600px;">
            <div class="container">
                <div class="row">
                    <div class="col-md-12">
                        <div>
                                <img class="img-fluid me-5 mb-3" src="/public/img/logo-icomp.png" alt="" width="320px">
                                <img class="img-fluid mb-3" src="/public/img/logo-ufam.png" alt="" width="136">
                        </div>
                        <span class="text-white mb-4 mt-sm-3 header-title">ICOMP EM NÚMEROS</span>
                        <p class="text-white fs-4 lead ">Confira abaixo as estatísticas do Instituto de Computação da Universidade Federal do Amazonas (UFAM)</p>
                    </div>
                    
                </div>
            </div>
            </div>
    </header>

    <section id="alunos" class="pt-9">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-12 text-center">
                <h3>Alunos Matriculados</h3>
                <hr style="border-top: 3px solid; border-top-color: #000; border-color: #000;">
                </div>
            </div>
            <div class="row">
                <div class="col-sm-12">
                    <div class="row justify-content-around">
                        <div class="col-md-4 d-flex position-relative align-items-center">
                            <div class="p-3 w-100 text-center">
                                <div>
                                    <h3>Graduação</h3>
                                </div>
                            </div> 
                        </div>
                        <div class="col-md-4 position-relative">
                            <div class="p-3 text-center">
                                <h2 style="color: #18bc9c;"><span id="state1" countto={{contagem.matriculados.CC}}>{{contagem.matriculados.CC}}</span></h2>
                                <h5 class="mt-3">Ciência da Computação</h5>
                            
                            </div>
                            
                        </div>
                        <div class="col-md-4 position-relative">
                            <div class="p-3 text-center">
                                <h2 style="color: #18bc9c;"> <span id="state2" countto={{add contagem.matriculados.ES contagem.matriculados.SI}}>{{add contagem.matriculados.ES contagem.matriculados.SI}}</span></h2>
                                <h5 class="mt-3">Engenharia de Software / Sistemas de Informação</h5>
    
                            </div>
                        </div>
                    </div>
                    <br/>
                    <div class="row">
                        <div class="col-md-12 text-end">
                            <small >Fonte: SIE, {{formataData contagem.data}}.</small>
                        </div>
                    </div>
                    <hr class="horizontal dark">
                    <div class="row justify-content-around pt-4">
                        <div class="col-md-4 d-flex position-relative align-items-center">
                            <div class="p-3 w-100 text-center">
                                <div>
                                    <h3>Pós-Graduação</h3>
                                </div>
                            </div> 
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 text-center">
                                <h2 style="color: #18bc9c;" id="state3" countto={{contagem.matriculados.M}}>{{contagem.matriculados.M}}</h2>
                                <h5 class="mt-3">Mestrado</h5>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 text-center">
                                <h2 style="color: #18bc9c;" id="state4" countto={{contagem.matriculados.D}}>{{contagem.matriculados.D}}</h2>
                                <h5 class="mt-3">Doutorado</h5>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <br/>
            <div class="row">
            <div class="col-md-12 text-end">
                <small >Fonte: SIE, {{formataData contagem.data}}.</small>
            </div>
            </div>
        </div>
    </section>


    <section class="py-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-12 text-center">
                <h3>Alunos Egressos</h3>
                <hr style="border-top: 3px solid; border-top-color: #000; border-color: #000;">
                </div>
            </div>
            <div class="row">
                <div class="col-sm-12">
                    <div class="row justify-content-around">
                        <div class="col-md-4 d-flex position-relative align-items-center">
                            <div class="p-3 w-100 text-center">
                                <div>
                                    <h3>Graduação</h3>
                                </div>
                            </div> 
                        </div>
                        <div class="col-md-2 position-relative">
                            <div class="p-3 text-center">
                                <h2>
                                    <a href="/numerosIcomp/alunos/processamento-de-dados">
                                    <span style="color: #18bc9c;">{{contagem.egressos.PD}}</span>       
                                        <span class="secundary-color material-icons position-relative fs-4">search</span>
                                    </a>
                                </h2>
                                <h5 class="mt-3">Processamento de Dados</h5>
                            </div> 
                        </div>
                        <div class="col-md-2 position-relative">
                            <div class="p-3 text-center">
                                <h2 >
                                    <a href="/numerosIcomp/alunos/ciencia-computacao">
                                    <span style="color: #18bc9c;">{{contagem.egressos.CC}}</span>       
                                        <span class="secundary-color material-icons position-relative fs-4">search</span>
                                    </a>
                                </h2>
                                <h5 class="mt-3">Ciência da Computação</h5>
                            </div> 
                        </div>
                        
                        <div class="col-md-2 position-relative">
                            <div class="p-3 text-center">
                                <h2>
                                    <a href="/numerosIcomp/alunos/engenharia-de-software">
                                    <span style="color: #18bc9c;">{{add contagem.egressos.ES contagem.egressos.SI}}</span>       
                                        <span class="secundary-color material-icons position-relative fs-4">search</span>
                                    </a>
                                </h2>
                                <h5 class="mt-3">Engenharia de Software / Sistemas de Informação</h5>
    
                            </div>
                        </div>
                        
                        
                    </div>
                    <br/>
                    <div class="row">
                        <div class="col-md-12 text-end">
                            <small >Fonte: SIE, {{formataData contagem.data}}.</small>
                        </div>
                    </div>
                    <hr class="horizontal dark">
                    <div class="row justify-content-around pt-4">
                        <div class="col-md-4 d-flex position-relative align-items-center">
                            <div class="p-3 w-100 text-center">
                                <div>
                                    <h3>Pós-Graduação</h3>
                                </div>
                            </div> 
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 text-center">
                                <h2>
                                    <a href="/numerosIcomp/alunos/mestrado">
                                    <span style="color: #18bc9c;">{{contagem.egressos.M}}</span>       
                                        <span class="secundary-color material-icons position-relative fs-4">search</span>
                                    </a>
                                </h2>
                                <h5 class="mt-3">Mestrado</h5>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 text-center">
                                <h2>
                                    <a href="/numerosIcomp/alunos/doutorado">
                                    <span style="color: #18bc9c;">{{contagem.egressos.D}}</span>       
                                        <span class="secundary-color material-icons position-relative fs-4">search</span>
                                    </a>
                                </h2>
                                <h5 class="mt-3">Doutorado</h5>
                            </div>
                        </div>
                    </div>
                    <br/>
                    <div class="row">
                        <div class="col-md-12 text-end">
                            <small >Fonte: SIE, {{formataData contagem.data}}.</small>
                        </div>
                    </div>
                </div>
                
                
            </div>
        </div>
    </section>

    {{> numerosIcomp/footer}}

</div>