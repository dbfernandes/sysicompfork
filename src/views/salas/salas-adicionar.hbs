{{> header}}
{{> sidebar module='salas' page='salas-adicionar'}}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-9">
                    <h1>Adicionar Sala</h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Salas</a></li>
                        <li class="breadcrumb-item active">Adicionar</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 col-md-3 col-lg-1 min-width-button">
                    <a type="button" class="btn btn-block btn-secondary" href="/salas/gerenciar">
                        <i class="fa fa-arrow-left color-white"></i>
                        Voltar
                    </a>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <section class="content">
        <div class="col-md-6">
                <div class="card card-secondary">
                <div class="card-header">
                <h3 class="card-title">Nova Sala</h3>
                </div>
                <!-- /.card-header -->
                <!-- form start -->
                    <form method="POST" action="/salas/adicionar">
                     <input type="hidden" name="_csrf" value="{{csrf}}"/> 
                        <div class="card-body">
                            <div class="form-group">
                                <label for="nomeSalaInput">
                                    <font color="#FF0000"></font> Nome:
                                </label>
                                <input type="text" class="form-control" id="nome" name="nome" placeholder="Ex. Auditório 1" >
                            </div>

                            <div class="form-group">
                                <label for="numSalaInput">
                                    Número:
                                </label>
                                <input type="number" class="form-control" id="numero" name="numero" placeholder="Ex. 1241">
                            </div>

                            <div class="form-group">
                                <label for="blocSalaInput">
                                    <font color="#FF0000">*</font> Bloco:
                                </label>
                                <input type="text" class="form-control" id="bloco" name="bloco" placeholder="Ex. IComp 1" required> 
                            </div>

                           <div class="form-group">
                                <label for="andarSalaInput">
                                    <font color="#FF0000">*</font> Andar:
                                </label>
                                <input type="number" class="form-control" id="andar" name="andar" placeholder="Ex. 3" required> 
                            </div>


                            <div class="form-group">
                                <label for="capSalaInput">
                                    <font color="#FF0000"></font> Capacidade:
                                </label>
                                <input type="number" class="form-control" id="capacidade" name="capacidade" placeholder="Ex. 10 "> 

                            </div>
                          
                        </div>
                        <!-- /.card-body -->
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">Adiconar</button>
                        </div>
                    </form>
                </div> 
        </div>
        <!-- /.card -->
    </section>
</div>
{{> footer}}