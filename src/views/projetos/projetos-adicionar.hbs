{{> header}}
{{> sidebar module='projetos' page='projetos-adicionar'}}
    <!-- Content Wrapper. Contains page content -->
    <div class="content-wrapper">
        <!-- Content Header (Page header) -->
        <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-9">
                    <h1>Adicionar novo projeto</h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Projetos</a></li>
                        <li class="breadcrumb-item active">Adicionar</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-3 col-md-2 col-lg-1">
                    <button type="button" class="btn btn-block btn-secondary">
                        <i class="fa fa-arrow-left color-white"></i>
                        Voltar
                    </button>
                </div>
            </div>
        </div><!-- /.container-fluid -->
        </section>

        <!-- Main content -->
        <section class="content">
        <div class="row">
            <div class="col">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Dados do Projeto</h3>

                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                            <i class="fas fa-minus"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <form action="/projetos/adicionar" method="POST">
                        <div class="form-group">
                            <label for="inputNomeProjeto">Nome do Projeto</label>
                            <input type="text" id="inputNomeProjeto" name="inputNomeProjeto" class="form-control">
                        </div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>Data de Início do Projeto:</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="far fa-calendar-alt"></i></span>
                                    </div>
                                    <input id="dateInicioProjeto" name="dateInicioProjeto" type="text" class="form-control datemask" data-inputmask-alias="datetime" data-inputmask-inputformat="dd/mm/yyyy" data-mask>
                                </div>
                                <!-- /.input group -->
                            </div>
                            <!-- /.Data Início -->
                            <div class="form-group col-md-6">
                                <label>Data de Término do Projeto:</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="far fa-calendar-alt"></i></span>
                                    </div>
                                <input id="dateFimProjeto" name="dateFimProjeto" type="text" class="form-control datemask" data-inputmask-alias="datetime" data-inputmask-inputformat="dd/mm/yyyy" data-mask>
                                </div>
                                <!-- /.input group -->
                            </div>
                            <!-- /.Data Fim -->
                        </div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label for="inputConvenioProjeto">Número de Convênio com a Instituição</label>
                                <input type="text" id="inputConvenioProjeto" name="inputConvenioProjeto" class="form-control">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="inputContaBancariaProjeto">Conta Bancária do Projeto</label>
                                <input type="text" id="inputContaBancariaProjeto" name="inputContaBancariaProjeto" class="form-control">
                            </div>
                        </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
            <div class="card-footer">
                    <div class="col">
                    <input type="reset" value="Redefinir" class="btn btn-secondary" />
                    <input type="submit" value="Criar novo Projeto" class="btn btn-success float-right">
                    </div>
                </div>
                </form>
            </div>
            <!-- /.col -->
        </div>
        </section>
        <!-- /.content -->
    </div>
{{> footer}}