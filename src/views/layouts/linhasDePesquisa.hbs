<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/public/img/favicon 2.ico" rel="icon" type="image/png">

  <title>{{ pageTitle }}</title>

  {{!-- Google Font: Source Sans Pro --}}
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback"
  >
  {{!-- Font Awesome Icons --}}
  <link rel="stylesheet" href="/script-adminlte/plugins/fontawesome-free/css/all.min.css">
  <!-- IonIcons -->
  <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
  {{!-- DataTables --}}
  <link rel="stylesheet" href="/script-adminlte/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
  <link rel="stylesheet" href="/script-adminlte/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
  <link rel="stylesheet" href="/script-adminlte/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
  <!-- SweetAlert2 -->
  <link rel="stylesheet" href="/script-adminlte/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
  {{!-- Theme Style --}}
  <link rel="stylesheet" href="/script-adminlte/dist/css/adminlte.min.css">
  <!-- Toasts -->
  <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
  
  <!-- XML2JSON -->
  <script type='text/javascript' src="/public/js/xml2json.js"></script>
  
  <!-- Lattes Loader -->
  <script type='text/javascript' src="/public/js/lattesExtractor.js"></script>

</head>

<body class="hold-transition sidebar-mini">

  {{{ body }}}

  <!-- jQuery -->
  <script src="/script-adminlte/plugins/jquery/jquery.min.js"></script>
  <!-- Bootstrap 4 -->
  <script src="/script-adminlte/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
  <!-- DataTables  & Plugins -->
  <script src="/script-adminlte/plugins/datatables/jquery.dataTables.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-buttons/js/buttons.bootstrap4.min.js"></script>
  <script src="/script-adminlte/plugins/jszip/jszip.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-buttons/js/buttons.html5.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-buttons/js/buttons.print.min.js"></script>
  <script src="/script-adminlte/plugins/datatables-buttons/js/buttons.colVis.min.js"></script>
  <!-- SweetAlert2 -->
  <script src="/script-adminlte/plugins/sweetalert2/sweetalert2.min.js"></script>
  <!-- AdminLTE App -->
  <script src="/script-adminlte/dist/js/adminlte.min.js"></script>

  <!-- Page specific script -->
  <script>
    $(function () {
      try {
        masks();
      } catch { }

      try {
        usuariosAdicionarPage();
      } catch { }

      try {
        loginPage();
      } catch { }

      try {
        dataTable();
      } catch { }
    });

    function masks() {
      //Datemask dd/mm/yyyy
      $('.datemask').inputmask('dd/mm/yyyy', { 'placeholder': 'dd/mm/yyyy' })
      $('.cpf').inputmask('999.999.999-99', { 'placeholder': '___.___.___-__' })
      $('.telefone').inputmask('(99)99999-9999', { 'placeholder': '(__)_____-____' })
    }

    function dataTable() {
      $('#example2').DataTable({
        "paging": true,
        "lengthChange": false,
        "searching": false,
        "ordering": true,
        "info": true,
        "autoWidth": false,
        "responsive": true,
      });
    }
  </script>
</body>
</html>