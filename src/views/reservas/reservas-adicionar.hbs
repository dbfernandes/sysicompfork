{{> header}}
{{> sidebar module='reservas' page='reservas-adicionar'}}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-3">
                <div class="col-sm-9">
                    <h1>Adicionar Reserva</h1>
                </div>
                <div class="col-sm-3">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/reservas/gerenciar">Reservas</a></li>
                        <li class="breadcrumb-item active">Adicionar</li>
                    </ol>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 col-md-3 col-lg-1 min-width-button">
                    <a type="button" class="btn btn-warning color-white" href="/reservas/gerenciar">
                        <i class="fa fa-arrow-left color-white"></i>
                        Voltar
                    </a>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <section class="content">
        <div class="row">
            <div class="col">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title"><b>Dados da Reserva</b></h3>
                    </div>
                    <div class="container-fluid">
                        <form id="formAdicionarSala" method="POST" action="/reservas/adicionar">
                            <input type="hidden" id="_csrf" name="_csrf" value="{{csrf}}" />
                            <input type="hidden" id="UsuarioId" name="UsuarioId" value="{{UsuarioId}}" />
                            <div class="card-body ">


                                <div class="form-group">
                                    <label for="atividade">
                                        <font color="#FF0000">*</font> Atividade:
                                    </label>
                                    <input type="text" class="form-control" id="atividade" name="atividade"
                                        placeholder="Ex: Seminários ">
                                </div>

                                <div class="form-group ">
                                    <label for="bloco">
                                        <font color="#FF0000">*</font> Tipo:
                                    </label>
                                    <select class="form-control" id="tipo" name="tipo" required>
                                        <option value="Aula">Aula</option>
                                        <option value="Defesa">Defesa</option>
                                        <option value="Exame">Exame</option>
                                        <option value="Reunião">Reunião</option>
                                    </select>
                                </div>

                                <div class="form-group ">
                                    <label for="SalaId">
                                        <font color="#FF0000">*</font> Sala:
                                    </label>
                                    <select class="form-control" id="SalaId" name="SalaId" required>
                                        {{#each salas}}
                                        <option value="{{id}}">{{nome}} - {{bloco}} - {{andar}}° andar</option>
                                        {{/each}}
                                    </select>

                                </div>

                                <div class="row">

                                    <div class="form-group col-md-1">
                                        <label for="carta_recomendacao">
                                            <font color="#FF0000">*</font> Reserva Única?
                                        </label>
                                    </div>
                                    <div class="form-group ">
                                        <input type="checkbox" name="unica" data-bootstrap-switch
                                            data-off-color="danger" data-on-color="success" data-on-text="Sim"
                                            data-off-text="Não" value="1" id="unica">
                                    </div>
                                </div>




                                <div class="form-group " id="conditionalInput">

                                    <label class="control-label" for="candidato-nome">
                                        <font color="#FF0000"> &nbsp&nbsp</font>
                                        <b>Dias da semana:</b>
                                    </label>

                                    <label class="checkbox-inline ml-2 ">
                                        <input type="checkbox" id="dia1" name="dia" value="Segunda">
                                        Segunda
                                    </label>

                                    <label class="checkbox-inline ml-4 ">
                                        <input type="checkbox" id="dia2" name="dia" value="Terça">
                                        Terça
                                    </label>

                                    <label class="checkbox-inline ml-4">
                                        <input type="checkbox" id="dia3" name="dia" value="Quarta">
                                        Quarta
                                    </label>
                                    <label class="checkbox-inline ml-4">
                                        <input type="checkbox" id="dia4" name="dia" value="Segunda" value="Quinta">
                                        Quinta
                                    </label>
                                    <label class="checkbox-inline ml-4">
                                        <input type="checkbox" id="dia5" name="dia" value="Sexta">
                                        Sexta
                                    </label>
                                    <label class="checkbox-inline ml-4">
                                        <input type="checkbox" id="dia6" name="dia" value="Sábado">
                                        Sábado
                                    </label>
                                </div>


                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label for="dataInicio">
                                            <font color="#FF0000">*</font> Data Inicial:
                                        </label>

                                        <div class="input-group date  " data-target-input="nearest">

                                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>

                                            <input type="date" class="form-control datetimepicker-input "
                                                placeholder="Data de Início" id="dataInicio" name="dataInicio"
                                                data-inputmask-inputformat="dd/mm/yyyy" placeholder="dd/mm/yyyy"
                                                required id="data_inicio">

                                            <div class="invalid-feedback" id="dataInicioError">Data inválida. Por favor,
                                                insira datas válidas.</div>
                                        </div>

                                    </div>
                                    <div class="form-group col-md-6" id="conditionalInput2">
                                        <label for="dataTermino">
                                            <font color="#FF0000">*</font> Data Término:
                                        </label>
                                        <div class="input-group date" data-target-input="nearest">

                                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                                            <input type="date" class="form-control datetimepicker-input"
                                                placeholder="Data de Início" id="dataTermino" name="dataTermino"
                                                placeholder="dd/mm/yyyy" data-inputmask-inputformat="dd/mm/yyyy"
                                                placeholder="DD-MM-YYYY">
                                            <div class="invalid-feedback" id="dataTerminoError">Data inválida. Por
                                                favor,
                                                insira datas válidas.</div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row">
                                    <div class="form-group  col-md-6 ">
                                        <label for="horaInicio">
                                            <font color="#FF0000">*</font> Hora Inicial:
                                        </label>
                                        <div class="input-group date" data-target-input="nearest">
                                            <div class="input-group-append" data-target="#horaTermino"
                                                data-toggle="datetimepicker">
                                                <div class="input-group-text"><i class="fa fa-clock"></i></div>
                                            </div>
                                            <input type="time" class="form-control datetimepicker-input"
                                                data-target="#horaInicio" id="horaInicio" name="horaInicio"
                                                placeholder='HH:mm'>

                                        </div>
                                    </div>
                                    <div class="form-group col-md-6 ">
                                        <label for="horaTermino">
                                            <font color="#FF0000">*</font> Hora Término:
                                        </label>
                                        <div class="input-group date" data-target-input="nearest">
                                            <div class="input-group-append" data-target="#horaTermino"
                                                data-toggle="datetimepicker">
                                                <div class="input-group-text"><i class="fa fa-clock"></i></div>
                                            </div>
                                            <input type="time" class="form-control  datetimepicker-input"
                                                data-target="#horaTermino" id="horaTermino" name="horaTermino"
                                                placeholder='HH:mm'>
                                            <div class="invalid-feedback" id="horaTerminoError">Hora inválida. Por
                                                favor,
                                                insira horas válidas.</div>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <div class="card-footer pr-0">
                                <div style="margin-right: auto;" class="d-flex justify-content-end">
                                    <button type="submit" class="btn btn-success float-right">
                                        Adicionar Reserva
                                    </button>

                                </div>
                            </div>
                        </form>


                    </div>
                </div>
            </div>
            <!-- /.card -->
    </section>
</div>

{{> footer}}

<script>
    $(document).ready(function () {
        const conditionalInput = document.getElementById('conditionalInput');
        const conditionalInput2 = document.getElementById('conditionalInput2');

        // Inicialize o switch
        $("input[data-bootstrap-switch]").each(function () {
            $(this).bootstrapSwitch('state', $(this).is(':checked'));
        });

        // lógica do switch
        $("#unica").on('switchChange.bootstrapSwitch', function (event, state) {
            const unica = $("#unica").prop('checked');
            if (unica) {
                conditionalInput.style.display = 'none';
                conditionalInput2.style.display = 'none';
            } else {
                conditionalInput.style.display = 'block';
                conditionalInput2.style.display = 'block';
            }

        });
    });


    function pegaDados() {       
        const num_edital = $("#num_edital").val();
        const documento = $("#documento").val();
        const data_inicio = $("#data_inicio").val();
        const data_fim = $("#data_fim").val();

        return {
            vaga_regular_mestrado,
            vaga_suplementar_mestrado,
            vaga_regular_doutorado,
            vaga_suplementar_doutorado,
            carta_recomendacao,
            carta_orientador,
            num_edital,
            documento,
            data_inicio,
            data_fim
        };
    }

    async function buscarReservas() {
        try {
            const response = await fetch('/reservas/listar'); // Rota para buscar reservas
            if (!response.ok) {
                throw new Error('Erro ao buscar reservas');
            }
            const data = await response.json();
            return data;
        } catch (error) {
            console.error(error);
            return [];
        }
    }

    function verificaConflitoComReservasnovaReserva(reserva, reservasExistente) {

        return false; // Não há conflito
    }

    document.getElementById("formAdicionarSala").addEventListener("submit", async function (event) {
        event.preventDefault();

        // Obtém as datas inseridas
        const dataInicio = new Date(document.getElementById("dataInicio").value);
        let dataFim = new Date(document.getElementById("dataTermino").value);
        const horaInicio = document.getElementById("horaInicio").value
        const horaTermino = document.getElementById("horaTermino").value
        const unica = document.getElementById("unica").value;

        // Verifica se as datas termino
        if (isNaN(dataFim.getTime())) {
            if (unica == '1') {
                dataFim = dataInicio
            } else {
                document.getElementById("dataTerminoError").textContent = "Por favor, insira uma data.";
                document.getElementById("dataTermino").classList.add("is-invalid");
                return;
            }

            document.getElementById("dataTerminoError").textContent = "";
            document.getElementById("dataTermino").classList.remove("is-invalid");
        }

        // Verifica se a data de início é anterior à data de fim
        if (dataInicio > dataFim) {
            document.getElementById("dataTerminoError").textContent = "A data de termino deve ser posterior à data de inicio.";
            document.getElementById("dataTermino").classList.add("is-invalid");
            return;
        } else {
            document.getElementById("dataTerminoError").textContent = "";
            document.getElementById("dataTermino").classList.remove("is-invalid");
        }

        // Verifica se a data de início é anterior à data de fim
        if (horaInicio >= horaTermino) {
            document.getElementById("horaTerminoError").textContent = "A hora de termino deve ser posterior à hora de inicio.";
            document.getElementById("horaTermino").classList.add("is-invalid");
            return;
        } else {
            document.getElementById("horaTerminoError").textContent = "";
            document.getElementById("horaTermino").classList.remove("is-invalid");
        }


        alert("Formulário enviado com sucesso!");
        return;
        const reservas = await buscarReservas();
        console.log(reservas.reservas)

        // Verificar se a nova reserva entra em conflito com as reservas existentes
        const conflito = verificaConflitoComReservasnovaReserva(reservas, reservas);

        if (conflito) {
            alert("Existe um conflito com as reservas existentes.");
        } else {
            alert("A reserva foi feita com sucesso.");
        }

        // Se as datas são válidas e não há conflito com as reservas existentes, você pode prosseguir com o envio do formulário.
        alert("Formulário enviado com sucesso!");
        return;
    });

</script>