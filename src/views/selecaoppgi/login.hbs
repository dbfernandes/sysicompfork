<style>
	.login-page {
		height: 100vh;
		display: flex;
		background-color: #d2d6de;
		overflow-y: hidden;
	}

	.login-page .box {
		width: 35%;
		min-width: 360px;
		margin: auto;
		margin-top: 7%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	.login-page .box .card {
		width: 100%;

		padding: 20px;
		background-color: #fff;
		border-radius: 2px;
		box-shadow: 0px 0px 2px rgba(0, 0, 0, 0.2);
	}

	.login-page .box .card .card-body {
		padding: 20px;
		color: #666;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.login-page .box .card .card-body .title {
		font-size: 24px;
		margin-bottom: 16px;
		text-align: center;

		font-weight: bold;
	}

	.login-page .box .card .card-body .sub-title {
		font-size: 14px;
		margin-bottom: 16px;
		text-align: center;
	}

	.login-page .box .card .card-body .form-group {
		width: 80% !important;
		min-width: 280px;
	}

	.login-page .box .card .card-body .form-control:focus {
		border: 2px solid #3c8dbc;
	}

	.login-page .box .card .card-body .btn {
		width: 100%;
		margin-top: 20px;
		background-color: #3c8dbc;
		border-color: #3c8dbc;
		color: #fff;
	}

	.login-page .box .card .card-body .btn-default {
		background-color: #fff;
		border-color: #ccc;
		color: #666;
		width: 100%;
	}
</style>
<div class="login-page">
	<div class="box">


		<div class="card">
			<div class="card-body">
				<h1 class="title">
					Efetuar Login
				</h1>
				<p class="sub-title">Todos os campos são obrigatórios</p>
				<form id="loginform">
					<input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}">

					<div class="form-group">
						<input type="email" class="form-control" name="" id="email" aria-describedby="email" placeholder="Email">
					</div>

					<div class="form-group">
						<input type="password" class="form-control" name="" id="password" aria-describedby="senha"
							placeholder="Senha">
					</div>

					<div class="form-group">
						<select class="form-control" name="" id="edital">
							<option value="">Selecione um edital</option>
							{{#each editais}}
							<option value="{{editalId}}">{{editalId}}</option>
							{{/each}}
						</select>
					</div>
					<button onclick="Formlogin()" name="logar" id="login" class="btn btn-primary btn-block btn-flat">
						Continuar Inscrição
					</button>
					<button name="voltar" type="button" id="voltar" onclick="back()" class="btn btn-block btn-flat btn-default" role="button">
						Voltar
					</button>
				</form>
			</div>
		</div>
	</div>
</div>

<script>
	function back() {
		window.location.href = "{{url}}/selecaoppgi";
	}

	function teste() {
		window.alert("teste")
	}

	function Formlogin() {

		var email = $("#email").val();
		var senha = $("#password").val();
		var edital = $("#edital").val();
		$("#loginform").submit(function (event) {

			event.preventDefault();
			var email = $("#email").val();
			var senha = $("#password").val();
			var edital = $("#edital").val();
			const csrfToken = $("#csrfToken").val();

			$.ajax({
				url: "{{url}}/selecaoppgi/entrar",
				type: "POST",
				data: {
					email: email,
					senha: senha,
					edital: edital,
					_csrf: csrfToken,
				},
				success: function (data) {
					window.location.href = "{{url}}/selecaoppgi/formulario";
				},
				error: function (res, status, error) {
					console.log("Entrou no erro")
					const err = res.responseJSON
					errorSignin = err.error
					window.alert(errorSignin)
				}
			});
		});

	}


</script>