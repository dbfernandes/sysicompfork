		return bolsa;
	}

	function checkCondicao() {
		let deficiencia = document.getElementById("candidato-deficiencia1").checked;
		let condicaoInput = document.getElementById("candidato-condicao");
		if (!deficiencia) {
			condicaoInput.value = "";
			return 0;
		}
		return deficiencia;
	}

	function checkCotista() {
		let cotista = document.getElementById("cotista").checked;
		let cotistaCota = document.getElementById("tipo-cota");
		if (!cotista) {
			cotistaCota.value = "";
			return 0;
		}
		return cotista;
	}

	function getValueFromForm() {

		const form = document.getElementById('candidato-formulario');
		let data = {}
		data.Nome = document.getElementById('candidato-nome').value;
		data.Nascimento = document.getElementById('data-nascimento').value;
		data.Sexo = getSelectedSexo()
		data.NomeSocial = document.getElementById('candidato-nomesocial').value;
		data.CEP = document.getElementById('candidato-cep').value;
		data.UF = document.getElementById('candidato-uf').value;
		data.Endereco = document.getElementById('candidato-endereco').value;
		data.Cidade = document.getElementById('candidato-cidade').value;
		data.Bairro = document.getElementById('candidato-bairro').value;
		data.Nacionalidade = getSelectedNacionalidade();
		data.TelefonePrincipal = document.getElementById('candidato-telresidencial').value;
		data.TelefoneAlternativo = document.getElementById('candidato-telcelular').value;
		data.ComoSoube = getSelectedComoSoube();
		data.CursoDesejado = getSelectedCurso();
		data.RegimeDedicacao = getSelectedRegime();
		data.Cotista = checkCotista();
