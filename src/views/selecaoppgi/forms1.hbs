	}

	.forms-page .progress .progress-bar {
		background-color: #006eff;
	}

	.forms-page .pbar-1 {
		width: 12%;
	}

	.forms-page .pbar-2 {
		width: 38%;
	}

	.forms-page .pbar-3 {
		width: 62%;
	}

	.forms-page .pbar-4 {
		width: 88%;
	}

	.forms-page .pbar-5 {
		width: 100%;
	}

	.forms-page nav ul {
		list-style-type: none;
		width: 100%;
		display: flex;
		justify-content: space-between;
		z-index: 1;
	}

	.forms-page nav ul li {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		font-size: 28px;
	}

	.forms-page nav .nav-icon {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 90px;
		height: 90px;
		font-size: 1.8rem !important;
