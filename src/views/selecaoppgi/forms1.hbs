	function pesquisarCep() {
		const cep = document.getElementById('candidato-cep').value;
		const cepInput = document.getElementById('candidato-cep');
		const invalidFeedback = document.querySelector('.campo-candidato-cep .invalid-feedback');

		const cepValido = /^[0-9]{8}$/.test(cep);

		if (!cepValido) {
			cepInput.classList.add('is-invalid');
			invalidFeedback.textContent = "CEP inválido. Por favor, insira um CEP válido com 8 dígitos.";
			return;
		}

		cepInput.classList.remove('is-invalid');

		const url = `https://viacep.com.br/ws/${cep}/json/`;

		fetch(url)
			.then(response => {
				if (!response.ok) {
					console.log(response)
					throw new Error('CEP não encontrado.');
				}
				return response.json();
			})
			.then(data => {
				document.getElementById('candidato-endereco').value = data.logradouro;
				document.getElementById('candidato-cidade').value = data.localidade;
				document.getElementById('candidato-bairro').value = data.bairro;
				document.getElementById('candidato-uf').value = data.uf;
			})
			.catch(error => {
				cepInput.classList.add('is-invalid');
				invalidFeedback.textContent = error.message;
			});
	}

	document.getElementById('candidato-cep').addEventListener('blur', pesquisarCep);




