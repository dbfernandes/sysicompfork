		display: flex;
		justify-content: space-between;
		align-items: center;
		overflow-y: auto;
		color: #222;
	}

	.forms-page section h1 {
		font-size: 1.4rem;
		color: #222;
		margin-bottom: 10px;
	}

	.forms-page section .line {
		width: 100%;
		height: 1px;
		background-color: #c2c2c2;
		margin-bottom: 10px;
	}

	.forms-page section .info {
		width: 100%;
		height: 100%;
	}

	.forms-page section form {
		width: 100%;
		padding: 0 5%;
	}

	.forms-page section button {
		position: relative;
		bottom: 0;
	}

	.forms-page footer {
