<style>
  .forms-page {
    height: 100vh;
    display: block;
    justify-content: center;
    align-items: center;
    background-color: #fff;
    overflow-y: auto;
  }

  .forms-page header {
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1;
    height: 50px;
    background-color: #222;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    padding: 10px 45px;
    z-index: 9999;
  }

  .forms-page header h1 {
    font-size: 1.4rem;
    color: #dbdbdb;
    cursor: pointer;
  }

  .forms-page header h1:hover {
    color: #fff;
  }

  @media screen and (max-width: 720pt) {
    .forms-page header {
      padding: 10px 15px;
    }
  }

  .forms-page header .options {
    display: flex;
    align-items: center;
  }

  .forms-page header .options button {
    background-color: transparent;
    border: none;
    cursor: pointer;
    color: #c7c7c7;
    transition: all .3s;
  }

  .forms-page header .options button:hover {
    color: #fff;
  }

  .forms-page nav {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 250px;

    justify-content: center;
    align-items: center;
    font-size: 20px;
    font-weight: bold;
    color: rgb(27, 27, 27);
  }

  .forms-page section {
    display: flex;
    flex-direction: column;
    width: 90%;
    margin: auto;
    margin-top: 2%;
    min-height: 100vh;
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow-y: auto;
    color: #222;
  }

  .forms-page section h1 {
    font-size: 1.4rem;
    color: #222;
    margin-bottom: 10px;
  }

  .forms-page section .line {
    width: 100%;
    height: 1px;
    background-color: #c2c2c2;
    margin-bottom: 10px;
  }

  .forms-page section .info {
    width: 100%;
    height: 100%;
  }

  .forms-page section form {
    width: 100%;
    padding: 0 5%;
  }

  .forms-page section button {
    position: relative;
    bottom: 0;
  }

  .forms-page footer {
    width: 100%;
    height: 50px;
    position: fixed;
    bottom: 0;
    left: 0;
    background-color: #000;
  }

  .forms-page .progress {
    width: 100%;
    height: 10px;
    border-radius: 5px;
    background-color: rgba(0, 110, 255, 0.5);
    margin-top: -105px;
  }

  .forms-page .progress .progress-bar {
    background-color: #006eff;
  }

  .forms-page .pbar-1 {
    width: 12%;
  }

  .forms-page .pbar-2 {
    width: 38%;
  }

  .forms-page .pbar-3 {
    width: 62%;
  }

  .forms-page .pbar-4 {
    width: 88%;
  }

  .forms-page .pbar-5 {
    width: 100%;
  }

  .forms-page nav ul {
    list-style-type: none;
    width: 100%;
    display: flex;
    justify-content: space-between;
    z-index: 1;
  }

  .forms-page nav ul li {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size: 28px;
  }

  .forms-page nav .nav-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 90px;
    height: 90px;
    font-size: 1.8rem !important;
    border-radius: 50%;
    background-color: rgb(0, 110, 255);
    color: #fff;
  }

  .forms-page nav .active {
    background-color: #006eff;
  }
</style>
<link href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css" rel="stylesheet">

<div class="forms-page">
  <header>
    <h1>PPGI</h1>
    <div class="options">
      <button>Sair</button>
    </div>
  </header>



  {{!-- ALTERAÇÃO PARA NOVO FORMULARIO --}}

  <section class="content">
    <nav>
      <ul>
        <li>
          <i class="nav-icon fas fa-user active"></i>
          Dados
        </li>
        <li>
          <i class="nav-icon fas fa-history"></i>
          Histórico
        </li>
        <li>
          <i class="nav-icon fas fa-project-diagram"></i>
          Proposta de Projeto
        </li>
        <li>
          <i class="nav-icon fas fa-check"></i>
          Confirmação
        </li>
      </ul>
      <div class="progress">
        <div class="progress-bar pbar-2" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
        </div>
      </div>
    </nav>
    <div class="container-fluid">
      <form id="candidato-formulario">
        <input id="csrfToken" type="hidden" name="_csrf" value="{{csrfToken}}">
        <input id="email" type="hidden" value="{{email}}">
        <input id="editalPosicao" type="hidden" value="{{editalPosicao}}">


        <div class="card card-primary">
          <div class="card-header">
            <h3 class="card-title">Curso de Graduação</h3>
          </div>

          <div class="card-body">
            <div class="row">
              <div class="form-group col-6">
                <label for="candidato-curso">
                  <font color="#FF0000">*</font>
                  <b>Curso:</b>
                </label>
                <input class="form-control" id="candidato-curso" placeholder="Insira seu curso" type="text" name="Curso"
                  value="" maxlength="60">
              </div>

              <div class="col-md-6 ">
                <label class="control-label" for="candidato-instituicao">
                  <font color="#FF0000">*</font>
                  <b>Instituição:</b>
                </label>
                <input class="form-control" id="candidato-instituicao" placeholder="Insira sua instituição" type="text"
                  name="Instituicao" value="" maxlength="60">
              </div>
            </div>
            <div class="col-md-3 ">
              <label class="control-label" for="candidato-ano">
                <font color="#FF0000">*</font>
                <b>Ano de Egresso:</b>
              </label>
              <input class="form-control" id="candidato-ano" placeholder="Insira o ano" type="text" name="Egreco"
                value="" maxlength="60">
            </div>

          </div>
        </div>


        <div class="card card-primary">
          <div class="card-header">
            <h3 class="card-title">Curso de Pós-Graduação Stricto-Senso:</h3>
          </div>


          <div class="card-body">
            <div class="row">
              <div class="form-group col-6">
                <label for="candidato-curso-pos">
                  <b>Curso:</b>
                </label>
                <input class="form-control" id="candidato-curso-pos" type="text" name="Curso-Pos" value=""
                  maxlength="60">
              </div>

              <div class="col-md-6 " role="radiogroup">
                <label class="control-label" for="candidato-curso-tipo">
                  <font color="#FF0000">*</font>
                  <b>Tipo:</b>
                </label>
                <div id="candidato-curso-tipo" role="radiogroup"
                  style="display: flex; align-content:center; gap: 20px; max-width: 100%; flex-wrap: wrap;">
                  <div class="icheck-primary d-inline">
                    <input type="radio" id="Tipo1" name="CursoTipo" checked="">
                    <label for="Tipo1"> Mestrado Acadêmico
                    </label>
                  </div>

                  <div class="icheck-primary d-inline">
                    <input type="radio" id="Tipo2" name="CursoTipo">
                    <label for="Tipo2">Mestrado Profissional
                    </label>
                  </div>
                  <div class="icheck-primary d-inline">
                    <input type="radio" id="Tipo3" name="CursoTipo">
                    <label for="Tipo3">Doutorado
                    </label>
                  </div>
                </div>
              </div>

            </div>

            <div class="row">
              <div class="col-md-6 ">
                <label class="control-label" for="candidato-instituicao-pos">
                  <b>Instituição:</b>
                </label>
                <input class="form-control" id="candidato-instituicao-pos" type="text" name="InstituicaoPos" value=""
                  maxlength="60">
              </div>
              <div class="col-md-3">
                <label class="control-label" for="candidato-ano-pos">
                  <b>Ano de Egresso:</b>
                </label>
                <input class="form-control" id="candidato-ano-pos" type="text" name="EgrecoPos">
              </div>
            </div>

          </div>
        </div>


      </form>
    </div>
  </section>
</div>






</div>

<footer>
</footer>
<script>

</script>