          required: "Este campo é obrigatório."
        },
        "Instituicao": {
          required: "Este campo é obrigatório."
        },
        "AnoEgresso": {
          required: "Este campo é obrigatório."
        },
        "Curso-Pos": {
          conjuntoPreenchido: "Preencha o conjunto (Curso:, Instituição:, Ano de Egresso:) e Tipo: juntos ou deixe todos vazios."
        },
        "InstituicaoPos": {
          conjuntoPreenchido: "Preencha o conjunto (Curso:, Instituição:, Ano de Egresso:) e Tipo: juntos ou deixe todos vazios."
        },
        "AnoEgressoPos": {
          conjuntoPreenchido: "Preencha o conjunto (Curso:, Instituição:, Ano de Egresso:) e Tipo: juntos ou deixe todos vazios."
        },
        "VitaePDF": {
          required: "Este campo é obrigatório."
        }
      },
      submitHandler: function (form, e) {
        e.preventDefault();
        const csrfToken = $("#csrfToken").val();
        const email = $("#email").val();
        const editalPosicao = $("#editalPosicao").val();
        const id = $("#id").val();
        console.log("OOOOi")
        /*$.ajax({
          url: '',
