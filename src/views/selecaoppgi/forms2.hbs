<style>
  .forms-page {
    height: 100vh;
    display: block;
    justify-content: center;
    align-items: center;
    background-color: #fff;
    overflow-y: auto;
  }

  .forms-page header {
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1;
    height: 50px;
    background-color: #222;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    padding: 10px 45px;
    z-index: 9999;
  }

  .forms-page header h1 {
    font-size: 1.4rem;
    color: #dbdbdb;
    cursor: pointer;
  }

  .forms-page header h1:hover {
    color: #fff;
  }

  @media screen and (max-width: 720pt) {
    .forms-page header {
      padding: 10px 15px;
    }
  }

  .forms-page header .options {
    display: flex;
    align-items: center;
  }

  .forms-page header .options button {
    background-color: transparent;
    border: none;
    cursor: pointer;
    color: #c7c7c7;
    transition: all .3s;
  }

  .forms-page header .options button:hover {
    color: #fff;
  }

  .forms-page nav {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 250px;

    justify-content: center;
    align-items: center;
    font-size: 20px;
    font-weight: bold;
    color: rgb(27, 27, 27);
  }

  .forms-page section {
    display: flex;
    flex-direction: column;
    width: 90%;
    margin: auto;
    margin-top: 2%;
    min-height: 100vh;
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow-y: auto;
    color: #222;
  }

  .forms-page section h1 {
    font-size: 1.4rem;
    color: #222;
    margin-bottom: 10px;
  }

  .forms-page section .line {
    width: 100%;
    height: 1px;
    background-color: #c2c2c2;
    margin-bottom: 10px;
  }

  .forms-page section .info {
    width: 100%;
    height: 100%;
  }

  .forms-page section form {
    width: 100%;
    padding: 0 5%;
  }

  .forms-page section button {
    position: relative;
    bottom: 0;
  }

  .forms-page footer {
    width: 100%;
    height: 50px;
    position: fixed;
    bottom: 0;
    left: 0;
    background-color: #000;
  }

  .forms-page .progress {
    width: 100%;
    height: 10px;
    border-radius: 5px;
    background-color: rgba(0, 110, 255, 0.5);
    margin-top: -105px;
  }

  .forms-page .progress .progress-bar {
    background-color: #006eff;
  }

  .forms-page .pbar-1 {
    width: 12%;
  }

  .forms-page .pbar-2 {
    width: 38%;
  }

  .forms-page .pbar-3 {
    width: 62%;
  }

  .forms-page .pbar-4 {
    width: 88%;
  }

  .forms-page .pbar-5 {
    width: 100%;
  }

  .forms-page nav ul {
    list-style-type: none;
    width: 100%;
    display: flex;
    justify-content: space-between;
    z-index: 1;
  }

  .forms-page nav ul li {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size: 28px;
  }

  .nav-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 90px;
    height: 90px;
    font-size: 1.8rem !important;
    border-radius: 50%;
    background-color: #7FB6FF;
    color: #fff;
  }

  .nav-icon.active {
    background-color: #006eff;
    color: #fff;
  }

  .custom-button {
    margin-right: 10px;
    /* Adicione a margem desejada entre os botões */
    margin-bottom: 10px;
    /* Adicione a margem desejada na parte inferior dos botões (espaço vertical) */
  }
</style>
<link href="/script-adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css" rel="stylesheet">

<div class="forms-page">
