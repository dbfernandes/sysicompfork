<div class="edital-header w-100">
  <div class="edital-info">
    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2ZM18 20H6V4H13V9H18V20Z"/></svg>
    <p class="m-0">{{__ "ppgi.edital"}}:
    <a href="{{link}}" class="edital-link" target="_blank" rel="noopener noreferrer">
      <span>{{editalNome}}</span>
    </a>
    </p>
  </div>
  <div class="tempo-restante">
    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.59 20 4 16.41 4 12C4 7.59 7.59 4 12 4C16.41 4 20 7.59 20 12C20 16.41 16.41 20 12 20ZM12.5 7H11V13L16.25 16.15L17 14.92L12.5 12.25V7Z"/></svg>
    <p class="m-0">
      {{__ "ppgi.remainingTime"}}:
      {{! O atributo data-deadline é essencial para o script JS }}
      <span class="js-countdown" data-deadline="{{dataFimInscricao}}"> {{__ "ppgi.calculating"}}...</span>
    </p>
  </div>
</div>