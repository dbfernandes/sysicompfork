{
  "compilerOptions": {
    "target": "ES2023",          // ①
    "module": "CommonJS",        // ② continua em CJS
    "moduleResolution": "Node",
    "rootDir": "./src", // Mudando de "./src" para "."
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "allowJs": true,
    "checkJs": false,
    "outDir": "./build",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "baseUrl": ".", // Ajustando baseUrl também
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@resources/*": [
        "src/resources/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ]
    }
  },
  "include": [
    "./src/**/*",
    "./src/**/*.d.ts",

  ],
  "exclude": [
    "./build",
    "node_modules",
    "tests",
    "prisma"
  ]
}