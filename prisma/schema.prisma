generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AfastamentoTemporarios {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  usuarioNome    String   @db.VarChar(255)
  dataSaida      DateTime @db.Date
  dataRetorno    DateTime @db.Date
  tipoViagem     String   @db.VarChar(255)
  localViagem    String   @db.VarChar(255)
  justificativa  String   @db.Text
  planoReposicao String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Aluno {
  id               Int      @id @default(autoincrement())
  nomeCompleto     String   @db.VarChar(1024)
  curso            String   @db.VarChar(50)
  periodoIngresso  String   @db.VarChar(10)
  periodoConclusao String?  @db.VarChar(10)
  formado          Int      @db.SmallInt
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Avatar {
  id        Int      @id @default(autoincrement())
  idUsuario Int
  nome      String   @db.VarChar(255)
  caminho   String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Usuario   Usuario  @relation(fields: [idUsuario], references: [id], onUpdate: Restrict, map: "Avatar_ibfk_1")

  @@index([idUsuario], map: "idUsuario")
}

model Candidato {
  id                   BigInt    @id @default(autoincrement())
  posicaoEdital        Int?      @db.SmallInt
  senhaHash            String    @db.VarChar(255)
  tokenResetarSenha    String?   @db.VarChar(255)
  validarTokenResetada DateTime? @db.DateTime(0)
  idEdital             String    @db.VarChar(255)
  idLinhaPesquisa      Int?      @db.Int
  nome                 String?   @db.VarChar(60)
  email                String?   @db.VarChar(50)
  dataNascimento       DateTime? @db.Date
  sexo                 String?   @db.VarChar(1)
  nomeSocial           String?   @db.VarChar(60)
  cep                  String?   @db.VarChar(9)
  uf                   String?   @db.VarChar(2)
  endereco             String?   @db.VarChar(160)
  cidade               String?   @db.VarChar(40)
  bairro               String?   @db.VarChar(50)
  nacionalidade        String?   @db.VarChar(11)
  telefone             String?   @db.VarChar(18)
  telefoneSecundario   String?   @db.VarChar(18)
  comoSoube            String?   @db.VarChar(100)
  cursoDesejado        String?
  regime               String?
  cotista              Boolean?
  cotistaTipo          String?   @db.VarChar(100)
  condicao             Boolean?
  condicaoTipo         String?   @db.VarChar(100)
  bolsista             Boolean?
  cursoGraduacao       String?   @db.VarChar(50)
  instituicaoGraduacao String?   @db.VarChar(50)
  anoEgressoGraduacao  String?
  cursoPos             String?   @db.VarChar(50)
  tipoPos              String?   @db.VarChar(30)
  instituicaoPos       String?   @db.VarChar(50)
  anoEgressoPos        String?
  tituloProposta       String?   @db.VarChar(100)
  motivos              String?   @db.VarChar(1001)
  nomeOrientador       String?   @db.VarChar(200)
  curriculum           Bytes?
  cartaDoOrientador    Bytes?
  propostaDeTrabalho   Bytes?

  // Relations
  Edital           Edital            @relation(fields: [idEdital], references: [editalId])
  LinhasDePesquisa LinhasDePesquisa? @relation(fields: [idLinhaPesquisa], references: [id])

  CandidatoExperienciaAcademica CandidatoExperienciaAcademica[] @relation(fields: [], references: [])

  @@map("Candidato")
}

model CandidatoExperienciaAcademica {
  id          Int       @id @default(autoincrement())
  idCandidato BigInt
  instituicao String?   @db.VarChar(60)
  atividade   String?   @db.VarChar(60)
  periodo     String?   @db.VarChar(30)
  Candidato   Candidato @relation(fields: [idCandidato], references: [id])
}

model CandidatoPublicacoes {
  id          Int      @default(autoincrement())
  idCandidate Int
  titulo      String   @db.VarChar(255)
  ano         Int
  local       String?  @db.VarChar(255)
  tipo        Int
  natureza    String   @db.VarChar(255)
  autores     String   @db.VarChar(255)
  ISSN        String?  @db.VarChar(300)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([id, idCandidate])
}

model Edital {
  editalId             String      @id @unique(map: "editalId") @db.VarChar(255)
  vagaDoutorado        Int?
  cotasDoutorado       Int?
  vagaMestrado         Int?
  cotasMestrado        Int?
  cartaOrientador      String      @db.VarChar(255)
  cartaRecomendacao    String      @db.VarChar(255)
  documento            String      @db.VarChar(255)
  dataInicio           String      @db.VarChar(255)
  dataFim              String      @db.VarChar(255)
  status               String      @default("0") @db.VarChar(255)
  inscricoesIniciadas  Int         @default(0)
  inscricoesEncerradas Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  Candidato            Candidato[] @relation(fields: [], references: [])
}

model LinhasDePesquisa {
  id        Int         @id @default(autoincrement())
  nome      String      @db.VarChar(255)
  sigla     String      @db.VarChar(255)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  Candidato Candidato[] @relation(fields: [], references: [])
}

model Orientacao {
  id          Int      @id @default(autoincrement())
  idProfessor Int
  titulo      String   @db.VarChar(1024)
  aluno       String   @db.VarChar(500)
  ano         Int
  natureza    String?  @db.VarChar(1024)
  tipo        Int      @db.SmallInt
  status      Int      @db.SmallInt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Usuario     Usuario  @relation(fields: [idProfessor], references: [id], onUpdate: Restrict, map: "Orientacao_ibfk_1")

  @@index([idProfessor], map: "idProfessor")
}

model Premios {
  id          Int      @id @default(autoincrement())
  idProfessor Int
  titulo      String   @db.VarChar(255)
  entidade    String   @db.VarChar(255)
  ano         Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Usuario     Usuario  @relation(fields: [idProfessor], references: [id], onUpdate: Restrict, map: "Premios_ibfk_1")

  @@index([idProfessor], map: "idProfessor")
}

model Projeto {
  id            Int      @id @default(autoincrement())
  idProfessor   Int
  titulo        String   @db.VarChar(1024)
  descricao     String   @db.VarChar(5000)
  inicio        Int
  fim           Int?
  papel         String   @db.VarChar(500)
  financiadores String   @db.VarChar(1024)
  integrantes   String   @db.VarChar(1024)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  Usuario       Usuario  @relation(fields: [idProfessor], references: [id], onUpdate: Restrict, map: "Projeto_ibfk_1")

  @@index([idProfessor], map: "idProfessor")
}

model Publicacao {
  id                   Int                    @id @default(autoincrement())
  titulo               String                 @db.VarChar(1024)
  ano                  Int
  local                String?                @db.VarChar(1024)
  tipo                 Int
  natureza             String?                @db.VarChar(100)
  autores              String                 @db.VarChar(1024)
  ISSN                 String                 @db.VarChar(300)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  TipoPublicacao       TipoPublicacao         @relation(fields: [tipo], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Publicacao_ibfk_1")
  RelUsuarioPublicacao RelUsuarioPublicacao[]

  @@index([tipo], map: "tipo")
}

model Recomendacoes {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)
}

model RelUsuarioPublicacao {
  id           Int        @id @default(autoincrement())
  idUsuario    Int
  idPublicacao Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  Usuario      Usuario    @relation(fields: [idUsuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "RelUsuarioPublicacao_ibfk_1")
  Publicacao   Publicacao @relation(fields: [idPublicacao], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "RelUsuarioPublicacao_ibfk_2")

  @@index([idPublicacao], map: "idPublicacao")
  @@index([idUsuario], map: "idUsuario")
}

model ReservaSalas {
  id          Int       @id @default(autoincrement())
  SalaId      Int?
  UsuarioId   Int?
  atividade   String?   @db.VarChar(255)
  tipo        String?   @db.VarChar(255)
  dias        String?   @db.VarChar(255)
  dataInicio  DateTime? @db.Date
  dataTermino DateTime? @db.Date
  horaInicio  String?   @db.VarChar(255)
  horaTermino String?   @db.VarChar(255)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Salas       Salas?    @relation(fields: [SalaId], references: [id], onDelete: Cascade, map: "reserva_sala_fk")
  Usuario     Usuario?  @relation(fields: [UsuarioId], references: [id], onDelete: Cascade, map: "reserva_usuario_fk")

  @@index([SalaId], map: "reserva_sala_fk")
  @@index([UsuarioId], map: "reserva_usuario_fk")
}

model Salas {
  id           Int            @id @default(autoincrement())
  nome         String?        @db.VarChar(255)
  capacidade   Int?
  numero       Int?
  andar        String?        @db.VarChar(255)
  bloco        String?        @db.VarChar(255)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ReservaSalas ReservaSalas[]
}

model TipoPublicacao {
  id         Int          @id @default(autoincrement())
  nome       String       @db.VarChar(255)
  chave      String       @db.VarChar(255)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Publicacao Publicacao[]
}

model Usuario {
  id                         Int                    @id @default(autoincrement())
  nomeCompleto               String                 @db.VarChar(255)
  cpf                        String                 @unique(map: "cpf") @db.VarChar(255)
  senhaHash                  String                 @db.VarChar(255)
  tokenResetarSenha          String?                @unique(map: "tokenResetSenha") @db.VarChar(255)
  validadeTokenResetadaSenha DateTime?              @db.DateTime(0)
  email                      String                 @unique(map: "email") @db.VarChar(255)
  status                     Int                    @default(1) @db.SmallInt
  administrador              Int                    @default(0) @db.SmallInt
  coordenador                Int                    @default(0) @db.SmallInt
  secretaria                 Int                    @default(0) @db.SmallInt
  professor                  Int                    @default(0) @db.SmallInt
  perfil                     String?                @db.VarChar(255)
  siape                      String?                @db.VarChar(10)
  dataIngresso               String?                @db.VarChar(10)
  endereco                   String?                @db.VarChar(255)
  telCelular                 String?                @db.VarChar(20)
  telResidencial             String?                @db.VarChar(20)
  unidade                    String?                @db.VarChar(60)
  turno                      String?                @db.VarChar(32)
  idLattes                   BigInt?
  formacao                   String?                @db.VarChar(255)
  formacaoIngles             String?                @db.VarChar(255)
  resumo                     String?                @db.VarChar(5000)
  resumoIngles               String?                @db.VarChar(5000)
  ultimaAtualizacao          DateTime?              @db.DateTime(0)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  Avatar                     Avatar[]
  Orientacao                 Orientacao[]
  Premios                    Premios[]
  Projeto                    Projeto[]
  RelUsuarioPublicacao       RelUsuarioPublicacao[]
  ReservaSalas               ReservaSalas[]
}
