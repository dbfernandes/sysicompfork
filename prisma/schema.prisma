// Naming Conventions Applied:
// 1. Model Names (Tables):
//    - Model names should be in singular form, unless they are N to N tables.
// 2. Field Names:
//    - Foreign key fields are named in camelCase as [entityName]Id.
//    - Acronyms (abbreviations) are in lowercase.
//    - Use camelCase for field names.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AfastamentoTemporario {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  nomeCompleto   String   @db.VarChar(255)
  dataInicio     DateTime @db.Date
  dataFim        DateTime @db.Date
  tipoViagem     String   @db.VarChar(255)
  localViagem    String   @db.VarChar(255)
  justificativa  String   @db.Text
  planoReposicao String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model Aluno {
  id               Int      @id @default(autoincrement())
  nomeCompleto     String   @db.VarChar(1024)
  curso            String   @db.VarChar(50)
  periodoIngresso  String   @db.VarChar(10)
  periodoConclusao String?  @db.VarChar(10)
  formado          Int      @db.SmallInt
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Avatar {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  nome      String   @db.VarChar(255)
  caminho   String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Usuario   Usuario  @relation(fields: [usuarioId], references: [id], onUpdate: Restrict, map: "Avatar_ibfk_1")

  @@index([usuarioId], map: "usuarioId")
}

model Candidato {
  id                   String    @id @default(cuid())
  posicaoEdital        Int?      @db.SmallInt
  senhaHash            String    @db.VarChar(255)
  tokenResetSenha      String?   @db.VarChar(255)
  validadeTokenReset   DateTime? @db.DateTime(0)
  editalId             String
  linhaPesquisaId      Int?
  nome                 String?   @db.VarChar(60)
  email                String?   @db.VarChar(50)
  dataNascimento       DateTime? @db.Date
  pais                 String?   @db.VarChar(20)
  passaporte           String?   @db.VarChar(20)
  cpf                  String?   @db.Char(14)
  sexo                 String?   @db.VarChar(1)
  nomeSocial           String?   @db.VarChar(60)
  cep                  String?   @db.VarChar(9)
  uf                   String?   @db.VarChar(2)
  endereco             String?   @db.VarChar(160)
  cidade               String?   @db.VarChar(40)
  bairro               String?   @db.VarChar(50)
  nacionalidade        String?   @db.VarChar(11)
  telefone             String?   @db.VarChar(18)
  telefoneSecundario   String?   @db.VarChar(18)
  comoSoube            String?   @db.VarChar(100)
  cursoDesejado        String?
  regime               String?
  tae                  Boolean   @default(false)
  cotista              Boolean   @default(false)
  cotistaTipo          String?   @db.VarChar(100)
  condicao             Boolean   @default(false)
  condicaoTipo         String?   @db.VarChar(100)
  bolsista             Boolean   @default(false)
  cursoGraduacao       String?   @db.VarChar(50)
  instituicaoGraduacao String?   @db.VarChar(50)
  anoEgressoGraduacao  Int?
  cursoPos             String?   @db.VarChar(50)
  tipoPos              String?   @db.VarChar(30)
  instituicaoPos       String?   @db.VarChar(50)
  anoEgressoPos        Int?
  tituloProposta       String?   @db.VarChar(100)
  motivos              String?   @db.VarChar(1001)
  nomeOrientador       String?   @db.VarChar(200)
  createdAt            DateTime  @default(now())
  finishedAt           DateTime?

  // Relações
  edital                 Edital                          @relation(fields: [editalId], references: [id])
  linhaPesquisa          LinhaPesquisa?                  @relation(fields: [linhaPesquisaId], references: [id])
  recomendacoes          CandidatoRecomendacao[]
  experienciasAcademicas CandidatoExperienciaAcademica[]
  publicacoes            CandidatoPublicacao[]
  Defesa                 Defesa[]

  @@index([editalId])
  @@index([linhaPesquisaId])
}

model CandidatoExperienciaAcademica {
  id          Int     @default(autoincrement())
  candidatoId String
  instituicao String? @db.VarChar(60)
  atividade   String? @db.VarChar(60)
  periodo     String? @db.VarChar(30)

  candidato Candidato @relation(fields: [candidatoId], references: [id])

  @@id([id, candidatoId])
  @@index([candidatoId])
}

model CandidatoPublicacao {
  id          Int      @default(autoincrement())
  candidatoId String
  titulo      String   @db.VarChar(255)
  ano         Int
  local       String?  @db.VarChar(255)
  tipoId      Int      @map("tipo")
  natureza    String   @db.VarChar(255)
  autores     String   @db.VarChar(255)
  issn        String?  @db.VarChar(300)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidato Candidato @relation(fields: [candidatoId], references: [id])

  @@id([id, candidatoId])
  @@index([candidatoId])
}

model CandidatoRecomendacao {
  id                   Int       @default(autoincrement())
  dataEnvio            DateTime  @default(now())
  dataResposta         DateTime?
  prazo                DateTime
  nome                 String?   @db.VarChar(100)
  email                String    @db.VarChar(100)
  token                String    @db.VarChar(50)
  titulacao            String?   @db.VarChar(50)
  cargo                String?   @db.VarChar(50)
  instituicaoTitulacao String?   @db.VarChar(100)
  anoTitulacao         Int?
  instituicaoAtual     String?   @db.VarChar(100)
  dominio              Int?      @db.SmallInt
  aprendizado          Int?      @db.SmallInt
  assiduidade          Int?      @db.SmallInt
  relacionamento       Int?      @db.SmallInt
  iniciativa           Int?      @db.SmallInt
  expressao            Int?      @db.SmallInt
  classificacao        Float?
  informacoes          String?   @db.Text
  anoContato           Int?      @db.SmallInt
  conheceGraduacao     Int       @default(0) @db.SmallInt
  conhecePos           Int       @default(0) @db.SmallInt
  conheceEmpresa       Int       @default(0) @db.SmallInt
  conheceOutros        Int       @default(0) @db.SmallInt
  outrosLugares        String?   @db.VarChar(60)
  orientador           Int       @default(0) @db.SmallInt
  professor            Int       @default(0) @db.SmallInt
  empregador           Int       @default(0) @db.SmallInt
  coordenador          Int       @default(0) @db.SmallInt
  colegaCurso          Int       @default(0) @db.SmallInt
  colegaTrabalho       Int       @default(0) @db.SmallInt
  outrosContatos       Int       @default(0) @db.SmallInt
  outrasFuncoes        String?   @db.VarChar(60)
  passo                String    @default("1") @db.Char(1)
  candidatoId          String
  editalId             String?   @db.VarChar(20)

  candidato Candidato @relation(fields: [candidatoId], references: [id])
  edital    Edital?   @relation(fields: [editalId], references: [id])

  @@id([id, candidatoId])
  @@index([candidatoId])
  @@index([editalId])
}

model Edital {
  id                   String   @id @unique
  vagasDoutorado       Int?
  cotasDoutorado       Int?
  taesDoutorado        Int?
  vagasMestrado        Int?
  cotasMestrado        Int?
  taesMestrado         Int?
  cartaOrientador      String   @db.VarChar(255)
  cartaRecomendacao    String   @db.VarChar(255)
  documento            String   @db.VarChar(255)
  projetoPesquisa      Boolean  @default(true)
  dataInicio           DateTime
  dataFim              DateTime
  status               Int      @default(0) @db.SmallInt
  inscricoesIniciadas  Int      @default(0) @db.SmallInt
  inscricoesEncerradas Int      @default(0) @db.SmallInt
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  candidatos    Candidato[]
  recomendacoes CandidatoRecomendacao[]
}

model LinhaPesquisa {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(255)
  sigla     String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidatos Candidato[]
  Defesa     Defesa[]
}

// MODELOS PARA O LATTES
model Orientacao {
  id          Int      @id @default(autoincrement())
  professorId Int
  titulo      String   @db.VarChar(1024)
  aluno       String   @db.VarChar(500)
  ano         Int
  natureza    String?  @db.VarChar(1024)
  tipo        Int      @db.SmallInt
  status      Int      @db.SmallInt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professor Usuario @relation(fields: [professorId], references: [id])

  @@index([professorId])
}

model Premio {
  id          Int      @id @default(autoincrement())
  professorId Int
  titulo      String   @db.VarChar(255)
  entidade    String   @db.VarChar(255)
  ano         Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professor Usuario @relation(fields: [professorId], references: [id])

  @@index([professorId])
}

model Projeto {
  id            Int      @id @default(autoincrement())
  professorId   Int
  titulo        String   @db.VarChar(1024)
  descricao     String   @db.VarChar(5000)
  dataInicio    Int
  dataFim       Int?
  papel         String   @db.VarChar(500)
  financiadores String   @db.VarChar(1024)
  integrantes   String   @db.VarChar(1024)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  professor Usuario @relation(fields: [professorId], references: [id])

  @@index([professorId])
}

model Publicacao {
  id        Int      @id @default(autoincrement())
  titulo    String   @db.VarChar(1024)
  ano       Int
  local     String?  @db.VarChar(1024)
  tipoId    Int      @map("tipo")
  natureza  String?  @db.VarChar(100)
  autores   String   @db.VarChar(1024)
  issn      String   @db.VarChar(300)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tipo               TipoPublicacao      @relation(fields: [tipoId], references: [id])
  usuarioPublicacoes UsuarioPublicacao[]

  @@index([tipoId])
}

model TipoPublicacao {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(255)
  chave     String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publicacoes Publicacao[]
}

//////////////////////////////
model Recomendacoes {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)
}

model UsuarioPublicacao {
  id           Int        @id @default(autoincrement())
  usuarioId    Int
  publicacaoId Int
  usuario      Usuario    @relation(fields: [usuarioId], references: [id])
  publicacao   Publicacao @relation(fields: [publicacaoId], references: [id])

  @@index([usuarioId])
  @@index([publicacaoId])
}

model ReservaSala {
  id         Int       @id @default(autoincrement())
  salaId     Int?
  usuarioId  Int?
  atividade  String?   @db.VarChar(255)
  tipo       String?   @db.VarChar(255)
  dias       String?   @db.VarChar(255)
  dataInicio DateTime? @db.Date
  dataFim    DateTime? @db.Date
  horaInicio String?   @db.VarChar(255)
  horaFim    String?   @db.VarChar(255)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sala    Sala?    @relation(fields: [salaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([salaId])
  @@index([usuarioId])
}

model Sala {
  id         Int      @id @default(autoincrement())
  nome       String?  @db.VarChar(255)
  capacidade Int?
  numero     Int?
  andar      String?  @db.VarChar(255)
  bloco      String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reservas ReservaSala[]
}

model Usuario {
  id                      Int       @id @default(autoincrement())
  nomeCompleto            String    @db.VarChar(255)
  cpf                     String    @unique @db.VarChar(255)
  email                   String    @unique @db.VarChar(255)
  senhaHash               String    @db.VarChar(255)
  tokenResetSenha         String?   @unique @db.VarChar(255)
  validadeTokenResetSenha DateTime? @db.DateTime(0)

  status Int @default(1) @db.SmallInt // mantém seu status numérico

  administrador Int @default(0) @db.SmallInt
  coordenador   Int @default(0) @db.SmallInt
  secretaria    Int @default(0) @db.SmallInt
  diretor       Int @default(0) @db.SmallInt
  professor     Int @default(0) @db.SmallInt
  professorPPGI Int @default(0) @db.SmallInt

  perfil            String?   @db.VarChar(255)
  siape             String?   @db.VarChar(10)
  dataIngresso      DateTime? @db.Date
  endereco          String?   @db.VarChar(255)
  telCelular        String?   @db.VarChar(20)
  telResidencial    String?   @db.VarChar(20)
  unidade           String?   @db.VarChar(60)
  turno             String?   @db.VarChar(32)
  lattesId          BigInt?
  formacao          String?   @db.VarChar(255)
  formacaoIngles    String?   @db.VarChar(255)
  resumo            String?   @db.VarChar(5000)
  resumoIngles      String?   @db.VarChar(5000)
  ultimaAtualizacao DateTime? @db.DateTime(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relacionamentos existentes do seu projeto
  lattesProfessor LattesProfessor?
  avatares        Avatar[]
  orientacoes     Orientacao[]
  premios         Premio[]
  projetos        Projeto[]
  publicacoes     UsuarioPublicacao[]
  reservasSalas   ReservaSala[]
  afastamentos    AfastamentoTemporario[]

  // ===== Inversos para Defesa (conforme schema que desenhamos) =====
  defesasComoOrientador   Defesa[] @relation("OrientadorDefesa")
  defesasComoCoorientador Defesa[] @relation("CoorientadorDefesa")
  defesasCriadas          Defesa[] @relation("CriadorDefesa")

  Defesa   Defesa[]
  Processo Processo[]
}

enum DefesaTipo {
  QUALIFICACAO
  DEFESA_FINAL
}

enum DefesaNivel {
  MESTRADO
  DOUTORADO
}

enum DefesaModalidade {
  PRESENCIAL
  ONLINE
}

enum DefesaStatus {
  RASCUNHO
  AGUARDANDO_VALIDACAO
  EM_CORRECAO
  VALIDADO
  DIVULGADO
  CONCLUIDO
  CANCELADO
}

enum PapelBanca {
  PRESIDENTE
  MEMBRO
}

enum VinculoMembro {
  INTERNO
  EXTERNO
}

enum UploadTipo {
  PROPOSTA_PDF // Qualificação: proposta
  TESE_PDF // Defesa Final: tese/dissertação
  ARTIGO_COMPROVANTE_PDF // Comprovante (submetido/aceito)
  PORTARIA_PDF
  OUTRO
}

enum PresidenteOrigem {
  ORIENTADOR
  COORIENTADOR
}

model Defesa {
  id String @id @default(cuid())

  // criação mínima
  tipo  DefesaTipo
  nivel DefesaNivel

  // agora opcionais para permitir criação parcial
  candidatoNome String?    @db.VarChar(200)
  candidatoId   String?
  candidato     Candidato? @relation(fields: [candidatoId], references: [id])

  orientadorId Int?
  orientador   Usuario? @relation("OrientadorDefesa", fields: [orientadorId], references: [id])

  coorientadorId                 Int?
  coorientador                   Usuario? @relation("CoorientadorDefesa", fields: [coorientadorId], references: [id])
  coorientadorExternoNome        String?
  coorientadorExternoInstituicao String?

  tituloTrabalho String?
  dataHora       DateTime?
  modalidade     DefesaModalidade?
  localOuLink    String?

  // final: opcional até o passo 1 desse formulário
  linhaPesquisaId Int?
  linhaPesquisa   LinhaPesquisa? @relation(fields: [linhaPesquisaId], references: [id])

  status             DefesaStatus @default(RASCUNHO)
  correcaoSolicitada String?      @db.Text

  // rastreabilidade de quem iniciou
  criadoPorId Int
  criadoPor   Usuario @relation("CriadorDefesa", fields: [criadoPorId], references: [id])

  membros MembroBanca[]
  uploads DefesaUpload[]

  quali QualificacaoExtra?
  final DefesaFinalExtra?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  usuarioId Int?

  @@index([tipo, nivel])
  @@index([status, dataHora])
}

model QualificacaoExtra {
  // 1–1 com Defesa (tipo = QUALIFICACAO)
  defesaId String @id
  defesa   Defesa @relation(fields: [defesaId], references: [id], onDelete: Cascade)

  // Passo 3 – Dados do trabalho
  // “Resumo ou abstract” e “Palavras-chaves (pt ou en)”
  resumoOuAbstract String
  palavrasChaves   String // separadas por ";"

  // Créditos mínimos (12 M / 16 D) – validação de negócio na aplicação
  creditosMinimosOk Boolean

  // Passo 4 – Banca: presidente é orientador OU coorientador
  presidenteOrigem PresidenteOrigem

  // Passo 7 – Proposta e (se DOUTORADO) artigo
  // Proposta -> Upload em DefesaUpload(PROPOSTA_PDF)
  doutoradoArtigoComprovado Boolean? // apenas se nivel = DOUTORADO
  artigoTitulo              String?
  artigoVeiculoOuDoi        String?

  // Autoavaliação (ano vigente do programa)
  autoavaliacaoPreenchida Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefesaFinalExtra {
  // 1–1 com Defesa (tipo = DEFESA_FINAL)
  defesaId String @id
  defesa   Defesa @relation(fields: [defesaId], references: [id], onDelete: Cascade)

  // Passo 3 – Dados do trabalho
  resumoPt        String
  palavrasChavePt String // separadas por ";"
  abstractEn      String
  keywordsEn      String // separated by ";"
  idiomaTese      String // “Idioma da Tese”

  // Créditos – regra: D=16, M=36 (validação de negócio)
  creditosOk       Boolean
  creditosExigidos Int? // 16 (D) ou 36 (M), útil para auditoria/relatório

  // Passo 4 – Banca (regra negócio: externos >= internos; 4º membro obrigatório p/ Mestrado)
  // -> modelado via MembroBanca (abaixo)

  // Passo 6 – Tese, artigos e proficiência
  // Tese -> Upload em DefesaUpload(TESE_PDF)
  artigoEstratoSuperiorOk Boolean // Dr: aceito OU submetido; Ms: aceito (validar no serviço)
  artigoTitulo            String
  artigoVeiculoOuDoi      String

  // Agradecimentos CAPES/FAPEAM
  incluiuAgradecimentosObrigatorios Boolean
  textoAgradecimentos               String? // opcional armazenar o texto efetivo utilizado

  // Autoavaliação (ano vigente do programa)
  autoavaliacaoPreenchida Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MembroBanca {
  id       String @id @default(cuid())
  defesaId String
  defesa   Defesa @relation(fields: [defesaId], references: [id], onDelete: Cascade)

  nome        String
  email       String?
  instituicao String? // texto livre: “ICOMP/UFAM”, “Outra instituição”, etc.

  papel    PapelBanca // PRESIDENTE ou MEMBRO
  suplente Boolean    @default(false)

  // Para regras de composição (“Interno/Externo”)
  vinculo VinculoMembro // INTERNO ou EXTERNO

  // Metadados opcionais (convite/RSVP)
  rsvpToken         String?   @unique
  confirmouPresenca Boolean   @default(false)
  confirmadoEm      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([defesaId, suplente])
  @@index([vinculo, suplente])
}

model DefesaUpload {
  id       String @id @default(cuid())
  defesaId String
  defesa   Defesa @relation(fields: [defesaId], references: [id], onDelete: Cascade)

  tipo         UploadTipo
  path         String
  originalName String
  mimeType     String
  size         Int // bytes

  createdAt DateTime @default(now())

  @@index([defesaId, tipo])
}

enum ProcessoOrigem {
  MANUAL
  IA
  IMPORTADO
}

// ===== Processo (diagrama BPMN) =====
model Processo {
  id        String  @id @default(cuid())
  titulo    String  @db.VarChar(255)
  slug      String  @unique @db.VarChar(280) // p/ URLs estáveis e busca
  descricao String? @db.Text

  xmlPath     String  @db.VarChar(1024) // caminho do arquivo .bpmn (XML)
  previewPath String? @db.VarChar(1024) // caminho da imagem (png/svg) do diagrama

  origem ProcessoOrigem @default(MANUAL)

  bpmnVersion  String?  @db.VarChar(32) // ex.: "2.0"
  isExecutable Boolean? // útil se alguns processos forem executáveis

  criadoPorId Int
  criadoPor   Usuario @relation(fields: [criadoPorId], references: [id])

  // Colab em tempo real (opcional: sala do Yjs / roomId)
  collabRoomId String? @unique @db.VarChar(255)

  // Controle simples de revisão
  revisao         Int       @default(1)
  ultimaGeracaoAt DateTime? // quando a IA gerou/atualizou

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação N..N com Tag via tabela de junção
  tags ProcessoTag[]

  @@index([criadoPorId])
  @@index([slug])
  @@index([titulo])
}

// ===== Tag (catalogo de etiquetas) =====
model Tag {
  id        Int      @id @default(autoincrement())
  nome      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(120)
  corHex    String?  @db.VarChar(9) // ex.: "#AABBCC" ou "#AABBCCDD"
  descricao String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processos ProcessoTag[]
}

// ===== Junção N..N entre Processo e Tag =====
model ProcessoTag {
  processoId String
  tagId      Int

  processo Processo @relation(fields: [processoId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  // Evita duplicidade de tag no mesmo processo
  @@id([processoId, tagId])
  @@index([tagId])
  @@index([processoId])
}

//////////////////////////////////
// ===========================
// LATTES (NORMALIZADO) - MYSQL
// ===========================

model LattesAgenciaFinanciadora {
  agenciaFinanciadoraId            Int                                @id @default(autoincrement())
  nomeAgenciaFinanciadora          String?                            @db.VarChar(200)
  LattesFormacaoAcademicaTitulacao LattesFormacaoAcademicaTitulacao[]
  LattesFinanciamentoProjeto       LattesFinanciamentoProjeto[]
}

model LattesBaseDeConsulta {
  baseDeConsultaId   Int     @id @default(autoincrement())
  nomeBaseDeConsulta String? @db.VarChar(80)
}

model LattesAreaConhecimento {
