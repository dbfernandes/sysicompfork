# ==============================
# Configurações gerais
# ==============================

# Ambiente de execução (development, production, test)
NODE_ENV=

# URL de conexão do banco de dados (MySQL no seu caso)
DATABASE_URL=

# Segredo usado para assinar sessões (cookies, JWT, etc.)
SESSION_SECRET=

# ==============================
# Configurações do Redis
# ==============================
REDIS_HOST=
REDIS_PORT=

# ==============================
# Configurações do MySQL
# ==============================

# Porta do servidor MySQL (normalmente 3306)
MYSQL_PORT=
# Usuário da aplicação para se conectar ao MySQL
MYSQL_USER=
# Senha do usuário definido acima
MYSQL_PASSWORD=
# Senha do usuário root (usado em inicializações)
MYSQL_ROOT_PASSWORD=
# Nome do banco de dados da aplicação
MYSQL_DATABASE=

# ==============================
# Segurança
# ==============================

# Número de rounds do bcrypt/salt para hashing de senha
ROUNDS_SALT=

# ==============================
# Configuração de portas dos serviços
# ==============================

# Porta principal da aplicação
PORT=
# Porta específica para o módulo de seleção
PORT_SELECAO=
PORT_NUMEROS_ICOMP=

# Porta para o serviço do Gotenberg (conversão de docs em PDF)
PORT_GOTENBERG=

# Endpoint HTTP do serviço Gotenberg (ex: http://gotenberg:3000)
GOTENBERG_ENDPOINT=

# ==============================
# Regras de negócio / tempos
# ==============================

# Tempo em milissegundos para expiração de link de confirmação de e-mail
TIME_MILLIS_EXPIRE_EMAIL=

# ==============================
# Configurações de e-mail (SMTP)
# ==============================

# Host do servidor de e-mail (ex: smtp.gmail.com, smtp.zoho.com)
MAIL_HOST=
# Porta do servidor de e-mail (465 para SSL, 587 para TLS)
MAIL_PORT=
# true se usar SSL/TLS direto, false se STARTTLS
MAIL_SECURE=
# Usuário da conta de e-mail (normalmente o endereço de e-mail)
MAIL_USER=
# Senha da conta de e-mail (ou app password)
MAIL_PASS=
# E-mail que aparecerá como remetente
MAIL_FROM=


GOOGLE_API_KEY=xxxxx
GEMINI_MODEL=gemini-1.5-pro   # ou gemini-1.5-flash p/ custo/latência menor