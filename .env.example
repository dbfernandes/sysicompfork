# Prisma CLI
NODE_ENV=development
DATABASE_URL='mysql://root:root-very-secure-password@db:3306/sysicomp'
SESSION_SECRET=fakefakefakefakefakefake

MYSQL_PORT='3327'
MYSQL_USER='admim'
MYSQL_PASSWORD='user-very-secure-password'
MYSQL_ROOT_PASSWORD='root-very-secure-password'
MYSQL_DATABASE='syscomp'

ROUNDS_SALT=12
PORT=3300
PORT_SELECAO=3301
PORT_NUMEROS_ICOMP=3302
PORT_GOTENBERG=3002
GOTENBERG_ENDPOINT=http://gotenberg:3000


TIME_MILLIS_EXPIRE_EMAIL=3600000 
SENDGRID_API_KEY='fakefakefakefakefakefake'
SENDGRID_EMAIL_SEND='david@icomp.ufam.edu.br'

# Resend
RESEND_API_KEY=fakefakefakefakefakefake
RESEND_EMAIL_FROM=david@icomp.ufam.edu.br

# Nodemailer fallback (exemplo com Mailtrap)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=fake-email@gmail.com
MAIL_PASS=fakefakefakefakefakefake
MAIL_FROM='Syscomp UFAM <fake-email@gmail.com>'

GOOGLE_API_KEY=fakefakefakefakefakefake
GEMINI_MODEL=gemini-2.5-pro
